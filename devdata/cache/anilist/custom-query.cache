":"ANIME"},"timeUntilAiring":-127391},{"airingAt":1773491400,"episode":10,"id":405275,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/187941-wdkhGnf4LUH0.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1930d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187941-ykmc8WRedPpw.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187941-ykmc8WRedPpw.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187941-ykmc8WRedPpw.jpg"},"description":"Our hero needs to come out of his shell... literally! Reborn in another world inside a dragon egg, he doesn’t have the amazing magic or mighty physical strength of your typical isekai’d adventurer just yet. He’ll need to break free and grow from a weak hatchling and into a fearsome beast if he wants to escape the deep, dark forest unscathed. What battles and adventures await him in this unique take on the isekai phenomenon?\n\u003cbr\u003e\u003cbr\u003e\n(Source: HIDIVE)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Fantasy"],"id":187941,"idMal":61207,"isAdult":false,"meanScore":62,"nextAiringEpisode":{"airingAt":1774096200,"episode":11,"timeUntilAiring":477409},"season":"WINTER","siteUrl":"https://anilist.co/anime/187941","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["DoraTama"],"title":{"english":"Reincarnated as a Dragon Hatchling","native":"転生したらドラゴンの卵だった","romaji":"Tensei Shitara Dragon no Tamago Datta","userPreferred":"Tensei Shitara Dragon no Tamago Datta"},"trailer":{"id":"VPLmZd3ByAM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/VPLmZd3ByAM/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-127391},{"airingAt":1773480300,"episode":19,"id":404837,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4bb5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx186736-zYDrRDuC55s5.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx186736-zYDrRDuC55s5.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx186736-zYDrRDuC55s5.png"},"description":"The second season of \u003ci\u003eKagaku×Bouken Survival!\u003c/i\u003e","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":[],"id":186736,"idMal":60983,"isAdult":false,"meanScore":48,"nextAiringEpisode":{"airingAt":1774085100,"episode":20,"timeUntilAiring":466309},"season":"FALL","siteUrl":"https://anilist.co/anime/186736","startDate":{"day":4,"month":10,"year":2025},"status":"RELEASING","synonyms":[],"title":{"english":null,"native":"科学×冒険サバイバル！ 第2シリーズ","romaji":"Kagaku×Bouken Survival! 2nd Season","userPreferred":"Kagaku×Bouken Survival! 2nd Season"},"trailer":null,"type":"ANIME"},"timeUntilAiring":-138491},{"airingAt":1773478800,"episode":1193,"id":409738,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/235-MTmiz0uB0fMd.jpg","countryOfOrigin":"JP","coverImage":{"color":"#28a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx235-MyYT7K3chBdO.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx235-MyYT7K3chBdO.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx235-MyYT7K3chBdO.jpg"},"description":"Kudo Shinichi is a seventeen year-old high school detective whom people call the \"Modern Sherlock Holmes.\" However, one night after a date with his childhood sweetheart, Ran, Shinichi witnessed an illegal trade and, caught off his guard, was knocked unconscious and fed a drug that was supposed to kill him... but he woke up and found himself shrunken to a seven year-old. In order to track down the men who did this to him, Shinichi hid his identity and lived with Ran, whose father happened to be a hopeless detective, and with that came a series of murders and mysteries that he must solve. \u003cbr\u003e\u003cbr\u003e\n(Source: Anime News Network)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote:\u003cbr\u003e\n- Includes Keisatsu Gakkou-hen - Wild Police Story in episodes 1029, 1038, 1042, 1061\u003cbr\u003e\n- Episodes 11, 52, 76, 118, 162, 184, 208, 342, 356, 449, 452, 487, 488, 489, 490, 515, 516, 521, 522, 651, 734, 804, 805, 927, 928, 1187 aired with a runtime of ~50 minutes as opposed to the standard 25 minute long episode.\u003cbr\u003e\n- Episodes 96, 129, 174, 219, 263, 304, 383, 479 aired with a runtime of ~90 minutes as opposed to the standard 25 minute long episode.\u003cbr\u003e\n- Episode 345, 425 aired with a runtime of ~115 minutes as opposed to the standard 25 minute long episode.\u003cbr\u003e\n\u003c/i\u003e","duration":25,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Comedy","Mystery","Psychological"],"id":235,"idMal":235,"isAdult":false,"meanScore":82,"nextAiringEpisode":{"airingAt":1774083600,"episode":1194,"timeUntilAiring":464809},"season":"WINTER","siteUrl":"https://anilist.co/anime/235","startDate":{"day":8,"month":1,"year":1996},"status":"RELEASING","synonyms":["Detective Conan","Detectiu Conan","הבלש קונאן","Detektyw Conan","المحقق كونان","名侦探柯南","Meitantei Conan: Keisaku Gakkou Hen - Wild Police Story","名探偵コナン 警察学校編 Wild Police Story","Détective Conan","ยอดนักสืบจิ๋วโคนัน","Thám Tử Lừng Danh Conan","Detektiv Conan"],"title":{"english":"Case Closed","native":"名探偵コナン","romaji":"Meitantei Conan","userPreferred":"Meitantei Conan"},"trailer":null,"type":"ANIME"},"timeUntilAiring":-139991},{"airingAt":1773477000,"episode":12,"id":406911,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#50bbe4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx189258-qhtrra5ebBm6.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx189258-qhtrra5ebBm6.jpg","medium":"https://s4.a