e {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n  \",\"variables\":{\"airingAt_greater\":1772409190,\"airingAt_lesser\":1773618790,\"page\":1,\"perPage\":50,\"sort\":[\"TIME_DESC\"]}}":{"value":{"Page":{"airingSchedules":[{"airingAt":1773595200,"episode":10,"id":406857,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx203939-F8YG2X9LgfAX.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx203939-F8YG2X9LgfAX.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx203939-F8YG2X9LgfAX.png"},"description":"Sixteenth season of \u003ci\u003eYami Shibai\u003c/i\u003e.","duration":4,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV_SHORT","genres":["Horror","Supernatural"],"id":203939,"idMal":63087,"isAdult":false,"meanScore":59,"nextAiringEpisode":{"airingAt":1774200000,"episode":11,"timeUntilAiring":581209},"season":"WINTER","siteUrl":"https://anilist.co/anime/203939","startDate":{"day":12,"month":1,"year":2026},"status":"RELEASING","synonyms":["Yamishibai: Japanese Ghost Stories Sixteenth Season"],"title":{"english":"Theatre of Darkness: Yamishibai 16","native":"闇芝居 十六期","romaji":"Yami Shibai 16","userPreferred":"Yami Shibai 16"},"trailer":null,"type":"ANIME"},"timeUntilAiring":-23591},{"airingAt":1773590700,"episode":11,"id":410811,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e45d5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx198767-PoG84HHFXTit.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx198767-PoG84HHFXTit.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx198767-PoG84HHFXTit.jpg"},"description":"Kouta's world just got turned upside down. His dad's remarriage meant a new stepsister, Aika, and from their first encounter, it's clear she's everything he isn't. By day, Aika effortlessly plays the \"perfect angel\" for her parents, but behind closed doors, she's a cheeky teenager, a complete mismatch for Kouta. Their personalities clash violently, sparking arguments the moment their eyes meet. They might just be the world's worst siblings, locked in a constant battle of wills. Despite an incredibly rocky start, a subtle shift begins. Beneath Aika's wild exterior, a flicker of interest starts to grow for her caring brother.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Coolmic)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Episode 1 received an advanced distribution on AnimeFesta on December 12th, 2025. The start date reflects the start of the regular series broadcasting.\u003c/i\u003e","duration":7,"endDate":{"day":23,"month":3,"year":2026},"episodes":12,"format":"ONA","genres":["Comedy","Hentai","Romance"],"id":198767,"idMal":62897,"isAdult":true,"meanScore":56,"nextAiringEpisode":{"airingAt":1774195500,"episode":12,"timeUntilAiring":576709},"season":"WINTER","siteUrl":"https://anilist.co/anime/198767","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":[],"title":{"english":"Ichigo Aika: Strawberry Elegy","native":"イチゴ哀歌～雑で生イキな妹と割り切れない兄～","romaji":"Ichigo Aika: Zatsu de Namaiki na Imouto to Warikirenai Ani","userPreferred":"Ichigo Aika: Zatsu de Namaiki na Imouto to Warikirenai Ani"},"trailer":{"id":"j5m10YML4b4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/j5m10YML4b4/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-28091},{"airingAt":1773588600,"episode":11,"id":405050,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4a15d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx197731-6E0qjPFaNjC6.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx197731-6E0qjPFaNjC6.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx197731-6E0qjPFaNjC6.jpg"},"description":"In a society where torture is legal—and big business—Spirytus dominates the industry with skill, style, and surprisingly cheerful teamwork. Part-timers Cero, Shiu, Mikke, and Hugh tackle “client sessions,” office shenanigans, and even the occasional in-house assassin…all with a smile! Life at Spirytus proves that even in a world of pain, work can still be surprisingly fun!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":23,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy"],"id":197731,"idMal":61886,"isAdult":false,"meanScore":56,"nextAiringEpisode":{"airingAt":1774193400,"episode":12,"timeUntilAiring":574609},"season":"WINTER","siteUrl":"https://anilist.co/anime/197731","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["ชีวิตประจำวันของพนักงานพาร์ตไทม์รับจ้างทรมาน"],"title":{"english":"The Daily Life of a Part-time Torturer","native":"拷問バイトくんの日常","romaji":"Goumon Baito-kun no Nichijou","userPreferred":"Goumon Baito-kun no Nichijou"},"trailer":{"id":"EIJOU7qjq6s","site":"youtube","thumbnail":"https://i.ytimg.com/vi/EIJOU7qjq6s/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-30191},{"airingAt":1773586800,"episode":11,"id":407024,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/177385-lzz3yIhQhQdB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#aee4e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177385-TBpvkGdF28R7.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177385-TBpvkGdF28R7.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177385-TBpvkGdF28R7.png"},"description":"Reclusive novelist Makio Koudai has always preferred the company of books—but when her sister and brother-in-law pass away, Makio unexpectedly becomes the guardian of her 15-year-old niece, Asa Takumi. As they navigate grief, clashing personalities, and the challenges of living together, the two slowly open their hearts to each other, discovering warmth, understanding, and the meaning of family.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":30,"month":3,"year":2026},"episodes":13,"format":"TV","genres":["Drama","Slice of Life"],"id":177385,"idMal":58788,"isAdult":false,"meanScore":86,"nextAiringEpisode":{"airingAt":1774191600,"episode":12,"timeUntilAiring":572809},"season":"WINTER","siteUrl":"https://anilist.co/anime/177385","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["Diary of a Strange Land","Foreign Country Diary","Different Country Diary","บันทึกจากวิเทศ","مذكرات من بلد آخر","Entre les lignes","위국일기"],"title":{"english":"Journal with Witch","native":"違国日記","romaji":"Ikoku Nikki","userPreferred":"Ikoku Nikki"},"trailer":{"id":"DX6mmkoByyc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/DX6mmkoByyc/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-31991},{"airingAt":1773586800,"episode":11,"id":405430,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185993-6H7wGuRpwoSL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185993-BecPUaWfZJgR.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185993-BecPUaWfZJgR.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185993-BecPUaWfZJgR.png"},"description":"Noah, the world’s strongest six-year-old, has been privileged enough to be reborn as the emperor’s 13th child. What’s more, he’s been overpowered with an infinite level cap and a cheat that stacks the powers of anyone who serves him. But even privilege has its problems—the glittering facade of high society hides a world of conspiracies, schemes, and power struggles.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":