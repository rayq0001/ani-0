{"{\"query\":\"query ListAnime ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $season: MediaSeason, $seasonYear: Int, $format: MediaFormat, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: ANIME, search: $search, sort: $sort, status_in: $status, isAdult: $isAdult, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, season: $season, seasonYear: $seasonYear, format_not: MUSIC) {\\n\\t\\t\\t... baseAnime\\n\\t\\t}\\n\\t}\\n}\\nfragment baseAnime on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tseasonYear\\n\\tbannerImage\\n\\tepisodes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\tduration\\n\\ttrailer {\\n\\t\\tid\\n\\t\\tsite\\n\\t\\tthumbnail\\n\\t}\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tnextAiringEpisode {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":20,\"sort\":[\"TRENDING_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166613-drS86exJlIjG.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166613-uHB8q3D4qbon.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166613-uHB8q3D4qbon.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166613-uHB8q3D4qbon.jpg"},"description":"The second season of \u003ci\u003eJigokuraku\u003c/i\u003e.","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Adventure","Mystery","Supernatural"],"id":166613,"idMal":55825,"isAdult":false,"meanScore":81,"nextAiringEpisode":{"airingAt":1774190640,"episode":11,"timeUntilAiring":565142},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/166613","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["Hell’s Paradise: Jigokuraku Season 2","สุขาวดีอเวจี","Адский рай"],"title":{"english":"Hell’s Paradise Season 2","native":"地獄楽 第二期","romaji":"Jigokuraku 2nd Season","userPreferred":"Jigokuraku 2nd Season"},"trailer":{"id":"JLe_NUnAZVs","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JLe_NUnAZVs/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182255-wyHvp6zJbWsO.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dc9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182255-butzrqd4I0aC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182255-butzrqd4I0aC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182255-butzrqd4I0aC.jpg"},"description":"The second season of \u003ci\u003eSousou no Frieren\u003c/i\u003e.","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":10,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":182255,"idMal":59978,"isAdult":false,"meanScore":89,"nextAiringEpisode":{"airingAt":1774015200,"episode":9,"timeUntilAiring":389702},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182255","startDate":{"day":16,"month":1,"year":2026},"status":"RELEASING","synonyms":["Провожающая в последний путь Фрирен 2","장송의 프리렌 2기"],"title":{"english":"Frieren: Beyond Journey’s End Season 2","native":"葬送のフリーレン 第2期","romaji":"Sousou no Frieren 2nd Season","userPreferred":"Sousou no Frieren 2nd Season"},"trailer":{"id":"RH-FcW94z00","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RH-FcW94z00/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/184951-Rx1mZZfKa9IU.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1ae28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx184951-s8Lg2muPBhdX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx184951-s8Lg2muPBhdX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx184951-s8Lg2muPBhdX.jpg"},"description":"Suzuki’s a high school girl in love, but the guy she’s fallen for is nothing like her! While she’s cheerful, outgoing, and always trying to fit in, her classmate Yusuke Tani is stoic, quiet, and doesn’t seem to care what people think of him. Will Suzuki be able to overcome her anxieties and ask him out, or will she discover that opposites really don’t attract?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy","Drama","Romance","Slice of Life"],"id":184951,"idMal":60371,"isAdult":false,"meanScore":82,"nextAiringEpisode":{"airingAt":1774166400,"episode":11,"timeUntilAiring":540902},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/184951","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["ลุ้นรักฉบับคู่ต่างขั้ว","정반대의 너와 나"],"title":{"english":"You and I Are Polar Opposites","native":"正反対な君と僕","romaji":"Seihantai na Kimi to Boku","userPreferred":"Seihantai na Kimi to Boku"},"trailer":{"id":"b5vpRUDkhT0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/b5vpRUDkhT0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/172463-3J2o3qQZadFJ.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5093d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx172463-LnXqHzt74SJL.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx172463-LnXqHzt74SJL.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx172463-LnXqHzt74SJL.jpg"},"description":"The third season of \u003ci\u003eJujutsu Kaisen\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\nAfter the Shibuya Incident, a deadly jujutsu battle known as the Culling Game orchestrated by Noritoshi Kamo erupts across ten colonies in Japan.\u003cbr\u003e\u003cbr\u003e\nHaunted by guilt over the mass killings in Shibuya and wary of Sukuna’s interest in Fushiguro, Itadori chooses not to return to Jujutsu High. Instead, he teams up with Choso to exorcise the countless cursed spirits unleashed by Noritoshi Kamo.\nAmid this chaos, the Jujutsu Headquarters revokes Yuji Itadori’s suspended death sentence and appoints special-grade sorcerer Yuta Okkotsu as his executioner. \u003cbr\u003e\u003cbr\u003e\nNewly awakened modern sorcerers and resurrected ancient ones,  now fighting as players in the Culling Game, collide with conflicting motives, driving the world once more toward an age ruled by jujutsu.\u003cbr\u003e\u003cbr\u003e\n(Source: TOHO Animation)","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Drama","Supernatural"],"id":172463,"idMal":57658,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773933960,"episode":11,"timeUntilAiring":308462},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/172463","startDate":{"day":9,"month":1,"year":2026},"status":"RELEASING","synonyms":["Jujutsu Kaisen 3rd Season","呪術廻戦 第3期","JJK3","มหาเวทย์ผนึกมาร จรดลล้างบาง พาร์ต 1"],"title":{"english":"JUJUTSU KAISEN Season 3: The Culling Game Part 1","native":"呪術廻戦 死滅回游 前編","romaji":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen","userPreferred":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen"},"trailer":{"id":"ruX3rIj3--w","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ruX3rIj3--w/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185993-6H7wGuRpwoSL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185993-BecPUaWfZJgR.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185993-BecPUaWfZJgR.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185993-BecPUaWfZJgR.png"},"description":"Noah, the world’s strongest six-year-old, has been privileged enough to be reborn as the emperor’s 13th child. What’s more, he’s been overpowered with an infinite level cap and a cheat that stacks the powers of anyone who serves him. But even privilege has its problems—the glittering facade of high society hides a world of conspiracies, schemes, and power struggles.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":185993,"idMal":60692,"isAdult":false,"meanScore":60,"nextAiringEpisode":{"airingAt":1774191600,"episode":12,"timeUntilAiring":566102},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185993","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["เกิดใหม่มาเป็นผู้สูงศักดิ์ ~สุดแกร่งไร้เทียมทานแต่กำเนิด~"],"title":{"english":"Noble Reincarnation: Born Blessed, So I'll Obtain Ultimate Power","native":"貴族転生 ～恵まれた生まれから最強の力を得る～","romaji":"Kizoku Tensei: Megumareta Umare kara Saikyou no Chikara wo Eru","userPreferred":"Kizoku Tensei: Megumareta Umare kara Saikyou no Chikara wo Eru"},"trailer":{"id":"RIj0yJCVNuU","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RIj0yJCVNuU/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/177385-lzz3yIhQhQdB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#aee4e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177385-TBpvkGdF28R7.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177385-TBpvkGdF28R7.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177385-TBpvkGdF28R7.png"},"description":"Reclusive novelist Makio Koudai has always preferred the company of books—but when her sister and brother-in-law pass away, Makio unexpectedly becomes the guardian of her 15-year-old niece, Asa Takumi. As they navigate grief, clashing personalities, and the challenges of living together, the two slowly open their hearts to each other, discovering warmth, understanding, and the meaning of family.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":30,"month":3,"year":2026},"episodes":13,"format":"TV","genres":["Drama","Slice of Life"],"id":177385,"idMal":58788,"isAdult":false,"meanScore":86,"nextAiringEpisode":{"airingAt":1774191600,"episode":12,"timeUntilAiring":566102},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/177385","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["Diary of a Strange Land","Foreign Country Diary","Different Country Diary","บันทึกจากวิเทศ","مذكرات من بلد آخر","Entre les lignes","위국일기"],"title":{"english":"Journal with Witch","native":"違国日記","romaji":"Ikoku Nikki","userPreferred":"Ikoku Nikki"},"trailer":{"id":"DX6mmkoByyc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/DX6mmkoByyc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/186333-JN8lx2aNOTg1.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5da1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx186333-32qDHxLkndpg.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx186333-32qDHxLkndpg.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx186333-32qDHxLkndpg.png"},"description":"Kunon, a young man who cannot see, has the goal of creating new eyes with water magic. After just five months of learning sorcery, Kunon surpassed his own mentor and honed his talent as he tried to do a feat that's never been done before. A fantasy about a young man, a blind genius, who opens up the world through curiosity in the pursuit for magic is about to begin.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":22,"month":3,"year":2026},"episodes":13,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":186333,"idMal":60810,"isAdult":false,"meanScore":64,"nextAiringEpisode":{"airingAt":1774184400,"episode":13,"timeUntilAiring":558902},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/186333","startDate":{"day":4,"month":1,"year":2026},"status":"RELEASING","synonyms":["จอมเวทผู้มองเห็นทุกสิ่ง คุนอน"],"title":{"english":"Kunon the Sorcerer Can See","native":"魔術師クノンは見えている","romaji":"Majutsushi Kunon wa Mieteiru","userPreferred":"Majutsushi Kunon wa Mieteiru"},"trailer":{"id":"8AdpUgiFs2o","site":"youtube","thumbnail":"https://i.ytimg.com/vi/8AdpUgiFs2o/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166617-P4w3p0H4lE1O.jpg","countryOfOrigin":"JP","coverImage":{"color":"#1a1af1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166617-34fpC9y47tTx.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166617-34fpC9y47tTx.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166617-34fpC9y47tTx.png"},"description":"In a Holy Grail War, Mages (Masters) and their Heroic Spirits (Servants) fight for the control of the Holy Grail—an omnipotent wish-granting device said to fulfill any desire. Years have passed since the end of the Fifth Holy Grail War in Japan. Now, signs portend the emergence of a new Holy Grail in the western American city of Snowfield. Sure enough, Masters and Servants begin to gather... \u003cbr\u003e\u003cbr\u003e\n\nA missing Servant class...\u003cbr\u003e\nImpossible Servant summonings...\u003cbr\u003e\nA nation shrouded in secrecy...\u003cbr\u003e\nAnd a city created as a battleground.\u003cbr\u003e\n\u003cbr\u003e\nIn the face of such irregularities, the Holy Grail War is twisted and driven into the depth of madness. Let the curtain rise on a masquerade of humans and heroes, made to dance upon the stage of a false Holy Grail. \u003ci\u003eThis is a Holy Grail War covered in lies.\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Official Site, Aniplex USA, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003c/i\u003e\u003cbr\u003e\n•  \u003ci\u003eSpecial premiere of Episode 1 in its English Dub occurred in Los Angeles at the Fate 20th Anniversary Showcase event and as well through Crunchyroll’s YouTube Channel on November 23, 2024 before the Japanese television premiere.\u003c/i\u003e\u003cbr\u003e\n•  \u003ci\u003eThe Japanese advanced premiere occurred during the \"Fate New Year's Eve TV Special 2024\" on December 31, 2024.\u003c/i\u003e","duration":25,"endDate":{"day":28,"month":3,"year":2026},"episodes":13,"format":"TV","genres":["Action","Adventure","Fantasy","Mystery","Supernatural"],"id":166617,"idMal":55830,"isAdult":false,"meanScore":83,"nextAiringEpisode":{"airingAt":1774103400,"episode":12,"timeUntilAiring":477902},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/166617","startDate":{"day":3,"month":1,"year":2026},"status":"RELEASING","synonyms":["Судьба/Странная подделка"],"title":{"english":"Fate/strange Fake","native":"Fate/strange Fake","romaji":"Fate/strange Fake","userPreferred":"Fate/strange Fake"},"trailer":{"id":"k1G8EvZg_BY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/k1G8EvZg_BY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/167152-6QxZG8Dmf1EL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx167152-u0cBZkqDowHP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx167152-u0cBZkqDowHP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx167152-u0cBZkqDowHP.jpg"},"description":"In a world where heroism is a punishment, Xylo Forbartz, a condemned goddess killer, battles endless hordes of monstrous abominations as part of Penal Hero Unit 9004. Death is no escape, only a cycle of resurrection and relentless combat. But when Xylo encounters a mysterious new goddess, their unlikely alliance sparks a rebellion that could shatter the chains of eternal punishment.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- The first episode aired with a runtime of ~58 minutes as opposed to the standard 24 minute long episode.\u003cbr\u003e\n- Initially scheduled to air in October, 2025 \u003c/i\u003e","duration":25,"endDate":{"day":26,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Comedy","Drama","Fantasy"],"id":167152,"idMal":56009,"isAdult":false,"meanScore":79,"nextAiringEpisode":{"airingAt":1773927000,"episode":11,"timeUntilAiring":301502},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/167152","startDate":{"day":3,"month":1,"year":2026},"status":"RELEASING","synonyms":["ผู้กล้าโทษประหาร : บันทึกการรับโทษของหน่วยผู้กล้าต้องโทษ 9004","용사형에 처함"],"title":{"english":"Sentenced to Be a Hero","native":"勇者刑に処す　懲罰勇者9004隊刑務記録","romaji":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku","userPreferred":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku"},"trailer":{"id":"GcRs1JC7xeg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/GcRs1JC7xeg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21-ELSYx3yMPcKM.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21-ELSYx3yMPcKM.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21-ELSYx3yMPcKM.jpg"},"description":"Gold Roger was known as the Pirate King, the strongest and most infamous being to have sailed the Grand Line. The capture and death of Roger by the World Government brought a change throughout the world. His last words before his death revealed the location of the greatest treasure in the world, One Piece. It was this revelation that brought about the Grand Age of Pirates, men who dreamed of finding One Piece (which promises an unlimited amount of riches and fame), and quite possibly the most coveted of titles for the person who found it, the title of the Pirate King.\u003cbr\u003e\u003cbr\u003e\nEnter Monkey D. Luffy, a 17-year-old boy that defies your standard definition of a pirate. Rather than the popular persona of a wicked, hardened, toothless pirate who ransacks villages for fun, Luffy’s reason for being a pirate is one of pure wonder; the thought of an exciting adventure and meeting new and intriguing people, along with finding One Piece, are his reasons of becoming a pirate. Following in the footsteps of his childhood hero, Luffy and his crew travel across the Grand Line, experiencing crazy adventures, unveiling dark mysteries and battling strong enemies, all in order to reach One Piece.\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003e*This includes following special episodes:\u003c/b\u003e\u003cbr\u003e\n- Chopperman to the Rescue! Protect the TV Station by the Shore! (Episode 336)\u003cbr\u003e\n- The Strongest Tag-Team! Luffy and Toriko's Hard Struggle! (Episode 492)\u003cbr\u003e\n- Team Formation! Save Chopper (Episode 542)\u003cbr\u003e\n- History's Strongest Collaboration vs. Glutton of the Sea (Episode 590)\u003cbr\u003e\n- 20th Anniversary! Special Romance Dawn (Episode 907)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":21,"idMal":21,"isAdult":false,"meanScore":88,"nextAiringEpisode":{"airingAt":1775398560,"episode":1156,"timeUntilAiring":1773062},"season":"FALL","seasonYear":1999,"siteUrl":"https://anilist.co/anime/21","startDate":{"day":20,"month":10,"year":1999},"status":"RELEASING","synonyms":["ワンピース","海贼王","וואן פיס","ون بيس","วันพีซ","Vua Hải Tặc","All'arrembaggio!","Tutti all'arrembaggio!","Ντρέηκ, το Κυνήγι του Θησαυρού","OP","Ван-Пис"],"title":{"english":"ONE PIECE","native":"ONE PIECE","romaji":"ONE PIECE","userPreferred":"ONE PIECE"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179062-ZnxW4uWEsV3H.jpg","countryOfOrigin":"JP","coverImage":{"color":"#febb28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179062-pbzYE1miZq61.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179062-pbzYE1miZq61.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179062-pbzYE1miZq61.png"},"description":"The second cour of \u003ci\u003eEnen no Shouboutai: San no Shou\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e \n\nAs chaos spreads, Shinra and Company 8 fight to stop a final, world-ending blaze.\u003cbr\u003e\u003cbr\u003e \n\n(Source: Crunchyroll News)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":13,"format":"TV","genres":["Action","Drama","Sci-Fi","Supernatural"],"id":179062,"idMal":59229,"isAdult":false,"meanScore":80,"nextAiringEpisode":{"airingAt":1774025580,"episode":11,"timeUntilAiring":400082},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/179062","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["Enen no Shouboutai 3rd Season Part 2","หน่วยผจญคนไฟลุก ภาค 3"],"title":{"english":"Fire Force Season 3 Part 2","native":"炎炎ノ消防隊 参ノ章 第2クール","romaji":"Enen no Shouboutai: San no Shou Part 2","userPreferred":"Enen no Shouboutai: San no Shou Part 2"},"trailer":{"id":"voLZJvdwUEE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/voLZJvdwUEE/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/192507-nv0NJmhQYTgz.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5086e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx192507-SCmImUlUnpAD.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx192507-SCmImUlUnpAD.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx192507-SCmImUlUnpAD.jpg"},"description":"Yoi Takiguchi has long legs, a deep voice, and a handsome face…in other words, Yoi is such a good-looking guy that most people don’t notice or care that she is, in fact, a girl. Indeed, she’s had the nickname “Prince” for as long as she can remember. That is, until she met Ichimura-senpai…the only person who really seemed to see her for herself. To her surprise, she’s not sure how to handle this new relationship, especially when her newfound friend is a prince himself (and a guy prince, at that). The story of the two high school princes starts here!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Romance","Slice of Life"],"id":192507,"idMal":61663,"isAdult":false,"meanScore":73,"nextAiringEpisode":{"airingAt":1774164600,"episode":11,"timeUntilAiring":539102},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/192507","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["เมื่อสาวหล่อขอมีรัก"],"title":{"english":"In the Clear Moonlit Dusk","native":"うるわしの宵の月","romaji":"Uruwashi no Yoi no Tsuki","userPreferred":"Uruwashi no Yoi no Tsuki"},"trailer":{"id":"VzJSWjCCn8M","site":"youtube","thumbnail":"https://i.ytimg.com/vi/VzJSWjCCn8M/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182587-SLNmuinewbUF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45df1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182587-fsU8LOjmd7oj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182587-fsU8LOjmd7oj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182587-fsU8LOjmd7oj.jpg"},"description":"The third season of \u003ci\u003e[Oshi no Ko]\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nThe story enters a new stage.\n\u003cbr\u003e\u003cbr\u003e\nIt's been six months since \"POP IN 2\" was released. Thanks to MEM-Cho's hard work, B-Komachi is about to get their major break. Aqua is a multi-talented entertainer, and Akane's career as a talented actress is going smoothly. Meanwhile, Kana lost the cheerfulness she once had. To track down the truth behind Ai and Goro's deaths, Ruby keeps rising in the entertainment world...\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eUsing lies as a weapon.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":25,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Drama","Mystery","Psychological","Supernatural"],"id":182587,"idMal":60058,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773842400,"episode":10,"timeUntilAiring":216902},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182587","startDate":{"day":14,"month":1,"year":2026},"status":"RELEASING","synonyms":["[OSHI NO KO] Season 3"],"title":{"english":"【OSHI NO KO】Season 3","native":"【推しの子】第3期","romaji":"[Oshi no Ko] 3rd Season","userPreferred":"[Oshi no Ko] 3rd Season"},"trailer":{"id":"JGYY6Pui5Kc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JGYY6Pui5Kc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183660-RmcBY27wn8A4.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f15d35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183660-B6o9cMfSfScX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx183660-B6o9cMfSfScX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx183660-B6o9cMfSfScX.jpg"},"description":"Kaya-chan attends Hanamugi Kindergarten, and she has an incredibly strong sixth sense. She secretly beats up the ghosts that stalk her friends and family, but in turn, she’s treated like a troublemaker since nobody understands her strange behavior. Everything changes when her teacher, Chie, discovers her secret. Kaya-chan's fists will go flying at any sinister spirits that show up!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy","Horror","Slice of Life"],"id":183660,"idMal":60223,"isAdult":false,"meanScore":70,"nextAiringEpisode":{"airingAt":1774168200,"episode":11,"timeUntilAiring":542702},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/183660","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["カヤコワ","KayaKowa","คายะจังไม่กลัวหรอกนะ"],"title":{"english":"Kaya-chan Isn't Scary","native":"カヤちゃんはコワくない","romaji":"Kaya-chan wa Kowakunai","userPreferred":"Kaya-chan wa Kowakunai"},"trailer":{"id":"un9g38-wbHw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/un9g38-wbHw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185262-6EExIkvGk1dI.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbe450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185262-95wbx3Y9hCwm.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185262-95wbx3Y9hCwm.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185262-95wbx3Y9hCwm.jpg"},"description":"Thirty-five-year-old Kenichi Yamada has spent his life playing every single MMORPG he can get his hands on. Tired of new games that cater to casual players, he leaps at the chance to try out a never-ending game with an intimidating “Hell Mode” that raises the difficulty (and chances to level up) to impossible heights. But, as soon as he selects the “Summoner,” Kenichi finds himself transported into the world of the game and reborn to a family of serfs as a baby named Allen! With nothing but his memories and wits to guide him, Allen sets off to conquer Hell Mode, unearth the secrets of the Summoner class, and free his newfound family from their fate.\u003cbr\u003e\n\u003cbr\u003e\n(Source: HIDIVE)","duration":23,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"TV","genres":["Action","Adventure","Fantasy"],"id":185262,"idMal":60460,"isAdult":false,"meanScore":67,"nextAiringEpisode":{"airingAt":1774024500,"episode":11,"timeUntilAiring":399002},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185262","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["HELL MODE อยากเล่นโหด ขอโหมดนรก"],"title":{"english":"HELL MODE: The Hardcore Gamer Dominates in Another World with Garbage Balancing","native":"ヘルモード ～やり込み好きのゲーマーは廃設定の異世界で無双する～","romaji":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru","userPreferred":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru"},"trailer":{"id":"CjO1Bo297N4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/CjO1Bo297N4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#fff193","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177580-ujQw6Ws3oVCi.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177580-ujQw6Ws3oVCi.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177580-ujQw6Ws3oVCi.jpg"},"description":"Mizuki Ashiya is on a mission: disguise herself as a boy and enroll in a male boarding school to meet her idol, high jump star Izumi Sano. But after successfully infiltrating the school, she discovers he’s suddenly quit the sport! Now Mizuki must dodge suspicion, protect her cover, and somehow reach the boy she came all this way for—all while surviving the chaos of an all-boys dorm!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":15,"month":3,"year":2026},"episodes":12,"format":"ONA","genres":["Comedy","Drama","Romance","Slice of Life"],"id":177580,"idMal":58861,"isAdult":false,"meanScore":67,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/177580","startDate":{"day":4,"month":1,"year":2026},"status":"FINISHED","synonyms":["Hana-Kimi: For You in Full Blossom","สับขั้วมาลุ้นรัก"],"title":{"english":"Hana-Kimi","native":"花ざかりの君たちへ","romaji":"Hanazakari no Kimitachi e","userPreferred":"Hanazakari no Kimitachi e"},"trailer":{"id":"CemNP0vIiJI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/CemNP0vIiJI/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/195518-IpfwJgnWa6nD.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5d86e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx195518-XXcYHi6tXM6v.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx195518-XXcYHi6tXM6v.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx195518-XXcYHi6tXM6v.jpg"},"description":"Tiararose Lapis Clamentile is set to marry Hartknights, crown prince of Lapis Lazuli—until she suddenly remembers her past life and realizes she’s been reincarnated into her favorite game, The Ring of Lapis Lazuli, as the doomed villainess! But just as she’s about to lose hope, the crown prince of Aquasteed proposes instead. Could this unexpected turn finally lead to a happy ending of her own?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Fantasy","Romance"],"id":195518,"idMal":62000,"isAdult":false,"meanScore":58,"nextAiringEpisode":{"airingAt":1774188000,"episode":11,"timeUntilAiring":562502},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/195518","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["The Villainess Is Being Doted on by the Crown Prince of the Neighboring Country","ท่านหญิงนางร้ายถูกเจ้าชายรัชทายาท ของอาณาจักรข้างเคียงหลงรัก"],"title":{"english":"The Villainess Is Adored by the Prince of the Neighbor Kingdom","native":"悪役令嬢は隣国の王太子に溺愛される","romaji":"Akuyaku Reijou wa Ringoku no Outaishi ni Dekiai Sareru","userPreferred":"Akuyaku Reijou wa Ringoku no Outaishi ni Dekiai Sareru"},"trailer":{"id":"3wNyyhzLqA0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/3wNyyhzLqA0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187264-aOUNQvTriPkX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187264-aOUNQvTriPkX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187264-aOUNQvTriPkX.jpg"},"description":"Betrayed by his childhood friend and cast out of the Hero Party, Orhun Dura—once their loyal Enchanter—is branded by his former comrades as “a jack-of-all-trades but a master of none.” Alone, he sets out to forge a new path as a solo adventurer. His journey sparks explosive battles, deadly rivals, and unexpected allies—and he’ll rise to shatter every expectation. The ultimate solo comeback begins!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":187264,"idMal":61128,"isAdult":false,"meanScore":66,"nextAiringEpisode":{"airingAt":1773846000,"episode":12,"timeUntilAiring":220502},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/187264","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Yuusha Party wo Oidasareta Kiyou Binbou: Party Jijou de Fuyo Jutsushi wo Yatteita Kenshi, Bannou e to Itaru","勇者パーティを追い出された器用貧乏　～パーティ事情で付与術士をやっていた剣士、万能へと至る～","เก่งรอบด้านแต่ไร้ทีเด็ด เลยถูกเฉดหัวจากปาร์ตี้ผู้กล้า","용사 파티에서 쫓겨난 다재무능"],"title":{"english":"Jack-of-All-Trades, Party of None","native":"勇者パーティを追い出された器用貧乏","romaji":"Yuusha Party wo Oidasareta Kiyou Binbou","userPreferred":"Yuusha Party wo Oidasareta Kiyou Binbou"},"trailer":{"id":"dLDimMasKBM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dLDimMasKBM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/145064-esDtAY2He7sk.jpg","countryOfOrigin":"JP","coverImage":{"color":"#a178d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx145064-hSNRJM03pvv1.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx145064-hSNRJM03pvv1.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx145064-hSNRJM03pvv1.jpg"},"description":"The second season of \u003ci\u003eJujutsu Kaisen\u003c/i\u003e.\u003cbr\u003e\n\u003cbr\u003e\nThe past comes to light when second-year students Satoru Gojou and Suguru Getou are tasked with escorting young Riko Amanai to Master Tengen. But when a non-sorcerer user tries to kill them, their mission to protect the Star Plasma Vessel threatens to turn them into bitter enemies and cement their destinies—one as the world’s strongest sorcerer, and the other its most twisted curse user!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crun