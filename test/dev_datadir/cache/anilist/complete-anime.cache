7404-QMZJVARntkbv.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx167404-QMZJVARntkbv.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx167404-QMZJVARntkbv.jpg"},"description":"\u003ci\u003eMONSTERS: 103 Mercies Dragon Damnation\u003c/i\u003e by Eiichiro Oda tells the tale of Ryuuma, the legendary swordsman that hails from the Land of Wano in \u003ci\u003eOne Piece\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e \n\nA samurai's path leads him to a young waitress whose hometown was destroyed by a dragon. He doesn't want any trouble - but it finds them anyway.\u003cbr\u003e\u003cbr\u003e\n\n(Source: Netflix Anime, edited)","duration":25,"endDate":{"day":21,"month":1,"year":2024},"episodes":1,"format":"ONA","genres":["Action","Comedy","Drama"],"id":167404,"idMal":56055,"isAdult":false,"meanScore":76,"season":"WINTER","seasonYear":2024,"siteUrl":"https://anilist.co/anime/167404","startDate":{"day":21,"month":1,"year":2024},"status":"FINISHED","synonyms":["الوحوش: لعنة التنين","Monsters: El infierno del dragón","Monsters 103: Emociones del dragón volador del samurái extremo","Монстры: Сто три милости — Проклятие дракона","Monsters ร้อยสาม จิตอาวรณ์ ขุนศึกผยอง มังกรทะยานฟ้า","Monstros: A Maldição do Dragão","MONSTERS 103 emoções! Inferno extremo do dragão voador"],"title":{"english":"MONSTERS: 103 Mercies Dragon Damnation","native":"MONSTERS 一百三情飛龍侍極","romaji":"MONSTERS: Ippaku Sanjou Hiryuu Jigoku","userPreferred":"MONSTERS: Ippaku Sanjou Hiryuu Jigoku"},"trailer":{"id":"Q6tmyHjEFcE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Q6tmyHjEFcE/hqdefault.jpg"},"type":"ANIME"},"relationType":"PREQUEL"},{"node":{"countryOfOrigin":"JP","coverImage":{"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx171630-CULIbflZbhK1.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx171630-CULIbflZbhK1.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx171630-CULIbflZbhK1.jpg"},"description":"To commemorate the \u003ci\u003eONE PIECE\u003c/i\u003e anime's 25th anniversary: \u003ci\u003eTHE ONE PIECE\u003c/i\u003e anime by WIT Studio will recreate the story of the original \u003ci\u003eONE PIECE\u003c/i\u003e manga, starting from the East Blue arc.\u003cbr\u003e\u003cbr\u003e\n\n(Source: Netflix, edited)","endDate":{},"genres":["Adventure"],"id":171630,"idMal":57557,"isAdult":false,"siteUrl":"https://anilist.co/anime/171630","startDate":{},"status":"NOT_YET_RELEASED","synonyms":["ザワンピース"],"title":{"english":"THE ONE PIECE","native":"THE ONE PIECE","romaji":"THE ONE PIECE","userPreferred":"THE ONE PIECE"},"trailer":{"id":"OxXx-iApUi0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/OxXx-iApUi0/hqdefault.jpg"},"type":"ANIME"},"relationType":"ALTERNATIVE"},{"node":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/177475-wHviMxtu8KT7.jpg","countryOfOrigin":"JP","coverImage":{"color":"#d6ae6b","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177475-8HlvUgopoH0S.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177475-8HlvUgopoH0S.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177475-8HlvUgopoH0S.png"},"description":"A promotional video collaboration between ONE PIECE and KAWAISOUNI!, advertising the release of the 108th ONE PIECE manga volume.","duration":1,"endDate":{"day":3,"month":3,"year":2024},"episodes":1,"format":"ONA","genres":["Comedy","Fantasy"],"id":177475,"idMal":58307,"isAdult":false,"meanScore":61,"siteUrl":"https://anilist.co/anime/177475","startDate":{"day":3,"month":3,"year":2024},"status":"FINISHED","title":{"native":"ONE PIECE×可哀想に！～この帽子を お前に預ける～","romaji":"ONE PIECE×KAWAISOUNI! Kono Boushi wo Omae ni Azukeru","userPreferred":"ONE PIECE×KAWAISOUNI! Kono Boushi wo Omae ni Azukeru"},"trailer":{"id":"jmsV1MmwkL0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/jmsV1MmwkL0/hqdefault.jpg"},"type":"ANIME"},"relationType":"OTHER"},{"node":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182469-obNr7bznMzN7.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182469-JQ808NBPxmgn.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182469-JQ808NBPxmgn.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182469-JQ808NBPxmgn.jpg"},"description":"To commemorate the 25th anniversary of the \u003ci\u003eONE PIECE\u003c/i\u003e TV anime: an animated adaptation of the \"ONE PIECE novel: Mugiwara Stories\". \u003cbr\u003e\u003cbr\u003e\n\nTwo years after the Paramount War, the Straw Hats are about to reunite on the Sabaody Archipelago. At the same time, a girl who is head over heels for Nami is trying to hand a fan letter to her before the group leaves the island.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":25,"endDate":{"day":20,"month":10,"year":2024},"episodes":1,"format":"SPECIAL","genres":["Action","Adventure","Fantasy"],"id":182469,"idMal":60022,"isAdult":false,"meanScore":90,"season":"FALL","seasonYear":2024,"siteUrl":"https://anilist.co/anime/182469","startDate":{"day":20,"month":10,"year":2024},"status":"FINISHED","title":{"english":"ONE PIECE FAN LETTER","native":"ONE PIECE FAN LETTER","romaji":"ONE PIECE FAN LETTER","userPreferred":"ONE PIECE FAN LETTER"},"trailer":{"id":"MewJ5bEM-5U","site":"youtube","thumbnail":"https://i.ytimg.com/vi/MewJ5bEM-5U/hqdefault.jpg"},"type":"ANIME"},"relationType":"SIDE_STORY"},{"node":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183423-kYnannPuKynK.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1bb35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183423-6Iiu194UDxD0.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx183423-6Iiu194UDxD0.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx183423-6Iiu194UDxD0.jpg"},"description":"A condensed and remastered reairing of the \u003ci\u003eFish-Man Island Saga\u003c/i\u003e (episodes 517-574) from \u003ci\u003eONE PIECE\u003c/i\u003e, with updated visuals, a new ending song, and brand-new episode previews.\u003cbr\u003e\u003cbr\u003e\n\nThe Straw Hats reunite at Sabaody! The promised day has arrived. The Straw Hats have made it back to Sabaody Archipelago after two arduous years of separation. In the very same place where they once lost to Pacifista, the Straw Hats have proven themselves to be stronger and ready to begin their journey to the New World. With the Thousand Sunny now equipped to travel underwater, the next stop is the Fish-Man Island. “One Piece Log: Fish-Man Island Saga” is a special edited version of the original arc from “One Piece”, in an abridged 21-episode story with an enhanced contemporary visual look.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":30,"month":3,"year":2025},"episodes":21,"format":"TV","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":183423,"idMal":60108,"isAdult":false,"meanScore":78,"season":"FALL","seasonYear":2024,"siteUrl":"https://anilist.co/anime/183423","startDate":{"day":3,"month":11,"year":2024},"status":"FINISHED","title":{"english":"One Piece Log: Fish-Man Island Saga","native":"SPECIAL EDITED VERSION『ONE PIECE』魚人島編","romaji":"ONE PIECE: Gyojin Tou-hen","userPreferred":"ONE PIECE: Gyojin Tou-hen"},"trailer":{"id":"RSM5Heu-lKw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RSM5Heu-lKw/hqdefault.jpg"},"type":"ANIME"},"relationType":"SUMMARY"},{"node":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/187225-Ku5KUWpp0uGq.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4ae35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187225-H0ppAOkOYMxM.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187225-H0ppAOkOYMxM.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187225-H0ppAOkOYMxM.jpg"},"description":"On February 28, \u003ci\u003eONE PIECE\u003c/i\u003e took over Crypto.com Arena for a special game night collab event with the Los Angeles Lakers. The Lakers ended up taking down their opponents in a close 106-102 game, and maybe some of that juice is thanks to the presence of the Straw Hats and a special piece of animation created for the event.\u003cbr\u003e\u003cbr\u003e\n\nThe anime short—which depicts a Lakers uniform-clad Luffy in an intense basketball match against a team of Marines—can be seen in all its 30 seconds of glory. \u003ci\u003eCan our captain Luffy take home the win?\u003c/i\u003e \u003cbr\u003e\u003cbr\u003e\n\n(Source: Crunchyroll News, ONE PIECE Official ENG YouTube description, edited)","duration":1,"endDate":{"day":28,"month":2,"year":2025},"episodes":1,"format":"SPECIAL","genres":["Action","Comedy","Fantasy","Sports"],"id":187225,"isAdult":false,"meanScore":78,"season":"WINTER","seasonYear":2025,"siteUrl":"https://anilist.co/anime/187225","startDate":{"day":28,"month":2,"year":2025},"status":"FINISHED","synonyms":["LOS ANGELES LAKERS x ONE PIECE Special Collab Anime"],"title":{"native":"LOS ANGELES LAKERS x ONE PIECE","romaji":"LOS ANGELES LAKERS x ONE PIECE","userPreferred":"LOS ANGELES LAKERS x ONE PIECE"},"trailer":{"id":"VfKwPIbycbg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/VfKwPIbycbg/hqdefault.jpg"},"type":"ANIME"},"relationType":"CHARACTER"},{"node":{"countryOfOrigin":"JP","coverImage":{"color":"#35bbf1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx188668-rOB7rkgOz89w.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx188668-rOB7rkgOz89w.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx188668-rOB7rkgOz89w.jpg"},"description":"The premise of this spinoff is about three high school students: a young male student, his girlfriend and a third wheel who is a One Piece fanatic. Their names are similar to the Straw Hat Pirates and the group form a fan club dedicated to One Piece.\n\u003cbr\u003e\u003cBr\u003e\n(Source: One Piece Wiki)","duration":7,"endDate":{"day":5,"month":4,"year":2025},"episodes":5,"format":"ONA","genres":["Comedy","Romance"],"id":188668,"idMal":61293,"isAdult":false,"meanScore":67,"season":"SPRING","seasonYear":2025,"siteUrl":"https://anilist.co/anime/188668","startDate":{"day":1,"month":4,"year":2025},"status":"FINISHED","synonyms":["One Piece in Love"],"title":{"native":"恋するワンピース","romaji":"Koisuru ONE PIECE","userPreferred":"Koisuru ONE PIECE"},"type":"ANIME"},"relationType":"SIDE_STORY"},{"node":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/197178-kVx0Zt3P0MvD.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45d86","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx197178-Ui8PY9HQbNgu.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx197178-Ui8PY9HQbNgu.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx197178-Ui8PY9HQbNgu.jpg"},"description":"Based on the novel series \u003ci\u003eONE PIECE novel HEROINES\u003c/i\u003e, one chapter, “episode : NAMI” is getting an anime adaptation. \n\u003cbr\u003e\u003cbr\u003e\nAfter buying poorly made shoes, Nami returns to the shop and meets Lebno, the designer. He offers to create a new pair from scratch, on the condition that she becomes his model. However, the craftsperson Miucha is the one who does the work.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Toei Animation Europe)","endDate":{"day":5,"month":7,"year":2026},"episodes":1,"format":"SPECIAL","id":197178,"idMal":62233,"isAdult":false,"nextAiringEpisode":{"airingAt":1783260900,"episode":1,"timeUntilAiring":10431588},"season":"SUMMER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/197178