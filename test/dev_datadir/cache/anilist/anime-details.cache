":{"id":132478,"name":{"full":"Hiroaki Miyamoto"}},"role":"Episode Director"},{"node":{"id":104171,"name":{"full":"Atsuko Kawamura"}},"role":"Animation Director"},{"node":{"id":103815,"name":{"full":"Katsumi Ishizuka"}},"role":"Animation Director (eps 290, 298, 309, 317, 342, 353, 401, 419, 437, 447, 457, 464, 476, 486, 497, 511, 525, 538, 551, 561, 572, 583, 594, 1062, 1093, 1122, 1125, 1129, 1144)"},{"node":{"id":102679,"name":{"full":"Noboru Koizumi"}},"role":"Animation Director"},{"node":{"id":103802,"name":{"full":"Masayuki Takagi"}},"role":"Animation Director (eps 118, 133, 139, 145, 151, 173, 180, 186, 191, 198, 204, 287, 294, 301, 308, 316, 324, 332, 389, 397, 405, 415, 423, 432, 441, 449, 458, 469, 480, 531, 546, 556, 564, 574"}]},"startDate":{"day":20,"month":10,"year":1999},"studios":{"nodes":[{"id":18,"name":"Toei Animation"}]}}},"updated_at":"2026-03-06T23:35:08.843562+03:00"},"21116":{"value":{"Media":{"averageScore":54,"characters":{"edges":[{"id":99754,"node":{"age":"15","dateOfBirth":{},"description":"A child soldier that arrives at Mermaid Island on the same day as Mamori. Quickly establishing herself as a powerful Liberator, Mirei can be mistaken as cruel due to her stunted social skills and intimidating appearance. In reality, she is kindhearted and stoic unless Mamori is being bullied or threatened.","gender":"Female","id":89144,"image":{"large":"https://s4.anilist.co/file/anilistcdn/character/large/b89144-Xk3C0XdPOBr1.png"},"isFavourite":false,"name":{"full":"Mirei Shikishima","native":"敷島魅零"},"siteUrl":"https://anilist.co/character/89144"},"role":"MAIN"},{"id":99755,"node":{"age":"16","dateOfBirth":{},"description":"A high schooler forcibly sent to Mermaid Island after contracting the A-Virus. Mamori is a gentle girl who abhors violence. This puts her at odds with her ability to transform into a deadly weapon as an Extar. She is frequently teased over her family name being written with the same Kanji as \"Virgin\".","id":89143,"image":{"large"