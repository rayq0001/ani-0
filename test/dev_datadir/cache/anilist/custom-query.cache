gAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":20,\"sort\":[\"TRENDING_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182255-wyHvp6zJbWsO.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dc9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182255-butzrqd4I0aC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182255-butzrqd4I0aC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182255-butzrqd4I0aC.jpg"},"description":"The second season of \u003ci\u003eSousou no Frieren\u003c/i\u003e.","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":10,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":182255,"idMal":59978,"isAdult":false,"meanScore":89,"nextAiringEpisode":{"airingAt":1773410400,"episode":8,"timeUntilAiring":574230},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182255","startDate":{"day":16,"month":1,"year":2026},"status":"RELEASING","synonyms":["Провожающая в последний путь Фрирен 2","장송의 프리렌 2기"],"title":{"english":"Frieren: Beyond Journey’s End Season 2","native":"葬送のフリーレン 第2期","romaji":"Sousou no Frieren 2nd Season","userPreferred":"Sousou no Frieren 2nd Season"},"trailer":{"id":"RH-FcW94z00","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RH-FcW94z00/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/172463-3J2o3qQZadFJ.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5093d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx172463-LnXqHzt74SJL.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx172463-LnXqHzt74SJL.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx172463-LnXqHzt74SJL.jpg"},"description":"The third season of \u003ci\u003eJujutsu Kaisen\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\nAfter the Shibuya Incident, a deadly jujutsu battle known as the Culling Game orchestrated by Noritoshi Kamo erupts across ten colonies in Japan.\u003cbr\u003e\u003cbr\u003e\nHaunted by guilt over the mass killings in Shibuya and wary of Sukuna’s interest in Fushiguro, Itadori chooses not to return to Jujutsu High. Instead, he teams up with Choso to exorcise the countless cursed spirits unleashed by Noritoshi Kamo.\nAmid this chaos, the Jujutsu Headquarters revokes Yuji Itadori’s suspended death sentence and appoints special-grade sorcerer Yuta Okkotsu as his executioner. \u003cbr\u003e\u003cbr\u003e\nNewly awakened modern sorcerers and resurrected ancient ones,  now fighting as players in the Culling Game, collide with conflicting motives, driving the world once more toward an age ruled by jujutsu.\u003cbr\u003e\u003cbr\u003e\n(Source: TOHO Animation)","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Drama","Supernatural"],"id":172463,"idMal":57658,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773329160,"episode":10,"timeUntilAiring":492990},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/172463","startDate":{"day":9,"month":1,"year":2026},"status":"RELEASING","synonyms":["Jujutsu Kaisen 3rd Season","呪術廻戦 第3期","JJK3","มหาเวทย์ผนึกมาร จรดลล้างบาง พาร์ต 1"],"title":{"english":"JUJUTSU KAISEN Season 3: The Culling Game Part 1","native":"呪術廻戦 死滅回游 前編","romaji":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen","userPreferred":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen"},"trailer":{"id":"ruX3rIj3--w","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ruX3rIj3--w/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179062-ZnxW4uWEsV3H.jpg","countryOfOrigin":"JP","coverImage":{"color":"#febb28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179062-pbzYE1miZq61.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179062-pbzYE1miZq61.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179062-pbzYE1miZq61.png"},"description":"The second cour of \u003ci\u003eEnen no Shouboutai: San no Shou\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e \n\nAs chaos spreads, Shinra and Company 8 fight to stop a final, world-ending blaze.\u003cbr\u003e\u003cbr\u003e \n\n(Source: Crunchyroll News)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":13,"format":"TV","genres":["Action","Drama","Sci-Fi","Supernatural"],"id":179062,"idMal":59229,"isAdult":false,"meanScore":80,"nextAiringEpisode":{"airingAt":1773420780,"episode":10,"timeUntilAiring":584610},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/179062","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["Enen no Shouboutai 3rd Season Part 2","หน่วยผจญคนไฟลุก ภาค 3"],"title":{"english":"Fire Force Season 3 Part 2","native":"炎炎ノ消防隊 参ノ章 第2クール","romaji":"Enen no Shouboutai: San no Shou Part 2","userPreferred":"Enen no Shouboutai: San no Shou Part 2"},"trailer":{"id":"voLZJvdwUEE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/voLZJvdwUEE/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185262-6EExIkvGk1dI.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbe450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185262-95wbx3Y9hCwm.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185262-95wbx3Y9hCwm.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185262-95wbx3Y9hCwm.jpg"},"description":"Thirty-five-year-old Kenichi Yamada has spent his life playing every single MMORPG he can get his hands on. Tired of new games that cater to casual players, he leaps at the chance to try out a never-ending game with an intimidating “Hell Mode” that raises the difficulty (and chances to level up) to impossible heights. But, as soon as he selects the “Summoner,” Kenichi finds himself transported into the world of the game and reborn to a family of serfs as a baby named Allen! With nothing but his memories and wits to guide him, Allen sets off to conquer Hell Mode, unearth the secrets of the Summoner class, and free his newfound family from their fate.\u003cbr\u003e\n\u003cbr\u003e\n(Source: HIDIVE)","duration":23,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"TV","genres":["Action","Adventure","Fantasy"],"id":185262,"idMal":60460,"isAdult":false,"meanScore":67,"nextAiringEpisode":{"airingAt":1773419700,"episode":10,"timeUntilAiring":583530},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185262","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["HELL MODE อยากเล่นโหด ขอโหมดนรก"],"title":{"english":"HELL MODE: The Hardcore Gamer Dominates in Another World with Garbage Balancing","native":"ヘルモード ～やり込み好きのゲーマーは廃設定の異世界で無双する～","romaji":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru","userPreferred":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru"},"trailer":{"id":"CjO1Bo297N4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/CjO1Bo297N4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/167152-6QxZG8Dmf1EL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx167152-u0cBZkqDowHP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx167152-u0cBZkqDowHP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx167152-u0cBZkqDowHP.jpg"},"description":"In a world where heroism is a punishment, Xylo Forbartz, a condemned goddess killer, battles endless hordes of monstrous abominations as part of Penal Hero Unit 9004. Death is no escape, only a cycle of resurrection and relentless combat. But when Xylo encounters a mysterious new goddess, their unlikely alliance sparks a rebellion that could shatter the chains of eternal punishment.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- The first episode aired with a runtime of ~58 minutes as opposed to the standard 24 minute long episode.\u003cbr\u003e\n- Initially scheduled to air in October, 2025 \u003c/i\u003e","duration":25,"endDate":{"day":26,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Comedy","Drama","Fantasy"],"id":167152,"idMal":56009,"isAdult":false,"meanScore":80,"nextAiringEpisode":{"airingAt":1773322200,"episode":10,"timeUntilAiring":486030},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/167152","startDate":{"day":3,"month":1,"year":2026},"status":"RELEASING","synonyms":["ผู้กล้าโทษประหาร : บันทึกการรับโทษของหน่วยผู้กล้าต้องโทษ 9004","용사형에 처함"],"title":{"english":"Sentenced to Be a Hero","native":"勇者刑に処す　懲罰勇者9004隊刑務記録","romaji":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku","userPreferred":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku"},"trailer":{"id":"GcRs1JC7xeg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/GcRs1JC7xeg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182587-SLNmuinewbUF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45df1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182587-fsU8LOjmd7oj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182587-fsU8LOjmd7oj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182587-fsU8LOjmd7oj.jpg"},"description":"The third season of \u003ci\u003e[Oshi no Ko]\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nThe story enters a new stage.\n\u003cbr\u003e\u003cbr\u003e\nIt's been six months since \"POP IN 2\" was released. Thanks to MEM-Cho's hard work, B-Komachi is about to get their major break. Aqua is a multi-talented entertainer, and Akane's career as a talented actress is going smoothly. Meanwhile, Kana lost the cheerfulness she once had. To track down the truth behind Ai and Goro's deaths, Ruby keeps rising in the entertainment world...\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eUsing lies as a weapon.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":25,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Drama","Mystery","Psychological","Supernatural"],"id":182587,"idMal":60058,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773237600,"episode":9,"timeUntilAiring":401430},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182587","startDate":{"day":14,"month":1,"year":2026},"status":"RELEASING","synonyms":["[OSHI NO KO] Season 3"],"title":{"english":"【OSHI NO KO】Season 3","native":"【推しの子】第3期","romaji":"[Oshi no Ko] 3rd Season","userPreferred":"[Oshi no Ko] 3rd Season"},"trailer":{"id":"JGYY6Pui5Kc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JGYY6Pui5Kc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21-ELSYx3yMPcKM.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21-ELSYx3yMPcKM.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21-ELSYx3yMPcKM.jpg"},"description":"Gold Roger was known as the Pirate King, the strongest and most infamous being to have sailed the Grand Line. The capture and death of Roger by the World Government brought a change throughout the world. His last words before his death revealed the location of the greatest treasure in the world, One Piece. It was this revelation that brought about the Grand Age of Pirates, men who dreamed of finding One Piece (which promises an unlimited amount of riches and fame), and quite possibly the most coveted of titles for the person who found it, the title of the Pirate King.\u003cbr\u003e\u003cbr\u003e\nEnter Monkey D. Luffy, a 17-year-old boy that defies your standard definition of a pirate. Rather than the popular persona of a wicked, hardened, toothless pirate who ransacks villages for fun, Luffy’s reason for being a pirate is one of pure wonder; the thought of an exciting adventure and meeting new and intriguing people, along with finding One Piece, are his reasons of becoming a pirate. Following in the footsteps of his childhood hero, Luffy and his crew travel across the Grand Line, experiencing crazy adventures, unveiling dark mysteries and battling strong enemies, all in order to reach One Piece.\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003e*This includes following special episodes:\u003c/b\u003e\u003cbr\u003e\n- Chopperman to the Rescue! Protect the TV Station by the Shore! (Episode 336)\u003cbr\u003e\n- The Strongest Tag-Team! Luffy and Toriko's Hard Struggle! (Episode 492)\u003cbr\u003e\n- Team Formation! Save Chopper (Episode 542)\u003cbr\u003e\n- History's Strongest Collaboration vs. Glutton of the Sea (Episode 590)\u003cbr\u003e\n- 20th Anniversary! Special Romance Dawn (Episode 907)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":21,"idMal":21,"isAdult":false,"meanScore":88,"nextAiringEpisode":{"airingAt":1775398560,"episode":1156,"timeUntilAiring":2562390},"season":"FALL","seasonYear":1999,"siteUrl":"https://anilist.co/anime/21","startDate":{"day":20,"month":10,"year":1999},"status":"RELEASING","synonyms":["ワンピース","海贼王","וואן פיס","ون بيس","วันพีซ","Vua Hải Tặc","All'arrembaggio!","Tutti all'arrembaggio!","Ντρέηκ, το Κυνήγι του Θησαυρού","OP","Ван-Пис"],"title":{"english":"ONE PIECE","native":"ONE PIECE","romaji":"ONE PIECE","userPreferred":"ONE PIECE"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166613-drS86exJlIjG.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166613-uHB8q3D4qbon.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166613-uHB8q3D4qbon.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166613-uHB8q3D4qbon.jpg"},"description":"The second season of \u003ci\u003eJigokuraku\u003c/i\u003e.","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Adventure","Mystery","Supernatural"],"id":166613,"idMal":55825,"isAdult":false,"meanScore":81,"nextAiringEpisode":{"airingAt":1772981040,"episode":9,"timeUntilAiring":144870},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/166613","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["Hell’s Paradise: Jigokuraku Season 2","สุขาวดีอเวจี","Адский рай"],"title":{"english":"Hell’s Paradise Season 2","native":"地獄楽 第二期","romaji":"Jigokuraku 2nd Season","userPreferred":"Jigokuraku 2nd Season"},"trailer":{"id":"JLe_NUnAZVs","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JLe_NUnAZVs/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187264-aOUNQvTriPkX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187264-aOUNQvTriPkX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187264-aOUNQvTriPkX.jpg"},"description":"Betrayed by his childhood friend and cast out of the Hero Party, Orhun Dura—once their loyal Enchanter—is branded by his former comrades as “a jack-of-all-trades but a master of none.” Alone, he sets out to forge a new path as a solo adventurer. His journey sparks explosive battles, deadly rivals, and unexpected allies—and he’ll rise to shatter every expectation. The ultimate solo comeback begins!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":187264,"idMal":61128,"isAdult":false,"meanScore":66,"nextAiringEpisode":{"airingAt":1773241200,"episode":11,"timeUntilAiring":405030},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/187264","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Yuusha Party wo Oidasareta Kiyou Binbou: Party Jijou de Fuyo Jutsushi wo Yatteita Kenshi, Bannou e to Itaru","勇者パーティを追い出された器用貧乏　～パーティ事情で付与術士をやっていた剣士、万能へと至る～","เก่งรอบด้านแต่ไร้ทีเด็ด เลยถูกเฉดหัวจากปาร์ตี้ผู้กล้า","용사 파티에서 쫓겨난 다재무능"],"title":{"english":"Jack-of-All-Trades, Party of None","native":"勇者パーティを追い出された器用貧乏","romaji":"Yuusha Party wo Oidasareta Kiyou Binbou","userPreferred":"Yuusha Party wo Oidasareta Kiyou Binbou"},"trailer":{"id":"dLDimMasKBM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dLDimMasKBM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/176276-ES97CHqKSrLg.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1505d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx176276-rtF8mYd2OWw2.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx176276-rtF8mYd2OWw2.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx176276-rtF8mYd2OWw2.png"},"description":"The second season of \u003ci\u003eMato Seihei no Slave.\u003c/i\u003e","duration":24,"endDate":{"day":26,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Adventure","Drama","Ecchi","Fantasy","Romance"],"id":176276,"idMal":58505,"isAdult":false,"meanScore":73,"nextAiringEpisode":{"airingAt":1773324000,"episode":10,"timeUntilAiring":487830},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/176276","startDate":{"day":8,"month":1,"year":2026},"status":"RELEASING","synonyms":["Mabotai 2","魔都精兵のスレイブ 第２期","Mato Seihei no Slave 2nd Season","ทาสสุดแกร่งแห่งหน่วยป้องกันอสูร ซีซั่น 2"],"title":{"english":"Chained Soldier Season 2","native":"魔都精兵のスレイブ2","romaji":"Mato Seihei no Slave 2","userPreferred":"Mato Seihei no Slave 2"},"trailer":{"id":"IDgkCjcNxtU","site":"youtube","thumbnail":"https://i.ytimg.com/vi/IDgkCjcNxtU/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/191718-PjYwTxKsdQva.jpg","countryOfOrigin":"JP","coverImage":{"color":"#28bbe4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx191718-FeR6bnlkqF0J.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx191718-FeR6bnlkqF0J.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx191718-FeR6bnlkqF0J.png"},"description":"Flum has been chosen by God to be in the hero's party despite having stats of zero across the board. All she has is the \"Reversal\" ability that she still doesn't fully understand. Predictably, she proves useless in battle, but she refuses to give up and continues to do all she can for the party. Her partymate Jean, a genius and renowned sage, picks on her at every opportunity and eventually sells her off into slavery. Even as a slave, she's treated as incompetent and persecuted, and ultimately thrown to monsters as bait for her master's entertainment. Flum is left with two options: take up the cursed sword that inevitably brings death to its wielder, or be eaten by monsters. The moment she chooses to fight back is when the \"Reversal\" of her life begins...\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Adventure","Drama","Fantasy","Horror"],"id":191718,"idMal":61587,"isAdult":false,"meanScore":64,"nextAiringEpisode":{"airingAt":1773329400,"episode":10,"timeUntilAiring":493230},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/191718","startDate":{"day":9,"month":1,"year":2026},"status":"RELEASING","synonyms":["おまごと","Omagoto","กระจอกอย่างแกยังไงก็แพ้จอมมาร"],"title":{"english":"ROLL OVER AND DIE: I Will Fight for an Ordinary Life with My Love and Cursed Sword!","native":"「お前ごときが魔王に勝てると思うな」と勇者パーティを追放されたので、王都で気ままに暮らしたい","romaji":"\"Omae Gotoki ga Maou ni Kateru to Omou na\" to Yuusha Party wo Tsuihou Sareta node, Outo de Kimama ni Kurashitai","userPreferred":"\"Omae Gotoki ga Maou ni Kateru to Omou na\" to Yuusha Party wo Tsuihou Sareta node, Outo de Kimama ni Kurashitai"},"trailer":{"id":"LdHck8lxAj8","site":"youtube","thumbnail":"https://i.ytimg.com/vi/LdHck8lxAj8/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/184951-Rx1mZZfKa9IU.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1ae28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx184951-s8Lg2muPBhdX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx184951-s8Lg2muPBhdX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx184951-s8Lg2muPBhdX.jpg"},"description":"Suzuki’s a high school girl in love, but the guy she’s fallen for is nothing like her! While she’s cheerful, outgoing, and always trying to fit in, her classmate Yusuke Tani is stoic, quiet, and doesn’t seem to care what people think of him. Will Suzuki be able to overcome her anxieties and ask him out, or will she discover that opposites really don’t attract?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy","Drama","Romance","Slice of Life"],"id":184951,"idMal":60371,"isAdult":false,"meanScore":81,"nextAiringEpisode":{"airingAt":1772956800,"episode":9,"timeUntilAiring":120630},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/184951","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["ลุ้นรักฉบับคู่ต่างขั้ว","정반대의 너와 나"],"title":{"english":"You and I Are Polar Opposites","native":"正反対な君と僕","romaji":"Seihantai na Kimi to Boku","userPreferred":"Seihantai na Kimi to Boku"},"trailer":{"id":"b5vpRUDkhT0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/b5vpRUDkhT0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/178025-WvcXi1J2SGRa.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx178025-cWJKEsZynkil.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx178025-cWJKEsZynkil.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx178025-cWJKEsZynkil.jpg"},"description":"A boy lives in a floating town, where the poor scrape by and the rich live a sumptuous life, simply casting their garbage off the side, into the abyss. When he’s falsely accused of murder, though, his wrongful conviction leads to an unimaginable punishment—exile off the edge, with the rest of the trash. Down on the surface, the cast-off waste of humanity has bred vicious monsters, and to travel the path to vengeance against those who cast him into Hell, a boy will have to become a warrior…\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)","duration":24,"endDate":{"day":21,"month":12,"year":2025},"episodes":24,"format":"TV","genres":["Action","Drama","Fantasy"],"id":178025,"idMal":59062,"isAdult":false,"meanScore":82,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2025,"siteUrl":"https://anilist.co/anime/178025","startDate":{"day":6,"month":7,"year":2025},"status":"FINISHED","synonyms":["Гачиакута"],"title":{"english":"Gachiakuta","native":"ガチアクタ","romaji":"Gachiakuta","userPreferred":"Gachiakuta"},"trailer":{"id":"yeRvDchyo44","site":"youtube","thumbnail":"https://i.ytimg.com/vi/yeRvDchyo44/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/269-08ar2HJOUAuL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx269-d2GmRkJbMopq.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx269-d2GmRkJbMopq.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx269-d2GmRkJbMopq.png"},"description":"Ichigo Kurosaki is a rather normal high school student apart from the fact he has the ability to see ghosts. This ability never impacted his life in a major way until the day he encounters the Shinigami Kuchiki Rukia, who saves him and his family's lives from a Hollow, a corrupt spirit that devours human souls. \n\u003cbr\u003e\u003cbr\u003e\nWounded during the fight against the Hollow, Rukia chooses the only option available to defeat the monster and passes her Shinigami powers to Ichigo. Now forced to act as a substitute until Rukia recovers, Ichigo hunts down the Hollows that plague his town. \n\n\n","duration":24,"endDate":{"day":27,"month":3,"year":2012},"episodes":366,"format":"TV","genres":["Action","Adventure","Supernatural"],"id":269,"idMal":269,"isAdult":false,"meanScore":79,"nextAiringEpisode":null,"season":"FALL","seasonYear":2004,"siteUrl":"https://anilist.co/anime/269","startDate":{"day":5,"month":10,"year":2004},"status":"FINISHED","synonyms":["ブリーチ","'בליץ","เทพมรณะ","بليتش","Блич"],"title":{"english":"Bleach","native":"BLEACH","romaji":"BLEACH","userPreferred":"BLEACH"},"trailer":{"id":"0c4IoCA5fY0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/0c4IoCA5fY0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183270-LO0vGZ0mCJgW.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4d6ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183270-CmZikKu34WPd.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx183270-CmZikKu34WPd.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx183270-CmZikKu34WPd.jpg"},"description":"Betrayed by her fiancé’s lover and sentenced to public execution, Constance Grail, a plain viscount’s daughter known for her honesty, faces death—until a mysterious voice offers salvation. Scarlett Castiel, a noblewoman long thought dead, may be her only hope. Together, these unlikely allies uncover a dark conspiracy lurking in the heart of high society, where betrayal, secrets, and power collide.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Drama","Fantasy","Mystery","Romance","Supernatural"],"id":183270,"idMal":60151,"isAdult":false,"meanScore":68,"nextAiringEpisode":{"airingAt":1773327360,"episode":10,"timeUntilAiring":491190},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/183270","startDate":{"day":8,"month":1,"year":2026},"status":"RELEASING","synonyms":["ผีนางร้ายจับคู่สาวซื่อ รื้อคดีใหญ่"],"title":{"english":"The Holy Grail of Eris","native":"エリスの聖杯","romaji":"Eris no Seihai","userPreferred":"Eris no Seihai"},"trailer":{"id":"Xl9PRzU1MVw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Xl9PRzU1MVw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/178005-X4Tr7p0sCQbx.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f15078","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx178005-pCEReATswrup.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx178005-pCEReATswrup.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx178005-pCEReATswrup.jpg"},"description":"Utage Kinoshita is a high school girl who works part-time as a housekeeper. She has devoted her life to her favorite idol, Tamon Fukuhara, from the group F/ACE. Then one day, Utage ends up being assigned to Tamon’s house! There she discovers that off-stage, he is nothing like his wild idol persona. A gloomy, introverted boy with no self-confidence, Utage still finds herself falling for him anyway.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":26,"month":3,"year":2026},"episodes":13,"format":"ONA","genres":["Comedy","Romance"],"id":178005,"idMal":59047,"isAdult":false,"meanScore":79,"nextAiringEpisode":{"airingAt":1773241200,"episode":11,"timeUntilAiring":405030},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/178005","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Two F/aced Tamon","Which Face Does Tamon Have Now?","ทามอนคุง ตอนนี้อยู่โหมดไหน!?"],"title":{"english":"Tamon's B-Side","native":"多聞くん今どっち！？","romaji":"Tamon-kun Ima Docchi!?","userPreferred":"Tamon-kun Ima Docchi!?"},"trailer":{"id":"qFmSz2ZVxCA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/qFmSz2ZVxCA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/180746-AyfiOMkuHegF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50c9fe","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx180746-eqDiHbzoHMFh.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx180746-eqDiHbzoHMFh.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx180746-eqDiHbzoHMFh.jpg"},"description":"At just seventeen, Yuki is a professional death game player. She’s survived enough rounds to know that survival is calculation, not luck—and that failure is final. For most players, the games are a nightmare with no escape. For Yuki, they’re simply business. Yet in a world where rooms turn into graves and every choice could be her last, even experience offers no protection.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: The first episode aired with a runtime of ~47 minutes as opposed to the standard 24 minute long episode.\u003c/i\u003e","duration":24,"endDate":{"day":18,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Action","Drama","Mystery","Thriller"],"id":180746,"idMal":59711,"isAdult":false,"meanScore":75,"nextAiringEpisode":{"airingAt":1773239400,"episode":10,"timeUntilAiring":403230},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/180746","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":["SHIBOYUGI: Jogos Mortais para Colocar Comida na Mesa","SHIBOYUGI: Juegos mortales para ganarse el pan","SHIBOYUGI: Das Phantom-Mädchen im Spiel des Todes","Смертельная игра ради еды на столе","Смертельні ігри заради їжі на столі","Kiếm Cơm Bằng Trò Chơi Sinh Tử","靠死亡游戏混饭吃。","ลิขิตชะตาเกมท้าตาย","SHIBOYUGI : Survivre est mon métier","사망 유희로 밥을 먹는다."],"title":{"english":"SHIBOYUGI: Playing Death Games to Put Food on the Table","native":"死亡遊戯で飯を食う。","romaji":"Shibou Yuugi de Meshi wo Kuu.","userPreferred":"Shibou Yuugi de Meshi wo Kuu."},"trailer":{"id":"rqp_JkzslnM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/rqp_JkzslnM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185514-I19hOYFDzU1X.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f16b35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185514-mfJqhtz22l1Z.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185514-mfJqhtz22l1Z.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185514-mfJqhtz22l1Z.jpg"},"description":"Luna, a black witch who lives quietly in a poisonous mushroom house, deep in the Black Forest. She lives in the city making high-efficiency medicines, but it is said that if the \"Mushroom Witch\" touches you, you'll die, and she is avoided ... The life of a witch who doesn't know the warmth of people is carefully and momentarily drawn.","duration":24,"endDate":{"day":20,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Drama","Fantasy","Supernatural"],"id":185514,"idMal":60509,"isAdult":false,"meanScore":68,"nextAiringEpisode":{"airingAt":1773334680,"episode":11,"timeUntilAiring":498510},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185514","startDate":{"day":9,"month":1,"year":2026},"status":"RELEASING","synonyms":["Champignon's Witch"],"title":{"english":"Champignon Witch","native":"シャンピニオンの魔女","romaji":"Champignon no Majo","userPreferred":"Champignon no Majo"},"trailer":{"id":"v3JunzVhGwQ","site":"youtube","thumbnail":"https://i.ytimg.com/vi/v3JunzVhGwQ/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e47843","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx208766-PYhW16CKj4fO.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx208766-PYhW16CKj4fO.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx208766-PYhW16CKj4fO.png"},"description":null,"duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Slice of Life"],"id":208766,"idMal":null,"isAdult":false,"meanScore":null,"nextAiringEpisode":null,"season":null,"seasonYear":null,"siteUrl":"https://anilist.co/anime/208766","startDate":{"day":null,"month":null,"year":2027},"status":"NOT_YET_RELEASED","synonyms":[],"title":{"english":null,"native":"ブレス","romaji":"Bless","userPreferred":"Bless"},"trailer":{"id":"ECI_iIX7LU0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ECI_iIX7LU0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/191205-1ZMdtwrP4ClU.jpg","countryOfOrigin":"JP","coverImage":{"color":"#a1c9e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx191205-ALhucRyrwOW1.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx191205-ALhucRyrwOW1.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx191205-ALhucRyrwOW1.jpg"},"description":"Van, fourth son of a marquis, is just a toddler when he realizes he’s been reincarnated. Thanks to his literal lifetime of knowledge, he’s raised as a child prodigy—until his production magic manifests, and it’s the last thing his snooty mage family wants to see! His disappointed father banishes him to a podunk town on the verge of collapse, yet Van can only see the place’s potential. Can our hero’s bastion of battlements build a better life than battle magic ever could?!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Adventure","Fantasy"],"id":191205,"idMal":61549,"isAdult":false,"meanScore":67,"nextAiringEpisode":{"airingAt":1773234000,"episode":10,"timeUntilAiring":397830},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/191205","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":["หนูน้อยเจ้าแคว้นกับแผนพิทักษ์เมือง เปลี่ยนเมืองไร้ชื่อให้กลายเป็นนครป้อมปราการด้วยเวทมนตร์การผลิต"],"title":{"english":"Easygoing Territory Defense by the Optimistic Lord","native":"お気楽領主の楽しい領地防衛","romaji":"Okiraku Ryoushu no Tanoshii Ryouchi Bouei","userPreferred":"Okiraku Ryoushu no Tanoshii Ryouchi Bouei"},"trailer":{"id":"-lgT3jToqOI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/-lgT3jToqOI/hqdefault.jpg"},"type":"ANIME"}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":250,"perPage":20,"total":5000}}},"updated_at":"2026-03-07T01:29:30.897778+03:00"},"{\"query\":\"query ListAnime ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $season: MediaSeason, $seasonYear: Int, $format: MediaFormat, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: ANIME, search: $search, sort: $sort, status_in: $status, isAdult: $isAdult, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, season: $season, seasonYear: $seasonYear, format_not: MUSIC) {\\n\\t\\t\\t... baseAnime\\n\\t\\t}\\n\\t}\\n}\\nfragment baseAnime on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tseasonYear\\n\\tbannerImage\\n\\tepisodes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\tduration\\n\\ttrailer {\\n\\t\\tid\\n\\t\\tsite\\n\\t\\tthumbnail\\n\\t}\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tnextAiringEpisode {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":48,\"sort\":[\"SCORE_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/154587-ivXNJ23SM1xB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbf1a1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx154587-qQTzQnEJJ3oB.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx154587-qQTzQnEJJ3oB.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx154587-qQTzQnEJJ3oB.jpg"},"description":"The adventure is over but life goes on for an elf mage just beginning to learn what living is all about. Elf mage Frieren and her courageous fellow adventurers have defeated the Demon King and brought peace to the land. But Frieren will long outlive the rest of her former party. How will she come to understand what life means to the people around her? Decades after their victory, the funeral of one her friends confronts Frieren with her own near immortality. Frieren sets out to fulfill the last wishes of her comrades and finds herself beginning a new adventure…\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":22,"month":3,"year":2024},"episodes":28,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":154587,"idMal":52991,"isAdult":false,"meanScore":91,"nextAiringEpisode":null,"season":"FALL","seasonYear":2023,"siteUrl":"https://anilist.co/anime/154587","startDate":{"day":29,"month":9,"year":2023},"status":"FINISHED","synonyms":["Frieren at the Funeral","장송의 프리렌","Frieren - Oltre la Fine del Viaggio","คำอธิษฐานในวันที่จากลา Frieren","Frieren e a Jornada para o Além","Frieren – Nach dem Ende der Reise","葬送的芙莉蓮","Frieren: Más allá del final del viaje","Frieren en el funeral","Sōsō no Furīren","Frieren. U kresu drogi","Frieren - Pháp sư tiễn táng","Фрирен, провожающая в последний путь","فريرن: ما وراء نهاية الرحلة","Frieren: Tras finalizar el viaje"],"title":{"english":"Frieren: Beyond Journey’s End","native":"葬送のフリーレン","romaji":"Sousou no Frieren","userPreferred":"Sousou no Frieren"},"trailer":{"id":"qgQunxD0qCk","site":"youtube","thumbnail":"https://i.ytimg.com/vi/qgQunxD0qCk/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/114129-ZsLDkdwaYeJY.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e48643","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx114129-RLgSuh6YbeYx.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx114129-RLgSuh6YbeYx.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx114129-RLgSuh6YbeYx.jpg"},"description":"\u003ci\u003eGintama: THE FINAL\u003c/i\u003e is the 3rd and final film adaptation of the remainder of the Silver Soul arc and is the series finale.\n\u003cbr\u003e\u003cbr\u003e\nTwo years have passed following the Tendoshuu's invasion of the O-Edo Central Terminal. Since then, the Yorozuya have gone their separate ways. Foreseeing Utsuro's return, Gintoki Sakata begins surveying Earth's ley lines for traces of the other man's Altana. After an encounter with the remnants of the Tendoshuu—who continue to press on in search of immortality—Gintoki returns to Edo.\n\u003cbr\u003e\u003cbr\u003e\nLater, the regrouped Shinsengumi and Yorozuya begin an attack on the occupied Central Terminal. With the Altana harvested by the wreckage of the Tendoshuu's ship in danger of detonating, the Yorozuya and their allies fight their enemies while the safety of Edo—and the rest of the world—hangs in the balance. Fulfilling the wishes of their teacher, Shouyou Yoshida's former students unite and relive their pasts one final time in an attempt to save their futures.","duration":104,"endDate":{"day":8,"month":1,"year":2021},"episodes":1,"format":"MOVIE","genres":["Action","Comedy","Drama","Sci-Fi"],"id":114129,"idMal":39486,"isAdult":false,"meanScore":91,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2021,"siteUrl":"https://anilist.co/anime/114129","startDate":{"day":8,"month":1,"year":2021},"status":"FINISHED","synonyms":["กินทามะ THE FINAL"],"title":{"english":"Gintama: THE VERY FINAL","native":"銀魂 THE FINAL","romaji":"Gintama: THE FINAL","userPreferred":"Gintama: THE FINAL"},"trailer":{"id":"SvRHM7AONB4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/SvRHM7AONB4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20996-gaNJKtjmy3Pf.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45d86","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20996-kBEGEGdeK1r7.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx20996-kBEGEGdeK1r7.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx20996-kBEGEGdeK1r7.jpg"},"description":"Gintoki, Shinpachi, and Kagura return as the fun-loving but broke members of the Yorozuya team! Living in an alternate-reality Edo, where swords are prohibited and alien overlords have conquered Japan, they try to thrive on doing whatever work they can get their hands on. However, Shinpachi and Kagura still haven't been paid... Does Gin-chan really spend all that cash playing pachinko?\n\nMeanwhile, when Gintoki drunkenly staggers home one night, an alien spaceship crashes nearby. A fatally injured crew member emerges from the ship and gives Gintoki a strange, clock-shaped device, warning him that it is incredibly powerful and must be safeguarded. Mistaking it for his alarm clock, Gintoki proceeds to smash the device the next morning and suddenly discovers that the world outside his apartment has come to a standstill. With Kagura and Shinpachi at his side, he sets off to get the device fixed; though, as usual, nothing is ever that simple for the Yorozuya team.\n\nFilled with tongue-in-cheek humor and moments of heartfelt emotion, Gintama's fourth season finds Gintoki and his friends facing both their most hilarious misadventures and most dangerous crises yet.\n\n\u003cbr\u003e\u003c/br\u003e(Source: MAL Rewrite)","duration":24,"endDate":{"day":30,"month":3,"year":2016},"episodes":51,"format":"TV","genres":["Action","Comedy","Drama","Sci-Fi"],"id":20996,"idMal":28977,"isAdult":false,"meanScore":91,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2015,"siteUrl":"https://anilist.co/anime/20996","startDate":{"day":8,"month":4,"year":2015},"status":"FINISHED","synonyms":[],"title":{"english":"Gintama Season 3","native":"銀魂゜","romaji":"Gintama°","userPreferred":"Gintama°"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/171627-7esVHhgw69rn.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e43550","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx171627-ZN9D7P46yHnw.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx171627-ZN9D7P46yHnw.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx171627-ZN9D7P46yHnw.png"},"description":"Theatrical follow-up to \u003ci\u003eChainsaw Man\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\nDenji became “Chainsaw Man”, a boy with a devil’s heart, and is now part of Special Division 4’s devil hunters. After a date with Makima, the woman of his dreams, Denji takes shelter from the rain. There he meets Reze, a girl who works in a café.\u003cbr\u003e\u003cbr\u003e\n\n(Source: MAPPA CHANNEL)\n\n","duration":100,"endDate":{"day":19,"month":9,"year":2025},"episodes":1,"format":"MOVIE","genres":["Action","Drama","Horror","Romance","Supernatural"],"id":171627,"idMal":57555,"isAdult":false,"meanScore":90,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2025,"siteUrl":"https://anilist.co/anime/171627","startDate":{"day":19,"month":9,"year":2025},"status":"FINISHED","synonyms":["CSM: Reze-hen","CSM – The Movie: Reze Arc","Chainsaw Man – O Filme: Arco da Reze","Chainsaw Man - La película: El arco de Reze","Chainsaw Man - Il Film: La Storia di Reze","Человек-бензопила: Фильм – История Резе"],"title":{"english":"Chainsaw Man – The Movie: Reze Arc","native":"チェンソーマン レゼ篇","romaji":"Chainsaw Man: Reze-hen","userPreferred":"Chainsaw Man: Reze-hen"},"trailer":{"id":"pv8A7eubPQQ","site":"youtube","thumbnail":"https://i.ytimg.com/vi/pv8A7eubPQQ/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182469-obNr7bznMzN7.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182469-JQ808NBPxmgn.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182469-JQ808NBPxmgn.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182469-JQ808NBPxmgn.jpg"},"description":"To commemorate the 25th anniversary of the \u003ci\u003eONE PIECE\u003c/i\u003e TV anime: an animated adaptation of the \"ONE PIECE novel: Mugiwara Stories\". \u003cbr\u003e\u003cbr\u003e\n\nTwo years after the Paramount War, the Straw Hats are about to reunite on the Sabaody Archipelago. At the same time, a girl who is head over heels for Nami is trying to hand a fan letter to her before the group leaves the island.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":25,"endDate":{"day":20,"month":10,"year":2024},"episodes":1,"format":"SPECIAL","genres":["Action","Adventure","Fantasy"],"id":182469,"idMal":60022,"isAdult":false,"meanScore":90,"nextAiringEpisode":null,"season":"FALL","seasonYear":2024,"siteUrl":"https://anilist.co/anime/182469","startDate":{"day":20,"month":10,"year":2024},"status":"FINISHED","synonyms":[],"title":{"english":"ONE PIECE FAN LETTER","native":"ONE PIECE FAN LETTER","romaji":"ONE PIECE FAN LETTER","userPreferred":"ONE PIECE FAN LETTER"},"trailer":{"id":"MewJ5bEM-5U","site":"youtube","thumbnail":"https://i.ytimg.com/vi/MewJ5bEM-5U/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/5114-q0V5URebphSG.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4c993","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx5114-nSWCgQlmOMtj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx5114-nSWCgQlmOMtj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx5114-nSWCgQlmOMtj.jpg"},"description":"\"In order for something to be obtained, something of equal value must be lost.\"\n\u003cbr\u003e\u003cbr\u003e\nAlchemy is bound by this Law of Equivalent Exchange—something the young brothers Edward and Alphonse Elric only realize after attempting human transmutation: the one forbidden act of alchemy. They pay a terrible price for their transgression—Edward loses his left leg, Alphonse his physical body. It is only by the desperate sacrifice of Edward's right arm that he is able to affix Alphonse's soul to a suit of armor. Devastated and alone, it is the hope that they would both eventually return to their original bodies that gives Edward the inspiration to obtain metal limbs called \"automail\" and become a state alchemist, the Fullmetal Alchemist.\n\u003cbr\u003e\u003cbr\u003e\nThree years of searching later, the brothers seek the Philosopher's Stone, a mythical relic that allows an alchemist to overcome the Law of Equivalent Exchange. Even with military allies Colonel Roy Mustang, Lieutenant Riza Hawkeye, and Lieutenant Colonel Maes Hughes on their side, the brothers find themselves caught up in a nationwide conspiracy that leads them not only to the true nature of the elusive Philosopher's Stone, but their country's murky history as well. In between finding a serial killer and racing against time, Edward and Alphonse must ask themselves if what they are doing will make them human again... or take away their humanity.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":25,"endDate":{"day":4,"month":7,"year":2010},"episodes":64,"format":"TV","genres":["Action","Adventure","Drama","Fantasy"],"id":5114,"idMal":5114,"isAdult":false,"meanScore":90,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2009,"siteUrl":"https://anilist.co/anime/5114","startDate":{"day":5,"month":4,"year":2009},"status":"FINISHED","synonyms":["FMA","FMAB","Hagaren","الخيميائي الفولاذي","אלכימאי המתכת: אחוות אחים","Full Metal Alchemist: Brotherhood","钢之炼金术师 FULLMETAL ALCHEMIST","แขนกล คนแปรธาตุ: บราเธอร์ฮูด","Stalowy alchemik: Misja braci","Сталевий алхімік. Братерство","Стальной алхимик: Братство"],"title":{"english":"Fullmetal Alchemist: Brotherhood","native":"鋼の錬金術師 FULLMETAL ALCHEMIST","romaji":"Hagane no Renkinjutsushi: FULLMETAL ALCHEMIST","userPreferred":"Hagane no Renkinjutsushi: FULLMETAL ALCHEMIST"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/124194-IB2X2IdALUYB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#28aee4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx124194-TJlqMMR7BGn9.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx124194-TJlqMMR7BGn9.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx124194-TJlqMMR7BGn9.jpg"},"description":"After last season’s revelations, the Soma family moves forward, but the emotional chains that bind them are not easily broken. Unable to admit why she wants the cure, Tohru wrestles with the truth, aware that time is running out for someone close.\n\u003cbr\u003e\u003cbr\u003e\nAnd a secret still lurks that could break another’s heart. But hope is not lost—a clue to the curse is found. Could their imprisonment’s end be near?\u003cbr\u003e\u003cbr\u003e\n(Source: Funimation)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: This season premiered on Funimation and AnimeLab on March 20, 2021. The Japanese broadcast started two weeks later on April 6, 2021.\u003c/i\u003e","duration":24,"endDate":{"day":29,"month":6,"year":2021},"episodes":13,"format":"TV","genres":["Comedy","Drama","Psychological","Romance","Slice of Life","Supernatural"],"id":124194,"idMal":42938,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2021,"siteUrl":"https://anilist.co/anime/124194","startDate":{"day":6,"month":4,"year":2021},"status":"FINISHED","synonyms":["Furuba","Fruba","フルバ","Fruits Basket Season 3","水果篮子 最终季","เสน่ห์สาวข้าวปั้น ภาค 3","เสน่ห์สาวข้าวปั้น ภาคสุดท้าย","Корзинка фруктов: Финал"],"title":{"english":"Fruits Basket The Final Season","native":"フルーツバスケットThe Final","romaji":"Fruits Basket: The Final","userPreferred":"Fruits Basket: The Final"},"trailer":{"id":"ci2XSskC_wA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ci2XSskC_wA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/104578-z7SadpYEuAsy.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx104578-k61nx3LPjvgd.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx104578-k61nx3LPjvgd.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx104578-k61nx3LPjvgd.jpg"},"description":"The battle to retake Wall Maria begins now! With Eren’s new hardening ability, the Scouts are confident they can seal the wall and take back Shiganshina District. If they succeed, Eren can finally unlock the secrets of the basement—and the world. But danger lies in wait as Reiner, Bertholdt, and the Beast Titan have plans of their own. Could this be humanity’s final battle for survival?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Funimation)","duration":24,"endDate":{"day":1,"month":7,"year":2019},"episodes":10,"format":"TV","genres":["Action","Drama","Fantasy","Mystery"],"id":104578,"idMal":38524,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2019,"siteUrl":"https://anilist.co/anime/104578","startDate":{"day":29,"month":4,"year":2019},"status":"FINISHED","synonyms":["SnK 3","AoT 3","Shingeki no Kyojin Season 3 (2019)","L'Attaco dei Giganti 3 Parte 2","L'Attacco dei Giganti - Terza Stagione Parte 2","מתקפת הטיטאנים עונה 3 חלק 2","L'Attaque des Titans Saison 3 Partie 2 ","ผ่าพิภพไททัน ภาค 3 Part 2","ผ่าพิภพไททัน ภาค 3 พาร์ท 2","حمله به تایتان فصل 3"],"title":{"english":"Attack on Titan Season 3 Part 2","native":"進撃の巨人 Season３ Part.2","romaji":"Shingeki no Kyojin Season 3 Part 2","userPreferred":"Shingeki no Kyojin Season 3 Part 2"},"trailer":{"id":"fJm2nD3cv_4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/fJm2nD3cv_4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21745-5psGR43Ck4RZ.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dbbe4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21745-VrhhJjZNdBXV.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21745-VrhhJjZNdBXV.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21745-VrhhJjZNdBXV.png"},"description":"Third and “Final Season” of the Monogatari Series, part 4/5. Contains the arcs Mayoi Hell, Hitagi Rendezvous, and Ougi Dark from the Owarimonogatari light novels.\n\u003cbr\u003e\u003cbr\u003e\nKoyomi wakes up to see Mayoi Hachikuji before him, the girl who supposedly had gone to the afterlife. She tells Koyomi that they are currently in Avichi, the lowest levels of hell. Koyomi is dubious of how Mayoi knew about the exact timing of his death and which hell he would drop into, when Mayoi tells him that she was there to pick him up by the request of a certain individual.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Aniplex)","duration":24,"endDate":{"day":13,"month":8,"year":2017},"episodes":7,"format":"TV","genres":["Comedy","Mystery","Psychological","Romance","Supernatural"],"id":21745,"idMal":35247,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2017,"siteUrl":"https://anilist.co/anime/21745","startDate":{"day":12,"month":8,"year":2017},"status":"FINISHED","synonyms":["Owarimonogatari 2","End Tale"],"title":{"english":"Owarimonogatari Second Season","native":"終物語（下）","romaji":"Owarimonogatari (Ge)","userPreferred":"Owarimonogatari (Ge)"},"trailer":{"id":"7WdyIcDlK2o","site":"youtube","thumbnail":"https://i.ytimg.com/vi/7WdyIcDlK2o/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/n9253-JIhmKgBKsWUN.jpg","countryOfOrigin":"JP","coverImage":{"color":"#ffd6ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx9253-tIUXF2gfU8Sg.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx9253-tIUXF2gfU8Sg.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx9253-tIUXF2gfU8Sg.jpg"},"description":"Self-proclaimed mad scientist Okabe Rintarou lives in a small room in Akihabara, where he invents \"future gadgets\" with fellow lab members Shiina Mayuri, his air-headed childhood friend, and Hashida Itaru, an otaku hacker. The three pass the time by tinkering with their latest creation, a \"Phone Microwave\" that can be controlled through text messages. \n\u003cbr\u003e\u003cbr\u003e\nThe lab members soon face a string of mysterious incidents that lead to a game-changing discovery: the Phone Microwave can send emails to the past and thus alter history. Adapted from the critically acclaimed visual novel by 5pb. and Nitroplus, Steins;Gate takes Okabe to the depths of scientific theory and human despair as he faces the dire consequences of changing the past.","duration":24,"endDate":{"day":14,"month":9,"year":2011},"episodes":24,"format":"TV","genres":["Drama","Psychological","Sci-Fi","Thriller"],"id":9253,"idMal":9253,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2011,"siteUrl":"https://anilist.co/anime/9253","startDate":{"day":6,"month":4,"year":2011},"status":"FINISHED","synonyms":["S;G","סטיינס;גייט","命运石之门","Врата;Штейна"],"title":{"english":"Steins;Gate","native":"シュタインズ・ゲート","romaji":"Steins;Gate","userPreferred":"Steins;Gate"},"trailer":{"id":"27OZc-ku6is","site":"youtube","thumbnail":"https://i.ytimg.com/vi/27OZc-ku6is/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/98478-BDH64RDmBlr8.jpg","countryOfOrigin":"JP","coverImage":{"color":"#ffc993","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx98478-Yua5iL9zbrji.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx98478-Yua5iL9zbrji.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx98478-Yua5iL9zbrji.jpg"},"description":"The second season of \u003ci\u003e3-gatsu no Lion\u003c/i\u003e.\u003cbr\u003e\n\u003cbr\u003e\nNow in his second year of high school, Rei Kiriyama continues pushing through his struggles in the professional shogi world as well as his personal life. Surrounded by vibrant personalities at the shogi hall, the school club, and in the local community, his solitary shell slowly begins to crack. Among them are the three Kawamoto sisters—Akari, Hinata, and Momo—who forge an affectionate and familial bond with Rei. Through these ties, he realizes that everyone is burdened by their own emotional hardships and begins learning how to rely on others while supporting them in return.\u003cbr\u003e\n\u003cbr\u003e\nNonetheless, the life of a professional is not easy. Between tournaments, championships, and title matches, the pressure mounts as Rei advances through the ranks and encounters incredibly skilled opponents. As he manages his relationships with those who have grown close to him, the shogi player continues to search for the reason he plays the game that defines his career.\n","duration":25,"endDate":{"day":31,"month":3,"year":2018},"episodes":22,"format":"TV","genres":["Drama","Slice of Life"],"id":98478,"idMal":35180,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"FALL","seasonYear":2017,"siteUrl":"https://anilist.co/anime/98478","startDate":{"day":14,"month":10,"year":2017},"status":"FINISHED","synonyms":["Sangatsu no Lion 2","מרץ מגיע כאריה 2"],"title":{"english":"March comes in like a lion Season 2","native":"３月のライオン 第2シリーズ","romaji":"3-gatsu no Lion 2nd Season","userPreferred":"3-gatsu no Lion 2nd Season"},"trailer":{"id":"OfSaJb5OOPA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/OfSaJb5OOPA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/11061-8WkkTZ6duKpq.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1d65d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx11061-y5gsT1hoHuHw.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx11061-y5gsT1hoHuHw.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx11061-y5gsT1hoHuHw.png"},"description":"A new adaption of the manga of the same name by Togashi Yoshihiro.\u003cbr\u003e\u003cbr\u003e\nA Hunter is one who travels the world doing all sorts of dangerous tasks. From capturing criminals to searching deep within uncharted lands for any lost treasures. Gon is a young boy whose father disappeared long ago, being a Hunter. He believes if he could also follow his father's path, he could one day reunite with him.\u003cbr\u003e\u003cbr\u003e\nAfter becoming 12, Gon leaves his home and takes on the task of entering the Hunter exam, notorious for its low success rate and high probability of death to become an official Hunter. He befriends the revenge-driven Kurapika, the doctor-to-be Leorio and the rebellious ex-assassin Killua in the exam, with their friendship prevailing throughout the many trials and threats they come upon taking on the dangerous career of a Hunter.","duration":24,"endDate":{"day":24,"month":9,"year":2014},"episodes":148,"format":"TV","genres":["Action","Adventure","Fantasy"],"id":11061,"idMal":11061,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"FALL","seasonYear":2011,"siteUrl":"https://anilist.co/anime/11061","startDate":{"day":2,"month":10,"year":2011},"status":"FINISHED","synonyms":["ハンター×ハンター","HxH","全职猎人","האנטר האנטר","ฮันเตอร์ x ฮันเตอร์","القناص ","Мисливець X Мисливець"],"title":{"english":"Hunter x Hunter (2011)","native":"HUNTER×HUNTER (2011)","romaji":"HUNTER×HUNTER (2011)","userPreferred":"HUNTER×HUNTER (2011)"},"trailer":{"id":"d6kBeJjTGnY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/d6kBeJjTGnY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/125367-hGPJLSNfprO3.jpg","countryOfOrigin":"JP","coverImage":{"color":"#d6f1a1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx125367-1yuq9NFcQuLI.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx125367-1yuq9NFcQuLI.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx125367-1yuq9NFcQuLI.png"},"description":"The elite members of Shuchiin Academy's student council continue their competitive day-to-day antics. Council president Miyuki Shirogane clashes daily against vice-president Kaguya Shinomiya, each fighting tooth and nail to trick the other into confessing their romantic love. Kaguya struggles within the strict confines of her wealthy, uptight family, rebelling against her cold default demeanor as she warms to Shirogane and the rest of her friends.\u003cbr\u003e\n\u003cbr\u003e\nMeanwhile, council treasurer Yuu Ishigami suffers under the weight of his hopeless crush on Tsubame Koyasu, a popular upperclassman who helps to instill a new confidence in him. Miko Iino, the newest student council member, grows closer to the rule-breaking Ishigami while striving to overcome her own authoritarian moral code.\u003cbr\u003e\n\u003cbr\u003e\nAs love further blooms at Shuchiin Academy, the student council officers drag their outsider friends into increasingly comedic conflicts.\u003cbr\u003e\n\u003cbr\u003e\n(Source: MAL Rewrite)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: The first episode had an advanced screening on April 2, in both New York \u0026 Los Angeles.\u003cbr\u003e","duration":24,"endDate":{"day":25,"month":6,"year":2022},"episodes":13,"format":"TV","genres":["Comedy","Psychological","Romance","Slice of Life"],"id":125367,"idMal":43608,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2022,"siteUrl":"https://anilist.co/anime/125367","startDate":{"day":9,"month":4,"year":2022},"status":"FINISHED","synonyms":["Kaguya-sama: Love is War Season 3","辉夜大小姐想让我告白～天才们的恋爱头脑战～ 3","辉夜大小姐想让我告白～天才们的恋爱头脑战～ 第三季","Kaguya-sama wa Kokurasetai: Tensai-tachi no Renai Zunousen 3","สารภาพรักกับคุณคางุยะซะดี ๆ ~สงครามประสาทความรักของเหล่าอัจฉริยะ~ ภาค 3","สารภาพรักกับคุณคางุยะ ซะดี ๆ -อุลตร้า โรแมนติก-","Kaguya-sama wa Kokurasetai 3rd Season","Kaguya-sama: Cuộc Chiến Tỏ Tình - Ultra Romantic","Госпожа Кагуя: в любви как на войне. Ультраромантика","Nona Kaguya Ingin Ditembak: Ultra Romantic"],"title":{"english":"Kaguya-sama: Love is War -Ultra Romantic-","native":"かぐや様は告らせたい-ウルトラロマンティック-","romaji":"Kaguya-sama wa Kokurasetai: Ultra Romantic","userPreferred":"Kaguya-sama wa Kokurasetai: Ultra Romantic"},"trailer":{"id":"RN4FFgHpAZo","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RN4FFgHpAZo/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/15417-0T9JCwFZM99Q.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50aed6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15417-Uc2uNdWEixwi.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx15417-Uc2uNdWEixwi.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx15417-Uc2uNdWEixwi.jpg"},"description":"While Gintoki Sakata was away, the Yorozuya found themselves a new leader: Kintoki, Gintoki's golden-haired doppelganger. In order to regain his former position, Gintoki will need the help of those around him, a troubling feat when no one can remember him! Between Kintoki and Gintoki, who will claim the throne as the main character?\n\u003cbr\u003e\u003cbr\u003e\nIn addition, Yorozuya make a trip back down to red-light district of Yoshiwara to aid an elderly courtesan in her search for her long-lost lover. Although the district is no longer in chains beneath the earth's surface, the trio soon learn of the tragic backstories of Yoshiwara's inhabitants that still haunt them. With flashback after flashback, this quest has Yorozuya witnessing everlasting love and protecting it as best they can with their hearts and souls.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eGintama'\u003c/i\u003e: Enchousen includes moments of action-packed intensity along with their usual lighthearted, slapstick humor for Gintoki and his friends.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":24,"endDate":{"day":28,"month":3,"year":2013},"episodes":13,"format":"TV","genres":["Action","Comedy","Drama","Sci-Fi"],"id":15417,"idMal":15417,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"FALL","seasonYear":2012,"siteUrl":"https://anilist.co/anime/15417","startDate":{"day":4,"month":10,"year":2012},"status":"FINISHED","synonyms":["Gintama' (2012)","Gintama' Overdrive","Kintama"],"title":{"english":"Gintama Season 2 Part 2","native":"銀魂’延長戦","romaji":"Gintama': Enchousen","userPreferred":"Gintama': Enchousen"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/9969-pxE6nSzGGyUB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#6baed6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx9969-0GaRABYVdUcH.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx9969-0GaRABYVdUcH.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx9969-0GaRABYVdUcH.png"},"description":"After a one-year hiatus, Shinpachi Shimura returns to Edo, only to stumble upon a shocking surprise: Gintoki and Kagura, his fellow Yorozuya members, have become completely different characters! Fleeing from the Yorozuya headquarters in confusion, Shinpachi finds that all the denizens of Edo have undergone impossibly extreme changes, in both appearance and personality. Most unbelievably, his sister Otae has married the Shinsengumi chief and shameless stalker Isao Kondou and is pregnant with their first child.\n\u003cbr\u003e\u003cbr\u003e\nBewildered, Shinpachi agrees to join the Shinsengumi at Otae and Kondou's request and finds even more startling transformations afoot both in and out of the ranks of the the organization. However, discovering that Vice Chief Toushirou Hijikata has remained unchanged, Shinpachi and his unlikely Shinsengumi ally set out to return the city of Edo to how they remember it.\n\u003cbr\u003e\u003cbr\u003e\nWith even more dirty jokes, tongue-in-cheek parodies, and shameless references, Gintama' follows the Yorozuya team through more of their misadventures in the vibrant, alien-filled world of Edo.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":24,"endDate":{"day":26,"month":3,"year":2012},"episodes":51,"format":"TV","genres":["Action","Comedy","Drama","Sci-Fi"],"id":9969,"idMal":9969,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2011,"siteUrl":"https://anilist.co/anime/9969","startDate":{"day":4,"month":4,"year":2011},"status":"FINISHED","synonyms":["Gintama (2011)"],"title":{"english":"Gintama Season 2","native":"銀魂’","romaji":"Gintama'","userPreferred":"Gintama'"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182255-wyHvp6zJbWsO.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dc9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182255-butzrqd4I0aC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182255-butzrqd4I0aC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182255-butzrqd4I0aC.jpg"},"description":"The second season of \u003ci\u003eSousou no Frieren\u003c/i\u003e.","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":10,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":182255,"idMal":59978,"isAdult":false,"meanScore":89,"nextAiringEpisode":{"airingAt":1773410400,"episode":8,"timeUntilAiring":575748},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182255","startDate":{"day":16,"month":1,"year":2026},"status":"RELEASING","synonyms":["Провожающая в последний путь Фрирен 2","장송의 프리렌 2기"],"title":{"english":"Frieren: Beyond Journey’s End Season 2","native":"葬送のフリーレン 第2期","romaji":"Sousou no Frieren 2nd Season","userPreferred":"Sousou no Frieren 2nd Season"},"trailer":{"id":"RH-FcW94z00","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RH-FcW94z00/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/97889-z0Gm66dFW93U.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4d650","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx97889-ytqHdmus9wQi.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx97889-ytqHdmus9wQi.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx97889-ytqHdmus9wQi.jpg"},"description":"After joining the resistance against the bakufu, Gintoki and the gang are in hiding, along with Katsura and his Joui rebels. The Yorozuya is soon approached by Nobume Imai and two members of the Kiheitai, who explain that the Harusame pirates have turned against 7th Division Captain Kamui and their former ally Takasugi. The Kiheitai present Gintoki with a job: find Takasugi, who has been missing since his ship was ambushed in a Harusame raid. Nobume also makes a stunning revelation regarding the Tendoushuu, a secret organization pulling the strings of numerous factions, and their leader Utsuro, the shadowy figure with an uncanny resemblance to Gintoki's former teacher.\u003cbr\u003e\n\u003cbr\u003e\nHitching a ride on Sakamoto's space ship, the Yorozuya and Katsura set out for Rakuyou, Kagura's home planet, where the various factions have gathered and tensions are brewing. Long-held grudges, political infighting, and the Tendoushuu's sinister overarching plan finally culminate into a massive, decisive battle on Rakuyou.\u003cbr\u003e\n\u003cbr\u003e\n(Source: MAL Rewrite)","duration":24,"endDate":{"day":27,"month":3,"year":2017},"episodes":12,"format":"TV","genres":["Action","Comedy","Drama","Sci-Fi"],"id":97889,"idMal":34096,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2017,"siteUrl":"https://anilist.co/anime/97889","startDate":{"day":9,"month":1,"year":2017},"status":"FINISHED","synonyms":["Gintama. (2017)"],"title":{"english":"Gintama Season 4","native":"銀魂。","romaji":"Gintama.","userPreferred":"Gintama."},"trailer":{"id":"LOdAAEJiebM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/LOdAAEJiebM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/176301-GkuTF1YTT6b2.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4bb50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx176301-TIGmldLffQGX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx176301-TIGmldLffQGX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx176301-TIGmldLffQGX.jpg"},"description":"Using her wit and vast knowledge of medicines and poisons alike, Maomao played a pivotal role in solving a series of mysteries and conspiracies that plagued the imperial court. Having recently come to terms with the secrets of her parents, she returns to fulfill her normal duties on behalf of the emperor's highest-ranking consorts. Maomao also works alongside the eunuch Jinshi to better the consorts' many ladies-in-waiting, including helping them learn to read.\n\u003cbr\u003e\u003cbr\u003e\nHowever, with the arrival of a merchant caravan comes a new wave of intrigue. A pattern of strange coincidences involving the visitors and their wares unsettles Maomao, driving her to investigate the puzzling circumstances behind the convoy. As dangers from both outside and within threaten the balance between the imperial concubines, Maomao continues to utilize her cunning and medical expertise to keep the women safe from harm.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":24,"endDate":{"day":4,"month":7,"year":2025},"episodes":24,"format":"TV","genres":["Drama","Mystery"],"id":176301,"idMal":58514,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2025,"siteUrl":"https://anilist.co/anime/176301","startDate":{"day":10,"month":1,"year":2025},"status":"FINISHED","synonyms":["Die Tagebücher der Apothekerin Season 2","Diários de uma Apotecária 2ª Temporada","Монолог фармацевта 2","Les Carnets de l'apothicaire Saison 2"],"title":{"english":"The Apothecary Diaries Season 2","native":"薬屋のひとりごと 第2期","romaji":"Kusuriya no Hitorigoto 2nd Season","userPreferred":"Kusuriya no Hitorigoto 2nd Season"},"trailer":{"id":"3BYutu3Pf_0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/3BYutu3Pf_0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/116674-l2YlIyJzvGSV.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45043","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx116674-p3zK4PUX2Aag.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx116674-p3zK4PUX2Aag.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx116674-p3zK4PUX2Aag.jpg"},"description":"Was it all just a coincidence, or was it inevitable?\n\u003cbr\u003e\u003cbr\u003e\nIchigo Kurosaki gained the powers of a Soul Reaper through a chance encounter. As a Substitute\nSoul Reaper, Ichigo became caught in the turmoil of the Soul Society, a place where deceased\nsouls gather. But with help from his friends, Ichigo overcame every challenge to become even\nstronger.\n\u003cbr\u003e\u003cbr\u003e\nWhen new Soul Reapers and a new enemy appear in his hometown of Karakura, Ichigo jumps\nback into the battlefield with his Zanpakuto to help those in need. Meanwhile, the Soul Society\nis observing a sudden surge in the number of Hollows being destroyed in the World of the Living.\nThey also receive separate reports of residents in the Rukon District having gone missing. Finally,\nthe Seireitei, home of the Soul Reapers, comes under attack by a group calling themselves the\nWandenreich.\n\u003cbr\u003e\u003cbr\u003e\nLed by Yhwach, the father of all Quincies, the Wandenreich declare war against the Soul Reapers\nwith the following message: \u003ci\u003e\"Five days from now, the Soul Society will be annihilated by the\nWandenreich.\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\nThe history and truth kept hidden by the Soul Reapers for a thousand long years is finally brought\nto light.\n\u003cbr\u003e\u003cbr\u003e\nAll things must come to an end as Ichigo Kurosaki's final battle begins!","duration":24,"endDate":{"day":27,"month":12,"year":2022},"episodes":13,"format":"TV","genres":["Action","Adventure","Supernatural"],"id":116674,"idMal":41467,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"FALL","seasonYear":2022,"siteUrl":"https://anilist.co/anime/116674","startDate":{"day":11,"month":10,"year":2022},"status":"FINISHED","synonyms":["بليتش: حرب الألف سنة الدموية","Bleach: La guerre sanglante de mille ans","BLEACH TYBW"],"title":{"english":"BLEACH: Thousand-Year Blood War","native":"BLEACH 千年血戦篇","romaji":"BLEACH: Sennen Kessen-hen","userPreferred":"BLEACH: Sennen Kessen-hen"},"trailer":{"id":"fzR82oXbjnY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/fzR82oXbjnY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/2921-8cz7wULNyEgs.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f13550","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2921-PxFepBRCGD0K.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx2921-PxFepBRCGD0K.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx2921-PxFepBRCGD0K.jpg"},"description":"Yabuki Joe is left downhearted and hopeless after a certain tragic event. In attempt to put the past behind him, Joe leaves the gym behind and begins wandering. On his travels he comes across the likes of Wolf Kanagushi and Goromaki Gondo, men who unintentionally fan the dying embers inside him, leading him to putting his wanderings to an end. His return home puts Joe back on the path to boxing, but unknown to himself and his trainer, he now suffers deep-set issues holding him back from fighting. In attempt to quell those issues, Carlos Rivera, a world renowned boxer is invited from Venezuela to help Joe recover.\n","duration":24,"endDate":{"day":31,"month":8,"year":1981},"episodes":47,"format":"TV","genres":["Action","Drama","Slice of Life","Sports"],"id":2921,"idMal":2921,"isAdult":false,"meanScore":89,"nextAiringEpisode":null,"season":"FALL","seasonYear":1980,"siteUrl":"https://anilist.co/anime/2921","startDate":{"day":13,"month":10,"year":1980},"status":"FINISHED","synonyms":["Rocky Joe 2","Champion Joe 2"],"title":{"english":"Tomorrow's Joe 2","native":"あしたのジョー２","romaji":"Ashita no Joe 2","userPreferred":"Ashita no Joe 2"},"trailer":{"id":"hJ5KjrjfD40","site":"youtube","thumbnail":"https://i.ytimg.com/vi/hJ5KjrjfD40/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/820-FcKc3kvg60z8.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bb8628","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx820-x5dNLNFeKb8B.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx820-x5dNLNFeKb8B.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx820-x5dNLNFeKb8B.png"},"description":"For decades, the Galactic Empire has been locked in an interstellar war with the Free Planets Alliance, a conflict that involves thousands of spaceships and millions of soldiers on both sides. Two new commanders enter the conflict with great hopes: Imperial Admiral Reinhard von Lohengramm and the FPA's Yang Wen-Li. As they deal with superiors and subordinates, maneuver through complicated political arrangements, plot strategies, and win battles, each will be tested, and ultimately, changed, by the reality of war. \u003cbr\u003e\u003cbr\u003e\n(Source: Anime News Network)","duration":26,"endDate":{"day":17,"month":3,"year":1997},"episodes":110,"format":"OVA","genres":["Drama","Sci-Fi"],"id":820,"idMal":820,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"WINTER","seasonYear":1988,"siteUrl":"https://anilist.co/anime/820","startDate":{"day":8,"month":1,"year":1988},"status":"FINISHED","synonyms":["LoGH","LoTGH","Gin'eiden","Heldensagen vom Kosmosinsel","אגדת הגיבורים הגלקטיים"],"title":{"english":"Legend of the Galactic Heroes","native":"銀河英雄伝説","romaji":"Ginga Eiyuu Densetsu","userPreferred":"Ginga Eiyuu Densetsu"},"trailer":{"id":"Ou37P25tjJY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Ou37P25tjJY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/136430-ktoFZnyubhHg.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4a135","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx136430-gsBsJjA7hGh9.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx136430-gsBsJjA7hGh9.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx136430-gsBsJjA7hGh9.jpg"},"description":"The second season of \u003ci\u003eVinland Saga\u003c/i\u003e. \u003cbr\u003e\u003cbr\u003e\nAfter his father's death and the destruction of his village at the hands of English raiders, Einar wishes for a peaceful life with his family on their newly rebuilt farms. However, fate has other plans: his village is invaded once again. Einar watches helplessly as the marauding Danes burn his lands and slaughter his family. The invaders capture Einar and take him back to Denmark as a slave.\n\u003cbr\u003e\u003cbr\u003e\nEinar clings to his mother's final words to survive. He is purchased by Ketil, a kind slave owner and landlord who promises that Einar can regain his freedom in return for working in the fields. Soon, Einar encounters his new partner in farm cultivation—Thorfinn, a dejected and melancholic slave. As Einar and Thorfinn work together toward their freedom, they are haunted by both sins of the past and the ploys of the present. Yet they carry on, grasping for a glimmer of hope, redemption, and peace in a world that is nothing but unjust and unforgiving.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":26,"endDate":{"day":20,"month":6,"year":2023},"episodes":24,"format":"TV","genres":["Action","Adventure","Drama"],"id":136430,"idMal":49387,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2023,"siteUrl":"https://anilist.co/anime/136430","startDate":{"day":10,"month":1,"year":2023},"status":"FINISHED","synonyms":["Сага о Винланде 2"],"title":{"english":"Vinland Saga Season 2","native":"ヴィンランド・サガ SEASON2","romaji":"VINLAND SAGA SEASON 2","userPreferred":"VINLAND SAGA SEASON 2"},"trailer":{"id":"6pX93dXfH9s","site":"youtube","thumbnail":"https://i.ytimg.com/vi/6pX93dXfH9s/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/20954-f30bHMXa5Qoe.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dbbe4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx20954-sYRfE5jQRtSB.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx20954-sYRfE5jQRtSB.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx20954-sYRfE5jQRtSB.jpg"},"description":"After transferring into a new school, a deaf girl, Shouko Nishimiya, is bullied by the popular Shouya Ishida. As Shouya continues to bully Shouko, the class turns its back on him. Shouko transfers and Shouya grows up as an outcast. Alone and depressed, the regretful Shouya finds Shouko to make amends.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Eleven Arts)","duration":130,"endDate":{"day":17,"month":9,"year":2016},"episodes":1,"format":"MOVIE","genres":["Drama","Romance","Slice of Life"],"id":20954,"idMal":28851,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2016,"siteUrl":"https://anilist.co/anime/20954","startDate":{"day":17,"month":9,"year":2016},"status":"FINISHED","synonyms":["The Shape of Voice","A Voz do Silêncio","A Forma da Voz","La Forma della Voce","צורתו של קול","声之形","الحزن الصامت","Una voz silenciosa","La Forme de la voix","Форма голоса","Форма голосу","Tylus balsas","Balss forma","Дауыс пішіні","Sakit səs","รักไร้เสียง"],"title":{"english":"A Silent Voice","native":"聲の形","romaji":"Koe no Katachi","userPreferred":"Koe no Katachi"},"trailer":{"id":"Sy4bPCuzfiQ","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Sy4bPCuzfiQ/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/19-kJhwsB0Z97tL.jpg","countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx19-gtMC64182sm4.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx19-gtMC64182sm4.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx19-gtMC64182sm4.jpg"},"description":"Dr. Kenzo Tenma is a renowned Japanese brain surgeon working at a leading hospital in Germany. One night, Dr. Tenma risks his reputation and career to save the life of a critically wounded young boy over that of the town mayor who had been planning to support the hospital financially. A string of mysterious murders begin to occur soon after the operation, and Dr. Tenma emerges as the primary suspect despite no incriminating evidence. \n\u003cbr\u003e\u003cbr\u003e\nA doctor is taught to believe that all life is equal; however, when another series of murders occur in the surgeon's vicinity, Dr. Tenma's beliefs are shaken as his actions that night are shown to have much broader consequences than he could have imagined. Leaving behind his life as a surgeon he embarks on a journey across the country to unravel the mystery of the boy he saved.","duration":24,"endDate":{"day":28,"month":9,"year":2005},"episodes":74,"format":"TV","genres":["Drama","Horror","Mystery","Psychological","Thriller"],"id":19,"idMal":19,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2004,"siteUrl":"https://anilist.co/anime/19","startDate":{"day":7,"month":4,"year":2004},"status":"FINISHED","synonyms":["モンスター","מונסטר","מפלצת","مونستر ","وحش","Монстр"],"title":{"english":"Monster","native":"MONSTER","romaji":"MONSTER","userPreferred":"MONSTER"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/161645-oqzTZYIvviWI.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1865d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx161645-QLbzHXiYRgV2.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx161645-QLbzHXiYRgV2.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx161645-QLbzHXiYRgV2.jpg"},"description":"Maomao lived a peaceful life with her apothecary father. Until one day, she’s sold as a lowly servant to the emperor’s palace. But she wasn’t meant for a compliant life among royalty. So when imperial heirs fall ill, she decides to step in and find a cure! This catches the eye of Jinshi, a handsome palace official who promotes her. Now, she’s making a name for herself solving medical mysteries!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":23,"endDate":{"day":24,"month":3,"year":2024},"episodes":24,"format":"TV","genres":["Drama","Mystery"],"id":161645,"idMal":54492,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"FALL","seasonYear":2023,"siteUrl":"https://anilist.co/anime/161645","startDate":{"day":22,"month":10,"year":2023},"status":"FINISHED","synonyms":["Drugstore Soliloquy","Les Carnets de l'Apothicaire","Zapiski zielarki","Diários de uma Apotecária","Il monologo della Speziale","Los diarios de la boticaria","สืบคดีปริศนา หมอยาตำรับโคมแดง","Записки аптекаря","Die Tagebücher der Apothekerin","يوميات الصيدلانيّة","藥師少女的獨語","药屋少女的呢喃","Монолог фармацевта","약사의 혼잣말"],"title":{"english":"The Apothecary Diaries","native":"薬屋のひとりごと","romaji":"Kusuriya no Hitorigoto","userPreferred":"Kusuriya no Hitorigoto"},"trailer":{"id":"oyHqh8ue4zw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/oyHqh8ue4zw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21-ELSYx3yMPcKM.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21-ELSYx3yMPcKM.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21-ELSYx3yMPcKM.jpg"},"description":"Gold Roger was known as the Pirate King, the strongest and most infamous being to have sailed the Grand Line. The capture and death of Roger by the World Government brought a change throughout the world. His last words before his death revealed the location of the greatest treasure in the world, One Piece. It was this revelation that brought about the Grand Age of Pirates, men who dreamed of finding One Piece (which promises an unlimited amount of riches and fame), and quite possibly the most coveted of titles for the person who found it, the title of the Pirate King.\u003cbr\u003e\u003cbr\u003e\nEnter Monkey D. Luffy, a 17-year-old boy that defies your standard definition of a pirate. Rather than the popular persona of a wicked, hardened, toothless pirate who ransacks villages for fun, Luffy’s reason for being a pirate is one of pure wonder; the thought of an exciting adventure and meeting new and intriguing people, along with finding One Piece, are his reasons of becoming a pirate. Following in the footsteps of his childhood hero, Luffy and his crew travel across the Grand Line, experiencing crazy adventures, unveiling dark mysteries and battling strong enemies, all in order to reach One Piece.\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003e*This includes following special episodes:\u003c/b\u003e\u003cbr\u003e\n- Chopperman to the Rescue! Protect the TV Station by the Shore! (Episode 336)\u003cbr\u003e\n- The Strongest Tag-Team! Luffy and Toriko's Hard Struggle! (Episode 492)\u003cbr\u003e\n- Team Formation! Save Chopper (Episode 542)\u003cbr\u003e\n- History's Strongest Collaboration vs. Glutton of the Sea (Episode 590)\u003cbr\u003e\n- 20th Anniversary! Special Romance Dawn (Episode 907)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":21,"idMal":21,"isAdult":false,"meanScore":88,"nextAiringEpisode":{"airingAt":1775398560,"episode":1156,"timeUntilAiring":2563908},"season":"FALL","seasonYear":1999,"siteUrl":"https://anilist.co/anime/21","startDate":{"day":20,"month":10,"year":1999},"status":"RELEASING","synonyms":["ワンピース","海贼王","וואן פיס","ون بيس","วันพีซ","Vua Hải Tặc","All'arrembaggio!","Tutti all'arrembaggio!","Ντρέηκ, το Κυνήγι του Θησαυρού","OP","Ван-Пис"],"title":{"english":"ONE PIECE","native":"ONE PIECE","romaji":"ONE PIECE","userPreferred":"ONE PIECE"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/17074-4tGsvEIjba22.jpg","countryOfOrigin":"JP","coverImage":{"color":"#43a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx17074-xMhVAZsEDH66.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx17074-xMhVAZsEDH66.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx17074-xMhVAZsEDH66.png"},"description":"Second season of the Monogatari Series, part 1/2. Contains the arcs Tsubasa Tiger, Mayoi Jiangshi, Nadeko Medusa, Shinobu Time, and Hitagi End, from the Nekomonogatari White, Kabukimonogatari, Otorimonogatari, Onimonogatari and Koimonogatari light novels, respectively.\n\u003cbr\u003e\u003cbr\u003e\nThese stories take place after the end of the summer vacation when the apparition of the bee had left and the apparition of the phoenix avoided any consequences… Now that Koyomi Araragi and the girls were entering their new school terms, they were once again about to encounter supernatural beings…but this time, they may not be so easy to deal with.\n\u003cbr\u003e\u003cbr\u003e\nTsubasa Hanekawa, Mayoi Hachikuji, Nadeko Sengoku, Shinobu Oshino, and finally Hitagi Senjougahara. The girls’ loneliness, their confessions, and their departures… 5 new “stories” begin now.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Aniplex)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNotes:\u003ci\u003e\n\u003cbr\u003e\n \u003ci\u003eIncludes 3 recap episodes from the TV version (Ep. 6, 11, 16).\u003c/i\u003e\n\u003cbr\u003e\n\u003ci\u003eThe recap episodes were not included in the Blu-Ray version of the anime.\u003c/i\u003e","duration":26,"endDate":{"day":29,"month":12,"year":2013},"episodes":26,"format":"TV","genres":["Comedy","Drama","Mystery","Psychological","Romance","Supernatural"],"id":17074,"idMal":17074,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2013,"siteUrl":"https://anilist.co/anime/17074","startDate":{"day":7,"month":7,"year":2013},"status":"FINISHED","synonyms":["Nekomonogatari White","Kabukimonogatari","Otorimonogatari","Onimonogatari","Koimonogatari"],"title":{"english":"Monogatari Series Second Season","native":"〈物語〉シリーズ セカンドシーズン","romaji":"Monogatari Series: Second Season","userPreferred":"Monogatari Series: Second Season"},"trailer":{"id":"-c__dc_csNo","site":"youtube","thumbnail":"https://i.ytimg.com/vi/-c__dc_csNo/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/109731-O9wpjWphEhKn.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4c95d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx109731-EwHzbtywdcyG.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx109731-EwHzbtywdcyG.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx109731-EwHzbtywdcyG.png"},"description":"The third season of \u003ci\u003eHibike! Euphonium\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nKumiko's third year finally begins! With the concert band at Kitauji High School over 90 members, Kumiko is now the president and does her best with her final high school club activities to try to win her long-desired gold at nationals.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll, edited)","duration":25,"endDate":{"day":30,"month":6,"year":2024},"episodes":13,"format":"TV","genres":["Drama","Music","Slice of Life"],"id":109731,"idMal":39894,"isAdult":false,"meanScore":88,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2024,"siteUrl":"https://anilist.co/anime/109731","startDate":{"day":7,"month":4,"year":2024},"status":"FINISHED","synonyms":["響け! ユーフォニアム 久美子3年生編","Hibike! Euphonium: Kumiko 3 Nensei-hen","Sound! Euphonium Season 3","Résonne ! Euphonium"],"title":{"english":"Sound! Euphonium 3","native":"響け！ユーフォニアム３","romaji":"Hibike! Euphonium 3","userPreferred":"Hibike! Euphonium 3"},"trailer":{"id":"dzSh0bjmUVA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dzSh0bjmUVA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/4181.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1e450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx4181-zUKE7BZC62OF.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx4181-zUKE7BZC62OF.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx4181-zUKE7BZC62OF.png"},"description":"A few months have passed since Tomoya declared his love to Nagisa, and his life keeps moving forward as he continues to meet a variety of new people, expanding his world in the process. While Tomoya's world continues to expand, his and Nagisa's relationship is entering a new phase, and neither of them is quite sure where it will take them. Through his relationship with Nagisa, Tomoya begins to understand the meaning and importance of family.\u003cbr\u003e\n\u003cbr\u003e\nBut as Tomoya and Nagisa begin a family of their own, they are faced with many hardships along the way in Clannad: After Story\u003cbr\u003e\n\u003cbr\u003e\n(Source: Sentai Filmworks, edited)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes 2 un-numbered 'extra' and 'summary' episodes that aired at the end of the series.\u003c/i\u003e","duration":24,"endDate":{"day":27,"month":3,"year":2009},"episodes":24,"format":"TV","genres":["Drama","Romance","Slice of Life","Supernatural"],"id":4181,"idMal":4181,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2008,"siteUrl":"https://anilist.co/anime/4181","startDate":{"day":3,"month":10,"year":2008},"status":"FINISHED","synonyms":[],"title":{"english":"Clannad: After Story","native":"ＣＬＡＮＮＡＤ ~After Story~ クラナド アフターストーリー","romaji":"CLANNAD: After Story","userPreferred":"CLANNAD: After Story"},"trailer":{"id":"IecYMqp1N4k","site":"youtube","thumbnail":"https://i.ytimg.com/vi/IecYMqp1N4k/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/101925-eyVjqcyh4Gsu.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5da1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101925-gcA84dgcSj2w.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx101925-gcA84dgcSj2w.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx101925-gcA84dgcSj2w.png"},"description":"The second season of the Silver Soul arc.","duration":24,"endDate":{"day":8,"month":10,"year":2018},"episodes":14,"format":"TV","genres":["Action","Comedy","Drama","Sci-Fi"],"id":101925,"idMal":37491,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2018,"siteUrl":"https://anilist.co/anime/101925","startDate":{"day":9,"month":7,"year":2018},"status":"FINISHED","synonyms":["Gintama.: Silver Soul Arc 2","Gintama. Silver Soul Arc Season 2","Gintama.: Shirogane no Tamashii-hen Season 2"],"title":{"english":"Gintama.: Silver Soul Arc - Second Half War","native":"銀魂. 銀ノ魂篇2","romaji":"Gintama.: Shirogane no Tamashii-hen - Kouhan-sen","userPreferred":"Gintama.: Shirogane no Tamashii-hen - Kouhan-sen"},"trailer":{"id":"E2rzD37MCSg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/E2rzD37MCSg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/101338-Rl54Qhx71dUq.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50e4f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101338-rokVscjRYzdP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx101338-rokVscjRYzdP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx101338-rokVscjRYzdP.jpg"},"description":"The second season of \u003ci\u003eMob Psycho 100\u003c/i\u003e. \u003cbr\u003e\n\u003cbr\u003eKageyama is an ordinary 8th grader who just wants to live a normal life. Although he can disappear in the crowd in a flash, he was actually the most powerful psychic. The lives of those around Mob and his numerous feelings that softly piles up for the eventual explosion. The mysterious group \"Claw\" stands before him once again. In the midst of his youthful days, where will his roaring heart take him!?\n\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":1,"month":4,"year":2019},"episodes":13,"format":"TV","genres":["Action","Comedy","Drama","Psychological","Slice of Life","Supernatural"],"id":101338,"idMal":37510,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2019,"siteUrl":"https://anilist.co/anime/101338","startDate":{"day":7,"month":1,"year":2019},"status":"FINISHED","synonyms":["Mob Psycho Hyaku","ม็อบไซโค 100 คนพลังจิต ภาค 2","Моб Психо 100 II"],"title":{"english":"Mob Psycho 100 II","native":"モブサイコ100 II","romaji":"Mob Psycho 100 II","userPreferred":"Mob Psycho 100 II"},"trailer":{"id":"Pr43Sayk37s","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Pr43Sayk37s/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/101348-pivKKffCAwAY.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45d50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx101348-2fhDFPCuMNiz.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx101348-2fhDFPCuMNiz.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx101348-2fhDFPCuMNiz.jpg"},"description":"Thorfinn is son to one of the Vikings' greatest warriors, but when his father is killed in battle by the mercenary leader Askeladd, he swears to have his revenge. Thorfinn joins Askeladd's band in order to challenge him to a duel, and ends up caught in the middle of a war for the crown of England.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)","duration":24,"endDate":{"day":30,"month":12,"year":2019},"episodes":24,"format":"TV","genres":["Action","Adventure","Drama"],"id":101348,"idMal":37521,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2019,"siteUrl":"https://anilist.co/anime/101348","startDate":{"day":8,"month":7,"year":2019},"status":"FINISHED","synonyms":["סאגת וינלנד","فينلاند ساغا","สงครามคนทมิฬ","Сага о Винланде"],"title":{"english":"Vinland Saga","native":"ヴィンランド・サガ","romaji":"VINLAND SAGA","userPreferred":"VINLAND SAGA"},"trailer":{"id":"5xqEp7R9SYM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/5xqEp7R9SYM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/15335-uARkRgyx8adp.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbd6f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx15335-QjijwChGTBs0.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx15335-QjijwChGTBs0.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx15335-QjijwChGTBs0.png"},"description":"When Gintoki apprehends a movie pirate at a premiere, he checks the camera's footage and finds himself transported to a bleak, post-apocalyptic version of Edo, where a mysterious epidemic called the \"White Plague\" has ravished the world's population. It turns out that the movie pirate wasn't a pirate after all—it was an android time machine, and Gintoki has been hurtled five years into the future! Shinpachi and Kagura, his Yorozuya cohorts, have had a falling out and are now battle-hardened solo vigilantes and he himself has been missing for years, disappearing without a trace after scribbling a strange message in his journal.\n\nSetting out in the disguise given to him by the android time machine, Gintoki haphazardly reunites the Yorozuya team to investigate the White Plague, and soon discovers that the key to saving the future lies in the darkness of his own past. Determined to confront a powerful foe, he makes an important discovery—with a ragtag band of friends and allies at his side, he doesn't have to fight alone.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":110,"endDate":{"day":6,"month":7,"year":2013},"episodes":1,"format":"MOVIE","genres":["Action","Comedy","Sci-Fi"],"id":15335,"idMal":15335,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2013,"siteUrl":"https://anilist.co/anime/15335","startDate":{"day":6,"month":7,"year":2013},"status":"FINISHED","synonyms":["Gintama Movie 2","Gintama the Final Movie"],"title":{"english":"Gintama: The Final Chapter - Be Forever Yorozuya","native":"劇場版 銀魂 完結篇 万事屋よ永遠なれ","romaji":"Gintama: Kanketsu-hen - Yorozuya yo Eien Nare","userPreferred":"Gintama: Kanketsu-hen - Yorozuya yo Eien Nare"},"trailer":{"id":"UhJM5rVqaF8","site":"youtube","thumbnail":"https://i.ytimg.com/vi/UhJM5rVqaF8/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21400-5zcYUeVBptdG.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4d628","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21400-38ykNo3j4xXo.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21400-38ykNo3j4xXo.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21400-38ykNo3j4xXo.png"},"description":"First season of the Monogatari Series, part 4/6. Contains the arc Koyomi Vamp from the Kizumonogatari light novel.\n\u003cbr\u003e\u003cbr\u003e\nWith help from Meme Oshino, the apparition specialist, Koyomi defeats the three powerful vampire hunters: Dramaturgy, Episode and Guillotinecutter. Koyomi takes back all the limbs of Kiss-Shot Acerola-Orion Heart-Under-Blade in order to become a human again. But, when he returns to Kiss-Shot, she reveals to him the cold truth of what it means to be a vampire—a creature of the night. Unable to take back what he has done, Koyomi feels nothing but regret and can only deny his dreadful fate. While Koyomi is struggling to face reality, his “friend” Tsubasa Hanekawa comes to him with a certain plan…\n\u003cbr\u003e\u003cbr\u003e\n(Source: Aniplex)","duration":82,"endDate":{"day":6,"month":1,"year":2017},"episodes":1,"format":"MOVIE","genres":["Action","Drama","Ecchi","Mystery","Psychological","Supernatural"],"id":21400,"idMal":31758,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2017,"siteUrl":"https://anilist.co/anime/21400","startDate":{"day":6,"month":1,"year":2017},"status":"FINISHED","synonyms":["Wound Tale 3: Cold Blood"],"title":{"english":"Kizumonogatari Part 3: Reiketsu","native":"傷物語〈Ⅲ冷血篇〉","romaji":"Kizumonogatari III: Reiketsu-hen","userPreferred":"Kizumonogatari III: Reiketsu-hen"},"trailer":{"id":"4nTLr6Uf9Ug","site":"youtube","thumbnail":"https://i.ytimg.com/vi/4nTLr6Uf9Ug/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/140439-r9SRh0q0UgX1.jpg","countryOfOrigin":"JP","coverImage":{"color":"#28c9fe","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx140439-bPKmhe1wNxc9.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx140439-bPKmhe1wNxc9.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx140439-bPKmhe1wNxc9.jpg"},"description":"The third season of \u003ci\u003eMob Psycho 100\u003c/i\u003e. \u003cbr\u003e\u003cbr\u003e\nThe appearance of a divine tree and new religion turns Mob and Reigen's city upside down!\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":22,"month":12,"year":2022},"episodes":12,"format":"TV","genres":["Action","Comedy","Drama","Psychological","Slice of Life","Supernatural"],"id":140439,"idMal":50172,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2022,"siteUrl":"https://anilist.co/anime/140439","startDate":{"day":6,"month":10,"year":2022},"status":"FINISHED","synonyms":["モブサイコ100 III","ม็อบไซโค 100 คนพลังจิต ภาค 3","Моб Психо 100 III"],"title":{"english":"Mob Psycho 100 III","native":"モブサイコ100 Ⅲ","romaji":"Mob Psycho 100 III","userPreferred":"Mob Psycho 100 III"},"trailer":{"id":"Ah7lTT-NKMw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Ah7lTT-NKMw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/103047-Tjvsh5w1XZP4.jpg","countryOfOrigin":"JP","coverImage":{"color":"#1a86d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx103047-odblDHHEdehK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx103047-odblDHHEdehK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx103047-odblDHHEdehK.jpg"},"description":"While writing other people’s emotions, she may have neglected her own. Violet Evergarden, the child soldier turned Auto Memory Doll, writes letters that evoke the words her clients can’t. But when a terminally ill boy requests her services for his family, her own feelings about love and loss resurface. Now she must confront her past and the death of the Major.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Funimation)","duration":140,"endDate":{"day":18,"month":9,"year":2020},"episodes":1,"format":"MOVIE","genres":["Drama","Fantasy","Slice of Life"],"id":103047,"idMal":37987,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2020,"siteUrl":"https://anilist.co/anime/103047","startDate":{"day":18,"month":9,"year":2020},"status":"FINISHED","synonyms":["Виолетта Эвергарден","Вайоллет Эвергарден","薇尔莉特·伊芙加登"],"title":{"english":"Violet Evergarden: the Movie","native":"劇場版 ヴァイオレット・エヴァーガーデン","romaji":"Violet Evergarden Movie","userPreferred":"Violet Evergarden Movie"},"trailer":{"id":"BUfSen2rYQs","site":"youtube","thumbnail":"https://i.ytimg.com/vi/BUfSen2rYQs/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182896-iJt79hYTpv8w.jpg","countryOfOrigin":"JP","coverImage":{"color":"#c9d6f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182896-mvxTVHGdDB4q.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182896-mvxTVHGdDB4q.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182896-mvxTVHGdDB4q.jpg"},"description":"The eighth and final season of \u003ci\u003eBoku no Hero Academia\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\n\nDeku and the heroes are plunged into a final battle against villains across Japan. Deku, by fully unleashing One For All Quirks, faces off against Shigaraki. A young and refreshed All For One faces Armored All Might, Quirkless in his powered armor suit. Will Deku be able to bring the story of how they all became the greatest heroes to its finale? Or will everything be destroyed?!\u003cbr\u003e\u003cbr\u003e\n\n(Source: Crunchyroll)","duration":23,"endDate":{"day":13,"month":12,"year":2025},"episodes":11,"format":"TV","genres":["Action","Adventure"],"id":182896,"idMal":60098,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/182896","startDate":{"day":4,"month":10,"year":2025},"status":"FINISHED","synonyms":["Boku no Hero Academia 8","My Hero Academia 8","BNHA 8","MHA 8","Моя геройская академия 8","ヒロアカ 8","มายฮีโร่ อคาเดเมีย ไฟนอลซีซัน"],"title":{"english":"My Hero Academia FINAL SEASON","native":"僕のヒーローアカデミア FINAL SEASON","romaji":"Boku no Hero Academia FINAL SEASON","userPreferred":"Boku no Hero Academia FINAL SEASON"},"trailer":{"id":"wQgQij8Ry4g","site":"youtube","thumbnail":"https://i.ytimg.com/vi/wQgQij8Ry4g/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/162314-N5M4XMz6O1j4.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5daee4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162314-qIWdAAFtvY8J.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx162314-qIWdAAFtvY8J.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx162314-qIWdAAFtvY8J.jpg"},"description":"Eren, as the Founding Titan, advances on Fort Salta with countless other Titans. Appearing before the refugees, who stand on the brink of despair, are Mikasa, Armin, Jean, Conny, Reiner, Pieck, and Levi, who narrowly escaped from the rumbling. The battle between former comrades and childhood friends with Eren concludes here.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":85,"endDate":{"day":5,"month":11,"year":2023},"episodes":1,"format":"SPECIAL","genres":["Action","Drama","Fantasy","Psychological","Romance"],"id":162314,"idMal":null,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2023,"siteUrl":"https://anilist.co/anime/162314","startDate":{"day":5,"month":11,"year":2023},"status":"FINISHED","synonyms":["Shingeki no Kyojin: The Final Season Final Edition","Attack on Titan Final Season Part 3 Final Arc Part 2","Attack on Titan: The Final Season Part 4","Shingeki no Kyojin: The Final Season Part 4","SnK 4","AoT 4"],"title":{"english":"Attack on Titan Final Season THE FINAL CHAPTERS Special 2","native":"進撃の巨人 The Final Season完結編 後編","romaji":"Shingeki no Kyojin: The Final Season - Kanketsu-hen Kouhen","userPreferred":"Shingeki no Kyojin: The Final Season - Kanketsu-hen Kouhen"},"trailer":{"id":"sBLsE-NKEoI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/sBLsE-NKEoI/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/151384-JybfIpHr2gx6.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45d78","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx151384-gv0q8wOE6D58.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx151384-gv0q8wOE6D58.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx151384-gv0q8wOE6D58.jpg"},"description":"Shuchiin Academy’s student council room: the place where Student Council Vice President Kaguya Shinomiya and President Miyuki Shirogane met. After a long battle in love, these two geniuses communicated their feelings and, at the Hoshin Festival, had their very first kiss. However, there was no clear confession of love. The relationship between these two, who assumed they would be a couple, remains ambiguous. Now, overly conscious of their feelings, they must face the biggest challenge yet: Christmas. It’s Shirogane who wants it to be perfect versus Kaguya who pursues the imperfect situation. This is the very “normal” love story of two geniuses and the first kiss that never ends.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Aniplex of America)\n\u003cbr\u003e\u003cbr\u003e\n\u003cem\u003eNote: The anime first premiered in theaters across Japan on December 17, 2022. It was later split into 2 parts on TV, and 4 episodes on streaming, and Blu-Ray/DVD.\u003c/em\u003e","duration":25,"endDate":{"day":3,"month":4,"year":2023},"episodes":4,"format":"TV","genres":["Comedy","Psychological","Romance","Slice of Life"],"id":151384,"idMal":52198,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2023,"siteUrl":"https://anilist.co/anime/151384","startDate":{"day":1,"month":4,"year":2023},"status":"FINISHED","synonyms":["Kaguya-sama: Love is War Movie","Kaguya-sama: Cuộc chiến tỏ tình - Nụ hôn đầu không hồi kết","Госпожа Кагуя: в любви как на войне. Бесконечный первый поцелуй"],"title":{"english":"Kaguya-sama: Love is War -The First Kiss That Never Ends-","native":"かぐや様は告らせたい -ファーストキッスは終わらない-","romaji":"Kaguya-sama wa Kokurasetai: First Kiss wa Owaranai","userPreferred":"Kaguya-sama wa Kokurasetai: First Kiss wa Owaranai"},"trailer":{"id":"W3IvBLpebQ4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/W3IvBLpebQ4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/146984-yAkTtW2AExVj.jpg","countryOfOrigin":"JP","coverImage":{"color":"#ffae35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx146984-GXrLeT6vQqyP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx146984-GXrLeT6vQqyP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx146984-GXrLeT6vQqyP.jpg"},"description":"The fate of the world hangs in the balance as Eren unleashes the ultimate power of the Titans. With a burning determination to eliminate all who threaten Eldia, he leads an unstoppable army of Colossal Titans towards Marley. Now a motley crew of his former comrades and enemies scramble to halt his deadly mission, the only question is, can they stop him?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":61,"endDate":{"day":4,"month":3,"year":2023},"episodes":1,"format":"SPECIAL","genres":["Action","Drama","Fantasy","Mystery","Psychological"],"id":146984,"idMal":51535,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2023,"siteUrl":"https://anilist.co/anime/146984","startDate":{"day":4,"month":3,"year":2023},"status":"FINISHED","synonyms":["Shingeki no Kyojin: The Final Season Final Edition","Shingeki no Kyojin: The Final Season Part 3","ผ่าพิภพไททัน ภาค 4","ผ่าพิภพไททัน ไฟนอล ซีซั่น Part 3","Attack on Titan Final Season Part 3 Final Arc Part 1","Attack on Titan The Final Season The Final Part Special","Attack on Titan The Final Season The Final Part Part 1","حمله به تایتان فصل آخر قسمت ویژه 1 ","SnK 4","AoT 4"],"title":{"english":"Attack on Titan Final Season THE FINAL CHAPTERS Special 1","native":"進撃の巨人 The Final Season完結編 前編","romaji":"Shingeki no Kyojin: The Final Season - Kanketsu-hen Zenpen","userPreferred":"Shingeki no Kyojin: The Final Season - Kanketsu-hen Zenpen"},"trailer":{"id":"hb-mo0URZBw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/hb-mo0URZBw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/113024-gjxwISIts05f.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45d50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx113024-OdzOh0OKFPTN.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx113024-OdzOh0OKFPTN.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx113024-OdzOh0OKFPTN.png"},"description":"The stage emulates life and compresses it, setting free skills learned over lifetimes in brief but dazzling displays for the amusement and judgment of others. For the performers, it is the ultimate risk, and some will rise while others must fall. Nowhere is this truer than at the Seisho Music Academy, where music, dance and real weapons all come into play in the creation of the next great Star. Karen and Hikari’s destinies have been linked since a childhood promise, but their journeys here have taken very different paths. Now, after Hikari leaves, Karen must discover who she is without her opposite, while Hikari must rediscover her own course.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Sentai Filmworks)","duration":120,"endDate":{"day":4,"month":6,"year":2021},"episodes":1,"format":"MOVIE","genres":["Action","Drama","Music","Psychological"],"id":113024,"idMal":40664,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2021,"siteUrl":"https://anilist.co/anime/113024","startDate":{"day":4,"month":6,"year":2021},"status":"FINISHED","synonyms":[],"title":{"english":"Revue Starlight: The Movie","native":"劇場版 少女☆歌劇 レヴュースタァライト","romaji":"Shoujo☆Kageki Revue Starlight Movie","userPreferred":"Shoujo☆Kageki Revue Starlight Movie"},"trailer":{"id":"576xjJdDBNg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/576xjJdDBNg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21698-jVFRIHAENS5B.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e48635","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21698-RL71mr1YU5Io.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21698-RL71mr1YU5Io.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21698-RL71mr1YU5Io.png"},"description":"After the victory against Aoba Jousai High, Karasuno High School, once called “a fallen powerhouse, a crow that can’t fly,” has finally reached the climax of the heated Spring tournament. Now, to advance to nationals, the Karasuno team has to defeat the powerhouse Shiratorizawa Academy. Karasuno’s greatest hurdle is their adversary’s ace, Wakatoshi Ushijima, the number one player in the Miyagi Prefecture, and one of the country’s top three aces.\n\u003cbr\u003e\u003cbr\u003e\nOnly the strongest team will make it to the national tournament. Since this match is the third-year players’ last chance to qualify for nationals, Karasuno has to use everything they learned during the training camp and prior matches to attain victory. Filled with restlessness and excitement, both teams are determined to come out on top in the third season of Haikyuu!!.\n\u003cbr\u003e\u003cbr\u003e\n[Written by MAL Rewrite]","duration":25,"endDate":{"day":10,"month":12,"year":2016},"episodes":10,"format":"TV","genres":["Comedy","Drama","Sports"],"id":21698,"idMal":32935,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2016,"siteUrl":"https://anilist.co/anime/21698","startDate":{"day":8,"month":10,"year":2016},"status":"FINISHED","synonyms":["Haikyu!! Karasuno High vs Shiratorizawa Academy","Haikyuu!! 3","ไฮคิว!! คู่ตบฟ้าประทาน ภาค 3"],"title":{"english":"HAIKYU!! 3rd Season","native":"ハイキュー!! 烏野高校 VS 白鳥沢学園高校","romaji":"Haikyuu!!: Karasuno Koukou VS Shiratorizawa Gakuen Koukou","userPreferred":"Haikyuu!!: Karasuno Koukou VS Shiratorizawa Gakuen Koukou"},"trailer":{"id":"kJfU5boNUIE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/kJfU5boNUIE/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/172420-QVRFOAha7oy5.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1bb43","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx172420-4LjhmwpNMHti.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx172420-4LjhmwpNMHti.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx172420-4LjhmwpNMHti.jpg"},"description":"\u003cb\u003eREACH OUT AND GRASP GREATNESS.\u003c/b\u003e\u003cbr\u003e\u003cbr\u003e\nJungle Pocket, known to her close friends as \"Pokke,\" is a free-spirited Umamusume who has proven her dominance in the freestyle racing scene. Overwhelmed by Fuji Kiseki's majestic performance at a graded Twinkle Series race, she resolves to take on the Twinkle Series herself.\n\u003cbr\u003e\u003cbr\u003e\nShortly after joining the Umamusume training school Tracen Academy, Pokke comes under the wing of Tanabe, a veteran trainer who fostered Fuji Kiseki's talent. Together, they aspire to dominate the Triple Crown series, a set of three races that can only be attempted once in a lifetime. Awaiting them are formidable rivals of Pokke's generation, whose talents surpass even her own.\n\u003cbr\u003e\u003cbr\u003e\nThere's Dantsu Flame, whose diligence and determination to win are second to none; Manhattan Cafe, who chases the shadowy silhouette of a \"friend\" that only she can see; and Agnes Tachyon, a veritable mad scientist seeking to push the very boundaries of what is possible for Umamusume.\n\u003cbr\u003e\u003cbr\u003e\nThese four runners take to the track with their very pride, spirit, and souls on the line. Past the finish of their epic clash is a door waiting to be opened—one that leads to the beginning of a new era.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e\"It doesn't matter who stands in my way! I'm gonna be the greatest!\"\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e\n(Source: Umamusume: Pretty Derby - Beginning of a New Era Site)","duration":108,"endDate":{"day":24,"month":5,"year":2024},"episodes":1,"format":"MOVIE","genres":["Drama","Psychological","Slice of Life","Sports"],"id":172420,"idMal":57647,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2024,"siteUrl":"https://anilist.co/anime/172420","startDate":{"day":24,"month":5,"year":2024},"status":"FINISHED","synonyms":["Uma Musume: Pretty Derby Movie","劇場版 ウマ娘 プリティーダービー","ウマ娘 プリティーダービー BEGINNING OF A NEW ERA"],"title":{"english":"Umamusume: Pretty Derby - Beginning of a New Era","native":"ウマ娘 プリティーダービー 新時代の扉","romaji":"Uma Musume: Pretty Derby - Shin Jidai no Tobira","userPreferred":"Uma Musume: Pretty Derby - Shin Jidai no Tobira"},"trailer":{"id":"h4dMQOzj-5g","site":"youtube","thumbnail":"https://i.ytimg.com/vi/h4dMQOzj-5g/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/128207-NogeWbSs2SpJ.jpg","countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx128207-SWpfVJMRfQ9X.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx128207-SWpfVJMRfQ9X.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx128207-SWpfVJMRfQ9X.jpg"},"description":"Shohoku's “speedster” and point guard, Ryota Miyagi, always plays with brains and lightning speed, running circles around his opponents while feigning composure. Born and raised in Okinawa, Ryota had a brother who was three years older. Following in the footsteps of his older brother, who was a famous local player from a young age, Ryota also became addicted to basketball.\n\u003cbr\u003e\u003cbr\u003e\nIn his second year of high school, Ryota plays with the Shohoku High School basketball team along with Sakuragi, Rukawa, Akagi, and Mitsui as they take the stage at the Inter-High School National Championship. And now, they are on the brink of challenging the reigning champions, Sannoh Kogyo High School.\u003cbr\u003e\u003cbr\u003e\n\n(Source: GKIDS)","duration":124,"endDate":{"day":3,"month":12,"year":2022},"episodes":1,"format":"MOVIE","genres":["Sports"],"id":128207,"idMal":45649,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2022,"siteUrl":"https://anilist.co/anime/128207","startDate":{"day":3,"month":12,"year":2022},"status":"FINISHED","synonyms":["Slam Dunk Movie","ザ・ファーストスラムダンク","סלאם דאנק"],"title":{"english":"THE FIRST SLAM DUNK","native":"THE FIRST SLAM DUNK","romaji":"THE FIRST SLAM DUNK","userPreferred":"THE FIRST SLAM DUNK"},"trailer":{"id":"0GGMhcs2v8Q","site":"youtube","thumbnail":"https://i.ytimg.com/vi/0GGMhcs2v8Q/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/2904-X71fcvE83n3s.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4bb50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx2904-Fet9Q33suC7G.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx2904-Fet9Q33suC7G.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx2904-Fet9Q33suC7G.jpg"},"description":"A year has passed since \"The Black Rebellion\" and the remaining Black Knights have vanished into the shadows, their leader and figurehead, Zero, executed by the Britannian Empire. Area 11 is once more squirming under the Emperor's oppressive heel as the Britannian armies concentrate their attacks on the European front. But for the Britannians living in Area 11, life is back to normal. On one such normal day, a Britannian student, skipping his classes in the Ashford Academy, sneaks out to gamble on his chess play. But unknown to this young man, several forces are eying him from the shadows, for soon, he will experience a shocking encounter with his own obscured past, and the masked rebel mastermind Zero will return.","duration":24,"endDate":{"day":28,"month":9,"year":2008},"episodes":25,"format":"TV","genres":["Action","Drama","Mecha","Sci-Fi","Thriller"],"id":2904,"idMal":2904,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2008,"siteUrl":"https://anilist.co/anime/2904","startDate":{"day":6,"month":4,"year":2008},"status":"FINISHED","synonyms":["Code Geass: Hangyaku no Lelouch 2nd Season","Code Geass: Hangyaku no Lelouch Second Season"],"title":{"english":"Code Geass: Lelouch of the Rebellion R2","native":"コードギアス 反逆のルルーシュ R2","romaji":"Code Geass: Hangyaku no Lelouch R2","userPreferred":"Code Geass: Hangyaku no Lelouch R2"},"trailer":{"id":"Ab9ztHX-DVg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Ab9ztHX-DVg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/130003-FEBlngeJSTEm.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4bb50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx130003-HTDmeL4RGeJ4.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx130003-HTDmeL4RGeJ4.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx130003-HTDmeL4RGeJ4.png"},"description":"Hitori Gotou, “Bocchi-chan,” is a girl who’s so introverted and shy around people that she’d always start her conversations with “Ah...”\u003cbr\u003e\n\u003cbr\u003e\nDuring her middle school years, she started playing the guitar, wanting to join a band because she thought it could be an opportunity for even someone shy like her to also shine. But because she had no friends, she ended up practicing guitar for six hours every day all by herself. After becoming a skilled guitar player, she uploaded videos of herself playing the guitar to the internet under the name “Guitar Hero” and fantasized about performing at her school’s cultural festival concert. But not only could she not find any bandmates, before she knew it, she was in high school and still wasn’t able to make a single friend!\u003cbr\u003e\n\u003cbr\u003e\nShe was really close to becoming a shut-in, but one day, Nijika Ijichi, the drummer in Kessoku Band, reached out to her. And because of that, her everyday life started to change little by little...\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":25,"month":12,"year":2022},"episodes":12,"format":"TV","genres":["Comedy","Music","Slice of Life"],"id":130003,"idMal":47917,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"FALL","seasonYear":2022,"siteUrl":"https://anilist.co/anime/130003","startDate":{"day":9,"month":10,"year":2022},"status":"FINISHED","synonyms":["РОК-ТИХОНЯ!","บจจิเดอะร็อก!","孤獨搖滾！","孤独摇滚！","외톨이 THE ROCK!","봇치 더 록!","BTR"],"title":{"english":"BOCCHI THE ROCK!","native":"ぼっち・ざ・ろっく！","romaji":"Bocchi the Rock!","userPreferred":"Bocchi the Rock!"},"trailer":{"id":"SyMMZF5zNW4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/SyMMZF5zNW4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/178788-tSHb5MiaNBNL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#35bbe4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx178788-zm3gtpB9TpRt.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx178788-zm3gtpB9TpRt.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx178788-zm3gtpB9TpRt.jpg"},"description":"\u003ci\u003ePart 1 of the theatrical trilogy adaptation of the Infinity Castle Arc.\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\nTanjiro Kamado – a boy who joined an organization dedicated to hunting down demons called the Demon Slayer Corps after his younger sister Nezuko was turned into a demon.\n\u003cbr\u003e\u003cbr\u003e\nWhile growing stronger and deepening his friendships and bonds with fellow corps members, Tanjiro has battled many demons with his comrades – Zenitsu Agatsuma and Inosuke Hashibira. Along the way, his journey has led him to fight alongside the Demon Slayer Corps’ highest-ranking swordsmen, the Hashira, including Flame Hashira Kyojuro Rengoku aboard the Mugen Train, Sound Hashira Tengen Uzui within the Entertainment District, as well as Mist Hashira Muichiro Tokito and Love Hashira Mitsuri Kanroji at the Swordsmith Village.\n\u003cbr\u003e\u003cbr\u003e\nAs the Demon Slayer Corps members and Hashira engaged in a group strength training program, the Hashira Training, in preparation for the forthcoming battle against the demons, Muzan Kibutsuji appears at the Ubuyashiki Mansion. With the head of the Demon Corps in danger, Tanjiro and the Hashira rush to the headquarters but are plunged into a deep descent to a mysterious space by the hands of Muzan Kibutsuji.\n\u003cbr\u003e\u003cbr\u003e\nThe destination of where Tanjiro and Demon Slayer Corps have fallen is the demons’ stronghold – the Infinity Castle. And so, the battleground is set as the final battle between the Demon Slayer Corps and the demons ignites.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":155,"endDate":{"day":18,"month":7,"year":2025},"episodes":1,"format":"MOVIE","genres":["Action","Adventure","Drama","Fantasy","Supernatural"],"id":178788,"idMal":59192,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"SUMMER","seasonYear":2025,"siteUrl":"https://anilist.co/anime/178788","startDate":{"day":18,"month":7,"year":2025},"status":"FINISHED","synonyms":["Demon Slayer: Kimetsu no Yaiba La Forteresse infinie","Demon Slayer: Kimetsu no Yaiba Castelo Infinito","Клинок, Рассекающий Демонов: Бесконечный Замок"],"title":{"english":"Demon Slayer: Kimetsu no Yaiba Infinity Castle","native":"劇場版「鬼滅の刃」無限城編 第一章 猗窩座再来","romaji":"Kimetsu no Yaiba: Mugenjou-hen Movie 1 - Akaza Sairai","userPreferred":"Kimetsu no Yaiba: Mugenjou-hen Movie 1 - Akaza Sairai"},"trailer":{"id":"ZfIXXgqxVn8","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ZfIXXgqxVn8/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166216-mmAL8hAH8Ttc.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166216-vCMkF4e3x5FB.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166216-vCMkF4e3x5FB.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166216-vCMkF4e3x5FB.jpg"},"description":"The second season of \u003ci\u003eBoku no Kokoro no Yabai Yatsu\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nAfter an eventful winter break, Kyoutarou Ichikawa and Anna Yamada reunite with a stronger bond. They continue to grow in their own ways, with Yamada taking on more challenging photoshoots and Ichikawa maturing both physically and emotionally as he tackles his affections for Yamada. However, spending time together outside of school allows for their relationship to deepen, and it becomes increasingly difficult to deny their budding romantic feelings.\n\u003cbr\u003e\u003cbr\u003e\nGrappling with these unexpected and new emotions, Ichikawa and Yamada realize that, with the passage of time, their relationship is bound to change—and they must ultimately decide whether they wish to remain close friends or finally become a couple.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":23,"endDate":{"day":31,"month":3,"year":2024},"episodes":13,"format":"TV","genres":["Comedy","Romance","Slice of Life"],"id":166216,"idMal":55690,"isAdult":false,"meanScore":87,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2024,"siteUrl":"https://anilist.co/anime/166216","startDate":{"day":7,"month":1,"year":2024},"status":"FINISHED","synonyms":["BokuYaba 2","僕ヤバ 2","เธอผู้อันตรายต่อใจผม ภาคที่ 2"],"title":{"english":"The Dangers in My Heart Season 2","native":"僕の心のヤバイやつ 第2期","romaji":"Boku no Kokoro no Yabai Yatsu 2nd Season","userPreferred":"Boku no Kokoro no Yabai Yatsu 2nd Season"},"trailer":{"id":"MIi8I2dgzo0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/MIi8I2dgzo0/hqdefault.jpg"},"type":"ANIME"}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":104,"perPage":48,"total":5000}}},"updated_at":"2026-03-07T01:04:13.01376+03:00"},"{\"query\":\"query ListManga ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $startDate_greater: FuzzyDateInt, $startDate_lesser: FuzzyDateInt, $format: MediaFormat, $countryOfOrigin: CountryCode, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: MANGA, isAdult: $isAdult, countryOfOrigin: $countryOfOrigin, search: $search, sort: $sort, status_in: $status, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, startDate_greater: $startDate_greater, startDate_lesser: $startDate_lesser, format_not: NOVEL) {\\n\\t\\t\\t... baseManga\\n\\t\\t}\\n\\t}\\n}\\nfragment baseManga on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tbannerImage\\n\\tchapters\\n\\tvolumes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":48,\"sort\":[\"SCORE_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30002-3TuoSMl20fUX.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#d6861a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30002-Cul4OeN7bYtn.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30002-Cul4OeN7bYtn.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30002-Cul4OeN7bYtn.jpg"},"description":"His name is Guts, the Black Swordsman, a feared warrior spoken of only in whispers. Bearer of a gigantic sword, an iron hand, and the scars of countless battles and tortures, his flesh is also indelibly marked with The Brand, an unholy symbol that draws the forces of darkness to him and dooms him as their sacrifice. But Guts won't take his fate lying down; he'll cut a crimson swath of carnage through the ranks of the damned—and anyone else foolish enough to oppose him! Accompanied by Puck the Elf, more an annoyance than a companion, Guts relentlessly follows a dark, bloodstained path that leads only to death...or vengeance.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Dark Horse)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Volumes 1-5 contain the 16 prequel chapters 0A - 0P.\u003cbr\u003e\n- \u003ca href=\"https://anilist.co/manga/95821/\"\u003eChapter 83\u003c/a\u003e was omitted from Volume 13 due to the author’s request.\u003cbr\u003e\n- Volume 14 includes “\u003ca href=\"https://anilist.co/manga/36408/\"\u003eBerserk: The Prototype\u003c/a\u003e”.\u003cbr\u003e\n- Due to the author's passing, starting from Chapter 365, the manga is illustrated by Studio Gaga (Miura's assistants) and supervised by Kouji Mori (a close friend of Miura's).\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Adventure","Drama","Fantasy","Horror","Psychological"],"id":30002,"idMal":2,"isAdult":false,"meanScore":93,"season":null,"siteUrl":"https://anilist.co/manga/30002","startDate":{"day":25,"month":8,"year":1989},"status":"RELEASING","synonyms":["بيرسيرك","Beruseruku","Берсерк","ברזרק","برزرک","เบอร์เซิร์ก","烙印勇士","烙印战士","베르세르크","Berserk Max","烙印戰士"],"title":{"english":"Berserk","native":"ベルセルク","romaji":"Berserk","userPreferred":"Berserk"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/31706-W4G3BFn56DOs.jpg","chapters":95,"countryOfOrigin":"JP","coverImage":{"color":"#c9e45d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx31706-lRncu9VbcBB7.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx31706-lRncu9VbcBB7.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx31706-lRncu9VbcBB7.png"},"description":"Riders from around the world gather in the Wild West for the race of the century! Johnny Joestar, a former jockey paralyzed from the waist down, comes to spectate, and momentarily regains the ability to walk while watching a duel fought by Gyro Zeppeli. Desperate to learn more about this power, Johnny joins the race alongside Gyro and embarks on the most epic and bizarre race to ever cross the American frontier!\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":19,"month":4,"year":2011},"format":"MANGA","genres":["Action","Adventure","Drama","Mystery","Supernatural"],"id":31706,"idMal":1706,"isAdult":false,"meanScore":92,"season":null,"siteUrl":"https://anilist.co/manga/31706","startDate":{"day":19,"month":1,"year":2004},"status":"FINISHED","synonyms":["Dai 7 Bu Johnny Joestar","JoJo's Bizarre Adventure Part 7: Steel Ball Run","מרוץ כדור הפלדה","Le bizzarre avventure di JoJo: Steel Ball Run"],"title":{"english":"JoJo's Bizarre Adventure: Part 7–Steel Ball Run","native":"ジョジョの奇妙な冒険 スティール・ボール・ラン","romaji":"JoJo no Kimyou na Bouken: Steel Ball Run","userPreferred":"JoJo no Kimyou na Bouken: Steel Ball Run"},"type":"MANGA","volumes":24},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30656-XYzvRlsc3iK4.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30656-9mW113O7rDnA.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30656-9mW113O7rDnA.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30656-9mW113O7rDnA.png"},"description":"At seventeen years of age, Miyamoto Musashi--still known by his childhood name, Shinmen Takezo--was a wild young brute just setting out along the way of the sword.\n\u003cbr\u003e\u003cbr\u003e\nIn the aftermath of the epic Battle of Sekigahara, Takezo finds himself a fugitive survivor on the losing side of the war. Takezo's vicious nature has made him an outcast even in his own village, and he is hunted down like an animal. At this crucial crossroads in Takezo's life, an eccentric monk and a childhood friend are the only ones who can help him find his way.\u003cbr\u003e\u003cbr\u003e(Source: VIZ Media)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Adventure","Drama"],"id":30656,"idMal":656,"isAdult":false,"meanScore":92,"season":null,"siteUrl":"https://anilist.co/manga/30656","startDate":{"day":3,"month":9,"year":1998},"status":"HIATUS","synonyms":["배가본드"],"title":{"english":"Vagabond","native":"バガボンド","romaji":"Vagabond","userPreferred":"Vagabond"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30013-hbbRZqC5MjYh.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30013-BeslEMqiPhlk.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30013-BeslEMqiPhlk.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30013-BeslEMqiPhlk.jpg"},"description":"As a child, Monkey D. Luffy was inspired to become a pirate by listening to the tales of the buccaneer \"Red-Haired\" Shanks. But his life changed when Luffy accidentally ate the Gum-Gum Devil Fruit and gained the power to stretch like rubber...at the cost of never being able to swim again! Years later, still vowing to become the king of the pirates, Luffy sets out on his adventure...one guy alone in a rowboat, in search of the legendary \"One Piece,\" said to be the greatest treasure in the world...\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Adventure","Comedy","Fantasy"],"id":30013,"idMal":13,"isAdult":false,"meanScore":91,"season":null,"siteUrl":"https://anilist.co/manga/30013","startDate":{"day":22,"month":7,"year":1997},"status":"RELEASING","synonyms":["원피스","וואן פיס ","One Piece - Большой куш","ワンピース","ONE PIECE～航海王～","วันพีซ"],"title":{"english":"One Piece","native":"ONE PIECE","romaji":"ONE PIECE","userPreferred":"ONE PIECE"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/64053-OsBJAWgrJIUM.jpg","chapters":42,"countryOfOrigin":"JP","coverImage":{"color":"#bbe4f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx64053-tHJHWLRrWbeA.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx64053-tHJHWLRrWbeA.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx64053-tHJHWLRrWbeA.png"},"description":"It's time once again for the annual family gathering on Rokkenjima! Ange Ushiromiya is just getting over a cold, but that won't dampen her excitement at seeing her cousins again! Granddad couldn't be more thrilled to see his beloved grandchildren and throws a special Halloween party where everyone gets lots of treats! By lunchtime on the first day, the aunts and uncles are chatting up a storm, and the cousins are eagerly planning the afternoon's fun. It's the very picture of a happy family-one that in no way resembles the bickering, bitter Ushiromiya clan! What is going on?!\u003cbr\u003e\u003cbr\u003e\n(Source: Yen Press)\u003cbr\u003e\u003cbr\u003e\u003ci\u003eNote: Includes 4 extra chapters.\u003c/i\u003e","endDate":{"day":22,"month":6,"year":2015},"format":"MANGA","genres":["Drama","Fantasy","Mystery","Supernatural"],"id":64053,"idMal":34053,"isAdult":false,"meanScore":92,"season":null,"siteUrl":"https://anilist.co/manga/64053","startDate":{"day":21,"month":1,"year":2012},"status":"FINISHED","synonyms":["When Seagulls Cry Episode 8: Twilight of the Golden Witch"],"title":{"english":"Umineko When They Cry Episode 8: Twilight of the Golden Witch","native":"うみねこのなく頃に散 - Episode 8: Twilight of the Golden Witch","romaji":"Umineko no Naku Koro ni Chiru Episode 8: Twilight of the Golden Witch","userPreferred":"Umineko no Naku Koro ni Chiru Episode 8: Twilight of the Golden Witch"},"type":"MANGA","volumes":9},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/1-x9ksIvb9cKK2.jpg","chapters":162,"countryOfOrigin":"JP","coverImage":{"color":"#50a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30001-Knby7l1jevE7.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30001-Knby7l1jevE7.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30001-Knby7l1jevE7.jpg"},"description":"Everyone faces uncertainty at some point in their lives. Even a brilliant surgeon like Kenzo Tenma is no exception. But there’s no way he could have known that his decision to stop chasing professional success and instead concentrate on his oath to save peoples’ lives would result in the birth of an abomination. The questions of good and evil now take on a terrifyingly real dimension.\n\u003cbr\u003e\u003cbr\u003e\nYears later, in Germany during the tumultuous post-reunification period, middle-aged childless couples are being killed one after another. The serial killer’s identity is known. The reasons why he kills are not. Dr. Tenma sets out on a journey to find the killer’s twin sister, who may hold some clues to solving the enigma of the “Monster.”\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":20,"month":12,"year":2001},"format":"MANGA","genres":["Drama","Mystery","Psychological","Thriller"],"id":30001,"idMal":1,"isAdult":false,"meanScore":91,"season":null,"siteUrl":"https://anilist.co/manga/30001","startDate":{"day":5,"month":12,"year":1994},"status":"FINISHED","synonyms":["몬스터"],"title":{"english":"Monster","native":"MONSTER","romaji":"MONSTER","userPreferred":"MONSTER"},"type":"MANGA","volumes":18},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30642-MeizzL2WDv6C.jpg","chapters":220,"countryOfOrigin":"JP","coverImage":{"color":"#f16b43","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30642-0mjRDkf4THpo.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30642-0mjRDkf4THpo.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30642-0mjRDkf4THpo.jpg"},"description":"As a child, Thorfinn sat at the feet of the great Leif Ericson and thrilled to wild tales of a land far to the west. But his youthful fantasies were shattered by a mercenary raid. Raised by the Vikings who murdered his father, Thorfinn became a terrifying warrior, forever seeking to kill the band's leader, Askeladd, and avenge his father. Sustaining Thorfinn through his ordeal are his pride in his family and his dreams of a fertile westward land, a land without war or slavery … the land Leif called Vinland.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Won the Grand Prize at the Japan Media Arts Festival in 2009.\u003cbr\u003e\n- Winner of the 36th Kodansha Manga Award in the General category in 2012.\u003c/i\u003e","endDate":{"day":25,"month":7,"year":2025},"format":"MANGA","genres":["Action","Adventure","Drama"],"id":30642,"idMal":642,"isAdult":false,"meanScore":90,"season":null,"siteUrl":"https://anilist.co/manga/30642","startDate":{"day":27,"month":4,"year":2005},"status":"FINISHED","synonyms":["Saga Winlandzka","Сага о Винланде","Сага про Вінланд","海盜戰記VINLAND SAGA","빈란드 사가"],"title":{"english":"Vinland Saga","native":"ヴィンランド・サガ","romaji":"Vinland Saga","userPreferred":"Vinland Saga"},"type":"MANGA","volumes":29},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30051-Cp4mFnqb6zhz.jpg","chapters":276,"countryOfOrigin":"JP","coverImage":{"color":"#f18650","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30051-5KJyPlO7z5F4.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30051-5KJyPlO7z5F4.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30051-5KJyPlO7z5F4.png"},"description":"Hanamichi Sakuragi's got no game with girls--none at all! It doesn't help that he's known for throwing down at a moment's notice and always coming out on top. A hopeless bruiser, he's been rejected by 50 girls in a row! All that changes when he meets the girl of his dreams, Haruko, and she's actually not afraid of him! When she introduces him to the game of basketball, his life is changed forever...\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":4,"month":6,"year":1996},"format":"MANGA","genres":["Comedy","Drama","Sports"],"id":30051,"idMal":51,"isAdult":false,"meanScore":90,"season":null,"siteUrl":"https://anilist.co/manga/30051","startDate":{"day":18,"month":9,"year":1990},"status":"FINISHED","synonyms":["スラムダンク","Slam Dunk: 10 Days After","سلام دانك","슬램덩크 "],"title":{"english":"Slam Dunk","native":"SLAM DUNK","romaji":"SLAM DUNK","userPreferred":"SLAM DUNK"},"type":"MANGA","volumes":31},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30025-IaxAxX9hIGx0.jpg","chapters":116,"countryOfOrigin":"JP","coverImage":{"color":"#f1ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30025-mpPVpCKFTowt.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30025-mpPVpCKFTowt.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30025-mpPVpCKFTowt.png"},"description":"Alchemy tore the Elric brothers’ bodies apart. Can their bond make them whole again?\u003cbr\u003e\nIn this world, alchemists are those who study and perform the art of alchemical transmutation—the science of manipulating and transforming matter. They are bounded by the Law of Equivalent Exchange: in order to gain something, one must sacrifice something of equal value.\u003cbr\u003e\nIn an alchemical ritual gone wrong, Edward Elric lost his arm and his leg, and his brother Alphonse became nothing but a soul in a suit of armor. Equipped with mechanical “auto-mail” limbs, Edward becomes a state alchemist, seeking the one thing that can restore his and his brother’s bodies...the legendary Philosopher’s Stone.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes eight extra chapters.\u003c/i\u003e","endDate":{"day":11,"month":6,"year":2010},"format":"MANGA","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":30025,"idMal":25,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/30025","startDate":{"day":12,"month":7,"year":2001},"status":"FINISHED","synonyms":["Full Metal Alchemist","FMA","HagaRen","Fullmetal Alchemist Gaiden","Çelik Simyacı","Fullmetal Alchemist - Ocelový alchymista"," Стальной Алхимик","Сталевий Алхімік","Cang Giả Kim Thuật Sư","Čelični alhemičar","鋼之鍊金術師","แขนกลคนแปรธาตุ","강철의 연금술사","Железният Алхимик"],"title":{"english":"Fullmetal Alchemist","native":"鋼の錬金術師","romaji":"Hagane no Renkinjutsushi","userPreferred":"Hagane no Renkinjutsushi"},"type":"MANGA","volumes":27},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/140407-WMGs02Q3fFUb.jpg","chapters":222,"countryOfOrigin":"KR","coverImage":{"color":"#ffc943","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx140407-fJQr0fmqq1IO.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx140407-fJQr0fmqq1IO.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx140407-fJQr0fmqq1IO.png"},"description":"When civil engineering student Su-Ho Kim falls asleep reading a fantasy novel, he wakes up as a character in the book! Su-Ho is now in the body of Lloyd Frontera, a lazy noble who loves to drink, and whose family is in a mountain of debt. Using his engineering knowledge, Su-Ho designs inventions to avert the terrible future that lies in wait for him. With the help of a giant hamster, a knight, and the world’s magic, can Su-Ho dig his new family out of debt and build a better future?\n\u003cbr\u003e\u003cbr\u003e(Source: WEBTOON, edited)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: includes 12 extra chapters.\u003c/i\u003e","endDate":{"day":1,"month":1,"year":2026},"format":"MANGA","genres":["Adventure","Comedy","Fantasy"],"id":140407,"idMal":147272,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/140407","startDate":{"day":5,"month":8,"year":2021},"status":"FINISHED","synonyms":["The World's Best Engineer","The Greatest Estate Designer ","El mejor desarrollador inmobiliario","史詩級領地設計師","史上最高の領地設計士","史诗级领地设计师","ยอดสถาปนิกผู้พิทักษ์อาณาจักร"],"title":{"english":"The Greatest Estate Developer","native":"역대급 영지 설계사","romaji":"Yeokdaegeum Yeongji Seolgyesa","userPreferred":"Yeokdaegeum Yeongji Seolgyesa"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/74489-iAeCc8td3qWX.jpg","chapters":108,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx74489-5HtDCFfut8Be.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx74489-5HtDCFfut8Be.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx74489-5HtDCFfut8Be.jpg"},"description":"In a world inhabited by crystalline lifeforms called The Lustrous, every unique gem must fight for their way of life against the threat of lunarians who would turn them into decorations. Phosphophyllite, the most fragile and brittle of gems, longs to join the battle. When Phos is instead assigned to complete a natural history of their world, it sounds like a dull and pointless task. But this new job brings Phos into contact with Cinnabar, a gem forced to live in isolation. Can Phos’s seemingly mundane assignment lead both Phos and Cinnabar to the fulfillment they desire?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Nominated for the 8th Manga Taisho in 2015.\u003c/i\u003e","endDate":{"day":25,"month":4,"year":2024},"format":"MANGA","genres":["Action","Drama","Fantasy","Mystery","Psychological","Sci-Fi"],"id":74489,"idMal":44489,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/74489","startDate":{"day":25,"month":10,"year":2012},"status":"FINISHED","synonyms":["La Tierra de las Gemas","L'Ère des Cristaux","Das Land der Juwelen","Terra das Gemas","Vương quốc bảo thạch","Terra das Gemas","HNK","LOTL","Kraina klejnotów","寶石之國","宝石之国","보석의 나라","Страна самоцветов","Край самоцвітів"],"title":{"english":"Land of the Lustrous","native":"宝石の国","romaji":"Houseki no Kuni","userPreferred":"Houseki no Kuni"},"type":"MANGA","volumes":13},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30657-jK5aBm6e15lB.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f16b28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30657-AzyyUOWMJ6fd.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30657-AzyyUOWMJ6fd.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30657-AzyyUOWMJ6fd.png"},"description":"A motorcycle accident, bone cancer, a speeding truck crashing into a boy on a stolen bicycle--tragic life-changing events turn the worlds of three young men upside down. These three very different personalities have only one thing in common--their passion for basketball.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Won an Excellence Prize for manga at the 2001 Japan Media Arts Festival.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Psychological","Sports"],"id":30657,"idMal":657,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/30657","startDate":{"day":11,"month":11,"year":1999},"status":"RELEASING","synonyms":[],"title":{"english":"Real","native":"リアル","romaji":"Real","userPreferred":"Real"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/46765-8DqCBEYyt9yP.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e46b43","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx46765-KPXir4sRqJBW.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx46765-KPXir4sRqJBW.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx46765-KPXir4sRqJBW.png"},"description":"Xin is a war orphan in a poor village in the kingdom of Qin. He has big dreams of becoming a great general, and when his best friend’s life is cut short by political machinations, Xin sets off to find a deposed ruler and help restore his place on the throne, while working his way up through the ranks of the Qin kingdom’s army to do what no one has ever done before—unify China.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Drama"],"id":46765,"idMal":16765,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/46765","startDate":{"day":26,"month":1,"year":2006},"status":"RELEASING","synonyms":[],"title":{"english":"Kingdom","native":"キングダム","romaji":"Kingdom","userPreferred":"Kingdom"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/65243-naohhXW4M4b9.jpg","chapters":404,"countryOfOrigin":"JP","coverImage":{"color":"#f17843","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx65243-mR4MnJFmfaOF.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx65243-mR4MnJFmfaOF.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx65243-mR4MnJFmfaOF.png"},"description":"\u003cb\u003eShouyou Hinata is out to prove that in volleyball you don’t need to be tall to fly!\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\nAfter losing his first and last volleyball match against Tobio Kageyama, “the King of the Court,” Shouyou Hinata swears to become his rival after graduating middle school. But what happens when the guy he wants to defeat ends up being his teammate?!\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes: \u003cbr\u003e\n- Winner of the 61st Shogakukan Manga Award in the Shounen Category in 2017.\u003cbr\u003e\n- Includes two extra chapters.\u003c/i\u003e","endDate":{"day":20,"month":7,"year":2020},"format":"MANGA","genres":["Comedy","Drama","Sports"],"id":65243,"idMal":35243,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/65243","startDate":{"day":20,"month":2,"year":2012},"status":"FINISHED","synonyms":["Ball High!!","HQ!!","High Kyuu!!","ไฮคิว!! คู่ตบฟ้าประทาน","Haikyu!! - Chàng khổng lồ tí hon"],"title":{"english":"Haikyu!!","native":"ハイキュー！！","romaji":"Haikyuu!!","userPreferred":"Haikyuu!!"},"type":"MANGA","volumes":45},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/1303-0YcHdL7MyKFB.jpg","chapters":171,"countryOfOrigin":"JP","coverImage":{"color":"#d61a50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx31303-l21HJn9AXl7w.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx31303-l21HJn9AXl7w.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx31303-l21HJn9AXl7w.jpg"},"description":"Joe Yabuki is a troubled young man who runs away from an orphanage. Wandering through the Tokyo slums, he meets former boxing trainer Danpei. Joe is later arrested and goes to a temporary jail where he fights Nishi, his future best friend, ​and leader of a group of hooligans. He and Nishi then go to a juvenile prison miles away from Tokyo. There Joe meets Rikiishi, a former boxing prodigy, and a rivalry develops between them. They face each other in a match in which Rikiishi dominates Joe until the latter hits him with a cross-counter, resulting in both being knocked out. This inspires the other prison inmates to take up boxing. Joe and Rikiishi vow to fight again.\u003cbr\u003e\u003cbr\u003e\n(Source: Wikipedia) ","endDate":{"day":13,"month":5,"year":1973},"format":"MANGA","genres":["Drama","Slice of Life","Sports"],"id":31303,"idMal":1303,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/31303","startDate":{"day":1,"month":1,"year":1968},"status":"FINISHED","synonyms":["Rocky Joe","Tomorrow's Joe","Joe del Mañana","Boy Action II","Ashita no Joe - Em Busca do Amanhã"],"title":{"english":"Ashita no Joe: Fighting for Tomorrow","native":"あしたのジョー","romaji":"Ashita no Joe","userPreferred":"Ashita no Joe"},"type":"MANGA","volumes":20},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/87395-oSAhMYznMKAE.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4a15d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx87395-axsA49kSZp72.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx87395-axsA49kSZp72.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx87395-axsA49kSZp72.jpg"},"description":"After moving out on his own to a seaside town, Iori Kitahara makes a college debut he never anticipated. A new chapter of his life unfolds, full of diving with beautiful girls and shenanigans with a gaggle of lovable bastards! Idiot-expert Kenji Inoue and au naturel authority Kimitake Yoshioka bring you a glorious college tale filled with booze-fueled antics!\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Comedy","Romance","Slice of Life","Sports"],"id":87395,"idMal":70345,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/87395","startDate":{"day":7,"month":4,"year":2014},"status":"RELEASING","synonyms":["Необъятный океан","Неосяжна блакить","ก๊วนป่วนชวนบุ๋งบุ๋ง"],"title":{"english":"Grand Blue Dreaming","native":"ぐらんぶる","romaji":"Grand Blue","userPreferred":"Grand Blue"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30104-CDra9ye7UPGI.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30104-sUVzNlTWZ5cu.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30104-sUVzNlTWZ5cu.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30104-sUVzNlTWZ5cu.jpg"},"description":"Hello! This is Koiwai Yotsuba, Yotsuba Koiwai...um, YOTSUBA! Yotsuba moved with Daddy to a new house from our old house waaaaaaay over there! And moving's fun 'cos people wave! (Ohhhh!!) And Yotsuba met these nice people next door and made friends to play with (one of 'em acted like one of those bad strangers Daddy told Yotsuba not to go with, but it was okay in the end). I hope we get to play a lot. And eat ice cream! And-and-and...oh yeah! You should come play with Yotsuba too!\u003cbr\u003e\u003cbr\u003e\n(Source: Yen Press)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Includes an interlude.\u003cbr\u003e\n- Won the Excellence Award for Manga at the Japan Media Arts Festival in 2006 and the Grand Prize of the 20th Osamu Tezuka Cultural Prize in 2016.\u003cbr\u003e\n- Was nominated for the Manga Taishō award in 2008 and for the 12th and 20th Osamu Tezuka Cultural Prize in 2008 and 2016.\u003cbr\u003e\n- Was nominated for the Eisner Award in the \"Best Publication for Kids\" category.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Comedy","Slice of Life"],"id":30104,"idMal":104,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/30104","startDate":{"day":21,"month":3,"year":2003},"status":"RELEASING","synonyms":["Yotsuba and!","Yotsuba!","Yotsubato","Ёцуба!","요츠바랑!","四葉妹妹!"],"title":{"english":"Yotsuba\u0026!","native":"よつばと！","romaji":"Yotsuba to!","userPreferred":"Yotsuba to!"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/135129-XnupDEUjJgS6.jpg","chapters":2,"countryOfOrigin":"JP","coverImage":{"color":"#f1e4bb","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b135129-rbQyUsPfUZTj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b135129-rbQyUsPfUZTj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b135129-rbQyUsPfUZTj.jpg"},"description":"Telling the later life of Vagabond's Musashi Miyamoto, it was depicted through 140 hand-drawn drawings with ink and brush. It was released at the Ueno Royal Museum in Tokyo in May 2008, and since then it has been displayed at three other venues, Kumamoto City Museum, Suntory Museum in Osaka, and Sendai Mediatheque, with new paintings and productions.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: The comic was compiled in two books: \"Inoueno: Mikazuki-hen\" (いのうえの 三日月篇) and \"Inoueno: Mangetsu-hen\" (いのうえの 満月篇).\u003c/i\u003e","endDate":{"day":15,"month":10,"year":2008},"format":"MANGA","genres":["Action","Drama","Psychological"],"id":135129,"idMal":null,"isAdult":false,"meanScore":89,"season":null,"siteUrl":"https://anilist.co/manga/135129","startDate":{"day":24,"month":5,"year":2008},"status":"FINISHED","synonyms":["Vagabond: The Last Manga Exhibition","いのうえの 三日月篇","いのうえの 満月篇"],"title":{"english":null,"native":"バガボンド 最後のマンガ展","romaji":"Vagabond: Saigo no Manga-ten","userPreferred":"Vagabond: Saigo no Manga-ten"},"type":"MANGA","volumes":2},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/119247-ktfRi6FB4mdE.jpg","chapters":210,"countryOfOrigin":"JP","coverImage":{"color":"#d61a1a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx119247-8ylxneez5fa8.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx119247-8ylxneez5fa8.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx119247-8ylxneez5fa8.jpg"},"description":"Uma Musume Cinderella Gray is a spin-off title of the Uma Musume project by Cygames. It follows Oguri Cap through her time at Kasamatsu Training Center Academy and on her journey of becoming a legendary horse girl.\n\n","endDate":{"day":25,"month":12,"year":2025},"format":"MANGA","genres":["Drama","Sports"],"id":119247,"idMal":133431,"isAdult":false,"meanScore":90,"season":null,"siteUrl":"https://anilist.co/manga/119247","startDate":{"day":10,"month":6,"year":2020},"status":"FINISHED","synonyms":[],"title":{"english":null,"native":"ウマ娘 シンデレラグレイ","romaji":"Uma Musume: Cinderella Gray","userPreferred":"Uma Musume: Cinderella Gray"},"type":"MANGA","volumes":23},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30028-42xc4ztbqalW.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#781a6b","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30028-VJqBC1ar6AxE.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30028-VJqBC1ar6AxE.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30028-VJqBC1ar6AxE.png"},"description":"Nana Komatsu is a young woman who's endured an unending string of boyfriend problems. Moving to Tokyo, she's hoping to take control of her life and put all those messy misadventures behind her. She's looking for love and she's hoping to find it in the big city.\u003cbr\u003e\u003cbr\u003e\nNana Osaki, on the other hand, is cool, confident and focused. She swaggers into town and proceeds to kick down the doors to Tokyo's underground punk scene. She's got a dream and won't give up until she becomes Japan's No. 1 rock'n'roll superstar.\u003cbr\u003e\u003cbr\u003e\nThis is the story of two 20-year-old women who share the same name. Even though they come from completely different backgrounds, they somehow meet and become best friends. The world of Nana is a world exploding with sex, music, fashion, gossip and all-night parties.\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Winner of the 48th Shogakukan Manga Award in the Shoujo Category in 2002.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Music","Romance","Slice of Life"],"id":30028,"idMal":28,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/30028","startDate":{"day":15,"month":5,"year":2000},"status":"HIATUS","synonyms":["ナナ","나나"],"title":{"english":"Nana","native":"NANA","romaji":"NANA","userPreferred":"NANA"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/34632-JULTgA6q6jAH.jpg","chapters":147,"countryOfOrigin":"JP","coverImage":{"color":"#e4c943","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx34632-5xMDkx3pXsEh.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx34632-5xMDkx3pXsEh.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx34632-5xMDkx3pXsEh.png"},"description":"Meet Punpun Punyama. He’s an average kid in an average town.\u003cbr\u003e\nHe wants to win a Nobel Prize and save the world.\u003cbr\u003e\nHe wants the girl he has a crush on to like him back.\u003cbr\u003e\nHe wants to find some porn.\u003cbr\u003e\nThat’s what he wants, but what does he get…?\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":2,"month":11,"year":2013},"format":"MANGA","genres":["Drama","Psychological","Slice of Life"],"id":34632,"idMal":4632,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/34632","startDate":{"day":15,"month":3,"year":2007},"status":"FINISHED","synonyms":["Dobranoc, Punpunie","Bonne nuit Punpun!","Boa Noite Punpun","Bona nit, Punpun","Buenas noches, Punpun","Gute Nacht, Punpun","잘자 뿡뿡","晚安布布","לילה טוב, פונפון","Buonanotte, Punpun","İyi Geceler, Punpun","ฝันดีนะปุนปุน","Laku noć, Punpune","Добраніч, Пунпуне"],"title":{"english":"Goodnight Punpun","native":"おやすみプンプン","romaji":"Oyasumi Punpun","userPreferred":"Oyasumi Punpun"},"type":"MANGA","volumes":13},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30003-MBm3u1K1uHsi.jpg","chapters":249,"countryOfOrigin":"JP","coverImage":{"color":"#e4c943","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30003-E84fwIh22LAQ.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30003-E84fwIh22LAQ.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30003-E84fwIh22LAQ.jpg"},"description":"Humanity, having faced extinction at the end of the 20th century, would not have entered the new millennium if it weren't for them. In 1969, during their youth, they created a symbol. In 1997, as the coming disaster slowly starts to unfold, that symbol returns. This is the story of a group of boys who try to save the world.\u003cbr\u003e\u003cbr\u003e\nFor Kenji, a simple convenience store manager who once dreamed of becoming a rock 'n' roll musician, a host of memories from his past come rushing back when one of his childhood friends mysteriously commits suicide. Could this new death be related to the rise of a bizarre new cult that's been implicated in several other murders and disappearances? Determined to dig deeper, Kenji reunites with some of his old buddies in the hope of learning the truth behind it all.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":24,"month":4,"year":2006},"format":"MANGA","genres":["Drama","Mystery","Psychological","Sci-Fi","Thriller"],"id":30003,"idMal":3,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/30003","startDate":{"day":27,"month":9,"year":1999},"status":"FINISHED","synonyms":["Nijuu Seiki Shounen","Nijuusseiki Shounen","20thCB","20th Century Boys - Chłopaki z dwudziestego wieku","فتيان القرن 20"],"title":{"english":"20th Century Boys","native":"20世紀少年","romaji":"20 Seiki Shounen","userPreferred":"20 Seiki Shounen"},"type":"MANGA","volumes":22},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30026-JXfraiazLTQe.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#ffbb43","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30026-uCvXMudMzmwI.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30026-uCvXMudMzmwI.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30026-uCvXMudMzmwI.jpg"},"description":"Gon might be a country boy, but he has high aspirations. Despite his Aunt Mito's protests, Gon decides to follow in his father's footsteps and become a legendary Hunter. The Hunter hopefuls begin their journey by storm-tossed ship, where Gon meets Leorio and Kurapika, the only other applicants who aren't devastated by bouts of seasickness.\n\u003cbr\u003e\u003cbr\u003e\nHaving survived the terrors of the high seas, Gon and his companions now have to prove their worth in a variety of tests in order to find the elusive Exam Hall. And once they get there, will they ever leave alive...?\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Adventure","Comedy","Fantasy"],"id":30026,"idMal":26,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/30026","startDate":{"day":3,"month":3,"year":1998},"status":"HIATUS","synonyms":["ハンター×ハンター","HxH","헌터×헌터","القناص"],"title":{"english":"Hunter x Hunter","native":"HUNTER×HUNTER","romaji":"HUNTER×HUNTER","userPreferred":"HUNTER×HUNTER"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/86082-L0gxhGsRsDDE.jpg","chapters":111,"countryOfOrigin":"JP","coverImage":{"color":"#e4865d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx86082-MXizJxzbijdd.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx86082-MXizJxzbijdd.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx86082-MXizJxzbijdd.jpg"},"description":"When young adventurer Laios and his company are attacked and soundly thrashed by a dragon deep in a dungeon, the party loses all its money and provisions...and a member! They're eager to go back and save her, but there is just one problem: If they set out with no food or coin to speak of, they're sure to starve on the way! But Laios comes up with a brilliant idea: \"Let's eat the monsters!\" Slimes, basilisks, and even dragons...none are safe from the appetites of these dungeon-crawling gourmands!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Yen Press)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Nominated in the 9th, 10th, 11th, and 12th Manga Taishou Award in 2016-2019.\u003cbr\u003e\n- Ranked first in the 2016 Kono Manga ga Sugoi! (Male Readers Division).\u003cbr\u003e\n- Includes 14 extra chapters.\u003c/i\u003e","endDate":{"day":15,"month":9,"year":2023},"format":"MANGA","genres":["Adventure","Comedy","Drama","Fantasy"],"id":86082,"idMal":85781,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/86082","startDate":{"day":15,"month":2,"year":2014},"status":"FINISHED","synonyms":["Dungeon Food","Dungeon Meal","Tragones y Mazmorras","Gloutons et Dragons","Подземное питание","던전밥","สูตรลับตำรับดันเจียน","Mỹ vị hầm ngục","迷宮飯","Підземелля смакоти","Delicious in Dungeon: Calabouços e Delícias","Dungeon Meshi: Lochy i smakołyki"],"title":{"english":"Delicious in Dungeon","native":"ダンジョン飯","romaji":"Dungeon Meshi","userPreferred":"Dungeon Meshi"},"type":"MANGA","volumes":14},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/75143-1sdQNTbJxYXs.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e48643","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx75143-qPFON51fyZpt.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx75143-qPFON51fyZpt.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx75143-qPFON51fyZpt.png"},"description":"Since the graduation of the senior members of the club, Takezou ends up being the sole member of the \"Koto\" (traditional Japanese string instrument) club. Now that the new school year has begun, Takezou will have to seek out new members into the club, or the club will become terminated. Out of nowhere, a new member barges into the near-abandoned club room, demanding to join the club. How will Takezou be able to keep his club alive and deal with this rascal of a new member?","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Music","Romance"],"id":75143,"idMal":45143,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/75143","startDate":{"day":4,"month":8,"year":2012},"status":"RELEASING","synonyms":["Stop this sound!","ฝากฝันไว้ที่เสียงโคโตะ!","Sounds of Life","一弦定音！"],"title":{"english":null,"native":"この音とまれ！","romaji":"Kono Oto Tomare!","userPreferred":"Kono Oto Tomare!"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/31224-7x74OyOI3qbj.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1c95d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx31224-dxugU08jahRT.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx31224-dxugU08jahRT.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx31224-dxugU08jahRT.jpg"},"description":"Rei Kiriyama is a child prodigy. Rei Kiriyama is also an orphan who lives alone in an empty apartment. Rei Kiriyama is a teen working in an adult's world. Life is complicated for Rei. He's an up-and-coming shogi player on the verge of turning pro, but he has no homelife, or much of a life period, outside his board game, but thankfully with the help of some life-long friends he has an opportunity start all over again.\n\u003cbr\u003e\u003cbr\u003e\n(Source: DENPA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Winner of the Grand Prize at the 4th Manga Taishou Award in 2011.\u003cbr\u003e\n- Winner of the 35th Kodansha Manga Award in 2011.\u003cbr\u003e\n- Winner of the Grand Prize at the Tezuka Osamu Cultural Prize in 2014.\u003cbr\u003e\n- Winner of the Grand Prize at the Japan Media Arts Festival in 2021.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Slice of Life"],"id":31224,"idMal":1224,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/31224","startDate":{"day":13,"month":7,"year":2007},"status":"RELEASING","synonyms":["Sangatsu no Lion","Lion of March","Un marzo da leoni","El león de marzo","Marcowy lew","O Leão de Março","Sư Tử Tháng 3","3月的獅子","3월의 라이온"],"title":{"english":"March Comes in Like a Lion","native":"3月のライオン","romaji":"3-gatsu no Lion","userPreferred":"3-gatsu no Lion"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/86635-qjRKbsrM3U9F.jpg","chapters":281,"countryOfOrigin":"JP","coverImage":{"color":"#d61a35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx86635-EdaLQmsn86Fy.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx86635-EdaLQmsn86Fy.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx86635-EdaLQmsn86Fy.png"},"description":"As leaders of their prestigious academy’s student council, Kaguya and Miyuki are the elite of the elite! But it’s lonely at the top… Luckily for them, they’ve fallen in love! There’s just one problem—they both have too much pride to admit it. And so begins the daily scheming to get the object of their affection to confess their romantic feelings first… Love is a war you win by losing.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes: \u003cbr\u003e\n- The first 10 chapters were published in Monthly Miracle Jump. It switched to Weekly Young Jump starting with Ch. 11, with the chapter count being reset. This entry still includes the first 10 chapters from Miracle Jump.\u003cbr\u003e\n- Winner of the 65th Shogakukan Manga Award for \"Best General Manga\" category in 2019.\u003c/i\u003e","endDate":{"day":2,"month":11,"year":2022},"format":"MANGA","genres":["Comedy","Psychological","Romance","Slice of Life"],"id":86635,"idMal":90125,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/86635","startDate":{"day":19,"month":5,"year":2015},"status":"FINISHED","synonyms":["Kaguya Wants to be Confessed To: The Geniuses' War of Love and Brains","카구야 님은 고백받고 싶어 ~천재들의 연애 두뇌전~","Miłość to wojna","Kaguya-sama wa Kokurasetai: Tensai-tachi no Renai Zunousen","Госпожа Кагуя: В любви как на войне. Любовная битва двух гениев","สารภาพรักกับคุณคางุยะซะดีๆ ~สงครามประสาทความรักของเหล่าอัจฉริยะ~ ","Kaguya-sama: Cuộc chiến tỏ tình","辉夜大小姐想让我告白 ~天才们的恋爱头脑战","輝夜姬想讓人告白~天才們的戀愛頭腦戰~","Kaguya-sama: Aşk Savaştır"],"title":{"english":"Kaguya-sama: Love is War","native":"かぐや様は告らせたい～天才たちの恋愛頭脳戦～","romaji":"Kaguya-sama wa Kokurasetai: Tensaitachi no Renai Zunousen","userPreferred":"Kaguya-sama wa Kokurasetai: Tensaitachi no Renai Zunousen"},"type":"MANGA","volumes":28},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/53900-J9a7WTAJT4Ra.jpg","chapters":48,"countryOfOrigin":"JP","coverImage":{"color":"#f1d650","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx53900-aDalkx2qmugI.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx53900-aDalkx2qmugI.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx53900-aDalkx2qmugI.png"},"description":"The time for logical debate and magical feints has come to an end; the revelation of the truth about Beatrice the Golden Witch is at hand. To facilitate this, game master Bernkastel has chosen Will Wright the Mage-Hunter to step onto her board and answer a single question: Who killed Beatrice? Joining him in the game is Lion Ushiromiya, Krauss's firstborn and heir, whose role is a mystery in its own right. Will's line of questioning draws together the stray strands from all the previous games, twisting them into a thread of truth, revisiting Kinzou's first encounter with the young Beatrice and working through the legends that have since sprung up around her...\u003cbr\u003e\u003cbr\u003e(Source: Yen Press)","endDate":{"day":12,"month":3,"year":2015},"format":"MANGA","genres":["Drama","Mystery","Psychological","Supernatural","Thriller"],"id":53900,"idMal":23900,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/53900","startDate":{"day":12,"month":4,"year":2011},"status":"FINISHED","synonyms":["When Seagulls Cry Episode 7: Requiem of the Golden Witch"],"title":{"english":"Umineko When They Cry Episode 7: Requiem of the Golden Witch","native":"うみねこのなく頃に散 - Episode 7: Requiem of the Golden Witch","romaji":"Umineko no Naku Koro ni Chiru Episode 7: Requiem of the Golden Witch","userPreferred":"Umineko no Naku Koro ni Chiru Episode 7: Requiem of the Golden Witch"},"type":"MANGA","volumes":9},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/140475-FgBKTTJY7Ry6.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx140475-QEGtrmdvbpOv.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx140475-QEGtrmdvbpOv.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx140475-QEGtrmdvbpOv.jpg"},"description":"This story takes place in a particular town with two infamous schools in constant dispute: Chidori High, a boys' school predominantly attended by low-class students with damning grades, and its neighbor Kikyo Girls' High, with most of its female students coming from wealthy and prestigious families. One day, high school second-year Rintaro Tsumugi, a fierce-looking but gentle-minded student at Chidori, is helping at his family's patisserie when he encounters a female customer by the name of Kaoruko Waguri. Rintaro enjoys his time with Kaoruko, as she doesn't judge him for his appearance, but this blissful peace is quickly disturbed when Rintaro makes the discovery that Kaoruko is actually a student at Kikyo. This revelation marks the beginning of the two's strenuous tale, as they fight against the limitations placed upon them by their schools and surroundings in an attempt to find their own path!\n\u003cbr\u003e\u003cbr\u003e\n(Source: K Manga)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":140475,"idMal":144267,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/140475","startDate":{"day":21,"month":10,"year":2021},"status":"RELEASING","synonyms":["薰香花朵凛然綻放","Kaoruhana","La Nobleza de las Flores","Kaoru und Rin: So nah und doch so fern","Kaoru i Rin. Rozkwitając z tobą","Bloom","The Fragrant Flower Blooms With Dignity - Kaoru \u0026 Rin","A Nobreza das Flores","Güzel Kokulu Çiçekler Zarafetle Açar","향기로운 꽃은 늠름하게 핀다"],"title":{"english":"The Fragrant Flower Blooms With Dignity","native":"薫る花は凛と咲く","romaji":"Kaoru Hana wa Rin to Saku","userPreferred":"Kaoru Hana wa Rin to Saku"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/118371-4WMnMw6FUakk.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#35c9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx118371-3xk9VUbWnnRR.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx118371-3xk9VUbWnnRR.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx118371-3xk9VUbWnnRR.jpg"},"description":"Inori is a little girl who dreams of becoming a figure skater. Yet, the obstacles to this dream feel insurmountable: Inori’s already “too old” (she’s 11); she’s always had trouble at school; and, worst of all, her older sister’s skating dreams ended in failure, so her mother is dead set against putting her other daughter through a similar experience. Still, the rink is the only place Inori can be herself, and she’s out on the ice when a fateful meeting takes place. Tsukasa, a frustrated coach on the edge of giving up competitive skating himself, will join Inori to form an unstoppable duo powered by hard work, transcendent joy, and an unshakeable belief that they can prove everyone wrong. \n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Winner of the 8th Next Manga Award in the Print Manga Category in 2022.\u003cbr\u003e\n- Winner of the 68th Shogakukan Manga Award in the General Category in 2022.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Psychological","Sports"],"id":118371,"idMal":129621,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/118371","startDate":{"day":25,"month":5,"year":2020},"status":"RELEASING","synonyms":["ทอฝันบนลานสเกต","Madalya Peşinde","Медалістка"],"title":{"english":"Medalist","native":"メダリスト","romaji":"Medalist","userPreferred":"Medalist"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/51525-WMZWU0tOPxKR.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f18643","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx51525-wZ1AjkbXrKns.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx51525-wZ1AjkbXrKns.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx51525-wZ1AjkbXrKns.png"},"description":"A red-haired princess loses her family and her kingdom—now she must rise and fight for her throne!\n\u003cbr\u003e\u003cbr\u003e\nPrincess Yona lives an ideal life as the only princess of her kingdom. Doted on by her father, the king, and protected by her faithful guard Hak, she cherishes the time spent with the man she loves, Su-won. But everything changes on her 16th birthday when tragedy strikes her family!\n\u003cbr\u003e\u003cbr\u003e\nYona reels from the shock of witnessing a loved one's murder and having to fight for her life. With Hak's help, she flees the palace and struggles to survive while evading her enemy's forces. But where will this displaced princess go when all the paths before her are uncertain?\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Adventure","Drama","Fantasy","Romance"],"id":51525,"idMal":21525,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/51525","startDate":{"day":5,"month":8,"year":2009},"status":"RELEASING","synonyms":["AkaYona","Yona: The Girl Standing in the Blush of Dawn","Yona, Princesa del Amanecer","Yona w blasku świtu","Yona - Prinzessin der Morgendämmerung","Yona - Công chúa bình minh","Yona, Princesse de l'Aube","Yona: A Princesa do Alvorecer"],"title":{"english":"Yona of the Dawn","native":"暁のヨナ","romaji":"Akatsuki no Yona","userPreferred":"Akatsuki no Yona"},"type":"MANGA","volumes":48},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/116170-0aywoLTUPAns.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx116170-Q9f5Wk6cod5E.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx116170-Q9f5Wk6cod5E.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx116170-Q9f5Wk6cod5E.jpg"},"description":"A chance encounter. A handsome soldier. A beautiful woman. A tentative love affair smolders on the snowy cobblestone streets, out of sight of those that might keep them apart.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eVeil\u003c/i\u003e is a beautifully illustrated full-color romance manga, told in stylish short vignettes, beautiful illustrations, and secret moments.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Udon Entertainment, edited) ","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Romance","Slice of Life"],"id":116170,"idMal":132678,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/116170","startDate":{"day":14,"month":5,"year":2018},"status":"RELEASING","synonyms":["面纱"],"title":{"english":"Veil","native":"Veil","romaji":"Veil","userPreferred":"Veil"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/112275-MI6MZ0HuZx1r.jpg","chapters":null,"countryOfOrigin":"CN","coverImage":{"color":"#e4c95d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx112275-fh0u5cH2qB5b.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx112275-fh0u5cH2qB5b.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx112275-fh0u5cH2qB5b.jpg"},"description":"800 years ago, Xie Lian was a pure-blooded and noble Crown Prince, a well-regarded child of Heaven with unlimited potential. But who knew that, after he ascended and became a god with tens of thousands of worshippers, his fate would take such a sharp downhill turn? He was demoted again and again, and fell to rock bottom. 800 years later, Xie Lian ascended again, but this time, without worshippers or and without incense. One day, after returning from collecting scraps, he took a mysterious young man home. And this young man was the Ghost King that made others pale in fear whenever discussed—Hua Cheng.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Bilibili Comics)\n","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Adventure","Drama","Fantasy","Romance"],"id":112275,"idMal":140765,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/112275","startDate":{"day":19,"month":10,"year":2019},"status":"HIATUS","synonyms":["Heaven Official’s Blessing","TGCF","La Bendicion Oficial Del Cielo","천관사복","สวรรค์ประทานพร","Thiên quan tứ phúc"],"title":{"english":"Heaven Official's Blessing","native":"天官赐福","romaji":"Tian Guan Ci Fu","userPreferred":"Tian Guan Ci Fu"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/37375-CWUiMtQsmdJI.jpg","chapters":170,"countryOfOrigin":"JP","coverImage":{"color":"#5da1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx37375-wkgev4kXhamw.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx37375-wkgev4kXhamw.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx37375-wkgev4kXhamw.png"},"description":"Transfer student Buntaro Mori starts his first day at his new school already on the administration’s radar. He’s withdrawn and sullen, and the teachers are just waiting for him to explode. When his annoying classmate Miyamoto promises to leave him alone forever if he climbs to the top of the school, Mori eagerly takes up the challenge and shocks everyone when he makes it all the way to the roof. Flushed with the victory of his first successful climb, Mori can’t resist the lure of the local peak, despite warnings from more experienced climbers about the risks of climbing alone. But Mori doesn’t care. A little danger is nothing in the face of his new obsession.\n\u003cBR\u003e\u003cBR\u003e\n(Source: VIZ Media)\n","endDate":{"day":10,"month":11,"year":2011},"format":"MANGA","genres":["Adventure","Drama","Psychological","Sports"],"id":37375,"idMal":7375,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/37375","startDate":{"day":1,"month":11,"year":2007},"status":"FINISHED","synonyms":["Ascension","Koko no Hito"],"title":{"english":"The Climber","native":"孤高の人","romaji":"Kokou no Hito","userPreferred":"Kokou no Hito"},"type":"MANGA","volumes":17},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30007-lPJnvyj6zJvD.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx30007-jVUNk721L0Uz.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx30007-jVUNk721L0Uz.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx30007-jVUNk721L0Uz.jpg"},"description":"Makunouchi Ippo has been bullied his entire life. Constantly running errands and being beaten up by his classmates, Ippo has always dreamed of changing himself, but never has the passion to act upon it. One day, in the midst of yet another bullying, Ippo is saved by Takamura Mamoru, who happens to be a boxer. Ippo faints from his injuries and is brought to Takamura boxing gym to recover. As he regains consciousness, he is awed and amazed at his new surroundings in the gym, though lacks confidence to attempt anything. Takamura places a photo of Ippo\u0026rsquo;s classmate on a punching bag and forces him to punch it. It is only then that Ippo feels something stir inside him and eventually asks Takamura to train him in boxing. Thinking that Ippo does not have what it takes, Takamura gives him a task deemed impossible and gives him a one week time limit. With a sudden desire to get stronger, for himself and his hard working mother, Ippo trains relentlessly to accomplish the task within the time limit. Thus Ippo\u0026rsquo;s journey to the top of the boxing world begins.\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Comedy","Drama","Sports"],"id":30007,"idMal":7,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/30007","startDate":{"day":27,"month":9,"year":1989},"status":"RELEASING","synonyms":["The Fighting!","Fighting Spirit","The Fighting! Ippo","Hajime no Ippo Gaiden: Naniwa Tiger","Fight!! Ippo"],"title":{"english":"Hajime no Ippo: Fighting Spirit!","native":"はじめの一歩","romaji":"Hajime no Ippo","userPreferred":"Hajime no Ippo"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/85135-BPNyMuWVvZjh.jpg","chapters":64,"countryOfOrigin":"JP","coverImage":{"color":"#e49343","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx85135-11OOnyaqV71k.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx85135-11OOnyaqV71k.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx85135-11OOnyaqV71k.png"},"description":"\u003ci\u003eBased on a one-shot that won the 80th Weekly Shounen Magazine Newbie Best Mangaka Award.\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e\nShouya is a bully. When Shouko, a girl who can't hear, enters his elementary school class, she becomes their favorite target, and Shouya and his friends goad each other into devising new tortures for her. But the children's cruelty goes too far. Shouko is forced to leave the school, and Shouya ends up shouldering all the blame. Six years later, the two meet again. Can Shouya make up for his past mistakes, or is it too late?\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes two extra chapters.\u003c/i\u003e","endDate":{"day":19,"month":11,"year":2014},"format":"MANGA","genres":["Drama","Romance","Slice of Life"],"id":85135,"idMal":56805,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/85135","startDate":{"day":7,"month":8,"year":2013},"status":"FINISHED","synonyms":["The Shape of Voice","A Voz do Silêncio","A Forma da Voz","Kształt twojego głosu","Sessizliğin Sesi","声之形","Форма голоса","Němý hlas","รักไร้เสียง","Oblik glasa","목소리의 형태","Форма голосу","Silhuett av en stemme"],"title":{"english":"A Silent Voice","native":"聲の形","romaji":"Koe no Katachi","userPreferred":"Koe no Katachi"},"type":"MANGA","volumes":7},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/187189-GM07UtEw5zAG.jpg","chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#a1c9e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx187189-B5zA4zPh3UJA.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx187189-B5zA4zPh3UJA.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx187189-B5zA4zPh3UJA.jpg"},"description":"One day, after being discovered in an abandoned house by a rescue team, Mori suddenly finds himself in a children's protection center. Here, he begins to learn a new way of life – one that includes grand care packages sent by a mysterious patron. But when his closest friend is reunited with her mother and leaves the center, Mori learns for the first time the existence of a mother for every child, and decides to embark on a journey to find his own. But what sort of obstacles wait along the way?\u003cbr\u003e\u003cbr\u003e(Source: WEBTOON)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Adventure","Fantasy"],"id":187189,"idMal":178182,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/187189","startDate":{"day":25,"month":11,"year":2024},"status":"RELEASING","synonyms":["On My Way to See My Mom","Camino a conocer a mamá","Le Chemin vers Maman","去见妈妈的路上","去見媽咪的路上","มัมหมีจ๋าหนูมาแบ๊ว"],"title":{"english":"On the Way to Meet Mom","native":"엄마를 만나러 가는 길","romaji":"Eommareul Mannareo Ganeun Gil","userPreferred":"Eommareul Mannareo Ganeun Gil"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/118586-R1c7mc72oPvS.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx118586-CXKgWikBFQgS.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx118586-CXKgWikBFQgS.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx118586-CXKgWikBFQgS.jpg"},"description":"The adventure is over but life goes on for an elf mage just beginning to learn what living is all about.\n\u003cbr\u003e\u003cbr\u003e\nElf mage Frieren and her courageous fellow adventurers have defeated the Demon King and brought peace to the land. With the great struggle over, they all go their separate ways to live a quiet life. But as an elf, Frieren, nearly immortal, will long outlive the rest of her former party. How will she come to terms with the mortality of her friends? How can she find fulfillment in her own life, and can she learn to understand what life means to the humans around her? Frieren begins a new journey to find the answer.\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Winner of the Grand Prize at the 14th Manga Taisho Awards.\u003cbr\u003e\n- Nominated for the 25th Annual Tezuka Osamu Cultural Prize.\u003cbr\u003e\n- Placed 3rd at the 7th Annual Next Manga Award.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Adventure","Drama","Fantasy"],"id":118586,"idMal":126287,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/118586","startDate":{"day":28,"month":4,"year":2020},"status":"HIATUS","synonyms":["Frieren at the Funeral","장송의 프리렌","Frieren: Oltre la Fine del Viaggio","คำอธิษฐานในวันที่จากลา Frieren","Frieren e a Jornada para o Além","Frieren – Nach dem Ende der Reise","葬送的芙莉蓮","Frieren After \"The End\"","Frieren: Remnants of the Departed","Frieren. U kresu drogi","Frieren","FRIEREN: Más allá del fin del viaje","Проводжальниця Фрірен","Frieren: Ved reisens ende"],"title":{"english":"Frieren: Beyond Journey’s End","native":"葬送のフリーレン","romaji":"Sousou no Frieren","userPreferred":"Sousou no Frieren"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/117620-hUfbQd7m83WC.jpg","chapters":32,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx117620-cyvy8nO9GLm8.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx117620-cyvy8nO9GLm8.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx117620-cyvy8nO9GLm8.jpg"},"description":"Shizuku is a shy girl who hardly talks to other people. Instead, she loses herself in creative writing, crafting a novel that she never plans to show anyone. But when Kaori–Shizuku’s cute, popular classmate–gets her hands on Shizuku’s manuscript, everything changes. Kaori is a huge fan, and suggests that Shizuku can get inspiration for her writing if the two of them start dating! Can these very different young ladies create their own love story together?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment)","endDate":{"day":18,"month":1,"year":2024},"format":"MANGA","genres":["Drama","Psychological","Romance"],"id":117620,"idMal":128365,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/117620","startDate":{"day":18,"month":5,"year":2020},"status":"FINISHED","synonyms":["KimiTsuzu","きみつづ","ร้อยเรียงรักไปกับเธอ","Notre été éphémère","Der Sommer, als du da warst","Un amor de tinta y espuma"],"title":{"english":"The Summer You Were There","native":"君と綴るうたかた","romaji":"Kimi to Tsuzuru Utakata","userPreferred":"Kimi to Tsuzuru Utakata"},"type":"MANGA","volumes":6},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/106331-iV0HjU9dSnDR.jpg","chapters":57,"countryOfOrigin":"JP","coverImage":{"color":"#fe9328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx106331-C1F1hqpHnJ0U.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx106331-C1F1hqpHnJ0U.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx106331-C1F1hqpHnJ0U.jpg"},"description":"The manga centers on 35-year-old novelist Makio Koudai and her 15-year-old niece Asa, who live together under one roof. Makio took Asa in on a sudden impulse after Asa's parents, which included Makio's older sister, passed away. The next day, Makio returns to her senses and remembers that she does not do well in the company of other people. So begins their daily life, as Makio attempts to acclimate to a roommate, while Asa attempts to get used to an adult that never acts like one.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Anime News Network)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes three extra chapters.\u003c/i\u003e","endDate":{"day":8,"month":6,"year":2023},"format":"MANGA","genres":["Drama","Slice of Life"],"id":106331,"idMal":118804,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/106331","startDate":{"day":8,"month":6,"year":2017},"status":"FINISHED","synonyms":["Different Country Diary","Foreign Country Diary","Entre les Lignes","異國日記","위국일기","Diary of a Strange Land"],"title":{"english":null,"native":"違国日記","romaji":"Ikoku Nikki","userPreferred":"Ikoku Nikki"},"type":"MANGA","volumes":11},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/98263-inZk3YmhgbQh.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1c950","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx98263-kIeaTXrAbGkj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx98263-kIeaTXrAbGkj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx98263-kIeaTXrAbGkj.jpg"},"description":"In a world where everyone takes wonders like magic spells and dragons for granted, Coco is a girl with a simple dream: she wants to be a witch. But everybody knows magicians are born, not made, and Coco was not born with a gift for magic. Resigned to her un-magical life, Coco is about to give up on her dream to become a witch … until the day she meets Qifrey, a mysterious, traveling magician. After secretly seeing Qifrey perform magic in a way she’s never seen before, Coco soon learns what everybody “knows” might not be the truth, and discovers that her magical dream may not be as far away as it may seem...\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\n\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- Nominated for the 11th Manga Taishou Award in 2018.\u003cbr\u003e\n- Won the Daruma d'Or at Japan Expo in 2019.\u003cbr\u003e\n- Won Best U.S. Edition of International Material - Asia at the Eisner Awards in 2020.\u003cbr\u003e\n- Won the Best Manga Award at the Harvey Awards in 2020.\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Adventure","Drama","Fantasy"],"id":98263,"idMal":100035,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/98263","startDate":{"day":22,"month":7,"year":2016},"status":"RELEASING","synonyms":["L'Atelier des Sorciers","Atelier spiczastych kapeluszy","Atelier of Witch Hat","Ателье колдовских колпаков"," 고깔모자의 아틀리에","Ateliér špičatých klobouků","Xưởng phép thuật","El Atelier de Sombreros de Mago"," จอมเวทฝึกหัดกับหมวกมหัศจรรย์","Ательє чаклунських капелюхів","Atelierul Vrăjitoarelor","魔法帽的工作室","Cadı Şapkası Atölyesi","尖帽子的魔法工坊","Das Geheimnis der Hexen","Heksehatt-atelieret"],"title":{"english":"Witch Hat Atelier","native":"とんがり帽子のアトリエ","romaji":"Tongari Boushi no Atelier","userPreferred":"Tongari Boushi no Atelier"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/43245-NzA5zqcGEdFj.jpg","chapters":248,"countryOfOrigin":"JP","coverImage":{"color":"#e46b35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx43245-Ied8R99LH3u6.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx43245-Ied8R99LH3u6.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx43245-Ied8R99LH3u6.jpg"},"description":"Chihaya is a girl in the sixth grade, still not old enough to even know the meaning of the word zeal. But one day, she meets Arata, a transfer student from rural Fukui prefecture. Though docile and quiet, he has an unexpected skill: his ability to play competitive karuta, a traditional Japanese card game.\n\u003cbr\u003e\u003cbr\u003e\nChihaya is struck by his obsession with the game, along with his ability to pick out the right card and swipe it away before any of his opponents. However, Arata is transfixed by her as well, all because of her unbelievable natural talent for the game. Don't miss this story of adolescent lives and emotions playing out in the most dramatic of ways!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- It won the 2nd Manga Taisho Award and the 35th annual Kodansha Manga Award for Best Shoujo.\u003cbr\u003e\n- It was nominated for the 20th Tezuka Osamu Cultural Prize in 2016.\u003c/i\u003e","endDate":{"day":1,"month":8,"year":2022},"format":"MANGA","genres":["Drama","Romance","Sports"],"id":43245,"idMal":13245,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/43245","startDate":{"day":28,"month":12,"year":2007},"status":"FINISHED","synonyms":["치하야후루","花牌情緣"],"title":{"english":"Chihayafuru","native":"ちはやふる","romaji":"Chihayafuru","userPreferred":"Chihayafuru"},"type":"MANGA","volumes":50},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30336-ze9H1QF5kh0g.jpg","chapters":208,"countryOfOrigin":"JP","coverImage":{"color":"#e4bb5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30336-KWTPMwsNTeSa.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30336-KWTPMwsNTeSa.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30336-KWTPMwsNTeSa.png"},"description":"Former juvenile delinquent Onizuka finds himself thrust into to role of high school teacher, facing students who behave just as he used to and an administration that doesn't trust him. Using the brash an unorthodox methods he picked up in his youth, Onizuka manages to reach through to his kids and help them with their problems.\n\u003cbr\u003e\u003cbr\u003e\n(Source: TOKYOPOP)\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eNotes:\u003c/b\u003e\u003cbr\u003e\n\u003ci\u003e- Won the 22nd Kodansha Manga Award for Best Shounen Manga.\u003cbr\u003e\n\u003ci\u003e- The chapter count includes the 7 chapters extra \u003cb\u003eGTO: Great Toroko Oppai♡\u003c/b\u003e \u003c/i\u003e(Tomoko's Big Adventures)\u003ci\u003e published in volumes 11 and 12, and one extra published in volume 25.\u003c/i\u003e","endDate":{"day":17,"month":4,"year":2002},"format":"MANGA","genres":["Action","Comedy","Drama","Ecchi"],"id":30336,"idMal":336,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/30336","startDate":{"day":16,"month":5,"year":1997},"status":"FINISHED","synonyms":["ジーティーオー","GTO: Tomoko's Big Adventures","Great Teacher Onizuka","グレート・ティーチャー・オニヅカ","GTO คุณครูพันธ์หายาก"],"title":{"english":"GTO: Great Teacher Onizuka","native":"GTO","romaji":"GTO","userPreferred":"GTO"},"type":"MANGA","volumes":25},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30081-JYNed0PplksD.png","chapters":67,"countryOfOrigin":"JP","coverImage":{"color":"#f1e435","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30081-oCRaPkTGq4vP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30081-oCRaPkTGq4vP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30081-oCRaPkTGq4vP.jpg"},"description":"On the planet Aqua, a world once known as Mars, Akari Mizunashi has just made her home in the town of Neo-Venezia, a futuristic imitation of the ancient city of Venice. In pursuit of her dream to become an Undine — a gondolier who leads high-end tours around the city — Akari joins as a trainee with the Aria Company, one of the three most prestigious water-guide companies in Neo-Venezia. There, she explores the beauty of the city and the world along with other trainees from Aria and rival companies, working hard for her dreams and making new friends along the way.\n\u003cbr\u003e\u003cbr\u003e\n(Source: TOKYOPOP)\n\u003cbr\u003e\u003cbr\u003e\n\u003cI\u003eNote: Includes seven extra chapters.\u003c/i\u003e","endDate":{"day":29,"month":2,"year":2008},"format":"MANGA","genres":["Adventure","Comedy","Drama","Fantasy","Sci-Fi","Slice of Life"],"id":30081,"idMal":81,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/30081","startDate":{"day":28,"month":2,"year":2002},"status":"FINISHED","synonyms":["アリア","Ария","Aria: The Masterpiece"],"title":{"english":"Aria","native":"ARIA","romaji":"ARIA","userPreferred":"ARIA"},"type":"MANGA","volumes":12},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/30044-3Q6rPDp3ZBIZ.jpg","chapters":709,"countryOfOrigin":"JP","coverImage":{"color":"#e4435d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx30044-vPmoz3vTPvZs.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx30044-vPmoz3vTPvZs.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx30044-vPmoz3vTPvZs.jpg"},"description":"The samurai didn't stand a chance. First, the aliens invaded Japan. Next, they took all the jobs. And then they confiscated everyone's swords. So what does a hotheaded former samurai like Sakata \"Gin\" Gintoki do to make ends meet? Take any odd job that comes his way, even if it means losing his dignity.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eIncluded Bonus Chapters:\u003c/b\u003e\u003cbr\u003e\nVolume 1: \u003ci\u003eDandelion (One-shot).\u003c/i\u003e\u003cbr\u003e\nVolume 2: \u003ci\u003eShirokuro (One-shot).\u003c/i\u003e\u003cbr\u003e\nVolume 24: \u003ci\u003e13 (One-shot).\u003c/i\u003e\u003cbr\u003e\nVolume 38: \u003ci\u003eBankara-san Ga Tooru (One-shot).\u003c/i\u003e\u003cbr\u003e\nVolume 41: \u003ci\u003eSpecial Lesson.\u003c/i\u003e","endDate":{"day":20,"month":6,"year":2019},"format":"MANGA","genres":["Action","Comedy","Drama","Sci-Fi"],"id":30044,"idMal":44,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/30044","startDate":{"day":8,"month":12,"year":2003},"status":"FINISHED","synonyms":["Dandelion","Shiro Kuro","Black and White","גינטמה","กินทามะ"],"title":{"english":"Gin Tama","native":"銀魂","romaji":"Gintama","userPreferred":"Gintama"},"type":"MANGA","volumes":77},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/107279-D36RyE2DG7S9.jpg","chapters":410,"countryOfOrigin":"JP","coverImage":{"color":"#f1c943","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx107279-R2vxyPQRqV0X.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx107279-R2vxyPQRqV0X.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx107279-R2vxyPQRqV0X.jpg"},"description":"Ashito Aoi, a third year middle school student from Ehime, meets Fukuda Tatsuya, a J Youth League coach. Even though he's still rough around the edges, Ashito has such amazing potential that he gets invited by coach Fukuda to participate in his team's try-outs in Tokyo. The story of a boy who will revolutionize Japanese football begins to unfold.\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes: \u003cbr\u003e\n- Nominated for the 2017 Manga Taishou Award.\u003cbr\u003e\n- Winner of the 65th Shogakukan Manga Award for \"Best General Manga\" category in 2019.\u003c/i\u003e","endDate":{"day":23,"month":6,"year":2025},"format":"MANGA","genres":["Sports"],"id":107279,"idMal":102256,"isAdult":false,"meanScore":87,"season":null,"siteUrl":"https://anilist.co/manga/107279","startDate":{"day":5,"month":1,"year":2015},"status":"FINISHED","synonyms":["AOASHI แข็งเด็กหัวใจนักสู้","Ao Ashi - Playmaker"],"title":{"english":"Aoashi","native":"アオアシ","romaji":"Aoashi","userPreferred":"Aoashi"},"type":"MANGA","volumes":40},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/89278-fQxh1HtQRpzc.jpg","chapters":155,"countryOfOrigin":"JP","coverImage":{"color":"#d61a35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx89278-2nemnSgiesJa.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx89278-2nemnSgiesJa.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx89278-2nemnSgiesJa.jpg"},"description":"Kaiji and Kazuya face off against each other in a high-stakes game of \"One Poker,\" a modified version of standard poker. Kazuya sets forth a gamble of 2,000,000,000 yen! How will Kaiji survive?! \u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eChapter count for this arc is 101-254 in the original tankoubon.\u003c/i\u003e","endDate":{"day":21,"month":8,"year":2017},"format":"MANGA","genres":["Drama","Psychological","Thriller"],"id":89278,"idMal":61579,"isAdult":false,"meanScore":88,"season":null,"siteUrl":"https://anilist.co/manga/89278","startDate":{"day":27,"month":4,"year":2013},"status":"FINISHED","synonyms":["Kaiji Part 5","Gambling Outcast Kaiji: One Poker Arc","Tobaku Datenroku Kaiji: One Poker Arc"],"title":{"english":null,"native":"賭博堕天録カイジ ワン・ポーカー編","romaji":"Tobaku Datenroku Kaiji: One Poker-hen","userPreferred":"Tobaku Datenroku Kaiji: One Poker-hen"},"type":"MANGA","volumes":16},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/86559-hHgBaQktjtsd.jpg","chapters":314,"countryOfOrigin":"JP","coverImage":{"color":"#f1860d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx86559-Y4xDmoz4ud43.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx86559-Y4xDmoz4ud43.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx86559-Y4xDmoz4ud43.jpg"},"description":"In the early twentieth century, Russo-Japanese War veteran Saichi “Immortal” Sugimoto scratches out a meager existence during the postwar gold rush in the wilderness of Hokkaido. When he stumbles across a map to a fortune in hidden Ainu gold, he sets off on a treacherous quest to find it. But Sugimoto is not the only interested party, and everyone who knows about the gold will kill to possess it! Faced with the harsh conditions of the northern wilderness, ruthless criminals and rogue Japanese soldiers, Sugimoto will need all his skills and luck—and the help of an Ainu girl named Asirpa—to survive.\n\u003cbr\u003e\u003cbr\u003e\n(Source: VIZ Media)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Won the 9th Manga Taisho Award in 2016 and the 22nd Tezuka Osamu Cultural Prize in 2018. Nominated for the 20th and 21st Tezuka Osamu Cultural Prize and the 40th Kodansha Manga Awards in 2016.\u003c/i\u003e","endDate":{"day":28,"month":4,"year":2022},"format":"MANGA","genres":["Action","Adventure","Comedy","Drama"],"id":86559,"idMal":85968,"isAdult":false,"meanScore":86,"season":null,"siteUrl":"https://anilist.co/manga/86559","startDate":{"day":21,"month":8,"year":2014},"status":"FINISHED","synonyms":["Golden Kamui","黃金神威","골든 카무이"],"title":{"english":"Golden Kamuy","native":"ゴールデンカムイ","romaji":"Golden Kamuy","userPreferred":"Golden Kamuy"},"type":"MANGA","volumes":31}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":104,"perPage":48,"total":5000}}},"updated_at":"2026-03-07T01:06:24.686929+03:00"},"{\"query\":\"query ListRecentAnime ($page: Int, $perPage: Int, $airingAt_greater: Int, $airingAt_lesser: Int, $sort: [AiringSort], $notYetAired: Boolean = false) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tairingSchedules(notYetAired: $notYetAired, sort: $sort, airingAt_greater: $airingAt_greater, airingAt_lesser: $airingAt_lesser) {\\n\\t\\t\\tid\\n\\t\\t\\tairingAt\\n\\t\\t\\tepisode\\n\\t\\t\\ttimeUntilAiring\\n\\t\\t\\tmedia {\\n\\t\\t\\t\\t... baseAnime\\n\\t\\t\\t}\\n\\t\\t}\\n\\t}\\n}\\nfragment baseAnime on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tbannerImage\\n\\tepisodes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\tduration\\n\\ttrailer {\\n\\t\\tid\\n\\t\\tsite\\n\\t\\tthumbnail\\n\\t}\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tnextAiringEpisode {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n  \",\"variables\":{\"airingAt_greater\":1771623785,\"airingAt_lesser\":1772833385,\"page\":1,\"perPage\":50,\"sort\":[\"TIME_DESC\"]}}":{"value":{"Page":{"airingSchedules":[{"airingAt":1772830800,"episode":23,"id":401292,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1c950","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx198413-IDC13Jyk0xYD.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx198413-IDC13Jyk0xYD.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx198413-IDC13Jyk0xYD.png"},"description":"Second season of \u003ci\u003eJOCHUM\u003c/i\u003e.","duration":2,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV_SHORT","genres":["Slice of Life"],"id":198413,"idMal":62231,"isAdult":false,"meanScore":51,"nextAiringEpisode":{"airingAt":1773435600,"episode":24,"timeUntilAiring":602211},"season":"FALL","siteUrl":"https://anilist.co/anime/198413","startDate":{"day":4,"month":10,"year":2025},"status":"RELEASING","synonyms":[],"title":{"english":null,"native":"ジェオチャム シーズン2 ","romaji":"JOCHUM Season 2","userPreferred":"JOCHUM Season 2"},"trailer":{"id":"cGOk6c2yFYA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/cGOk6c2yFYA/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-2589},{"airingAt":1772827200,"episode":9,"id":407353,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#1a93d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx203148-fMhz9uyA6HEK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx203148-fMhz9uyA6HEK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx203148-fMhz9uyA6HEK.jpg"},"description":"The anime's story is set in a world made of \"cuteness\" called Sun Kingdom. Ganso Hoppe-chan, who lost her memory, appears in the kingdom. Meanwhile, in the real world, an office worker named Hoho is slowly losing her self-esteem in her work and life, sending her on the verge of becoming lost in life. Somewhere between Ganso Hoppe-chan and Hoho's worlds, their paths cross. Back in Sun Kingdom, toxic Hoppe-chan creatures are creating an \"uncute place,\" and Ganso Hoppe-chan joins the \"Guardians\" to protect the kingdom.\n\u003cbr\u003e\u003cbr\u003e\n(Source: ANN)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Fantasy"],"id":203148,"idMal":63106,"isAdult":false,"meanScore":60,"nextAiringEpisode":{"airingAt":1773432000,"episode":10,"timeUntilAiring":598611},"season":"WINTER","siteUrl":"https://anilist.co/anime/203148","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["HOPPECHAN - Mystery of the Sun Kingdom and the Black-Cheek Team -"],"title":{"english":null,"native":"ほっぺちゃん ～サン王国と黒ほっぺ団の秘密～","romaji":"Hoppe-chan: Sun Oukoku to Kuro Hoppe-dan no Himitsu","userPreferred":"Hoppe-chan: Sun Oukoku to Kuro Hoppe-dan no Himitsu"},"trailer":{"id":"knIpSRsTyGY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/knIpSRsTyGY/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-6189},{"airingAt":1772815980,"episode":9,"id":403360,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179062-ZnxW4uWEsV3H.jpg","countryOfOrigin":"JP","coverImage":{"color":"#febb28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179062-pbzYE1miZq61.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179062-pbzYE1miZq61.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179062-pbzYE1miZq61.png"},"description":"The second cour of \u003ci\u003eEnen no Shouboutai: San no Shou\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e \n\nAs chaos spreads, Shinra and Company 8 fight to stop a final, world-ending blaze.\u003cbr\u003e\u003cbr\u003e \n\n(Source: Crunchyroll News)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":13,"format":"TV","genres":["Action","Drama","Sci-Fi","Supernatural"],"id":179062,"idMal":59229,"isAdult":false,"meanScore":80,"nextAiringEpisode":{"airingAt":1773420780,"episode":10,"timeUntilAiring":587391},"season":"WINTER","siteUrl":"https://anilist.co/anime/179062","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["Enen no Shouboutai 3rd Season Part 2","หน่วยผจญคนไฟลุก ภาค 3"],"title":{"english":"Fire Force Season 3 Part 2","native":"炎炎ノ消防隊 参ノ章 第2クール","romaji":"Enen no Shouboutai: San no Shou Part 2","userPreferred":"Enen no Shouboutai: San no Shou Part 2"},"trailer":{"id":"voLZJvdwUEE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/voLZJvdwUEE/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-17409},{"airingAt":1772814900,"episode":9,"id":405089,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185262-6EExIkvGk1dI.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbe450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185262-95wbx3Y9hCwm.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185262-95wbx3Y9hCwm.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185262-95wbx3Y9hCwm.jpg"},"description":"Thirty-five-year-old Kenichi Yamada has spent his life playing every single MMORPG he can get his hands on. Tired of new games that cater to casual players, he leaps at the chance to try out a never-ending game with an intimidating “Hell Mode” that raises the difficulty (and chances to level up) to impossible heights. But, as soon as he selects the “Summoner,” Kenichi finds himself transported into the world of the game and reborn to a family of serfs as a baby named Allen! With nothing but his memories and wits to guide him, Allen sets off to conquer Hell Mode, unearth the secrets of the Summoner class, and free his newfound family from their fate.\u003cbr\u003e\n\u003cbr\u003e\n(Source: HIDIVE)","duration":23,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"TV","genre