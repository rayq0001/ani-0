{"{\"query\":\"query ListAnime ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $season: MediaSeason, $seasonYear: Int, $format: MediaFormat, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: ANIME, search: $search, sort: $sort, status_in: $status, isAdult: $isAdult, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, season: $season, seasonYear: $seasonYear, format_not: MUSIC) {\\n\\t\\t\\t... baseAnime\\n\\t\\t}\\n\\t}\\n}\\nfragment baseAnime on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tseasonYear\\n\\tbannerImage\\n\\tepisodes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\tduration\\n\\ttrailer {\\n\\t\\tid\\n\\t\\tsite\\n\\t\\tthumbnail\\n\\t}\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tnextAiringEpisode {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":20,\"sort\":[\"TRENDING_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166613-drS86exJlIjG.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166613-uHB8q3D4qbon.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166613-uHB8q3D4qbon.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166613-uHB8q3D4qbon.jpg"},"description":"The second season of \u003ci\u003eJigokuraku\u003c/i\u003e.","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Adventure","Mystery","Supernatural"],"id":166613,"idMal":55825,"isAdult":false,"meanScore":81,"nextAiringEpisode":{"airingAt":1774190640,"episode":11,"timeUntilAiring":586430},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/166613","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["Hell’s Paradise: Jigokuraku Season 2","สุขาวดีอเวจี","Адский рай"],"title":{"english":"Hell’s Paradise Season 2","native":"地獄楽 第二期","romaji":"Jigokuraku 2nd Season","userPreferred":"Jigokuraku 2nd Season"},"trailer":{"id":"JLe_NUnAZVs","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JLe_NUnAZVs/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185993-6H7wGuRpwoSL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185993-BecPUaWfZJgR.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185993-BecPUaWfZJgR.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185993-BecPUaWfZJgR.png"},"description":"Noah, the world’s strongest six-year-old, has been privileged enough to be reborn as the emperor’s 13th child. What’s more, he’s been overpowered with an infinite level cap and a cheat that stacks the powers of anyone who serves him. But even privilege has its problems—the glittering facade of high society hides a world of conspiracies, schemes, and power struggles.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":185993,"idMal":60692,"isAdult":false,"meanScore":60,"nextAiringEpisode":{"airingAt":1774191600,"episode":12,"timeUntilAiring":587390},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185993","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["เกิดใหม่มาเป็นผู้สูงศักดิ์ ~สุดแกร่งไร้เทียมทานแต่กำเนิด~"],"title":{"english":"Noble Reincarnation: Born Blessed, So I'll Obtain Ultimate Power","native":"貴族転生 ～恵まれた生まれから最強の力を得る～","romaji":"Kizoku Tensei: Megumareta Umare kara Saikyou no Chikara wo Eru","userPreferred":"Kizoku Tensei: Megumareta Umare kara Saikyou no Chikara wo Eru"},"trailer":{"id":"RIj0yJCVNuU","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RIj0yJCVNuU/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/184951-Rx1mZZfKa9IU.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1ae28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx184951-s8Lg2muPBhdX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx184951-s8Lg2muPBhdX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx184951-s8Lg2muPBhdX.jpg"},"description":"Suzuki’s a high school girl in love, but the guy she’s fallen for is nothing like her! While she’s cheerful, outgoing, and always trying to fit in, her classmate Yusuke Tani is stoic, quiet, and doesn’t seem to care what people think of him. Will Suzuki be able to overcome her anxieties and ask him out, or will she discover that opposites really don’t attract?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy","Drama","Romance","Slice of Life"],"id":184951,"idMal":60371,"isAdult":false,"meanScore":82,"nextAiringEpisode":{"airingAt":1774166400,"episode":11,"timeUntilAiring":562190},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/184951","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["ลุ้นรักฉบับคู่ต่างขั้ว","정반대의 너와 나"],"title":{"english":"You and I Are Polar Opposites","native":"正反対な君と僕","romaji":"Seihantai na Kimi to Boku","userPreferred":"Seihantai na Kimi to Boku"},"trailer":{"id":"b5vpRUDkhT0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/b5vpRUDkhT0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182255-wyHvp6zJbWsO.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dc9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182255-butzrqd4I0aC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182255-butzrqd4I0aC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182255-butzrqd4I0aC.jpg"},"description":"The second season of \u003ci\u003eSousou no Frieren\u003c/i\u003e.","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":10,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":182255,"idMal":59978,"isAdult":false,"meanScore":89,"nextAiringEpisode":{"airingAt":1774015200,"episode":9,"timeUntilAiring":410990},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182255","startDate":{"day":16,"month":1,"year":2026},"status":"RELEASING","synonyms":["Провожающая в последний путь Фрирен 2","장송의 프리렌 2기"],"title":{"english":"Frieren: Beyond Journey’s End Season 2","native":"葬送のフリーレン 第2期","romaji":"Sousou no Frieren 2nd Season","userPreferred":"Sousou no Frieren 2nd Season"},"trailer":{"id":"RH-FcW94z00","site":"youtube","thumbnail":"https://i.ytimg.com/vi/RH-FcW94z00/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/186333-JN8lx2aNOTg1.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5da1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx186333-32qDHxLkndpg.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx186333-32qDHxLkndpg.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx186333-32qDHxLkndpg.png"},"description":"Kunon, a young man who cannot see, has the goal of creating new eyes with water magic. After just five months of learning sorcery, Kunon surpassed his own mentor and honed his talent as he tried to do a feat that's never been done before. A fantasy about a young man, a blind genius, who opens up the world through curiosity in the pursuit for magic is about to begin.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":22,"month":3,"year":2026},"episodes":13,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":186333,"idMal":60810,"isAdult":false,"meanScore":64,"nextAiringEpisode":{"airingAt":1774184400,"episode":13,"timeUntilAiring":580190},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/186333","startDate":{"day":4,"month":1,"year":2026},"status":"RELEASING","synonyms":["จอมเวทผู้มองเห็นทุกสิ่ง คุนอน"],"title":{"english":"Kunon the Sorcerer Can See","native":"魔術師クノンは見えている","romaji":"Majutsushi Kunon wa Mieteiru","userPreferred":"Majutsushi Kunon wa Mieteiru"},"trailer":{"id":"8AdpUgiFs2o","site":"youtube","thumbnail":"https://i.ytimg.com/vi/8AdpUgiFs2o/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/172463-3J2o3qQZadFJ.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5093d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx172463-LnXqHzt74SJL.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx172463-LnXqHzt74SJL.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx172463-LnXqHzt74SJL.jpg"},"description":"The third season of \u003ci\u003eJujutsu Kaisen\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\nAfter the Shibuya Incident, a deadly jujutsu battle known as the Culling Game orchestrated by Noritoshi Kamo erupts across ten colonies in Japan.\u003cbr\u003e\u003cbr\u003e\nHaunted by guilt over the mass killings in Shibuya and wary of Sukuna’s interest in Fushiguro, Itadori chooses not to return to Jujutsu High. Instead, he teams up with Choso to exorcise the countless cursed spirits unleashed by Noritoshi Kamo.\nAmid this chaos, the Jujutsu Headquarters revokes Yuji Itadori’s suspended death sentence and appoints special-grade sorcerer Yuta Okkotsu as his executioner. \u003cbr\u003e\u003cbr\u003e\nNewly awakened modern sorcerers and resurrected ancient ones,  now fighting as players in the Culling Game, collide with conflicting motives, driving the world once more toward an age ruled by jujutsu.\u003cbr\u003e\u003cbr\u003e\n(Source: TOHO Animation)","duration":24,"endDate":{"day":27,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Drama","Supernatural"],"id":172463,"idMal":57658,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773933960,"episode":11,"timeUntilAiring":329750},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/172463","startDate":{"day":9,"month":1,"year":2026},"status":"RELEASING","synonyms":["Jujutsu Kaisen 3rd Season","呪術廻戦 第3期","JJK3","มหาเวทย์ผนึกมาร จรดลล้างบาง พาร์ต 1"],"title":{"english":"JUJUTSU KAISEN Season 3: The Culling Game Part 1","native":"呪術廻戦 死滅回游 前編","romaji":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen","userPreferred":"Jujutsu Kaisen: Shimetsu Kaiyuu - Zenpen"},"trailer":{"id":"ruX3rIj3--w","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ruX3rIj3--w/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/177385-lzz3yIhQhQdB.jpg","countryOfOrigin":"JP","coverImage":{"color":"#aee4e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177385-TBpvkGdF28R7.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177385-TBpvkGdF28R7.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177385-TBpvkGdF28R7.png"},"description":"Reclusive novelist Makio Koudai has always preferred the company of books—but when her sister and brother-in-law pass away, Makio unexpectedly becomes the guardian of her 15-year-old niece, Asa Takumi. As they navigate grief, clashing personalities, and the challenges of living together, the two slowly open their hearts to each other, discovering warmth, understanding, and the meaning of family.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":30,"month":3,"year":2026},"episodes":13,"format":"TV","genres":["Drama","Slice of Life"],"id":177385,"idMal":58788,"isAdult":false,"meanScore":86,"nextAiringEpisode":{"airingAt":1774191600,"episode":12,"timeUntilAiring":587390},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/177385","startDate":{"day":5,"month":1,"year":2026},"status":"RELEASING","synonyms":["Diary of a Strange Land","Foreign Country Diary","Different Country Diary","บันทึกจากวิเทศ","مذكرات من بلد آخر","Entre les lignes","위국일기"],"title":{"english":"Journal with Witch","native":"違国日記","romaji":"Ikoku Nikki","userPreferred":"Ikoku Nikki"},"trailer":{"id":"DX6mmkoByyc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/DX6mmkoByyc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/167152-6QxZG8Dmf1EL.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx167152-u0cBZkqDowHP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx167152-u0cBZkqDowHP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx167152-u0cBZkqDowHP.jpg"},"description":"In a world where heroism is a punishment, Xylo Forbartz, a condemned goddess killer, battles endless hordes of monstrous abominations as part of Penal Hero Unit 9004. Death is no escape, only a cycle of resurrection and relentless combat. But when Xylo encounters a mysterious new goddess, their unlikely alliance sparks a rebellion that could shatter the chains of eternal punishment.\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- The first episode aired with a runtime of ~58 minutes as opposed to the standard 24 minute long episode.\u003cbr\u003e\n- Initially scheduled to air in October, 2025 \u003c/i\u003e","duration":25,"endDate":{"day":26,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Action","Comedy","Drama","Fantasy"],"id":167152,"idMal":56009,"isAdult":false,"meanScore":79,"nextAiringEpisode":{"airingAt":1773927000,"episode":11,"timeUntilAiring":322790},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/167152","startDate":{"day":3,"month":1,"year":2026},"status":"RELEASING","synonyms":["ผู้กล้าโทษประหาร : บันทึกการรับโทษของหน่วยผู้กล้าต้องโทษ 9004","용사형에 처함"],"title":{"english":"Sentenced to Be a Hero","native":"勇者刑に処す　懲罰勇者9004隊刑務記録","romaji":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku","userPreferred":"Yuusha Kei ni Shosu: Choubatsu Yuusha 9004-tai Keimu Kiroku"},"trailer":{"id":"GcRs1JC7xeg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/GcRs1JC7xeg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/166617-P4w3p0H4lE1O.jpg","countryOfOrigin":"JP","coverImage":{"color":"#1a1af1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx166617-34fpC9y47tTx.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx166617-34fpC9y47tTx.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx166617-34fpC9y47tTx.png"},"description":"In a Holy Grail War, Mages (Masters) and their Heroic Spirits (Servants) fight for the control of the Holy Grail—an omnipotent wish-granting device said to fulfill any desire. Years have passed since the end of the Fifth Holy Grail War in Japan. Now, signs portend the emergence of a new Holy Grail in the western American city of Snowfield. Sure enough, Masters and Servants begin to gather... \u003cbr\u003e\u003cbr\u003e\n\nA missing Servant class...\u003cbr\u003e\nImpossible Servant summonings...\u003cbr\u003e\nA nation shrouded in secrecy...\u003cbr\u003e\nAnd a city created as a battleground.\u003cbr\u003e\n\u003cbr\u003e\nIn the face of such irregularities, the Holy Grail War is twisted and driven into the depth of madness. Let the curtain rise on a masquerade of humans and heroes, made to dance upon the stage of a false Holy Grail. \u003ci\u003eThis is a Holy Grail War covered in lies.\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Official Site, Aniplex USA, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003c/i\u003e\u003cbr\u003e\n•  \u003ci\u003eSpecial premiere of Episode 1 in its English Dub occurred in Los Angeles at the Fate 20th Anniversary Showcase event and as well through Crunchyroll’s YouTube Channel on November 23, 2024 before the Japanese television premiere.\u003c/i\u003e\u003cbr\u003e\n•  \u003ci\u003eThe Japanese advanced premiere occurred during the \"Fate New Year's Eve TV Special 2024\" on December 31, 2024.\u003c/i\u003e","duration":25,"endDate":{"day":28,"month":3,"year":2026},"episodes":13,"format":"TV","genres":["Action","Adventure","Fantasy","Mystery","Supernatural"],"id":166617,"idMal":55830,"isAdult":false,"meanScore":83,"nextAiringEpisode":{"airingAt":1774103400,"episode":12,"timeUntilAiring":499190},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/166617","startDate":{"day":3,"month":1,"year":2026},"status":"RELEASING","synonyms":["Судьба/Странная подделка"],"title":{"english":"Fate/strange Fake","native":"Fate/strange Fake","romaji":"Fate/strange Fake","userPreferred":"Fate/strange Fake"},"trailer":{"id":"k1G8EvZg_BY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/k1G8EvZg_BY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/21-wf37VakJmZqs.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx21-ELSYx3yMPcKM.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx21-ELSYx3yMPcKM.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx21-ELSYx3yMPcKM.jpg"},"description":"Gold Roger was known as the Pirate King, the strongest and most infamous being to have sailed the Grand Line. The capture and death of Roger by the World Government brought a change throughout the world. His last words before his death revealed the location of the greatest treasure in the world, One Piece. It was this revelation that brought about the Grand Age of Pirates, men who dreamed of finding One Piece (which promises an unlimited amount of riches and fame), and quite possibly the most coveted of titles for the person who found it, the title of the Pirate King.\u003cbr\u003e\u003cbr\u003e\nEnter Monkey D. Luffy, a 17-year-old boy that defies your standard definition of a pirate. Rather than the popular persona of a wicked, hardened, toothless pirate who ransacks villages for fun, Luffy’s reason for being a pirate is one of pure wonder; the thought of an exciting adventure and meeting new and intriguing people, along with finding One Piece, are his reasons of becoming a pirate. Following in the footsteps of his childhood hero, Luffy and his crew travel across the Grand Line, experiencing crazy adventures, unveiling dark mysteries and battling strong enemies, all in order to reach One Piece.\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003e*This includes following special episodes:\u003c/b\u003e\u003cbr\u003e\n- Chopperman to the Rescue! Protect the TV Station by the Shore! (Episode 336)\u003cbr\u003e\n- The Strongest Tag-Team! Luffy and Toriko's Hard Struggle! (Episode 492)\u003cbr\u003e\n- Team Formation! Save Chopper (Episode 542)\u003cbr\u003e\n- History's Strongest Collaboration vs. Glutton of the Sea (Episode 590)\u003cbr\u003e\n- 20th Anniversary! Special Romance Dawn (Episode 907)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Comedy","Drama","Fantasy"],"id":21,"idMal":21,"isAdult":false,"meanScore":88,"nextAiringEpisode":{"airingAt":1775398560,"episode":1156,"timeUntilAiring":1794350},"season":"FALL","seasonYear":1999,"siteUrl":"https://anilist.co/anime/21","startDate":{"day":20,"month":10,"year":1999},"status":"RELEASING","synonyms":["ワンピース","海贼王","וואן פיס","ون بيس","วันพีซ","Vua Hải Tặc","All'arrembaggio!","Tutti all'arrembaggio!","Ντρέηκ, το Κυνήγι του Θησαυρού","OP","Ван-Пис"],"title":{"english":"ONE PIECE","native":"ONE PIECE","romaji":"ONE PIECE","userPreferred":"ONE PIECE"},"trailer":null,"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179062-ZnxW4uWEsV3H.jpg","countryOfOrigin":"JP","coverImage":{"color":"#febb28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179062-pbzYE1miZq61.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179062-pbzYE1miZq61.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179062-pbzYE1miZq61.png"},"description":"The second cour of \u003ci\u003eEnen no Shouboutai: San no Shou\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e \n\nAs chaos spreads, Shinra and Company 8 fight to stop a final, world-ending blaze.\u003cbr\u003e\u003cbr\u003e \n\n(Source: Crunchyroll News)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":13,"format":"TV","genres":["Action","Drama","Sci-Fi","Supernatural"],"id":179062,"idMal":59229,"isAdult":false,"meanScore":80,"nextAiringEpisode":{"airingAt":1774025580,"episode":11,"timeUntilAiring":421370},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/179062","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["Enen no Shouboutai 3rd Season Part 2","หน่วยผจญคนไฟลุก ภาค 3"],"title":{"english":"Fire Force Season 3 Part 2","native":"炎炎ノ消防隊 参ノ章 第2クール","romaji":"Enen no Shouboutai: San no Shou Part 2","userPreferred":"Enen no Shouboutai: San no Shou Part 2"},"trailer":{"id":"voLZJvdwUEE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/voLZJvdwUEE/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182587-SLNmuinewbUF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45df1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182587-fsU8LOjmd7oj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182587-fsU8LOjmd7oj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182587-fsU8LOjmd7oj.jpg"},"description":"The third season of \u003ci\u003e[Oshi no Ko]\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nThe story enters a new stage.\n\u003cbr\u003e\u003cbr\u003e\nIt's been six months since \"POP IN 2\" was released. Thanks to MEM-Cho's hard work, B-Komachi is about to get their major break. Aqua is a multi-talented entertainer, and Akane's career as a talented actress is going smoothly. Meanwhile, Kana lost the cheerfulness she once had. To track down the truth behind Ai and Goro's deaths, Ruby keeps rising in the entertainment world...\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eUsing lies as a weapon.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":25,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Drama","Mystery","Psychological","Supernatural"],"id":182587,"idMal":60058,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773842400,"episode":10,"timeUntilAiring":238190},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/182587","startDate":{"day":14,"month":1,"year":2026},"status":"RELEASING","synonyms":["[OSHI NO KO] Season 3"],"title":{"english":"【OSHI NO KO】Season 3","native":"【推しの子】第3期","romaji":"[Oshi no Ko] 3rd Season","userPreferred":"[Oshi no Ko] 3rd Season"},"trailer":{"id":"JGYY6Pui5Kc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JGYY6Pui5Kc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/192507-nv0NJmhQYTgz.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5086e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx192507-SCmImUlUnpAD.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx192507-SCmImUlUnpAD.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx192507-SCmImUlUnpAD.jpg"},"description":"Yoi Takiguchi has long legs, a deep voice, and a handsome face…in other words, Yoi is such a good-looking guy that most people don’t notice or care that she is, in fact, a girl. Indeed, she’s had the nickname “Prince” for as long as she can remember. That is, until she met Ichimura-senpai…the only person who really seemed to see her for herself. To her surprise, she’s not sure how to handle this new relationship, especially when her newfound friend is a prince himself (and a guy prince, at that). The story of the two high school princes starts here!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Romance","Slice of Life"],"id":192507,"idMal":61663,"isAdult":false,"meanScore":73,"nextAiringEpisode":{"airingAt":1774164600,"episode":11,"timeUntilAiring":560390},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/192507","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["เมื่อสาวหล่อขอมีรัก"],"title":{"english":"In the Clear Moonlit Dusk","native":"うるわしの宵の月","romaji":"Uruwashi no Yoi no Tsuki","userPreferred":"Uruwashi no Yoi no Tsuki"},"trailer":{"id":"VzJSWjCCn8M","site":"youtube","thumbnail":"https://i.ytimg.com/vi/VzJSWjCCn8M/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#fff193","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx177580-ujQw6Ws3oVCi.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx177580-ujQw6Ws3oVCi.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx177580-ujQw6Ws3oVCi.jpg"},"description":"Mizuki Ashiya is on a mission: disguise herself as a boy and enroll in a male boarding school to meet her idol, high jump star Izumi Sano. But after successfully infiltrating the school, she discovers he’s suddenly quit the sport! Now Mizuki must dodge suspicion, protect her cover, and somehow reach the boy she came all this way for—all while surviving the chaos of an all-boys dorm!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"ONA","genres":["Comedy","Drama","Romance","Slice of Life"],"id":177580,"idMal":58861,"isAdult":false,"meanScore":67,"nextAiringEpisode":null,"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/177580","startDate":{"day":4,"month":1,"year":2026},"status":"RELEASING","synonyms":["Hana-Kimi: For You in Full Blossom","สับขั้วมาลุ้นรัก"],"title":{"english":"Hana-Kimi","native":"花ざかりの君たちへ","romaji":"Hanazakari no Kimitachi e","userPreferred":"Hanazakari no Kimitachi e"},"trailer":{"id":"CemNP0vIiJI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/CemNP0vIiJI/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183660-RmcBY27wn8A4.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f15d35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183660-B6o9cMfSfScX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx183660-B6o9cMfSfScX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx183660-B6o9cMfSfScX.jpg"},"description":"Kaya-chan attends Hanamugi Kindergarten, and she has an incredibly strong sixth sense. She secretly beats up the ghosts that stalk her friends and family, but in turn, she’s treated like a troublemaker since nobody understands her strange behavior. Everything changes when her teacher, Chie, discovers her secret. Kaya-chan's fists will go flying at any sinister spirits that show up!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Comedy","Horror","Slice of Life"],"id":183660,"idMal":60223,"isAdult":false,"meanScore":70,"nextAiringEpisode":{"airingAt":1774168200,"episode":11,"timeUntilAiring":563990},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/183660","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["カヤコワ","KayaKowa","คายะจังไม่กลัวหรอกนะ"],"title":{"english":"Kaya-chan Isn't Scary","native":"カヤちゃんはコワくない","romaji":"Kaya-chan wa Kowakunai","userPreferred":"Kaya-chan wa Kowakunai"},"trailer":{"id":"un9g38-wbHw","site":"youtube","thumbnail":"https://i.ytimg.com/vi/un9g38-wbHw/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/195518-IpfwJgnWa6nD.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5d86e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx195518-XXcYHi6tXM6v.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx195518-XXcYHi6tXM6v.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx195518-XXcYHi6tXM6v.jpg"},"description":"Tiararose Lapis Clamentile is set to marry Hartknights, crown prince of Lapis Lazuli—until she suddenly remembers her past life and realizes she’s been reincarnated into her favorite game, The Ring of Lapis Lazuli, as the doomed villainess! But just as she’s about to lose hope, the crown prince of Aquasteed proposes instead. Could this unexpected turn finally lead to a happy ending of her own?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":29,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Fantasy","Romance"],"id":195518,"idMal":62000,"isAdult":false,"meanScore":58,"nextAiringEpisode":{"airingAt":1774188000,"episode":11,"timeUntilAiring":583790},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/195518","startDate":{"day":11,"month":1,"year":2026},"status":"RELEASING","synonyms":["The Villainess Is Being Doted on by the Crown Prince of the Neighboring Country","ท่านหญิงนางร้ายถูกเจ้าชายรัชทายาท ของอาณาจักรข้างเคียงหลงรัก"],"title":{"english":"The Villainess Is Adored by the Prince of the Neighbor Kingdom","native":"悪役令嬢は隣国の王太子に溺愛される","romaji":"Akuyaku Reijou wa Ringoku no Outaishi ni Dekiai Sareru","userPreferred":"Akuyaku Reijou wa Ringoku no Outaishi ni Dekiai Sareru"},"trailer":{"id":"3wNyyhzLqA0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/3wNyyhzLqA0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185262-6EExIkvGk1dI.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbe450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185262-95wbx3Y9hCwm.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185262-95wbx3Y9hCwm.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185262-95wbx3Y9hCwm.jpg"},"description":"Thirty-five-year-old Kenichi Yamada has spent his life playing every single MMORPG he can get his hands on. Tired of new games that cater to casual players, he leaps at the chance to try out a never-ending game with an intimidating “Hell Mode” that raises the difficulty (and chances to level up) to impossible heights. But, as soon as he selects the “Summoner,” Kenichi finds himself transported into the world of the game and reborn to a family of serfs as a baby named Allen! With nothing but his memories and wits to guide him, Allen sets off to conquer Hell Mode, unearth the secrets of the Summoner class, and free his newfound family from their fate.\u003cbr\u003e\n\u003cbr\u003e\n(Source: HIDIVE)","duration":23,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"TV","genres":["Action","Adventure","Fantasy"],"id":185262,"idMal":60460,"isAdult":false,"meanScore":67,"nextAiringEpisode":{"airingAt":1774024500,"episode":11,"timeUntilAiring":420290},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/185262","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["HELL MODE อยากเล่นโหด ขอโหมดนรก"],"title":{"english":"HELL MODE: The Hardcore Gamer Dominates in Another World with Garbage Balancing","native":"ヘルモード ～やり込み好きのゲーマーは廃設定の異世界で無双する～","romaji":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru","userPreferred":"Hell Mode: Yarikomi Suki no Gamer wa Haisettei no Isekai de Musou Suru"},"trailer":{"id":"CjO1Bo297N4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/CjO1Bo297N4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/162669-SvOE44IccAT0.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162669-FLYUTftoXgMh.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx162669-FLYUTftoXgMh.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx162669-FLYUTftoXgMh.jpg"},"description":"\u003cb\u003eThe story of Fushi the immortal enters the modern era.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\nFollowing the battles in Renril, Fushi, like a tree, spreads his roots throughout the world, fighting to eliminate the Nokkers. Hundreds of years later, having completed his mission, he awakens in the modern era. He enjoys a life of peace, free of enemy threats and surrounded by precious friends, new and old. But ominous shadows grow near yet again. Enemies that enter into the fissures of the mind. And Fushi learns of the true goals of his creator, the Beholder.\n\u003cbr\u003e\u003cbr\u003e\nFaced with new trials, the time approaches for Fushi to make the ultimate decision.\n\u003cbr\u003e\u003cbr\u003e\n(Source: NHK PR, edited)","duration":25,"endDate":{"day":null,"month":null,"year":null},"episodes":22,"format":"TV","genres":["Adventure","Drama","Fantasy","Psychological","Supernatural"],"id":162669,"idMal":54703,"isAdult":false,"meanScore":76,"nextAiringEpisode":{"airingAt":1774104300,"episode":20,"timeUntilAiring":500090},"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/162669","startDate":{"day":4,"month":10,"year":2025},"status":"RELEASING","synonyms":[],"title":{"english":"To Your Eternity Season 3","native":"不滅のあなたへ Season 3","romaji":"Fumetsu no Anata e Season 3","userPreferred":"Fumetsu no Anata e Season 3"},"trailer":{"id":"JmT51BjIJ5w","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JmT51BjIJ5w/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187264-aOUNQvTriPkX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187264-aOUNQvTriPkX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187264-aOUNQvTriPkX.jpg"},"description":"Betrayed by his childhood friend and cast out of the Hero Party, Orhun Dura—once their loyal Enchanter—is branded by his former comrades as “a jack-of-all-trades but a master of none.” Alone, he sets out to forge a new path as a solo adventurer. His journey sparks explosive battles, deadly rivals, and unexpected allies—and he’ll rise to shatter every expectation. The ultimate solo comeback begins!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":187264,"idMal":61128,"isAdult":false,"meanScore":66,"nextAiringEpisode":{"airingAt":1773846000,"episode":12,"timeUntilAiring":241790},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/187264","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Yuusha Party wo Oidasareta Kiyou Binbou: Party Jijou de Fuyo Jutsushi wo Yatteita Kenshi, Bannou e to Itaru","勇者パーティを追い出された器用貧乏　～パーティ事情で付与術士をやっていた剣士、万能へと至る～","เก่งรอบด้านแต่ไร้ทีเด็ด เลยถูกเฉดหัวจากปาร์ตี้ผู้กล้า","용사 파티에서 쫓겨난 다재무능"],"title":{"english":"Jack-of-All-Trades, Party of None","native":"勇者パーティを追い出された器用貧乏","romaji":"Yuusha Party wo Oidasareta Kiyou Binbou","userPreferred":"Yuusha Party wo Oidasareta Kiyou Binbou"},"trailer":{"id":"dLDimMasKBM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dLDimMasKBM/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/189275-WreT2tChg3a0.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50a1e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx189275-eHsK0lNnFfXH.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx189275-eHsK0lNnFfXH.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx189275-eHsK0lNnFfXH.jpg"},"description":"The second season of \u003ci\u003eMedalist.\u003c/i\u003e","duration":23,"endDate":{"day":22,"month":3,"year":2026},"episodes":9,"format":"TV","genres":["Drama","Psychological","Sports"],"id":189275,"idMal":61335,"isAdult":false,"meanScore":83,"nextAiringEpisode":{"airingAt":1774110600,"episode":9,"timeUntilAiring":506390},"season":"WINTER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/189275","startDate":{"day":25,"month":1,"year":2026},"status":"RELEASING","synonyms":[],"title":{"english":"Medalist Season 2","native":"メダリスト 第2期","romaji":"Medalist 2nd Season","userPreferred":"Medalist 2nd Season"},"trailer":{"id":"GTaqXo7scOY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/GTaqXo7scOY/hqdefault.jpg"},"type":"ANIME"}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":250,"perPage":20,"total":5000}}},"updated_at":"2026-03-15T22:50:11.703508+03:00"},"{\"query\":\"query ListManga ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $startDate_greater: FuzzyDateInt, $startDate_lesser: FuzzyDateInt, $format: MediaFormat, $countryOfOrigin: CountryCode, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: MANGA, isAdult: $isAdult, countryOfOrigin: $countryOfOrigin, search: $search, sort: $sort, status_in: $status, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, startDate_greater: $startDate_greater, startDate_lesser: $startDate_lesser, format_not: NOVEL) {\\n\\t\\t\\t... baseManga\\n\\t\\t}\\n\\t}\\n}\\nfragment baseManga on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tbannerImage\\n\\tchapters\\n\\tvolumes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":true,\"page\":3,\"perPage\":48,\"sort\":[\"SCORE_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/144209-8dlyQgNTRDaO.jpg","chapters":117,"countryOfOrigin":"KR","coverImage":{"color":"#78281a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b144209-7vUfBtagL4xs.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b144209-7vUfBtagL4xs.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b144209-7vUfBtagL4xs.png"},"description":"Kim Eui-Hyun is an omega at his limit. After living a life of troubles and owing an unpayable debt that isn’t even his, he’s ready to give up. Hoping to spare himself and his little brother a life of more pain, he opts to walk into the cold depths of the sea. With his escape in reach, it seems like everything will be over soon—until someone catches him. Yeo Tae-Ju, a sadistic alpha who seems to take pleasure in other’s pain, gives Eui-Hyun the choice to pay off his debt with his body but when the omega refuses, Tae-Ju proves he has no other choice.\n\u003cbr\u003e\u003cbr\u003e\nStill desperate for escape, Eui-Hyun tries to plan his next attempt while doing restaurant work. But with a sorry paycheck that barely covers his interests and his little brother to care for, will Eui-Hyun have to sell his body after all just to survive? And, is it even worth surviving if this is what his life is meant to be?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment, edited)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes 17 extra chapters.\u003c/i\u003e","endDate":{"day":8,"month":1,"year":2026},"format":"MANGA","genres":["Drama","Fantasy","Psychological","Romance"],"id":144209,"idMal":166205,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/144209","startDate":{"day":1,"month":12,"year":2021},"status":"FINISHED","synonyms":["Night by the Sea ","水邊之夜","水辺の夜","ทะเลรัตติกาล","Die Nacht am Ufer","La Noche Que Llega a la Ribera","Nuit au bord de l'eau"],"title":{"english":"Low Tide in Twilight","native":"물가의 밤","romaji":"Mulgaui Bam","userPreferred":"Mulgaui Bam"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":12,"countryOfOrigin":"JP","coverImage":{"color":"#e4e435","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx136901-5VGazeZt6kTP.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx136901-5VGazeZt6kTP.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx136901-5VGazeZt6kTP.png"},"description":"Outgoing, fierce Rui Hanamine and gentle, soft-hearted Yuujirou Matsukaze have been close friends since they were children. Though they were supposed to be nothing more than best friends, eventually they confessed their smoldering attraction to one another and began dating. Now their days are filled with sweetness, leaving them wondering, \"Am I really allowed to feel this happy?\" \n\u003cbr\u003e\u003cbr\u003e\nNow with the end of their time at high school and summer vacation fast approaching, what does the future hold for the love-struck couple? Sometimes sweetness comes with a little bitterness...\n\u003cbr\u003e\u003cbr\u003e\n(Source: TOKYOPOP)","endDate":{"day":2,"month":4,"year":2021},"format":"MANGA","genres":["Drama","Romance","Slice of Life"],"id":136901,"idMal":141844,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/136901","startDate":{"day":3,"month":4,"year":2020},"status":"FINISHED","synonyms":["Dekoboko Sugar Nights"],"title":{"english":"Dekoboko Bittersweet Days","native":"凸凹シュガーデイズ（もう一回！）","romaji":"Dekoboko Sugar Days (Mou Ikkai!)","userPreferred":"Dekoboko Sugar Days (Mou Ikkai!)"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":5,"countryOfOrigin":"JP","coverImage":{"color":"#f1e450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx135116-FyfFt8eiDPFH.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx135116-FyfFt8eiDPFH.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx135116-FyfFt8eiDPFH.jpg"},"description":"Deto and delinquent Zono are merely opponents. But then Deto discovered Zono's weakness. If his neck is touched, Zono will let out erotic sounds. Hearing Zono's erotic moans, Deto's lower-body reacted and left him confused. One day, Deto ran into Zono, who was beaten into a pulp by his father, despite being very strong in fighting. Deto rushed in to rescue Zono. And why was Zono wearing fancy, cute-looking clothes?","endDate":{"day":30,"month":9,"year":2020},"format":"MANGA","genres":["Comedy","Romance"],"id":135116,"idMal":142720,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/135116","startDate":{"day":30,"month":3,"year":2020},"status":"FINISHED","synonyms":["Indomitable Zono"],"title":{"english":null,"native":"不屈のゾノ","romaji":"Fukutsu no Zono","userPreferred":"Fukutsu no Zono"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4436b","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx113923-kx1o0OwS9cvr.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx113923-kx1o0OwS9cvr.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx113923-kx1o0OwS9cvr.png"},"description":"A lone wolf with a delinquent streak, Kashima enters high school with a reputation that scares off his classmates. Little do his classmates know, Kashima is not a typical delinquent: he is a masochist that enjoys being hit by guys. Ryouji Sanada, despite Kashima's reputation, goes out of his way to talk to Kashima on the first day of high school. Confused by Ryouji, Kashima rebuffs his handsome classmate. But, when Ryouji intervenes in one of Kashima's fight (and attempt to get off), Kashima realizes that Ryouji might just have a secret \"perversion\" too...\n\u003cbr\u003e\u003cbr\u003e\n(Source: Futekiya)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Romance"],"id":113923,"idMal":122074,"isAdult":true,"meanScore":82,"season":null,"siteUrl":"https://anilist.co/manga/113923","startDate":{"day":25,"month":3,"year":2016},"status":"RELEASING","synonyms":["Kan'i Teki Pervert Romance","간이적 파버트 로맨스"],"title":{"english":"Simplified Pervert Romance","native":"簡易的パーバートロマンス","romaji":"Kaniteki Pervert Romance","userPreferred":"Kaniteki Pervert Romance"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":70,"countryOfOrigin":"KR","coverImage":{"color":"#e4ae5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx110097-bZMt3roImVzP.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx110097-bZMt3roImVzP.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx110097-bZMt3roImVzP.jpg"},"description":"With the screech of rubber and a crunch of metal, Dojin departs the mortal world, leaving behind his beloved sister and niece. He awakens in the kingdom of Yooguk, where the people call him “emperor” and serve a god named Yellow Dragon. Dojin soon discovers that Yellow Dragon called him to Yooguk for a purpose: to share his “life force” and protect the kingdom. As Dojin slips deeper into Yellow Dragon’s cold embrace, how far will he go in order to get back home?\u003cbr\u003e\u003cbr\u003e(Source: Lezhin)","endDate":{"day":9,"month":4,"year":2020},"format":"MANGA","genres":["Action","Drama","Fantasy","Hentai","Romance"],"id":110097,"idMal":127167,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/110097","startDate":{"day":21,"month":12,"year":2018},"status":"FINISHED","synonyms":["Hwanglyongjeon","Hwangnyongjeon"],"title":{"english":"Tale of the Yellow Dragon","native":"황룡전","romaji":"Hwang Ryongjeon","userPreferred":"Hwang Ryongjeon"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#f1e4c9","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx174154-e3nKE4eowkmW.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx174154-e3nKE4eowkmW.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx174154-e3nKE4eowkmW.png"},"description":"Death delayed due to scheduling difficulties.\u003cbr\u003e\nChaeyoon, once a famous hero, now lives as an unknown hunter, fulfilling the odd dying wishes of ex-colleagues before he can end his own life. Haunted by the past and drawn to Jihan, a skilled hunter he meets, Chaeyoon questions whether fulfilling last wishes and finding his own solace is possible.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Manta)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Action","Drama","Romance","Supernatural"],"id":174154,"idMal":184862,"isAdult":true,"meanScore":81,"season":null,"siteUrl":"https://anilist.co/manga/174154","startDate":{"day":28,"month":12,"year":2022},"status":"RELEASING","synonyms":["เลื่อนวันตายเพื่อคำขอสุดท้าย","因為遺言暫時延後死去這件事"],"title":{"english":"Mission: Save the Hunter","native":"유언 때문에 죽는 건 잠깐 미뤘습니다","romaji":"Yueon Ttaemun-e Jugneun Geon Jamkkan Milwossseubnida","userPreferred":"Yueon Ttaemun-e Jugneun Geon Jamkkan Milwossseubnida"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/162478-ZuYODNvMTc12.jpg","chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#d61a28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx162478-1yi1hRTfNFad.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx162478-1yi1hRTfNFad.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx162478-1yi1hRTfNFad.jpg"},"description":"Baek Dohu’s a university student who writes BL novels on the side. And his preferred type of top character? The scumbag kind, who treats their partners like crap. And Dohu’s first impression of Seo Juheon is the complete opposite: the typical nice-guy—always smiling, always catering to the needs of those around him. But things take a turn when he accidentally comes across Juheon blackmailing someone in an alley. The real Juheon is a polar opposite from the facade he puts up; he swears, he has a temper, he’s manipulative…and Dohu loves it. Juheon could be THE inspiration for his next big novel that hit a dead end long ago. Excited, Dohu starts following Juheon around “observing” his character, which is bound to give Juheon some wrong ideas… Between the lines of artist and muse, business and pleasure, who’ll be the first to cross the line over to the other side?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Comedy","Romance"],"id":162478,"idMal":185009,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/162478","startDate":{"day":1,"month":3,"year":2023},"status":"RELEASING","synonyms":["공사구","Don't Mix Business With Pleasure!","Léeme entre líneas","Draw a line between public and private lives","公私請分明！"],"title":{"english":"Between the Lines","native":"공과 사는 구분해!","romaji":"Gonggwa Saneun Gubunhae!","userPreferred":"Gonggwa Saneun Gubunhae!"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/140155-5af8jDa8yysF.jpg","chapters":9,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx140155-I1SxaeDxZ9fC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx140155-I1SxaeDxZ9fC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx140155-I1SxaeDxZ9fC.jpg"},"description":"Tensei is a college student who's a hobbyist photographer. One day while taking photos, he encounters and becomes captivated by a boy with burn scars on his face, Makito. Worn down by people staring at his scars from an accident, Makito escaped the flashy modelling industry and instead found work at a small-town library. Tensei, who knows nothing about this past, comes to talk to Makito whenever he borrows and returns books. He begins to fall in love with Makito's delicate and beautiful profile, and before he knows it, he's pointing his camera at him. He's hopelessly attracted to the way Makito looks in his photos. But as he realizes his overwhelming feelings, a guy from Makito's modelling past shows up to take him back...?\n\u003cbr\u003e\u003cbr\u003e\nCollege kid with a photography hobby and a hidden possessive streak × ex-model with large burn scars on his face.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e\"Even your scars are beautiful. I just want to mess you up...\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\nThe story of a love affair, played out under a sky full of stars.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Takeshobo, translated)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes two extra chapters.\u003c/i\u003e","endDate":{"day":24,"month":7,"year":2022},"format":"MANGA","genres":["Romance","Slice of Life"],"id":140155,"idMal":150368,"isAdult":true,"meanScore":80,"season":null,"siteUrl":"https://anilist.co/manga/140155","startDate":{"day":24,"month":6,"year":2021},"status":"FINISHED","synonyms":["Nagigare Hoshi","Nagare Hoshi","Falling Star","Spadająca gwiazda"],"title":{"english":null,"native":"凪がれ星","romaji":"Nagareboshi","userPreferred":"Nagareboshi"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/128493-MxxoevtXCW2q.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f15d86","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx128493-q32s5t866DW3.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx128493-q32s5t866DW3.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx128493-q32s5t866DW3.jpg"},"description":"Devoted office worker Sakura Yuino has been transferred to work under a new supervisor: the handsome, gentlemanly Tatsuki Kiritani. From the outside, the two of them seem very put-together — but they're both hiding troublesome personal issues. Sakura has a scent fetish, and Tatsuki can't be around women without… getting aroused.\n\u003cBR\u003e\u003cBR\u003e\nTo help him out, dedicated subordinate Sakura proposes \"special training\" to help Tatsuki get over his issues with women (bonus: she can indulge her scent kink). What could possibly go wrong? \n\u003cbr\u003e\u003cbr\u003e\n(Source: Anime News Network)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Romance"],"id":128493,"idMal":134324,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/128493","startDate":{"day":1,"month":5,"year":2020},"status":"RELEASING","synonyms":["We Can't Do Just Plain Love: She's Got a Fetish, He's Got Low Self-Esteem"],"title":{"english":"We Can't Do Just Plain Love -She's Got a Fetish, Her Boss Has Low Self-Esteem-","native":"ただの恋愛なんかできっこない －こじらせ上司とフェチな部下－","romaji":"Tada no Renai Nanka de Kikkonai: Kojirase Joushi to Fechi na Buka","userPreferred":"Tada no Renai Nanka de Kikkonai: Kojirase Joushi to Fechi na Buka"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/121476-DmEWCCF7B851.jpg","chapters":73,"countryOfOrigin":"KR","coverImage":{"color":"#e45d5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx121476-PjGqJJSTYzSw.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx121476-PjGqJJSTYzSw.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx121476-PjGqJJSTYzSw.jpg"},"description":"The most important exam of his life… and Jeong-Seok blew it. Dumped by his girlfriend and rejected by his college of choice, the future looks bleak. But instead of moping, Jeong-Seok checks himself into a boarding cram school for a year. Sealed off from the outside world with nothing but a bunch of stressed-out, horny students for company, things start getting steamy in no time. How distracting! Perhaps some one-on-one lessons with the gorgeous, busty Ms. Kang will help him focus? Study hard, Jeong-Seok. Nice and hard…\u003cbr\u003e\u003cbr\u003e(Source: Lezhin US, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes two extra chapters.\u003c/i\u003e","endDate":{"day":23,"month":10,"year":2020},"format":"MANGA","genres":["Comedy","Hentai","Romance"],"id":121476,"idMal":147641,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/121476","startDate":{"day":15,"month":2,"year":2019},"status":"FINISHED","synonyms":["浪人ヘブン〜滑る門には福来る〜"],"title":{"english":"Lucky Guy","native":"재수 좋은 남자","romaji":"Jaesu Joeun Namja","userPreferred":"Jaesu Joeun Namja"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":15,"countryOfOrigin":"JP","coverImage":{"color":"#e4a15d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx58343-uoujDb7rWXKz.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx58343-uoujDb7rWXKz.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx58343-uoujDb7rWXKz.jpg"},"description":"Shuji, a divorced single dad running a modest corner shop, has an easygoing attitude and an eye out for anything to break the boredom of his days. So when Saji, the serious, reserved pediatrician who’s been coming into his store, suddenly declares that he’s gay and wants to take Shuji home, Shuji goes along with it out of simple curiosity. He thought they’d just mess around, have some fun, and that would be that. But he gets a lot more than he bargained for in this story of opposites in love!\n\u003cbr\u003e\u003cbr\u003e\n(Source: SuBLime)","endDate":{"day":30,"month":1,"year":2014},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":58343,"idMal":28343,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/58343","startDate":{"day":30,"month":5,"year":2011},"status":"FINISHED","synonyms":[],"title":{"english":"Hide and Seek","native":"秘めごとあそび","romaji":"Himegoto Asobi","userPreferred":"Himegoto Asobi"},"type":"MANGA","volumes":3},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/172094-JTJMpmSr3Prv.jpg","chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#e4ae93","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx172094-RQPqPHvdqXNb.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx172094-RQPqPHvdqXNb.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx172094-RQPqPHvdqXNb.jpg"},"description":"One day, a mysterious name card lands on Hun-Sang's hand. The name card presents him a new life in a new city, the haven of adultery, along with a significant sum of money in return for his physique.\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e“You are a ‘gift’ to the VIPs. Make them unable to forget you, even if they try.”\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e(Source: DAYcomics)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Hentai"],"id":172094,"idMal":null,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/172094","startDate":{"day":22,"month":12,"year":2023},"status":"RELEASING","synonyms":["モビーディック ～VIPに捧ぐ大きな〇〇～","慾海交鋒"],"title":{"english":"Moby Dick","native":"모비딕","romaji":"Moby Dick","userPreferred":"Moby Dick"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":50,"countryOfOrigin":"KR","coverImage":{"color":"#ffc993","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx163534-TKKNwLef7XLI.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx163534-TKKNwLef7XLI.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx163534-TKKNwLef7XLI.jpg"},"description":"Some people win the lottery or find their dream job, but Sohan…has an alien spaceship land on his brand-new house?! To make matters even worse, there’s an – admittedly sexy – alien inside threatening to wipe out the entire population. Sihwa has come to earth in search of someone specific and has no qualms about using Sohan to get what he wants. The thing is, things work differently on Sihwa’s home planet, and he seems to be expecting things from Sohan that sound downright impossible! Nevertheless, Sohan finds himself making a deal: help Sihwa find the person he’s looking for in exchange for the safety of humanity. But will this strange partnership turn into something...out of this world?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US)","endDate":{"day":2,"month":8,"year":2024},"format":"MANGA","genres":["Drama","Romance"],"id":163534,"idMal":185229,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/163534","startDate":{"day":5,"month":4,"year":2023},"status":"FINISHED","synonyms":["無重力ロマンス〜妊娠してみるか？地球人〜","Romance en gravedad cero","失重羅曼史","รักไร้แรงโน้มถ่วง","Schwerelose Liebe","L'amour en apesanteur"],"title":{"english":"Love in Orbit","native":"무중력 로맨스","romaji":"Mujungnyeong Romance","userPreferred":"Mujungnyeong Romance"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/159532-Xheql37Au5BK.jpg","chapters":121,"countryOfOrigin":"KR","coverImage":{"color":"#78351a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b159532-ycr7RCM0fpWN.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b159532-ycr7RCM0fpWN.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b159532-ycr7RCM0fpWN.jpg"},"description":"A professional gamer, in the past, has one thing he's best at... carrying people. Will his skills help him obtain... something more?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Toomics)","endDate":{"day":10,"month":3,"year":2025},"format":"MANGA","genres":["Drama","Hentai","Romance"],"id":159532,"idMal":null,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/159532","startDate":{"day":26,"month":12,"year":2022},"status":"FINISHED","synonyms":["That’s Not How You Do It"],"title":{"english":"The Carry","native":"그거 그렇게 하는거 아닌데","romaji":"Geugeo Geureohge Haneungeo Aninde","userPreferred":"Geugeo Geureohge Haneungeo Aninde"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":94,"countryOfOrigin":"KR","coverImage":{"color":"#e45d93","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx145350-W37Rn4P5hPRs.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx145350-W37Rn4P5hPRs.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx145350-W37Rn4P5hPRs.png"},"description":"Seon-woo is a pretty unassuming office worker, but he’s got a hardcore fetish: he wants some BDSM love from another man who’s willing to dominate. Enter his new co-worker, Tae-moon. Tae-moon is really hot, and based on a little snooping, he might be into men–and he’s showing signs of being a dom, to boot! Trying to start a sexy relationship at work can be rough, but Seon-woo likes it rough, so game on.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes 11 extra chapters.\u003c/i\u003e","endDate":{"day":20,"month":10,"year":2025},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":145350,"idMal":153985,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/145350","startDate":{"day":1,"month":2,"year":2022},"status":"FINISHED","synonyms":[],"title":{"english":"Punch Drunk Love","native":"펀치 드렁크 러브","romaji":"Punch Drunk Love","userPreferred":"Punch Drunk Love"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":7,"countryOfOrigin":"JP","coverImage":{"color":"#e45d86","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx141025-HpR8fxS1dB9e.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx141025-HpR8fxS1dB9e.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx141025-HpR8fxS1dB9e.jpg"},"description":"It's been a year since Ryuji Honjo graduated high school and started university. And so far, despite being recently dumped, he is having a grand old time. But what would his middle school self think about him now?... Meanwhile, Leo Ichinose, Ryuji's classmate in university, is as cool and reserved as ever. His unintentional glares scare people off. But something about him catches Ryuji's attention. Or... is it Ryuji who's caught Ichinose's attention? Ryuji swears he can feel his stares on him. Will the outgoing and charming Ryuji get along with the distant and unapproachable Ichinose? The two seem like polar opposites at first, but maybe they're not so different after all.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Futekiya)","endDate":{"day":25,"month":5,"year":2020},"format":"MANGA","genres":["Drama","Romance","Slice of Life"],"id":141025,"idMal":135203,"isAdult":true,"meanScore":84,"season":null,"siteUrl":"https://anilist.co/manga/141025","startDate":{"day":24,"month":5,"year":2019},"status":"FINISHED","synonyms":[],"title":{"english":"Paint Love and the Colors Will Bloom","native":"恋を描けば色が咲く","romaji":"Koi wo Egakeba Iro ga Saku","userPreferred":"Koi wo Egakeba Iro ga Saku"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/129020-OIbJSAM4F6Sd.jpg","chapters":35,"countryOfOrigin":"KR","coverImage":{"color":"#e43528","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx129020-ZNsd93jHxjPG.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx129020-ZNsd93jHxjPG.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx129020-ZNsd93jHxjPG.jpg"},"description":"First impressions are everything, right? But it doesn’t seem that way when Yi-Kyung comes across Joo-Bin. When they first meet, Joo-Bin is just a handsome stranger with an exciting air of mystery. Yi-Kyung itches to draw him, to sketch out his beauty on paper like the artist he is… But at their next encounter, Joo-Bin is a completely different person. Sensitive, outspoken, and passionate about his own work as a photographer, he proposes that Yi-Kyung become his model. And drawn to this other side of his, Yi-Kyung says yes. Between lens and paper, who’ll be the first to sketch out the other to perfection? \n\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US, edited)\n","endDate":{"day":6,"month":8,"year":2021},"format":"MANGA","genres":["Drama","Romance","Slice of Life"],"id":129020,"idMal":168994,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/129020","startDate":{"day":9,"month":1,"year":2021},"status":"FINISHED","synonyms":["Bosquejo","彼らのスケッチ","Sketch – Jedes Bild von dir"],"title":{"english":"Sketch","native":"스케치 시즌1","romaji":"Sketch Season 1","userPreferred":"Sketch Season 1"},"type":"MANGA","volumes":2},{"bannerImage":null,"chapters":51,"countryOfOrigin":"KR","coverImage":{"color":"#86e4d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b181287-86o2z2r26Hyt.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b181287-86o2z2r26Hyt.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b181287-86o2z2r26Hyt.png"},"description":"How far would you be willing to go to save the ones you love? With his grandfather bordering life and death, Taesun takes on multiple jobs in order to pay a seemingly endless stack of hospital bills. On one of his odd jobs, he ascends the great mountain Geumryang, unknowingly the home of an eponymous serpentine spirit. When Taesun encounters the divine being, he too is on the brink of death, desperate for water in his slithering form. Taesun offers him a sip of water, and saves the sacred snake from certain death. Later that night, a cold-blooded body embraces Taesun and offers him an exchange: bear the ancient being’s seed, and his grandfather will live. But is all really as it seems? After all, can one ever truly trust the forked tongue of a serpent…? \u003cbr\u003e\u003cbr\u003e(Source: Lezhin US)","endDate":{"day":21,"month":9,"year":2025},"format":"MANGA","genres":["Drama","Romance","Supernatural"],"id":181287,"idMal":185254,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/181287","startDate":{"day":7,"month":8,"year":2024},"status":"FINISHED","synonyms":["Das Schlingen der Schlange","La seducción de la serpiente sagrada","Pacte avec le serpent sacré","擁神之法","神の授かり方"],"title":{"english":"The Sacred Serpent's Seduction","native":"신을 품는 방법","romaji":"Sineul Pumneun Bangbeop","userPreferred":"Sineul Pumneun Bangbeop"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/176025-wSOpzlPeeH9R.jpg","chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#5dd6e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx176025-R1dz2gtesNAv.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx176025-R1dz2gtesNAv.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx176025-R1dz2gtesNAv.png"},"description":"Ha-Neul and Mincheol have been childhood friends for all of their lives, but their relationship takes on a whole new dynamic when they undergo a series of unexpected events. Although they vowed that they'd never be romantically attracted to each other, they just might be proven wrong... especially when things start to escalate and neither can predict where they'll end up.\u003cbr\u003e\u003cbr\u003e(Source: WEBTOON)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Comedy","Romance"],"id":176025,"idMal":168312,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/176025","startDate":{"day":13,"month":3,"year":2024},"status":"RELEASING","synonyms":["Just Friends","青梅竹馬情結","เพื่อนกันมันส์เกิน"],"title":{"english":"Childhood Friend Complex","native":"소꿉친구 컴플렉스","romaji":"Sokkupchingu Complex","userPreferred":"Sokkupchingu Complex"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":46,"countryOfOrigin":"KR","coverImage":{"color":"#d61a28","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx120918-klNcV38kbND8.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx120918-klNcV38kbND8.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx120918-klNcV38kbND8.jpg"},"description":"Seunghyun spent his 20s following his crush through college and grad school, only to wind up totally single and with no idea where to go in his career. When he manages to land an internship at a competitive marketing company, he’s ready for a fresh start without worrying over unrequited love. Except he’s put under the handsome workaholic Kim Jongchan, whose hot and cold attitude leaves Seunghyun flustered. And worse yet, his crush from school works in the same company too! Will Seunghyun survive his first job and a potential first relationship?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment) \u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes six extra chapters. \u003c/i\u003e","endDate":{"day":21,"month":8,"year":2021},"format":"MANGA","genres":["Romance","Slice of Life"],"id":120918,"idMal":146794,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/120918","startDate":{"day":31,"month":3,"year":2020},"status":"FINISHED","synonyms":["The New Employee","Le petit nouveau","Der Neuzugang","新進職員","新入社員"],"title":{"english":"The New Recruit","native":"신입사원","romaji":"Sinipsawon","userPreferred":"Sinipsawon"},"type":"MANGA","volumes":3},{"bannerImage":null,"chapters":10,"countryOfOrigin":"JP","coverImage":{"color":"#f14335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx116295-6G0PDRJq6J3I.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx116295-6G0PDRJq6J3I.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx116295-6G0PDRJq6J3I.jpg"},"description":"Due to low budget, the school library has no heating installed. Despite that, however, a trio of classmates have to perform their library duties, regardless of how cold that makes the two girls, Tsukami and Iidabashi. Everything appears to get solved, though, when the two discover that Mayumura has a high body temperature. That is, until Mayumura gets a boner, and, embarassed, confesses that he likes them both, after which one thing leads to another, and any complaints about temperature are slowly forgotten.\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Published in COMIC AUN 2019-04～2020-10.\u003c/i\u003e\n","endDate":{"day":28,"month":8,"year":2020},"format":"MANGA","genres":["Hentai"],"id":116295,"idMal":124921,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/116295","startDate":{"day":28,"month":2,"year":2019},"status":"FINISHED","synonyms":["プリース！フリーズ！プリース！"],"title":{"english":"Please! Freeze! Please!","native":"Please!Freeze!Please!","romaji":"Please! Freeze! Please!","userPreferred":"Please! Freeze! Please!"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/181859-yTZw25WYDDY9.jpg","chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#ffc9ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx181859-bhaSEsqYTVZB.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx181859-bhaSEsqYTVZB.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx181859-bhaSEsqYTVZB.jpg"},"description":"To regain his peace, Gangchan must welcome his blood-curdling, smoking neighbor and her housemates into his home.\u003cbr\u003e\u003cbr\u003e(Source: Toomics)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Hentai","Romance"],"id":181859,"idMal":null,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/181859","startDate":{"day":19,"month":9,"year":2024},"status":"RELEASING","synonyms":["¡Que alguien la detenga, por favor!","Arrêtez-la !","Haltet sie auf!","Fermatela!","Haltet sie auf!","お隣さんと俺の××攻防戦","缺德邻居难相处","缺德鄰居麥相害","ใครก็ได้ห้ามเธอหน่อย!"],"title":{"english":"Someone Stop Her!","native":"담배피지 마세요!","romaji":"Dambaepiji Maseyo!","userPreferred":"Dambaepiji Maseyo!"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":"#e4865d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx138890-V1KPyS0of51G.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx138890-V1KPyS0of51G.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx138890-V1KPyS0of51G.jpg"},"description":"What happens when roomates-turned-lovers turn into viral sensations? And what if your happily-ever-after has an expiration date…?\n\u003cBR\u003e\u003cBR\u003e\nIt’s been three months since roommates Mao and Hisashi took their relationship to the next level, and Mao couldn’t be more in love…or more nervous that he’s not doing enough to keep his experienced partner satisfied. Just when it seems like he may have figured things out, the film club’s movie goes viral, and suddenly everyone wants a piece of its breakaway star: Hisashi. With graduation right around the corner, Mao must find a way to keep them together or risk leaving their future to the uncertain tides of fate.\n\u003cbr\u003e\u003cBR\u003e\n(Source: Kodansha USA)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes 4 extra chapters\u003c/i\u003e","endDate":{"day":5,"month":8,"year":2020},"format":"MANGA","genres":["Drama","Romance"],"id":138890,"idMal":158769,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/138890","startDate":{"day":5,"month":7,"year":2020},"status":"FINISHED","synonyms":[],"title":{"english":"Twilight Out of Focus: Overlap","native":"黄昏アウトフォーカス overlap","romaji":"Tasogare Outfocus overlap","userPreferred":"Tasogare Outfocus overlap"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/95290-Dbwz6dMkgfBH.jpg","chapters":35,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx95290-67PE95aIldQO.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx95290-67PE95aIldQO.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx95290-67PE95aIldQO.png"},"description":"Lord Montague is a powerful figure in the nation, in need of a bodyguard following a threat to his life. Enter Viscount Adam Canning: a dashing blond-haired nobleman who swears to use his combat skills to protect Lord Montague…and woo anyone who catches his fancy while staying at Lord Montague’s estate. When Adam sees Lord Montague’s nephew, Joel, Adam is immediately smitten. But Joel is a serious young man, too busy rooting out crime and corruption to fall for Adam’s charms. Of course, that just makes Adam want him more! Can Joel stay focused on his lofty ideals, or will he fall for the devilishly handsome viscount?\u003cbr\u003e\u003cbr\u003e(Source: Seven Seas Entertainment)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes five extra chapters.\u003c/i\u003e","endDate":{"day":8,"month":1,"year":2022},"format":"MANGA","genres":["Comedy","Drama","Romance","Slice of Life"],"id":95290,"idMal":90418,"isAdult":true,"meanScore":81,"season":null,"siteUrl":"https://anilist.co/manga/95290","startDate":{"day":7,"month":4,"year":2014},"status":"FINISHED","synonyms":["바베리티스","宮廷祕戀","宫廷秘恋","Варварство"],"title":{"english":"BARBARITIES","native":"バーバリティース","romaji":"BARBARITIES","userPreferred":"BARBARITIES"},"type":"MANGA","volumes":4},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/144630-veGo1gIV5Rxe.jpg","chapters":150,"countryOfOrigin":"KR","coverImage":{"color":"#e49378","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx144630-XmSUm31GzdrQ.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx144630-XmSUm31GzdrQ.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx144630-XmSUm31GzdrQ.png"},"description":"He's been a loner all his life. However, he soon learns the secrets of the most beautiful girls in the engineering course. \n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e\"Please, don't tell anyone about this, I'll even suck you off...!\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: TOPTOON+)","endDate":{"day":19,"month":9,"year":2024},"format":"MANGA","genres":["Drama","Hentai","Romance","Slice of Life"],"id":144630,"idMal":null,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/144630","startDate":{"day":25,"month":11,"year":2021},"status":"FINISHED","synonyms":["Is There No Goddess in My College?","¡¿Hay Diosas en Ingeniería?!","誰說理組沒正妹?","工学ヘヴン"],"title":{"english":"Engineering Beauties","native":"공대엔 여신이 없다?","romaji":"Gongdaeen Yeosini Eopda?","userPreferred":"Gongdaeen Yeosini Eopda?"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/114780-rLbj1cRVFEGv.jpg","chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#f1c9c9","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx114780-5ip5gecQiIoB.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx114780-5ip5gecQiIoB.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx114780-5ip5gecQiIoB.png"},"description":"Inexperienced Yoshino is about to turn thirty. He’s nearly given up on ever falling in love, let alone having decent sex—until one day he steels himself and goes to a gay bar. There he meets Rou, a charming, silver-haired college student who is everything that Yoshino isn’t: mysterious, assertive, and experienced with both men and women. Yoshino finds himself hopelessly attracted to Rou, as their awkward courtship simmers into something more. But is it love?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Seven Seas Entertainment)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003c/i\u003e","endDate":{"day":23,"month":8,"year":2019},"format":"MANGA","genres":["Romance"],"id":114780,"idMal":126503,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/114780","startDate":{"day":25,"month":12,"year":2018},"status":"FINISHED","synonyms":["Non Volevo Innamorarmi","No quería enamorarme"," Nie chciałem się zakochać...","사랑을 할 생각은 없었다."],"title":{"english":"I Didn't Mean to Fall in Love","native":"恋をするつもりはなかった","romaji":"Koi wo Suru Tsumori wa Nakatta","userPreferred":"Koi wo Suru Tsumori wa Nakatta"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/103213-lBzakwKjNazk.jpg","chapters":71,"countryOfOrigin":"KR","coverImage":{"color":"#e46b5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx103213-bz8bl2YBOKPY.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx103213-bz8bl2YBOKPY.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx103213-bz8bl2YBOKPY.jpg"},"description":"Let's just say Jinwoo and Seyoung got off to a rocky start. Not knowing Seyoung would be living in a company dorm with a male employee, her direct superior at that, she barged into his room thinking it was hers. Her timing couldn't have been more inappropriate as Jinwoo was in the middle of his pleasure time. Embarrassed and nowhere to hide, Jinwoo's life was headed towards misery. However, little did he know Seyoung was no ordinary rookie. She had her own dirty little secret...\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US)","endDate":{"day":21,"month":9,"year":2019},"format":"MANGA","genres":["Comedy","Drama","Hentai","Romance","Slice of Life"],"id":103213,"idMal":119735,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/103213","startDate":{"day":11,"month":10,"year":2017},"status":"FINISHED","synonyms":["新卒妄想ちゃんの日常性活！","EL DIARIO DE UNA PERVERTIDA"],"title":{"english":"A Pervert's Daily Life","native":"일상생활 가능하세요?","romaji":"Ilsangsaenghwal Ganeunghaseyo?","userPreferred":"Ilsangsaenghwal Ganeunghaseyo?"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":7,"countryOfOrigin":"JP","coverImage":{"color":"#f1bb5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx87316-Z3AWJ6qAav0I.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx87316-Z3AWJ6qAav0I.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx87316-Z3AWJ6qAav0I.png"},"description":"Keisuke’s incredibly handsome best friend Masayuki has always rubbed him just a little bit the wrong way. Maybe it’s because Masayuki is rich, carefree, and so stunningly handsome that he can, and does, have any girl he wants? But one day, when Keisuke accidentally wears his older sister’s panty hose to gym class, it’s suddenly his hot friend who’s doing the rubbing…on Keisuke’s panty hose-clad legs! Has he unwittingly unleashed a secret fetish that will change their relationship forever?\u003cbr\u003e\u003cbr\u003e(Source: SuBLime)","endDate":{"day":30,"month":7,"year":2016},"format":"MANGA","genres":["Comedy","Romance","Slice of Life"],"id":87316,"idMal":97092,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/87316","startDate":{"day":13,"month":11,"year":2015},"status":"FINISHED","synonyms":["Jackass!: Sawatte li tte Dare ga Itta yo?","Touch my Jackass","Jackass! - Who said it was okay to touch?","Jackass! ¡Se mira, pero no se toca!"],"title":{"english":"Jackass!","native":"ジャッカス!","romaji":"Jackass!","userPreferred":"Jackass!"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":75,"countryOfOrigin":"KR","coverImage":{"color":"#e42835","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx155420-EGZA9oHbaecv.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx155420-EGZA9oHbaecv.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx155420-EGZA9oHbaecv.jpg"},"description":"As the heir to the Yooshin corporation, Yoo Taehyuk is living his best life. However, everything changes when he’s informed that the dragon, the patron deity of the Yoo family, wants to forsake them to be with his mate. When his sister is asked to take the fall for the family and announce herself as the dragon’s mate, Taehyuk steps up instead. He agrees to meet the dragon in the hopes that he can convince him to stay. But will Taehyuk succeed in slithering into the impervious dragon’s good graces or get under his scales?\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US)","endDate":{"day":21,"month":10,"year":2024},"format":"MANGA","genres":["Drama","Romance","Supernatural"],"id":155420,"idMal":169348,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/155420","startDate":{"day":5,"month":10,"year":2022},"status":"FINISHED","synonyms":[" Dawn, Clouds, River","拂曉、雲朵、江水","夜明け、雲、そして河"],"title":{"english":"Dawn of the Dragon","native":"새벽, 구름, 강","romaji":"Saebyeok, Gureum, Gang","userPreferred":"Saebyeok, Gureum, Gang"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":51,"countryOfOrigin":"KR","coverImage":{"color":"#f13543","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx144927-eRPIW95lL76U.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx144927-eRPIW95lL76U.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx144927-eRPIW95lL76U.png"},"description":"Yoon-Woo and Tae-Gyeom have been best friends since childhood, but Yoon-Woo is hiding a secret that could tear them apart–he’s an omega… and he’s in love with Tae-Gyeom.\n\u003cbr\u003e\u003cbr\u003e\nWhen a traumatic event leads Tae-Gyeom to despise all omegas, Yoon-Woo is forced to keep his identity a secret. After struggling for years to avoid Tae-Gyeom, they both end up at the same college, and Yoon-Woo’s carefully guarded secret is in danger of being exposed…\n\u003cbr\u003e\u003cbr\u003e\n(Source: Tapas)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes 10 extra chapters.\u003c/i\u003e","endDate":{"day":17,"month":10,"year":2023},"format":"MANGA","genres":["Drama","Romance"],"id":144927,"idMal":184996,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/144927","startDate":{"day":18,"month":1,"year":2022},"status":"FINISHED","synonyms":[],"title":{"english":"Omega Complex","native":"오메가 콤플렉스","romaji":"Omega Complex","userPreferred":"Omega Complex"},"type":"MANGA","volumes":5},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/135631-Zkxw5TaOlwYv.jpg","chapters":17,"countryOfOrigin":"JP","coverImage":{"color":"#e4c9ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx135631-GGk6G9pV2WF6.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx135631-GGk6G9pV2WF6.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx135631-GGk6G9pV2WF6.jpg"},"description":"Student council president Terano is confident and smart. On the other hand, the good-looking, but scary Kumazaki has been failing classes for the past few years. One day, a friend catches Terano texting someone. Terano remains quiet on the subject... No one would have guessed that the rebellious Kumazaki is actually quite shy, and is completely wrapped around Terano's finger...\n\u003cbr\u003e\u003cbr\u003e\n(Source: KUMA)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n- The original serialization ran for six chapters until 2021-09-24. It was restarted on 2022-09-24.\u003cbr\u003e\n- Contains 5 bonus chapters.\u003c/i\u003e","endDate":{"day":24,"month":1,"year":2025},"format":"MANGA","genres":["Comedy","Romance","Slice of Life"],"id":135631,"idMal":139145,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/135631","startDate":{"day":24,"month":11,"year":2020},"status":"FINISHED","synonyms":["เทราโนะคุงกับคุมาซากิคุง"],"title":{"english":"Terano-kun \u0026 Kumazaki-kun","native":"寺野くんと熊崎くん","romaji":"Terano-kun to Kumazaki-kun","userPreferred":"Terano-kun to Kumazaki-kun"},"type":"MANGA","volumes":2},{"bannerImage":null,"chapters":9,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx98429-NBUgrUH0BIvO.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx98429-NBUgrUH0BIvO.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx98429-NBUgrUH0BIvO.png"},"description":"The story tells of a stubborn young master and his loyal servant. Because of their statuses, their love story is at the mercy of fate. Aoi is the heir to his family, but due to some discord between him and his stepmother, he is forced to leave the house. And there to support him is his childhood butler, Miyauchi. After living his days being doted on and served, Aoi finds his position reversed, where he has to work all day. And what has supported him throughout this lifestyle is his unrequited love of 5 years for Jirou, the heir to the Saionji family, a leading automobile maker.\n","endDate":{"day":23,"month":4,"year":2016},"format":"MANGA","genres":["Drama","Romance"],"id":98429,"idMal":102504,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/98429","startDate":{"day":24,"month":11,"year":2015},"status":"FINISHED","synonyms":[],"title":{"english":"Yes, My Destiny","native":"かしこまりました、デスティニー","romaji":"Kashikomarimashita, Destiny","userPreferred":"Kashikomarimashita, Destiny"},"type":"MANGA","volumes":2},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/97518-2J702dUkYgh8.jpg","chapters":26,"countryOfOrigin":"JP","coverImage":{"color":"#e45043","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx97518-tGwVrHyFVbFj.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx97518-tGwVrHyFVbFj.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx97518-tGwVrHyFVbFj.png"},"description":"Uichi Rogi is in a bind, both literally and figuratively, when he meets Akitora Oyamato, the yakuza head who’s come to collect a debt from Uichi’s lover. Instantly smitten, Uichi schemes dubious and often dangerous ways of getting closer to the man, but his lies come at a heavy price—one he may regret having to pay for Akitora’s affections.\n\u003cbr\u003e\u003cbr\u003e\n(Source: SuBLime)","endDate":{"day":28,"month":5,"year":2021},"format":"MANGA","genres":["Drama","Romance"],"id":97518,"idMal":100267,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/97518","startDate":{"day":30,"month":7,"year":2016},"status":"FINISHED","synonyms":["젤러시"],"title":{"english":"Jealousy","native":"ジェラシー","romaji":"Jealousy","userPreferred":"Jealousy"},"type":"MANGA","volumes":5},{"bannerImage":null,"chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#e4a15d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx173936-7ypok1cN7jg1.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx173936-7ypok1cN7jg1.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx173936-7ypok1cN7jg1.jpg"},"description":"\u003ci\u003e\"I thought I had lost my future forever... But the moment I realized that it had returned to me, my hands trembled with both joy and wonder.\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\nYudrein Ail is a commoner who was bestowed with powers on the night the Red Stone fell. He is also the first omega to rise to the rank of Imperial Trooper, but was accused of a crime he didn’t commit and executed soon after - only to reawaken eleven years ago, before the war began. He can't repeat the mistakes of his past…to survive is to save the world. But in order to do so, he must prevent the man he killed from facing his inevitable death.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e\"The future won't be the same. I'll make sure of it.\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e \n(Source: Lezhin US)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Fantasy","Romance"],"id":173936,"idMal":184906,"isAdult":true,"meanScore":82,"season":null,"siteUrl":"https://anilist.co/manga/173936","startDate":{"day":26,"month":6,"year":2023},"status":"HIATUS","synonyms":[],"title":{"english":"Turning","native":"터닝","romaji":"Turning","userPreferred":"Turning"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/111621-8WvLfTjfyBd1.jpg","chapters":131,"countryOfOrigin":"KR","coverImage":{"color":"#d61a35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx111621-3JDuK3u66Szj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx111621-3JDuK3u66Szj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx111621-3JDuK3u66Szj.jpg"},"description":"Na-kyum is a talented artist who excels in painting beautiful gay erotica, though he does so under a pseudonym. Yet recently, he has given up painting, vowing never to create lewd art again. But the notoriously lust-driven nobleman Seungho Yoon didn’t get the memo—nor will he accept it—and forces Na-kyum to become his in-house painter, demanding the artist create his erotic works just for Seungho to enjoy. Can Na-kyum endure being Seungho’s personal painter of the night or will the late-night activities be too much for him?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment)\n\u003cbr\u003e\u003cbr\u003e\nNote: Chapter count includes epilogue.","endDate":{"day":31,"month":5,"year":2024},"format":"MANGA","genres":["Drama","Romance"],"id":111621,"idMal":139429,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/111621","startDate":{"day":13,"month":5,"year":2019},"status":"FINISHED","synonyms":["夜画帳","Scène de Nuit","Pintor Nocturno","Maler der Nacht"],"title":{"english":"Painter of the Night","native":"야화첩","romaji":"Yahwacheop","userPreferred":"Yahwacheop"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx110281-lKod4iUhTH2I.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx110281-lKod4iUhTH2I.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx110281-lKod4iUhTH2I.jpg"},"description":"Yuujirou Matsukaze has been close friends with Rui Hanamine since the two of them were children, and at that time, Yuujirou was the one who stood up for and took care of his adorable, soft-hearted friend. But as it turns out, Yuujirou's childhood dreams end up growing a little too big to handle — or, rather, too tall!\n\u003cbr\u003e\u003cbr\u003e\nAt over six feet in height, the cheerful and happy-go-lucky Rui towers over his would-be protector... and still has no idea Yuujirou's had a crush on him since they were kids!\u003cbr\u003e\u003cbr\u003e(Source: Tokyopop)","endDate":{"day":24,"month":7,"year":2018},"format":"MANGA","genres":["Comedy","Romance","Slice of Life"],"id":110281,"idMal":115289,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/110281","startDate":{"day":15,"month":8,"year":2017},"status":"FINISHED","synonyms":["Dekoboko Sugar Life"],"title":{"english":"Dekoboko Sugar Days","native":"凸凹シュガーデイズ","romaji":"Dekoboko Sugar Days","userPreferred":"Dekoboko Sugar Days"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":5,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx97746-bvIKDcBxfWLi.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx97746-bvIKDcBxfWLi.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx97746-bvIKDcBxfWLi.jpg"},"description":"The meeting of Haruto, who dreams of being a singer-songwriter, with Akira, sparked by a traffic accident—?!\u003cbr\u003e\u003cbr\u003e\n\nWhen Haruto, a lonely singer who never sings, suddenly becomes able to see ghosts, he meets Akira, a ghost with the skin of organdy. Apprehension turns to friendship, and friendship turns to…?\n","endDate":{"day":14,"month":12,"year":2016},"format":"MANGA","genres":["Romance","Supernatural"],"id":97746,"idMal":100927,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/97746","startDate":{"day":12,"month":8,"year":2016},"status":"FINISHED","synonyms":["Lonely and Organdy"],"title":{"english":null,"native":"ロンリーとオーガンジー","romaji":"Lonely to Organdy","userPreferred":"Lonely to Organdy"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx172731-sXXgWc3cvg82.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx172731-sXXgWc3cvg82.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx172731-sXXgWc3cvg82.jpg"},"description":"When Tomoya was in high school, he once went to a gay bar while lying about his age, and he has never been able to forget Kei, the mature and sexy man he met there. Inspired by Kei, who told him that he was cute, Tomoya has become a very popular idol with a stadium tour in the works. One day, Tomoya discovers Kei, the man of his dreams, backstage at his group's live concert! It turns out that Kei has been hired to be Tomoya's bodyguard to protect him from a stalker!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Core Magazine, translated)","endDate":{"day":25,"month":10,"year":2023},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":172731,"idMal":164042,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/172731","startDate":{"day":30,"month":9,"year":2022},"status":"FINISHED","synonyms":["舞臺下的單向愛戀","오프 스테이지 러브 사이드"],"title":{"english":null,"native":"オフステージラブサイド","romaji":"Off Stage Love Side","userPreferred":"Off Stage Love Side"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e4c935","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx149654-L166KoH37177.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx149654-L166KoH37177.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx149654-L166KoH37177.png"},"description":"Seishirou Amaya liked Azusa Shirayuki. She asked him, \"Will you let me lick your penis?\" She brings him to an unofficial club that once existed, the Fellatio Research Club, where Seishirou's big dick is sucked to practice fellatio......!!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Mujin Comics, translated)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Published in Comic Mugen Tensei 2020-12, 2021-07, 2022-02, 06, 2023-01\u003c/i\u003e","endDate":{"day":5,"month":12,"year":2022},"format":"MANGA","genres":["Hentai"],"id":149654,"idMal":156325,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/149654","startDate":{"day":5,"month":11,"year":2020},"status":"FINISHED","synonyms":["Fellatio Research Department","Blowjob Research Club","Fellatio Research Department Epilogue","Fellatio Research Club"],"title":{"english":null,"native":"フェラチオ研究部","romaji":"Fellatio Kenkyuubu","userPreferred":"Fellatio Kenkyuubu"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx117534-WlZcKKQugYcK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx117534-WlZcKKQugYcK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx117534-WlZcKKQugYcK.jpg"},"description":"Several months after becoming lovers, Usami and Shirou are very happy, but...?!\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003c/i\u003e","endDate":{"day":30,"month":6,"year":2020},"format":"MANGA","genres":["Fantasy","Romance","Slice of Life"],"id":117534,"idMal":129291,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/117534","startDate":{"day":30,"month":1,"year":2020},"status":"FINISHED","synonyms":["I Won't Let Go of Ookami-kun"],"title":{"english":null,"native":"オオカミくんははなさない","romaji":"Ookami-kun wa Hanasanai","userPreferred":"Ookami-kun wa Hanasanai"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#f16b35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx114038-SCO7IwWYu3FK.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx114038-SCO7IwWYu3FK.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx114038-SCO7IwWYu3FK.png"},"description":"University student Naruse appears as a customer before Kei, a travel host from an Erogenous Aesthetic shop specializing in services to women. Kei offers Naruse the limited edition \"Return to Origins Course\", after being asked to treat Naruse as he would a girl.\n\u003cBr\u003e\u003cBr\u003e\nHe can't provide an honest service to Naruse after being tricked, after all. But Naruse, who chose the service, experiences a profoundly sad memory amidst this encounter...\n\u003cbr\u003e\u003cbR\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003ci\u003e","endDate":{"day":28,"month":4,"year":2018},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":114038,"idMal":123680,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/114038","startDate":{"day":22,"month":4,"year":2017},"status":"FINISHED","synonyms":["Travel Host NYU Boy"],"title":{"english":null,"native":"出張ホスト NYU BOY","romaji":"Shucchou Host NYU BOY","userPreferred":"Shucchou Host NYU BOY"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":9,"countryOfOrigin":"JP","coverImage":{"color":"#f1935d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx42554-ukcnhRuXIXCa.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx42554-ukcnhRuXIXCa.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx42554-ukcnhRuXIXCa.jpg"},"description":"On his very first day at a brand-new job, shy Shima is trapped in the elevator with a hungover mess of a guy... who turns out to be his boss! Togawa's prickly exterior definitely puts the rookie recruit on-edge, but it doesn't take long before Shima's every waking thought is invaded by his overbearing yet totally thoughtful superior. Will Shima put aside a history of disappointment in order to take a chance on a complicated relationship?\u003cbr\u003e\u003cbr\u003e\u003cem\u003eNo Touching at All\u003c/em\u003e breaks every rule in the office handbook in the name of mixed signals, shared memories, and the sweet surrender of an after-hours liaison! Shima and Togawa butt heads both at work and in the bedroom... but their inexplicable chemistry is far too intense to ignore. Can these two men forget their painful pasts and move forward hand-in-hand?\u003cbr\u003e\u003cbr\u003e\n(Source: Jun\u0026eacute;)","endDate":{"day":1,"month":9,"year":2008},"format":"MANGA","genres":["Drama","Romance"],"id":42554,"idMal":12554,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/42554","startDate":{"day":23,"month":1,"year":2007},"status":"FINISHED","synonyms":["I Won't Touch You Anyway","Le Labyrinthe des sentiments","No Quiero Tocarte Para Nada","Labirynt uczuć","Non mi farò coinvolgere","Не касаясь друг друга","无论如何也不想碰触","Sin querer rozarnos"],"title":{"english":"No Touching at All","native":"どうしても触れたくない","romaji":"Doushitemo Furetakunai","userPreferred":"Doushitemo Furetakunai"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/119695-LzjXybZ4Uylk.jpg","chapters":12,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx119695-rkmQh8SGDySq.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx119695-rkmQh8SGDySq.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx119695-rkmQh8SGDySq.jpg"},"description":"When comic editor Masumi Shishio is transferred to a BL magazine, he finds himself out of his depth with this new genre, but he isn't about to let that stop him. He reaches out to an artist who's scary good at drawing the D, secures a meeting, and then finds out that the talented \"Miss Akiina\" is in fact a businessman named Satoru Akiba. The pair decide to make the most of being a two-man team by doing some hands-on research: photoshoots at love hotels to get the poses right, test-runs of kisses and dates to get the feelings right... even a bit of sex, just to safe!! If they want to sell a million copies, they'll have to really put their backs into it! But what if this editor-artist combo's romance simulations turn into something real...? \u003cbr\u003e\n\u003cbr\u003e\n(Source: MangaPlaza)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes 5 extra chapters.\u003c/i\u003e\n","endDate":{"day":14,"month":1,"year":2020},"format":"MANGA","genres":["Comedy","Drama","Romance"],"id":119695,"idMal":128941,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/119695","startDate":{"day":12,"month":4,"year":2019},"status":"FINISHED","synonyms":["Can't Stand Any Longer!","J'en peux plus, sensei !","Niech pan pomoże, panie redaktorze!","Prickelnde Posen"],"title":{"english":"Can't Help Myself Around You","native":"先生、もうダメですっ","romaji":"Sensei, Mou Dame desu","userPreferred":"Sensei, Mou Dame desu"},"type":"MANGA","volumes":2},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#f1c9a1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx108204-ZmFAObXkcXQ4.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx108204-ZmFAObXkcXQ4.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx108204-ZmFAObXkcXQ4.png"},"description":"In a world where half-humans who evolved distinctly from animals reside, a tough and hardheaded wolf named Shirou is often misunderstood due to his gaudy appearance. Shirou is in love with Usami, a rabbit with eye-catching brown skin. Though Shirou being a carnivore has Usami on edge, after the wolf saves him from a pervert, Usami shows a vulnerable side to Shirou that no one else can see. But then, Shirou starts to want to mate with Usami!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Yen Press)\n\u003cBR\u003e\u003cBR\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003c/i\u003e","endDate":{"day":30,"month":8,"year":2018},"format":"MANGA","genres":["Fantasy","Romance"],"id":108204,"idMal":116935,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/108204","startDate":{"day":29,"month":12,"year":2017},"status":"FINISHED","synonyms":["Ookami-kun is not scary"],"title":{"english":"This Wolf Is Not Scary","native":"オオカミくんはこわくない","romaji":"Ookami-kun wa Kowakunai","userPreferred":"Ookami-kun wa Kowakunai"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/51419-XtFxfr6wmFG7.jpg","chapters":117,"countryOfOrigin":"JP","coverImage":{"color":"#e46b50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx51419-MbntyvO82kdm.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx51419-MbntyvO82kdm.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx51419-MbntyvO82kdm.png"},"description":"Tatsuhiko Kido, a vocational/technical school student who's staying in his school's dorms, one day discovers a hole in the wall of his apartment room. He peeks through the hole, but when he does so, he sees his neighbor, Ikuno Emiru, masturbating and he's caught peeking! However, when he goes over to inform her of the hole in the wall, she shuts the door in his face. Luckily for him, he's able to stop the door from closing and pursues after her, but, in his haste, he trips and lands right on top of her. As luck would have it, she takes a picture of them in a compromising position and tries to blackmail him into getting naked?!","endDate":{"day":1,"month":2,"year":2013},"format":"MANGA","genres":["Drama","Ecchi","Romance"],"id":51419,"idMal":21419,"isAdult":true,"meanScore":74,"season":null,"siteUrl":"https://anilist.co/manga/51419","startDate":{"day":23,"month":1,"year":2009},"status":"FINISHED","synonyms":["A Peephole","Podejrzane sekrety","Nozoki Ana","Heimliche Blicke","Nozokiana"],"title":{"english":null,"native":"ノ・ゾ・キ・ア・ナ","romaji":"No Zo Ki A Na","userPreferred":"No Zo Ki A Na"},"type":"MANGA","volumes":13},{"bannerImage":null,"chapters":1,"countryOfOrigin":"JP","coverImage":{"color":"#f1bba1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx130691-7mU3W2U9FZKY.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx130691-7mU3W2U9FZKY.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx130691-7mU3W2U9FZKY.jpg"},"description":"\u003ci\u003eNote: A live-action AV adaptation (URE-101) was released on November 28th, 2023.\u003c/i\u003e","endDate":{"day":30,"month":12,"year":2019},"format":"MANGA","genres":["Comedy","Hentai","Romance"],"id":130691,"idMal":142143,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/130691","startDate":{"day":30,"month":12,"year":2019},"status":"FINISHED","synonyms":["Ayane-san From Next-Door","My Neighbor Ayane"],"title":{"english":null,"native":"となりのあやねさん","romaji":"Tonari no Ayane-san","userPreferred":"Tonari no Ayane-san"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":17,"countryOfOrigin":"KR","coverImage":{"color":"#e4505d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx129820-yC1HDFCIGB12.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx129820-yC1HDFCIGB12.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx129820-yC1HDFCIGB12.jpg"},"description":"Gyerin decides to leave behind her ill-fated first love with Doona and start anew. She quickly meets a woman who looks like her ideal type from head to toe... Is Juyeon, full of armor-piercing amounts of charm, her fortune or woe?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Bomtoon, translated)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: The chapter count includes a prologue.\u003c/i\u003e","endDate":{"day":20,"month":7,"year":2021},"format":"MANGA","genres":["Drama","Romance"],"id":129820,"idMal":177265,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/129820","startDate":{"day":31,"month":1,"year":2021},"status":"FINISHED","synonyms":["Sadistic Beauty: Side Story A"],"title":{"english":"Sadistic Beauty: Epilogue","native":"새디스틱 뷰티 : 외전A","romaji":"Sadistic Beauty: Oejeon A","userPreferred":"Sadistic Beauty: Oejeon A"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/129808-83O2Pqz9BRmb.jpg","chapters":64,"countryOfOrigin":"KR","coverImage":{"color":"#a14328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx129808-nRaIflL0KqhS.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx129808-nRaIflL0KqhS.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx129808-nRaIflL0KqhS.png"},"description":"\u003ci\u003e\"Aren't you here to look at the room? Why are you looking at my body?!\"\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e\nLiving in a share house full of sexy girls. The rent went down, but something else is going up!\u003cbr\u003e\u003cbr\u003e(Source: TOPTOON+)","endDate":{"day":3,"month":3,"year":2022},"format":"MANGA","genres":["Hentai","Romance","Slice of Life"],"id":129808,"idMal":null,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/129808","startDate":{"day":31,"month":12,"year":2020},"status":"FINISHED","synonyms":["Is There an Empty Room?","シェアハウス","還有空房嗎?"],"title":{"english":"Got A Room?","native":"빈방 있어요?","romaji":"Binbang Isseoyo?","userPreferred":"Binbang Isseoyo?"},"type":"MANGA","volumes":null}],"pageInfo":{"currentPage":3,"hasNextPage":true,"lastPage":104,"perPage":48,"total":5000}}},"updated_at":"2026-03-15T06:40:37.795318+03:00"},"{\"query\":\"query ListManga ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $startDate_greater: FuzzyDateInt, $startDate_lesser: FuzzyDateInt, $format: MediaFormat, $countryOfOrigin: CountryCode, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: MANGA, isAdult: $isAdult, countryOfOrigin: $countryOfOrigin, search: $search, sort: $sort, status_in: $status, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, startDate_greater: $startDate_greater, startDate_lesser: $startDate_lesser, format_not: NOVEL) {\\n\\t\\t\\t... baseManga\\n\\t\\t}\\n\\t}\\n}\\nfragment baseManga on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tbannerImage\\n\\tchapters\\n\\tvolumes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":true,\"page\":4,\"perPage\":48,\"sort\":[\"SCORE_DESC\"]}}":{"value":{"Page":{"media":[{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":"#784328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx121161-qYsZ5w1Yy1lr.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx121161-qYsZ5w1Yy1lr.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx121161-qYsZ5w1Yy1lr.png"},"description":"Puberty is a time when many become interested in the opposite sex for the first time, but Kasuga is hit more than most. She becomes so obsessed with thoughts of penises and balls that her grades are affected. Thus, when her childhood friend, Kobayashi, bets her that he will have a higher score on the next test, with the winner being able to request anything from the other, she sees her opportunity to witness male genitalia in the real world.\n\u003cbr\u003e\u003cbr\u003e\n1-7. \u003cb\u003eShishunki no Obenkyou\u003c/b\u003e (思春期のお勉強, Puberty Study Session); COMIC Shingeki 2019-01, 05, 08, 12, 2020-05, 08, 11.\n\u003cBR\u003e8. \u003cb\u003eOnee-chan ni Makasenasai!\u003c/b\u003e (お姉ちゃんに任せなさい!,Leave it to Onee-chan!); COMIC Shingeki 2018-09","endDate":{"day":24,"month":6,"year":2020},"format":"MANGA","genres":["Hentai","Romance"],"id":121161,"idMal":127121,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/121161","startDate":{"day":24,"month":1,"year":2019},"status":"FINISHED","synonyms":["Puberty Study Session","Onee-chan ni Makasenasai!","Leave It To Onee-chan!"],"title":{"english":null,"native":"思春期のお勉強","romaji":"Shishunki no Obenkyou","userPreferred":"Shishunki no Obenkyou"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx101375-YkTdS1dllgym.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx101375-YkTdS1dllgym.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx101375-YkTdS1dllgym.jpg"},"description":"Ethan lives a monotonous life trying to pay off his crippling debt—until the day Mike appears at the neighborhood laundromat looking worse for wear. Both men find themselves struggling to go on in different ways, and it's these struggles that bring them together while simultaneously threatening to tear them apart.\n\u003cbr\u003e\u003cbr\u003e\n(Source: SuBLime)","endDate":{"day":5,"month":3,"year":2019},"format":"MANGA","genres":["Drama"],"id":101375,"idMal":113836,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/101375","startDate":{"day":29,"month":8,"year":2017},"status":"FINISHED","synonyms":[],"title":{"english":"Midnight Rain","native":"ミッドナイトレイン","romaji":"Midnight Rain","userPreferred":"Midnight Rain"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/99395-kBrBETmIIwR2.jpg","chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e40d6b","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/nx99395-3DkqwKcR6r6Y.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/nx99395-3DkqwKcR6r6Y.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/nx99395-3DkqwKcR6r6Y.jpg"},"description":"Theo runs the town liquor store—too bad he’s a total lightweight! His lifelong best friend, Camilo, runs the cigarette store across the street, and recently, he’s been making his attraction to Theo quite clear. Unsure of how he feels about dating a man, Theo accepts Camilo’s offer of a trial run at dating, and with a little liquid courage and a lot of heavy petting, Theo sees a whole new side to his childhood friend. Will these new experiences clarify his feelings or only serve to further muddy the waters of love?\u003cbr\u003e\u003cbr\u003e\n(Source: SuBLime)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003c/i\u003e","endDate":{"day":9,"month":2,"year":2018},"format":"MANGA","genres":["Romance","Slice of Life"],"id":99395,"idMal":102516,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/99395","startDate":{"day":8,"month":10,"year":2016},"status":"FINISHED","synonyms":["Liquor and Cigarette","Alkohol i papierosy","Ликёр и Сигареты"],"title":{"english":"Liquor \u0026 Cigarettes","native":"リカー\u0026シガレット","romaji":"Liquor \u0026 Cigarette","userPreferred":"Liquor \u0026 Cigarette"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/98359-xEITItlXtybu.jpg","chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e45d5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx98359-4rmmyxTFmuzR.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx98359-4rmmyxTFmuzR.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx98359-4rmmyxTFmuzR.jpg"},"description":"1. \u003cb\u003eXXX Allergy\u003c/b\u003e\u003cbr\u003e\nGrowing up in an environment full of all kinds of animals, there’s only one animal that Shouhei loves and that’s rabbits. Because of his love for rabbits, he sometimes helps out in a rabbit specialist shop. And there, he meets Mito Itsuki, his unrequited love. However, he has a secret he has to keep no matter what. Would he be able to keep that secret in order to stay close to the one he loves…?! A cute and short love story by Hinohara Meguru.\u003cbr\u003e\u003cbr\u003e\n2-3. \u003cb\u003eSecret XXX\u003c/b\u003e\u003cbr\u003e\nAfter going through many hardships, Mito and Shouhei finally became lovers. Just when their love is starting to bloom, Mito begins to act strange for some reason. Shouhei still doesn't know much about Mito so he can only sense Mito is hiding something from him. One day, Shouhei saw Mito with another guy in his car?! What could Mito be hiding? Can Shouhei keep his faith in Mito.\u003cbr\u003e\u003cbr\u003e\n4-5. \u003cb\u003eRelation XXX\u003c/b\u003e\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eIncluded extra story:\u003c/b\u003e Happily Ever After\n","endDate":{"day":14,"month":3,"year":2017},"format":"MANGA","genres":["Romance","Slice of Life"],"id":98359,"idMal":100396,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/98359","startDate":{"day":14,"month":1,"year":2016},"status":"FINISHED","synonyms":["XXX Allergy","Relation XXX","Happily Ever After"],"title":{"english":"Secret XXX","native":"シークレット×××","romaji":"Secret XXX","userPreferred":"Secret XXX"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/176074-dJr6BsOWUtVx.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#e45050","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx176074-sXQ2h7mrfjjb.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx176074-sXQ2h7mrfjjb.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx176074-sXQ2h7mrfjjb.jpg"},"description":"Higuchi Kiyotaka has hit rock bottom. Once a promising doctor on his way to becoming a cardiovascular surgeon, a traumatic incident has forced him to relocate to a rural town in Kyushu where he's relegated to practicing general medicine. Each day is a struggle to communicate with his heavily accented patients and overcome his intense feelings of guilt and depression. After an evening spent drinking himself into a stupor, he has a fateful encounter with a mysterious yakuza named Tenju, who promises to help the young doctor forget all his troubles for a night. As Higuchi finds himself drowning in unknown pleasures, he can't help but wonder–just who exactly is Tenju? And what does he want from him?\u003cbr\u003e\n\u003cbr\u003e\n(Source: Seven Seas Entertainment)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Romance"],"id":176074,"idMal":168330,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/176074","startDate":{"day":28,"month":4,"year":2023},"status":"RELEASING","synonyms":["애프터글로우"],"title":{"english":"Afterglow","native":"アフターグロウ","romaji":"Afterglow","userPreferred":"Afterglow"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/113289-z6jVrk4gymKi.jpg","chapters":7,"countryOfOrigin":"JP","coverImage":{"color":"#f15dbb","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx113289-qiz6UuRlTRkl.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx113289-qiz6UuRlTRkl.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx113289-qiz6UuRlTRkl.jpg"},"description":"\"Love\", what a nuisance.\n\u003cbr\u003e\u003cbr\u003e\nLove Allergy a.k.a. Lovesickness Symptoms: Heart-shaped rashes appearing on the body, dizziness, heart palpitations Cause: A reaction to feelings of love Treatment: ... ?\n\u003cbr\u003e\u003cbr\u003e\nAfter his heart skips a beat at the sight of his childhood friend, Haname's smile, Arashi somehow awakens in a hospital bed...!? His body is covered in countless heart-shaped rashes.\n\u003cbr\u003e\u003cbr\u003e\nIn order to suppress the effects of the allergic reaction caused by feelings of love (a.k.a. Lovesickness), he was prescribed heart-shaped pills to control his love. Since that day, \"love\" was stolen from him...\n\u003cbr\u003e\u003cbr\u003e\nHe can kiss and have sex, but he doesn't know how to love...!? Pay attention to the heart-shaped rashes!\n\u003cbr\u003e\u003cbr\u003e\nChildhood friends restrained from love by a love allergy -- this is their heart-patterned, pure love-sick love!\n\u003cbr\u003e\u003cbr\u003e\nIncludes the backstory of the pair's assigned doctor, Miyoshi-sensei.\n","endDate":{"day":24,"month":3,"year":2019},"format":"MANGA","genres":["Drama","Romance","Supernatural"],"id":113289,"idMal":126476,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/113289","startDate":{"day":23,"month":7,"year":2018},"status":"FINISHED","synonyms":[],"title":{"english":null,"native":"dear signal","romaji":"Dear Signal","userPreferred":"Dear Signal"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e443ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx155535-ujrLeYjWqZ1U.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx155535-ujrLeYjWqZ1U.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx155535-ujrLeYjWqZ1U.jpg"},"description":"A young gang leader, the omega Yoshiharu, is ordered by his boss into an arranged marriage with an alpha from another clan.\nHowever, his matchmaking partner, impatient with the unwilling Yoshiharu, drugged him to put him in heat.\nWhen he is rescued by his second, Makoto, Yoshiharu discovers that Makoto is the one who is his truly destined partner.\nYoshiharu is relieved that his soul mate is someone he could trust, but Makoto refused to consummate the relationship...?\n\u003cBR\u003e\u003cBR\u003e\n(Source: Kadokawa, translated)\n\u003cBR\u003e\u003cBR\u003e\n\u003ci\u003eNote: Includes one extra chapter.\u003c/i\u003e","endDate":{"day":30,"month":4,"year":2021},"format":"MANGA","genres":["Drama","Romance"],"id":155535,"idMal":143958,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/155535","startDate":{"day":30,"month":8,"year":2020},"status":"FINISHED","synonyms":["The Omega Takes a Husband"],"title":{"english":null,"native":"オメガの婿取り","romaji":"Omega no Mukotori","userPreferred":"Omega no Mukotori"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e4bbae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx151136-Kg5BedCPVfPQ.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx151136-Kg5BedCPVfPQ.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx151136-Kg5BedCPVfPQ.jpg"},"description":"Natsume has a problem that’s keeping him single and alone: He’s lousy in bed! Frustrated by his inability to keep a lover, he comes up with a plan–become a master of sex and shove his newfound bedroom prowess right in his ex’s face! The first step? Hiring a male escort to help him improve his skills. But when the escort, Kou, arrives at his home, Natsume is stunned to find that this man is no stranger. In fact, he’s Natsume’s own housekeeper!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment)","endDate":{"day":30,"month":11,"year":2021},"format":"MANGA","genres":["Romance"],"id":151136,"idMal":147783,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/151136","startDate":{"day":29,"month":1,"year":2021},"status":"FINISHED","synonyms":["なつめさんは開発（ひら）かれたい","Natsume-san wa Kaihatsukaretai"],"title":{"english":"Natsume Wants to be Trained","native":"なつめさんは開発かれたい","romaji":"Natsume-san wa Hirakaretai","userPreferred":"Natsume-san wa Hirakaretai"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":1,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx146127-ent2zj6JQUUd.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx146127-ent2zj6JQUUd.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx146127-ent2zj6JQUUd.jpg"},"description":null,"endDate":{"day":1,"month":2,"year":2022},"format":"MANGA","genres":["Hentai","Horror","Romance","Supernatural"],"id":146127,"idMal":null,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/146127","startDate":{"day":1,"month":2,"year":2022},"status":"FINISHED","synonyms":["Lady K \u0026 The Sick Man","Kko to Yamioji Ha","K-ko to Yamioji pa"],"title":{"english":null,"native":"K子と病みおじ・派","romaji":"K-ko to Yamioji Ha","userPreferred":"K-ko to Yamioji Ha"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":6,"countryOfOrigin":"JP","coverImage":{"color":"#e49328","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx132836-ParjG8MlVkQo.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx132836-ParjG8MlVkQo.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx132836-ParjG8MlVkQo.png"},"description":"Getting stressed out by school? Don’t worry, the hall monitor on S.L.U.T. duty is here for you!\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNotes:\u003cbr\u003e\n• Originally published as a doujinshi series.\u003cbr\u003e\n• The tankoubon includes two extra chapters .\u003cbr\u003e\n• A live-action AV adaptation (EBOD-927) was released on July 15th, 2022.\n\u003c/i\u003e","endDate":{"day":10,"month":6,"year":2022},"format":"MANGA","genres":["Hentai"],"id":132836,"idMal":155302,"isAdult":true,"meanScore":82,"season":null,"siteUrl":"https://anilist.co/manga/132836","startDate":{"day":11,"month":9,"year":2020},"status":"FINISHED","synonyms":["The Hall Monitor on S.L.U.T Duty: Stopping Lewd and Unethical Tomfoolery","SEX ACTS with a Member of the Public Moral Committee","風紀委員とフーゾク活動 風紀を守るために継続的に行う活動","Fuuki Iin to Fuuzoku Katsudou: Fuuki wo Mamoru Tame ni Keizokuteki ni Okonau Katsudou"],"title":{"english":"The Hall Monitor on S.L.U.T. Duty","native":"風紀委員とフーゾク活動","romaji":"Fuuki Iin to Fuuzoku Katsudou","userPreferred":"Fuuki Iin to Fuuzoku Katsudou"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/117953-1w5kcaZVjWe9.jpg","chapters":108,"countryOfOrigin":"KR","coverImage":{"color":"#f1a135","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx117953-lWWJnntxiPnW.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx117953-lWWJnntxiPnW.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx117953-lWWJnntxiPnW.jpg"},"description":"Suk-Yun is Mr. Perfect from head to toe with crisp creases in his suit, a handsome and fit figure... and an expensive wristwatch dominating his timetable. Woo-in fell for him HARD, because he’s just so... perfect. But over time, the beep of the wristwatch had more power over Suk-Yun than his feelings for Woo-in, so he left. To get over the breakup, Woo-in starts working for a cleaning company and just who is his first customer? The crazy messy junk-filled home of Suk-Yun, Mr. (Not 100%) Perfect.\u003cbr\u003e\u003cbr\u003e(Source: Tapas)\n\u003cbr\u003e\u003cbr\u003e\nNote: Includes 10 extra chapters.","endDate":{"day":18,"month":7,"year":2023},"format":"MANGA","genres":["Romance"],"id":117953,"idMal":159558,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/117953","startDate":{"day":4,"month":12,"year":2019},"status":"FINISHED","synonyms":["Baekpeosenteu Keullineop","100% Cleanup"],"title":{"english":"Mr. 100% Perfect!","native":"백퍼센트 클린업","romaji":"Baek Percent Cleanup","userPreferred":"Baek Percent Cleanup"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":"#f16b5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx112250-4FVSqrKJNJNQ.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx112250-4FVSqrKJNJNQ.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx112250-4FVSqrKJNJNQ.jpg"},"description":"1-3. \u003cb\u003eMuramata-san no Himitsu\u003c/b\u003e (村又さんの秘密, Muramata-san's Secret); \u003ci\u003eComic Hotmilk 2019-01, 07, 10\u003c/i\u003e\u003cbr\u003e\nMuramata-san is the local senpai at our main character's office. She's fun and cheerful, but she also has a big secret?\u003cbr\u003e\n\u003cbr\u003e\n4. \u003cb\u003eSobaya no Haru-san\u003c/b\u003e (蕎麦屋の春さん, The Soba Restaurant's Haru-san); \u003ci\u003eComic Hotmilk 2019-03\u003c/i\u003e\u003cbr\u003e\n5. \u003cb\u003eMomose wa Shiru\u003c/b\u003e (百瀬は知る); \u003ci\u003eComic Hotmilk 2018-11\u003c/i\u003e\u003cbr\u003e\n6. \u003cb\u003eBackstage\u003c/b\u003e (バックステージ); \u003ci\u003eComic Hotmilk 2014-12\u003c/i\u003e\u003cbr\u003e\n7. \u003cb\u003eAme yo Muchi yo, Yumi to Gen\u003c/b\u003e (飴よ鞭よ、弓と弦); \u003ci\u003eComic Hotmilk 2014-06\u003c/i\u003e\u003cbr\u003e\n8. \u003cb\u003eMarching\u003c/b\u003e (MARCHING！); \u003ci\u003eComic Hotmilk 2014-04\u003c/i\u003e","endDate":{"day":31,"month":1,"year":2020},"format":"MANGA","genres":["Hentai","Romance"],"id":112250,"idMal":128596,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/112250","startDate":{"day":31,"month":1,"year":2020},"status":"FINISHED","synonyms":["Sobaya no Haru-san","Momose wa Shiru","Backstage","Ame yo Muchi yo, Yumi to Gen","Marching","Muramata-san's Secret","The Soba Restaurant's Haru-san"],"title":{"english":"MURAMATA’S SECRET","native":"村又さんの秘密","romaji":"Muramata-san no Himitsu","userPreferred":"Muramata-san no Himitsu"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":7,"countryOfOrigin":"JP","coverImage":{"color":"#f1505d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx98795-LdomHKZDuLfu.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx98795-LdomHKZDuLfu.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx98795-LdomHKZDuLfu.png"},"description":"Keiji has the special ability to see red strings of fate...threads that connect when two people are meant to spend the rest of their lives together. One day, he looks down at his hand and sees that his string has finally connected to someone!! But when Keiji finds the person on the other end, he realizes it's... a guy!!!\u003cbr\u003e\u003cbr\u003e\n(Source: Renta!)","endDate":{"day":31,"month":8,"year":2016},"format":"MANGA","genres":["Romance","Supernatural"],"id":98795,"idMal":105798,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/98795","startDate":{"day":30,"month":11,"year":2015},"status":"FINISHED","synonyms":["红线的缓期执行","붉은실의 집행유예","Le fil du destin","El hilo rojo del destino"],"title":{"english":"The Red String of Fate","native":"赤い糸の執行猶予","romaji":"Akai Ito no Shikkou Yuuyo","userPreferred":"Akai Ito no Shikkou Yuuyo"},"type":"MANGA","volumes":1},{"bannerImage":null,"chapters":null,"countryOfOrigin":"KR","coverImage":{"color":"#e45d50","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b187194-6gSxQTcRWm6Y.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b187194-6gSxQTcRWm6Y.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b187194-6gSxQTcRWm6Y.png"},"description":"\u003ci\u003e\"Did that... just move?!\"\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e\nU-Jin, a totally average engineering student, accidentally buys an onahole that syncs with women around him.\u003cbr\u003e\u003cbr\u003e(Source: DAYcomics, edited)","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Drama","Hentai","Supernatural"],"id":187194,"idMal":null,"isAdult":true,"meanScore":81,"season":null,"siteUrl":"https://anilist.co/manga/187194","startDate":{"day":22,"month":3,"year":2025},"status":"RELEASING","synonyms":["Wireless Onahole","リモートラブホール","飛機杯女神連線中"],"title":{"english":"Synced for Pleasure","native":"무선 연결 오나홀","romaji":"Museon Yeongyeol Onahole","userPreferred":"Museon Yeongyeol Onahole"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":8,"countryOfOrigin":"JP","coverImage":{"color":"#e4c9ae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx143831-n7BfR3v1Rn4u.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx143831-n7BfR3v1Rn4u.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx143831-n7BfR3v1Rn4u.jpg"},"description":"Aoki and Tengoku starts dating and slowly deepens their relationship. But one day, when Aoki is talking with his friend on speakerphone while cooking, he brings up what Aoki said some time ago that he had no plans to marry his current partner. Tengoku hears but says nothing about it. When Tengoku leaves after the dinner, Aoki walks together to the station with a slight feeling of uneasiness. They kiss on the way, on the dark, lonely street at night. When Aoki notices someone passing by see them kissing, he almost unintentionally says “...This sucks”. Now Tengoku suddenly changes his tune and walks away, leaving Aoki alone and perplexed. Why does Tengoku leave like that? Their good relationship now seems to be in crisis...\u003cbr\u003e\n\u003cbr\u003e\n(Source: Takeshobo)\u003cbr\u003e\n\u003cbr\u003e\n\u003ci\u003eNote: Includes 1 extra chapter.\u003ci/\u003e","endDate":{"day":1,"month":10,"year":2021},"format":"MANGA","genres":["Drama","Romance","Slice of Life"],"id":143831,"idMal":143507,"isAdult":true,"meanScore":80,"season":null,"siteUrl":"https://anilist.co/manga/143831","startDate":{"day":24,"month":8,"year":2019},"status":"FINISHED","synonyms":[],"title":{"english":"Heaven and Demon -sai-","native":"鬼と天国 再","romaji":"Oni to Tengoku Sai","userPreferred":"Oni to Tengoku Sai"},"type":"MANGA","volumes":1},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/121506-9ewou2PHkypy.jpg","chapters":109,"countryOfOrigin":"KR","coverImage":{"color":"#f1bbae","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b121506-daaWyjV40OPd.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b121506-daaWyjV40OPd.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b121506-daaWyjV40OPd.png"},"description":"Chi-Ho has been unlucky his whole life, but he was actually born with a rare, most auspicious destiny. It’s just that his mother, who is a shaman, decided to share his energies with seven girls in their neighborhood to help them overcome their cursed fates. But now that Chi-Ho has become an adult, it’s time for him to retrieve his energies. And the way to do that is… through touch?!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin US, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Chapter count includes 2 epilogues.\u003c/i\u003e","endDate":{"day":15,"month":1,"year":2022},"format":"MANGA","genres":["Drama","Hentai","Romance","Supernatural"],"id":121506,"idMal":132939,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/121506","startDate":{"day":4,"month":8,"year":2019},"status":"FINISHED","synonyms":["Touch On","タッチ・オン！〜触って封印解除〜"],"title":{"english":"Touch to Unlock","native":"만져서 봉인해제","romaji":"Manjyeoseo Bonginhaeje","userPreferred":"Manjyeoseo Bonginhaeje"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/111748-uF2WqEjrULEk.jpg","chapters":160,"countryOfOrigin":"KR","coverImage":{"color":"#f1bba1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx111748-Bgn026tOq9Kp.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx111748-Bgn026tOq9Kp.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx111748-Bgn026tOq9Kp.jpg"},"description":"We often follow stories of a man at the very top, surrounded by his harem. But what happens when we follow the man behind him, scheming to take it all out from under him? A drama of Machiavellian proportions, what's his is mine now.\u003cbr\u003e\u003cbr\u003e(Source: TOPTOON+)","endDate":{"day":9,"month":2,"year":2022},"format":"MANGA","genres":["Action","Drama","Hentai","Romance"],"id":111748,"idMal":null,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/111748","startDate":{"day":24,"month":8,"year":2018},"status":"FINISHED","synonyms":["Silent War","生残賭博","衝突"],"title":{"english":"My Kingdom","native":"작은 전쟁","romaji":"Jageun Jeonjaeng","userPreferred":"Jageun Jeonjaeng"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/44739-31IRdecy530N.jpg","chapters":25,"countryOfOrigin":"JP","coverImage":{"color":"#d6bb1a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx44739-iCHeu3u41FJQ.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx44739-iCHeu3u41FJQ.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx44739-iCHeu3u41FJQ.jpg"},"description":"Skipping class on the rooftop one day, Shunpei's best friend Fumi tells him he thinks he might be gay. All set to freak out (\"Then up 'til now he's been thinking that way about me?!\") Shunpei's a bit nonplussed when Fumi's confession turns out...to have nothing to do with him at all! In fact, Fumi's already going out with someone else. Cue adolescent meltdown.\n","endDate":{"day":30,"month":11,"year":2012},"format":"MANGA","genres":["Comedy","Romance"],"id":44739,"idMal":14739,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/44739","startDate":{"day":30,"month":4,"year":2009},"status":"FINISHED","synonyms":["Mousou Electricity","Delusion Elektel","Electric Delusion"],"title":{"english":null,"native":"妄想エレキテル","romaji":"Mousou Elektel","userPreferred":"Mousou Elektel"},"type":"MANGA","volumes":4},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/137989-ssU7RYG7ntwM.jpg","chapters":16,"countryOfOrigin":"KR","coverImage":{"color":"#e4865d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx137989-lNRl1TCo3YKK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx137989-lNRl1TCo3YKK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx137989-lNRl1TCo3YKK.jpg"},"description":"Three side stories arcs that have different pairings each of them.\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: While this has it's own page on Lezhin, in BomToon it starts after chapter 51.\u003c/i\u003e","endDate":{"day":14,"month":11,"year":2021},"format":"MANGA","genres":["Comedy","Romance"],"id":137989,"idMal":null,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/137989","startDate":{"day":8,"month":8,"year":2021},"status":"FINISHED","synonyms":[],"title":{"english":"Sora \u0026 Haena - Side Stories","native":"소라해나! 외전","romaji":"Sora Haena! Oejeon","userPreferred":"Sora Haena! Oejeon"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/124090-a7jheNA3vF9f.jpg","chapters":113,"countryOfOrigin":"KR","coverImage":{"color":"#e4506b","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b124090-ALya6arDXJsN.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/b124090-ALya6arDXJsN.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/b124090-ALya6arDXJsN.jpg"},"description":"Seung-Ho is dating a sweetheart, Min-Ha but he’s getting tired of her childish behavior. After getting a job followed by a long hiatus, he meets an attractive and talented young boss. He starts to struggle in between his boss and her girlfriend.\u003cbr\u003e\u003cbr\u003e(Source: TOPTOON+)","endDate":{"day":30,"month":12,"year":2021},"format":"MANGA","genres":["Drama","Hentai","Romance","Slice of Life"],"id":124090,"idMal":null,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/124090","startDate":{"day":5,"month":12,"year":2019},"status":"FINISHED","synonyms":["はらはら恋々"],"title":{"english":"Young Boss","native":"어린 상사","romaji":"Eorin Sangsa","userPreferred":"Eorin Sangsa"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":60,"countryOfOrigin":"KR","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx120148-aNvBX1eDaaKu.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx120148-aNvBX1eDaaKu.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx120148-aNvBX1eDaaKu.png"},"description":"In the dark alleys of this city, there's no hope for trash like Sehyun. Having sex with strangers in the cramped stall behind a bar is just a typical Thursday night. But after a chance encounter with the brash and violent Boris, Sehyun begins to dream of living a normal life and an end to his restless nights. Boris is unlike any other man he's encountered. After a life spent bound by thorns, can time truly heal all scars? \n\u003cbr\u003e\u003cbr\u003e\n(Source: Tappytoon)","endDate":{"day":7,"month":6,"year":2019},"format":"MANGA","genres":["Drama","Romance"],"id":120148,"idMal":null,"isAdult":true,"meanScore":79,"season":null,"siteUrl":"https://anilist.co/manga/120148","startDate":{"day":4,"month":5,"year":2018},"status":"FINISHED","synonyms":[],"title":{"english":"Stigma","native":"Stigma","romaji":"Stigma","userPreferred":"Stigma"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/119648-F0pIyXQdyjuN.jpg","chapters":147,"countryOfOrigin":"KR","coverImage":{"color":"#e46b5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx119648-JBfnDTSVHDQu.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx119648-JBfnDTSVHDQu.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx119648-JBfnDTSVHDQu.png"},"description":"My dad married his hot, young secretary and it's been torture for me. She's only 6 years older than me, and keeps walking around in her panties!..\u003cbr\u003e\u003cbr\u003e(Source: TOPTOON+)","endDate":{"day":29,"month":12,"year":2022},"format":"MANGA","genres":["Drama","Hentai","Romance"],"id":119648,"idMal":null,"isAdult":true,"meanScore":74,"season":null,"siteUrl":"https://anilist.co/manga/119648","startDate":{"day":25,"month":2,"year":2020},"status":"FINISHED","synonyms":["Stepmom's Friends","繼母的朋友們","ハーレム×ハーレム"],"title":{"english":"My Stepmother's Friends","native":"새엄마의 친구들","romaji":"Saeeommaui Chingudeul","userPreferred":"Saeeommaui Chingudeul"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/113580-imOap169pxu3.jpg","chapters":12,"countryOfOrigin":"JP","coverImage":{"color":"#ffc9a1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx113580-wgrSORMZj4PF.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx113580-wgrSORMZj4PF.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx113580-wgrSORMZj4PF.png"},"description":"\u003ci\u003e“Kuroi-kun, won’t you go on a date with me?”\u003c/i\u003e\u003cbr\u003e\u003cbr\u003e\nThe Wakagashira of the Kuroguro group, Kuroi Kengou, has a troublesome childhood friend. The lawyer, Shirakaba, has been with him since they were born. Whenever he has time, Shirakaba comes to flirt with Kuroi. To get Kuroi’s attention, this courageous man even married a woman for a month. Shirakaba, who pushes forth his overflowing love, and Kuroi-kun, who puts up with it, their relationship is warmly watched over by the Kuroguro group’s men. Then one day, Shirakaba announces he has taken on the position of the Kuroguro group’s legal advisor, and tensions rise between them!\u003cbr\u003e\u003cbr\u003e\u003ci\u003eNote: Includes 2 extra chapters.\u003c/i\u003e","endDate":{"day":7,"month":10,"year":2020},"format":"MANGA","genres":["Drama","Romance"],"id":113580,"idMal":123271,"isAdult":true,"meanScore":78,"season":null,"siteUrl":"https://anilist.co/manga/113580","startDate":{"day":7,"month":2,"year":2019},"status":"FINISHED","synonyms":["Naked Sword And Tree Peony Of Black"],"title":{"english":null,"native":"白刃と黒牡丹","romaji":"Hakujin to Kurobotan","userPreferred":"Hakujin to Kurobotan"},"type":"MANGA","volumes":2},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/87235-7zXC0JhrGR80.jpg","chapters":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1d6c9","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx87235-ZJMkgl34YZZ9.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx87235-ZJMkgl34YZZ9.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx87235-ZJMkgl34YZZ9.png"},"description":"Story about a boy and his demon elder sister.\u003cbr\u003e\u003cbr\u003e\nThe original doujinshi series that was adapted into Ane Naru Mono.\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Includes Ane Mono Naru 3.5, 4.5, 5.5, 7.5\u003c/i\u003e","endDate":{"day":null,"month":null,"year":null},"format":"MANGA","genres":["Hentai","Supernatural"],"id":87235,"idMal":96704,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/87235","startDate":{"day":16,"month":8,"year":2015},"status":"RELEASING","synonyms":["The Sister of the Woods with a Thousand Young","An Elder Sister","姉なるもの全集"],"title":{"english":"Ane Naru Mono: The Elder-Sister Like One ","native":"姉なるもの","romaji":"Ane Naru Mono","userPreferred":"Ane Naru Mono"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/141530-5h9TcSfHeBVd.jpg","chapters":36,"countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx141530-reFh6I3aDEQO.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx141530-reFh6I3aDEQO.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx141530-reFh6I3aDEQO.jpg"},"description":"After being dumped by her boyfriend, Koyori went to her longtime friend Hijiri's house to drink away her sorrow...and ended up spending the night with him! Not only that, he tells her he loves her—and she's not sure how to reconcile the new development with someone she's known since they were kids. After all, the stakes are high—if things don't work out, she'll hurt one of her closest friends. And to make matters worse, her ex wants to patch things up...? Koyori needs to figure out what she wants, before she loses it all.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Kodansha USA)","endDate":{"day":1,"month":4,"year":2022},"format":"MANGA","genres":["Romance","Slice of Life"],"id":141530,"idMal":129535,"isAdult":true,"meanScore":75,"season":null,"siteUrl":"https://anilist.co/manga/141530","startDate":{"day":1,"month":6,"year":2018},"status":"FINISHED","synonyms":["Switch Me On"],"title":{"english":"Changes of Heart","native":"ホンノウスイッチ","romaji":"Honnou Switch","userPreferred":"Honnou Switch"},"type":"MANGA","volumes":9},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/116562-hDqYPuE4H88A.jpg","chapters":187,"countryOfOrigin":"KR","coverImage":{"color":"#fec90d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx116562-FLgMY3SY8KoE.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx116562-FLgMY3SY8KoE.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx116562-FLgMY3SY8KoE.jpg"},"description":"Studying abroad in the US, Do-Jin has experienced his fair share of unexpected surprises. New schools, new people, new roommates. However, of all the surprises, Do-Jin never expected to catch his roommate’s handsome younger brother, Tae-Hui, jerking off to him in his sleep?! That’s when the scandal began… \n\u003cbr\u003e\u003cbr\u003e\n(Source: Tapas, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Chapter count includes six side stories.\u003c/i\u003e","endDate":{"day":8,"month":9,"year":2023},"format":"MANGA","genres":["Drama","Romance"],"id":116562,"idMal":157401,"isAdult":true,"meanScore":76,"season":null,"siteUrl":"https://anilist.co/manga/116562","startDate":{"day":27,"month":3,"year":2019},"status":"FINISHED","synonyms":["香蕉緋聞","バナナスキャンダル","บานาน่า สแกนเดิล","Der Bananen-Skandal","Bbanana Scandal"],"title":{"english":"Banana Scandal","native":"빠나나 스캔들","romaji":"Banana Scandal","userPreferred":"Banana Scandal"},"type":"MANGA","volumes":null},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/manga/banner/97843-knhuzbwkAI6g.jpg","chapters":61,"countryOfOrigin":"KR","coverImage":{"color":"#ffd6bb","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/97843-LYN8e4raT30F.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/97843-LYN8e4raT30F.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/97843-LYN8e4raT30F.jpg"},"description":"Blood Bank is where vampires come to buy human blood! In a land where vampires, the supreme beings, rule human beings, there are those that have abnormalities. These vampires, while still superior, prefer to be ruled and commanded by humans. See how Shell, the son of a Blood Bank lord, falls for a mere human banker, One.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Lezhin)","endDate":{"day":27,"month":3,"year":2017},"format":"MANGA","genres":["Fantasy","Romance","Supernatural"],"id":97843,"idMal":125386,"isAdult":true,"meanScore":74,"season":null,"siteUrl":"https://anilist.co/manga/97843","startDate":{"day":21,"month":12,"year":2015},"status":"FINISHED","synonyms":["Banco de Sangre","ブラッドバンク"],"title":{"english":"Blood Bank","native":"블러드 뱅크","romaji":"Blood Bank","userPreferred":"Blood Bank"},"type":"MANGA","volumes":null},{"bannerImage":null,"chapters":7,"countryOfOrigin":"JP","coverImage":{"color":"#43c9e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/large/bx151394-NiC2ZZ5MSu1s.png","large":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/medium/bx151394-NiC2ZZ5MSu1s.png","medium":"https://s4.anilist.co/file/anilistcdn/media/manga/cover/small/bx151394-NiC2ZZ5MSu1s.png"},"description":"First-year Shion Yoshino knows exactly what he wants: a boyfriend straight out of a shojo manga! After failing to find Mr. Right in several athletic teams, he settles on the Film Club and announces his intentions, only for retired Vice President Rei Inaba to make a stunning declaration: “There is 100% no way you’re going to find a boyfriend here.” That very same day, however, it’s Rei himself who kisses Shion and asks him out! What does it all mean? Is this really the love of Shion’s shojo dreams, or is Rei just a pretty face who won’t make room for anyone else in his life? One thins is for certain: Shion Yoshino won’t give up without a fight!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Vertical Comics)","endDate":{"day":5,"month":6,"year":2021},"format":"MANGA","genres":["Romance"],"id":151394,"idMal":148500,"isAdult":true,"meanScore":77,"season":null,"siteUrl":"https://anilist.co/manga/151394","startDate":{"day":5,"month":12,"year":2020},"status":"FINISHED","synonyms":[],"title":{"english":"Twilight Out of Focus: The Evening Monologues","native":"宵々モノローグ","romaji":"Yoiyoi Monologue","userPreferred":"Yoiyoi Monologue"},"type":"MANGA","volumes":1},{"bannerImage":"http