br\u003e\n(Source: ANN)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Fantasy"],"id":203148,"idMal":63106,"isAdult":false,"meanScore":56,"nextAiringEpisode":{"airingAt":1774036800,"episode":11,"timeUntilAiring":432396},"season":"WINTER","siteUrl":"https://anilist.co/anime/203148","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASING","synonyms":["HOPPECHAN - Mystery of the Sun Kingdom and the Black-Cheek Team -"],"title":{"english":null,"native":"ほっぺちゃん ～サン王国と黒ほっぺ団の秘密～","romaji":"Hoppe-chan: Sun Oukoku to Kuro Hoppe-dan no Himitsu","userPreferred":"Hoppe-chan: Sun Oukoku to Kuro Hoppe-dan no Himitsu"},"trailer":{"id":"knIpSRsTyGY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/knIpSRsTyGY/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-172404}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":100,"perPage":50,"total":5000}}},"updated_at":"2026-03-15T22:53:26.674332+03:00"}}
