endDate":{"day":21,"month":3,"year":2026},"episodes":24,"format":"TV_SHORT","genres":["Slice of Life"],"id":198413,"idMal":62231,"isAdult":false,"meanScore":51,"nextAiringEpisode":null,"season":"FALL","siteUrl":"https://anilist.co/anime/198413","startDate":{"day":4,"month":10,"year":2025},"status":"FINISHED","synonyms":[],"title":{"english":null,"native":"ジェオチャム シーズン2 ","romaji":"JOCHUM Season 2","userPreferred":"JOCHUM Season 2"},"trailer":{"id":"cGOk6c2yFYA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/cGOk6c2yFYA/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-111974},{"airingAt":1773432000,"episode":10,"id":407354,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#1a93d6","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx203148-fMhz9uyA6HEK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx203148-fMhz9uyA6HEK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx203148-fMhz9uyA6HEK.jpg"},"description":"The anime's story is set in a world made of \"cuteness\" called Sun Kingdom. Ganso Hoppe-chan, who lost her memory, appears in the kingdom. Meanwhile, in the real world, an office worker named Hoho is slowly losing her self-esteem in her work and life, sending her on the verge of becoming lost in life. Somewhere between Ganso Hoppe-chan and Hoho's worlds, their paths cross. Back in Sun Kingdom, toxic Hoppe-chan creatures are creating an \"uncute place,\" and Ganso Hoppe-chan joins the \"Guardians\" to protect the kingdom.\n\u003cbr\u003e\u003cbr\u003e\n(Source: ANN)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Fantasy"],"id":203148,"idMal":63106,"isAdult":false,"meanScore":56,"nextAiringEpisode":{"airingAt":1774036800,"episode":11,"timeUntilAiring":489226},"season":"WINTER","siteUrl":"https://anilist.co/anime/203148","startDate":{"day":10,"month":1,"year":2026},"status":"RELEASIN