://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx199635-rgif9o9VWMrt.png"},"description":"The stage moves from the Mysterious Amusement Park to the \"Strange Paradise,\" where our friends from season 1, PetitCure Mofurun and PetitCure Pollun, will meet new allies like PetitCure Niko and PetitCure Candy!\n\u003cbr\u003e\u003cbr\u003e\nIn a Strange Paradise entirely made up of sweets, everyone goes on a candy-eating spree!? Many more heartwarming and cute PetitCure stories that'll make you smile and feel all warm inside await ♡ \n\u003cbr\u003e\u003cbr\u003e\n (Source: Official Website News, translated, edited)","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Fantasy","Slice of Life"],"id":199635,"idMal":62676,"isAdult":false,"meanScore":70,"nextAiringEpisode":{"airingAt":1773307800,"episode":22,"timeUntilAiring":473317},"season":"FALL","siteUrl":"https://anilist.co/anime/199635","startDate":{"day":9,"month":10,"year":2025},"status":"RELEASING","synonyms":["PuchiCure 2"],"title":{"english":null,"native":"ぷちきゅあ～Precure Fairies～ シーズン２","romaji":"PetitCure: Precure Fairies Season 2","userPreferred":"PetitCure: Precure Fairies Season 2"},"trailer":{"id":"ld_1kgxUa08","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ld_1kgxUa08/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-131483},{"airingAt":1772661600,"episode":9,"id":407145,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#f15d93","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx205676-VlzcdwHYdJCe.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx205676-VlzcdwHYdJCe.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx205676-VlzcdwHYdJCe.png"},"description":"Osamu Tezuka's classic manga \"Black Jack\" has been adapted into a comedy anime by creator SoroTani, the man behind the YouTube channel \"SoroTani no Animetchi,\" which has been viewed over 1 billion times.","duration":2,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Comedy"],"id":205676,"idMal":63275,"isAdult":false,"meanScore":60,"nextAiringEpisode":{"airingAt":1773266400,"episode":10,"timeUntilAiring":431917},"season":"WINTER","siteUrl":"https://anilist.co/anime/205676","startDate":{"day":8,"month":1,"year":2026},"status":"RELEASING","synonyms":[],"title":{"english":null,"native":"ブラックジャックやねん","romaji":"Black Jack Yanen","userPreferred":"Black Jack Yanen"},"trailer":{"id":"OkiloDdugO0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/OkiloDdugO0/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-172883},{"airingAt":1772636400,"episode":10,"id":406921,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/178005-X4Tr7p0sCQbx.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f15078","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx178005-pCEReATswrup.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx178005-pCEReATswrup.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx178005-pCEReATswrup.jpg"},"description":"Utage Kinoshita is a high school girl who works part-time as a housekeeper. She has devoted her life to her favorite idol, Tamon Fukuhara, from the group F/ACE. Then one day, Utage ends up being assigned to Tamon’s house! There she discovers that off-stage, he is nothing like his wild idol persona. A gloomy, introverted boy with no self-confidence, Utage still finds herself falling for him anyway.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":26,"month":3,"year":2026},"episodes":13,"format":"ONA","genres":["Comedy","Romance"],"id":178005,"idMal":59047,"isAdult":false,"meanScore":79,"nextAiringEpisode":{"airingAt":1773241200,"episode":11,"timeUntilAiring":406717},"season":"WINTER","siteUrl":"https://anilist.co/anime/178005","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Two F/aced Tamon","Which Face Does Tamon Have Now?","ทามอนคุง ตอนนี้อยู่โหมดไหน!?"],"title":{"english":"Tamon's B-Side","native":"多聞くん今どっち！？","romaji":"Tamon-kun Ima Docchi!?","userPreferred":"Tamon-kun Ima Docchi!?"},"trailer":{"id":"qFmSz2ZVxCA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/qFmSz2ZVxCA/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-198083},{"airingAt":1772636400,"episode":9,"id":405298,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182771-93HQnmbLFYbE.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1d6c9","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182771-KVq712ii32fJ.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182771-KVq712ii32fJ.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182771-KVq712ii32fJ.jpg"},"description":"Lizel, a brilliant young chancellor of a powerful nation in a fantasy realm, suddenly finds himself transported to another world—mid-conversation, no less. Unfazed, he decides to treat it like a vacation and become an adventurer! Teaming up with Gil, a lone wolf top-ranker, Lizel uses his wit, charm, and intellect to navigate this new world. So begin the whimsical adventures of a noble off duty!\u003cbr\u003e\n\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Fantasy","Slice of Life"],"id":182771,"idMal":60071,"isAdult":false,"meanScore":65,"nextAiringEpisode":{"airingAt":1773241200,"episode":10,"timeUntilAiring":406717},"season":"WINTER","siteUrl":"https://anilist.co/anime/182771","startDate":{"day":8,"month":1,"year":2026},"status":"RELEASING","synonyms":["A Mild Noble's Vacation Suggestion"],"title":{"english":"A Gentle Noble's Vacation Recommendation","native":"穏やか貴族の休暇のすすめ。","romaji":"Odayaka Kizoku no Kyuuka no Susume.","userPreferred":"Odayaka Kizoku no Kyuuka no Susume."},"trailer":{"id":"LKlXRCtlOVY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/LKlXRCtlOVY/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-198083},{"airingAt":1772636400,"episode":10,"id":405037,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49350","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx187264-aOUNQvTriPkX.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx187264-aOUNQvTriPkX.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx187264-aOUNQvTriPkX.jpg"},"description":"Betrayed by his childhood friend and cast out of the Hero Party, Orhun Dura—once their loyal Enchanter—is branded by his former comrades as “a jack-of-all-trades but a master of none.” Alone, he sets out to forge a new path as a solo adventurer. His journey sparks explosive battles, deadly rivals, and unexpected allies—and he’ll rise to shatter every expectation. The ultimate solo comeback begins!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":12,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":187264,"idMal":61128,"isAdult":false,"meanScore":66,"nextAiringEpisode":{"airingAt":1773241200,"episode":11,"timeUntilAiring":406717},"season":"WINTER","siteUrl":"https://anilist.co/anime/187264","startDate":{"day":1,"month":1,"year":2026},"status":"RELEASING","synonyms":["Yuusha Party wo Oidasareta Kiyou Binbou: Party Jijou de Fuyo Jutsushi wo Yatteita Kenshi, Bannou e to Itaru","勇者パーティを追い出された器用貧乏　～パーティ事情で付与術士をやっていた剣士、万能へと至る～","เก่งรอบด้านแต่ไร้ทีเด็ด เลยถูกเฉดหัวจากปาร์ตี้ผู้กล้า","용사 파티에서 쫓겨난 다재무능"],"title":{"english":"Jack-of-All-Trades, Party of None","native":"勇者パーティを追い出された器用貧乏","romaji":"Yuusha Party wo Oidasareta Kiyou Binbou","userPreferred":"Yuusha Party wo Oidasareta Kiyou Binbou"},"trailer":{"id":"dLDimMasKBM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dLDimMasKBM/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-198083},{"airingAt":1772635560,"episode":9,"id":407110,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4ae43","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx191967-fLWqssc0gPI4.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx191967-fLWqssc0gPI4.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx191967-fLWqssc0gPI4.jpg"},"description":"The second cour of \u003ci\u003eJigoku Sensei Nube (2025)\u003c/i\u003e.","duration":23,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Comedy","Horror","Supernatural"],"id":191967,"idMal":61608,"isAdult":false,"meanScore":69,"nextAiringEpisode":{"airingAt":1773240360,"episode":10,"timeUntilAiring":405877},"season":"WINTER","siteUrl":"https://anilist.co/anime/191967","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":[],"title":{"english":"Hell Teacher: Jigoku Sensei Nube (2025) Part 2","native":"地獄先生ぬ～べ～ (2025) 第2クール","romaji":"Jigoku Sensei Nube (2025) Part 2","userPreferred":"Jigoku Sensei Nube (2025) Part 2"},"trailer":{"id":"qWHY5_G_BG0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/qWHY5_G_BG0/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-198923},{"airingAt":1772634600,"episode":9,"id":407462,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/180746-AyfiOMkuHegF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#50c9fe","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx180746-eqDiHbzoHMFh.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx180746-eqDiHbzoHMFh.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx180746-eqDiHbzoHMFh.jpg"},"description":"At just seventeen, Yuki is a professional death game player. She’s survived enough rounds to know that survival is calculation, not luck—and that failure is final. For most players, the games are a nightmare with no escape. For Yuki, they’re simply business. Yet in a world where rooms turn into graves and every choice could be her last, even experience offers no protection.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: The first episode aired with a runtime of ~47 minutes as opposed to the standard 24 minute long episode.\u003c/i\u003e","duration":24,"endDate":{"day":18,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Action","Drama","Mystery","Thriller"],"id":180746,"idMal":59711,"isAdult":false,"meanScore":75,"nextAiringEpisode":{"airingAt":1773239400,"episode":10,"timeUntilAiring":404917},"season":"WINTER","siteUrl":"https://anilist.co/anime/180746","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":["SHIBOYUGI: Jogos Mortais para Colocar Comida na Mesa","SHIBOYUGI: Juegos mortales para ganarse el pan","SHIBOYUGI: Das Phantom-Mädchen im Spiel des Todes","Смертельная игра ради еды на столе","Смертельні ігри заради їжі на столі","Kiếm Cơm Bằng Trò Chơi Sinh Tử","靠死亡游戏混饭吃。","ลิขิตชะตาเกมท้าตาย","SHIBOYUGI : Survivre est mon métier","사망 유희로 밥을 먹는다."],"title":{"english":"SHIBOYUGI: Playing Death Games to Put Food on the Table","native":"死亡遊戯で飯を食う。","romaji":"Shibou Yuugi de Meshi wo Kuu.","userPreferred":"Shibou Yuugi de Meshi wo Kuu."},"trailer":{"id":"rqp_JkzslnM","site":"youtube","thumbnail":"https://i.ytimg.com/vi/rqp_JkzslnM/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-199883},{"airingAt":1772632800,"episode":8,"id":406212,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/182587-SLNmuinewbUF.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e45df1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182587-fsU8LOjmd7oj.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182587-fsU8LOjmd7oj.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182587-fsU8LOjmd7oj.jpg"},"description":"The third season of \u003ci\u003e[Oshi no Ko]\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nThe story enters a new stage.\n\u003cbr\u003e\u003cbr\u003e\nIt's been six months since \"POP IN 2\" was released. Thanks to MEM-Cho's hard work, B-Komachi is about to get their major break. Aqua is a multi-talented entertainer, and Akane's career as a talented actress is going smoothly. Meanwhile, Kana lost the cheerfulness she once had. To track down the truth behind Ai and Goro's deaths, Ruby keeps rising in the entertainment world...\n\u003cbr\u003e\u003cbr\u003e\n\u003cb\u003eUsing lies as a weapon.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)\n","duration":24,"endDate":{"day":25,"month":3,"year":2026},"episodes":11,"format":"TV","genres":["Drama","Mystery","Psychological","Supernatural"],"id":182587,"idMal":60058,"isAdult":false,"meanScore":84,"nextAiringEpisode":{"airingAt":1773237600,"episode":9,"timeUntilAiring":403117},"season":"WINTER","siteUrl":"https://anilist.co/anime/182587","startDate":{"day":14,"month":1,"year":2026},"status":"RELEASING","synonyms":["[OSHI NO KO] Season 3"],"title":{"english":"【OSHI NO KO】Season 3","native":"【推しの子】第3期","romaji":"[Oshi no Ko] 3rd Season","userPreferred":"[Oshi no Ko] 3rd Season"},"trailer":{"id":"JGYY6Pui5Kc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JGYY6Pui5Kc/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-201683},{"airingAt":1772629200,"episode":9,"id":404877,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/191205-1ZMdtwrP4ClU.jpg","countryOfOrigin":"JP","coverImage":{"color":"#a1c9e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx191205-ALhucRyrwOW1.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx191205-ALhucRyrwOW1.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx191205-ALhucRyrwOW1.jpg"},"description":"Van, fourth son of a marquis, is just a toddler when he realizes he’s been reincarnated. Thanks to his literal lifetime of knowledge, he’s raised as a child prodigy—until his production magic manifests, and it’s the last thing his snooty mage family wants to see! His disappointed father banishes him to a podunk town on the verge of collapse, yet Van can only see the place’s potential. Can our hero’s bastion of battlements build a better life than battle magic ever could?!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Adventure","Fantasy"],"id":191205,"idMal":61549,"isAdult":false,"meanScore":67,"nextAiringEpisode":{"airingAt":1773234000,"episode":10,"timeUntilAiring":399517},"season":"WINTER","siteUrl":"https://anilist.co/anime/191205","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":["หนูน้อยเจ้าแคว้นกับแผนพิทักษ์เมือง เปลี่ยนเมืองไร้ชื่อให้กลายเป็นนครป้อมปราการด้วยเวทมนตร์การผลิต"],"title":{"english":"Easygoing Territory Defense by the Optimistic Lord","native":"お気楽領主の楽しい領地防衛","romaji":"Okiraku Ryoushu no Tanoshii Ryouchi Bouei","userPreferred":"Okiraku Ryoushu no Tanoshii Ryouchi Bouei"},"trailer":{"id":"-lgT3jToqOI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/-lgT3jToqOI/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-205283},{"airingAt":1772627400,"episode":9,"id":404927,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/192261-ccBYYYrlx24B.jpg","countryOfOrigin":"JP","coverImage":{"color":"#bbe4f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx192261-oaqwOjlr64ki.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx192261-oaqwOjlr64ki.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx192261-oaqwOjlr64ki.jpg"},"description":"Having spent his childhood in the slums, Hajime Shinonome desperately sought strength to survive.\n\u003cbr\u003e\u003cbr\u003e\nNow, he enjoys a peaceful and carefree life as a resident adventurer of the Komai Village.\n\u003cbr\u003e\u003cbr\u003e\nOne day, during a quest, he ventured into a dungeon and finds a young girl being partially eaten by a weakest kind of monster, a slime!\n\u003cbr\u003e\u003cbr\u003e\nThe girl's name was Lirui. Having been abandoned by her parents, she had no place to go and entered the dungeon alone in order to stay alive. Hajime couldn't just leave her there, so he took her back to the village to live with him!\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":25,"month":3,"year":2026},"episodes":12,"format":"TV","genres":["Adventure","Fantasy","Slice of Life"],"id":192261,"idMal":61637,"isAdult":false,"meanScore":58,"nextAiringEpisode":{"airingAt":1773232200,"episode":10,"timeUntilAiring":397717},"season":"WINTER","siteUrl":"https://anilist.co/anime/192261","startDate":{"day":7,"month":1,"year":2026},"status":"RELEASING","synonyms":["Everyday of the 29 years old single person adventurer.","The Everyday Life of a 29-Year Old Middling Adventurer","The Daily Life of a Single 29-Year-Old Adventurer","ชีวิตประจำวันของนักผจญภัยโสดวัย 29"],"title":{"english":"An Adventurer’s Daily Grind at Age 29","native":"29歳独身中堅冒険者の日常","romaji":"29-sai Dokushin Chuuken Boukensha no Nichijou","userPreferred":"29-sai Dokushin Chuuken Boukensha no Nichijou"},"trailer":{"id":"_htCsAG0hUo","site":"youtube","thumbnail":"https://i.ytimg.com/vi/_htCsAG0hUo/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-207083},{"airingAt":1772622000,"episode":21,"id":409242,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e46b5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx188529-6o9byjahRpEx.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx188529-6o9byjahRpEx.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx188529-6o9byjahRpEx.jpg"},"description":"What if cats appeared in that story…? When beloved old tales and fairy stories are joined by cats, a surreal and heartwarming new adventure begins…!? Tabby cats, orange cats, calico cats, and white cats— a delightful mix of feline friends woven into timeless stories is sure to soothe the hearts of all humanity! A charming cat comedy is about to unfold!\n\u003cbr\u003e\u003cbr\u003e\n(Source: AniOne Asia)","duration":3,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Comedy"],"id":188529,"idMal":61254,"isAdult":false,"meanScore":64,"nextAiringEpisode":{"airingAt":1773226800,"episode":22,"timeUntilAiring":392317},"season":"FALL","siteUrl":"https://anilist.co/anime/188529","startDate":{"day":15,"month":10,"year":2025},"status":"RELEASING","synonyms":["Move! Cat Folktales","ขยับแล้ว! นิทานก่อนนอนกับเจ้าเหมียว"],"title":{"english":"Cat Tales","native":"うごく！ねこむかしばなし","romaji":"Ugoku! Neko Mukashi Banashi","userPreferred":"Ugoku! Neko Mukashi Banashi"},"trailer":{"id":"n-jg8syMe08","site":"youtube","thumbnail":"https://i.ytimg.com/vi/n-jg8syMe08/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-212483},{"airingAt":1772589600,"episode":151,"id":408201,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/137671-Ifs5ZdWoDusy.jpg","countryOfOrigin":"CN","coverImage":{"color":"#e4c9a1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx137671-PzYKwpStSLIF.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx137671-PzYKwpStSLIF.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx137671-PzYKwpStSLIF.png"},"description":"The story took the nine dragons and the coffin as an introduction and brought out a huge world of primeval ages. Climbing the sky road, and singing songs, to see how Ye Fan shrouding the heavens.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Webnovel)","duration":22,"endDate":{"day":null,"month":null,"year":null},"episodes":156,"format":"ONA","genres":["Action","Adventure","Sci-Fi"],"id":137671,"idMal":51289,"isAdult":false,"meanScore":79,"nextAiringEpisode":{"airingAt":1773194400,"episode":152,"timeUntilAiring":359917},"season":null,"siteUrl":"https://anilist.co/anime/137671","startDate":{"day":3,"month":5,"year":2023},"status":"RELEASING","synonyms":["Shrounding the Heavens"],"title":{"english":"Shrouding the Heavens","native":"遮天","romaji":"Zhe Tian","userPreferred":"Zhe Tian"},"trailer":{"id":"a0N7s4OB0jA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/a0N7s4OB0jA/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-244883},{"airingAt":1772585640,"episode":7,"id":406311,"media":{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#f1c95d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx204698-6v7aAq92mKFl.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx204698-6v7aAq92mKFl.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx204698-6v7aAq92mKFl.png"},"description":"Anime based on industrial company Taica's mascot Gelpiyo.\n\u003cbr\u003e\u003cbr\u003e\nIn the story, Gelpiyo and similar characters contain the \"Alpha Gel\" quality that allow them to bounce back after any setback. They are sent out by Alpha Industry to the mysterious Geltown to further the company's plot of world domination. There, they plan to raise trouble, even though they constantly get involved in events in the town.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Anime News Network)","duration":4,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV_SHORT","genres":["Comedy"],"id":204698,"idMal":63216,"isAdult":false,"meanScore":30,"nextAiringEpisode":{"airingAt":1773190440,"episode":8,"timeUntilAiring":355957},"season":"WINTER","siteUrl":"https://anilist.co/anime/204698","startDate":{"day":21,"month":1,"year":2026},"status":"RELEASING","synonyms":[],"title":{"english":null,"native":"ゲルぴよ","romaji":"GelPiyo","userPreferred":"GelPiyo"},"trailer":{"id":"21RP0XW0nD4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/21RP0XW0nD4/hqdefault.jpg"},"type":"ANIME"},"timeUntilAiring":-248843},{"airingAt":1772578800,"episode":9,"id":407073,"media":{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/204656-ECYkRJKBxTLj.jpg","countryOfOrigin":"JP","coverImage":{"color":"#c9e443","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b204656-KXjxVB4bBhl8.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/b204656-KXjxVB4bBhl8.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/b204656-KXjxVB4bBhl8.jpg"},"description":"Shark Meow is an orange tabby kitty who wears a shark suit.\u003cbr\u003e\nA little clumsy and always taking things at their own cozy pace,\u003cbr\u003e\nbut every day with their best kitty friends — and the rescued baby kitty, Little Meow —\u003cbr\u003e\nis filled with unexpected little mishaps and sweet adventures.\u003cbr\u003e\u003cbr\u003e\n \nA sunny warm spot in the park, the sparkle of the sea,\u003cbr\u003e\nsteam rising from freshly roasted sweet potatoes,\u003cbr\u003e\nthe fluttery feeling of the first snowfall…\u003cbr\u003e\nThese small everyday moments fill their world with warmth and delight.\n \u003cbr\u003e\u003cbr\u003e\nYou can’t help but smile and think, “So true!”\u003cbr\u003e\nA soft and snuggly kitty anime that brings joy to everyday moments.\u003cbr\u003e\n\u003cbr\u003e\n(Source: QTORY Channel)","duration":1,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"ONA","genres":["Slice of Life"],"id":204656,"idMal":63151,"isAdult":false,"meanScore":68,"nextAiringEpisode":{"airingAt":1773183600,"episode":10,"timeUntilAiring":349117},"season":"WINTER","siteUrl":"h