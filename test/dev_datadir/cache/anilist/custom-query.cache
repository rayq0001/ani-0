ndDate":{"day":10,"month":12,"year":2025},"episodes":15,"format":"ONA","genres":["Action","Drama","Fantasy","Supernatural"],"id":187921,"idMal":61200,"isAdult":false,"meanScore":77,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/187921","startDate":{"day":10,"month":12,"year":2025},"status":"FINISHED","synonyms":["Record of Ragnarok Season 3"],"title":{"english":"Record of Ragnarok III","native":"終末のワルキューレ III","romaji":"Shuumatsu no Valkyrie III","userPreferred":"Shuumatsu no Valkyrie III"},"trailer":{"id":"o5GRIchY2M4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/o5GRIchY2M4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/140337-4bbYMgRfHPEe.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e44335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx140337-8EtbiPurofcC.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx140337-8EtbiPurofcC.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx140337-8EtbiPurofcC.jpg"},"description":"Anime movie announced during the live concert \"Zombie Land Saga LIVE ～FranChouChou Saga yo tomoni waite kure～\" held on Oct 17, 2021.","duration":null,"endDate":{"day":24,"month":10,"year":2025},"episodes":1,"format":"MOVIE","genres":["Comedy","Music","Supernatural"],"id":140337,"idMal":50159,"isAdult":false,"meanScore":82,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/140337","startDate":{"day":24,"month":10,"year":2025},"status":"FINISHED","synonyms":[],"title":{"english":"Zombie Land Saga: Yumeginga Paradise","native":"ゾンビランドサガ ゆめぎんがパラダイス","romaji":"Zombie Land Saga: Yume Ginga Paradise","userPreferred":"Zombie Land Saga: Yume Ginga Paradise"},"trailer":{"id":"irI7CoyF_Hk","site":"youtube","thumbnail":"https://i.ytimg.com/vi/irI7CoyF_Hk/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/170577-vhMpMZGyxdFg.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e4bb5d","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx170577-ocYSFAcry7ty.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx170577-ocYSFAcry7ty.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx170577-ocYSFAcry7ty.jpg"},"description":"The second season of \u003ci\u003eTondemo Skill de Isekai Hourou Meshi\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nWhen a magical realm looks to summon heroes, they’re sorely disappointed to end up with a mediocre salaryman. Mukoda Tsuyoshi may not be a hero, but this conjuring error has given him a delicious power—Online Grocery. And something about this modern food brings with it unbelievable effects. This easy access paired with his cooking skills will have patrons from across the land coming back for more!\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":24,"month":12,"year":2025},"episodes":12,"format":"TV","genres":["Adventure","Comedy","Fantasy"],"id":170577,"idMal":57025,"isAdult":false,"meanScore":77,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/170577","startDate":{"day":8,"month":10,"year":2025},"status":"FINISHED","synonyms":["とんでもスキルで異世界放浪メシ 第2期","Tondemo Skill de Isekai Hourou Meshi 2nd Season","สกิลสุดพิสดารกับมื้ออาหารในต่างโลก ซีซั่น 2","Кулинар со странными навыками в параллельном мире 2","擁有超常技能的異世界流浪美食家 S2"],"title":{"english":"Campfire Cooking in Another World with my Absurd Skill Season 2","native":"とんでもスキルで異世界放浪メシ2","romaji":"Tondemo Skill de Isekai Hourou Meshi 2","userPreferred":"Tondemo Skill de Isekai Hourou Meshi 2"},"trailer":{"id":"mJ1M8RyVFp4","site":"youtube","thumbnail":"https://i.ytimg.com/vi/mJ1M8RyVFp4/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179930-zFY4rcN45RK1.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1c91a","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179930-xUYfykPhQmGm.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179930-xUYfykPhQmGm.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179930-xUYfykPhQmGm.jpg"},"description":"A one-hour special that adapts the \"Winter Arc\".\n\u003cbr\u003e\u003cbr\u003e\nBilly betrays the Union and seizes the Round Table. Amidst a blizzard caused by UMA Winter, he receives a report on the Autumn battle and learns Undead and Unluck are evolving. Juiz appears, revealing to him that the artifacts are weapons meant to defeat God and that the Ark can only perform one more loop. She urges Billy to join forces once more and stake everything on Unluck to achieve their shared goal: “defeat God.” However, Billy declares that they cannot work together. Juiz realizes Billy’s true intention—to obtain Ark and Apocalypse—but before she can act, Billy drags them into a brutal clash involving UMAs on both sides.\n\u003cbr\u003e\u003cbr\u003e\n(Source: TMS Entertainment)","duration":48,"endDate":{"day":26,"month":12,"year":2025},"episodes":1,"format":"SPECIAL","genres":["Action","Comedy","Sci-Fi","Supernatural"],"id":179930,"idMal":59435,"isAdult":false,"meanScore":76,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/179930","startDate":{"day":26,"month":12,"year":2025},"status":"FINISHED","synonyms":["アンデッドアンラック スペシャル","Undead Unluck Special","アンデッドアンラック ウィンター編"],"title":{"english":"Undead Unluck: Winter Arc","native":"アンデッドアンラック Winter編","romaji":"Undead Unluck: Winter-hen","userPreferred":"Undead Unluck: Winter-hen"},"trailer":{"id":"dCmNVtLsYzA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/dCmNVtLsYzA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/162669-SvOE44IccAT0.jpg","countryOfOrigin":"JP","coverImage":{"color":"#f1a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162669-FLYUTftoXgMh.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx162669-FLYUTftoXgMh.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx162669-FLYUTftoXgMh.jpg"},"description":"\u003cb\u003eThe story of Fushi the immortal enters the modern era.\u003c/b\u003e\n\u003cbr\u003e\u003cbr\u003e\nFollowing the battles in Renril, Fushi, like a tree, spreads his roots throughout the world, fighting to eliminate the Nokkers. Hundreds of years later, having completed his mission, he awakens in the modern era. He enjoys a life of peace, free of enemy threats and surrounded by precious friends, new and old. But ominous shadows grow near yet again. Enemies that enter into the fissures of the mind. And Fushi learns of the true goals of his creator, the Beholder.\n\u003cbr\u003e\u003cbr\u003e\nFaced with new trials, the time approaches for Fushi to make the ultimate decision.\n\u003cbr\u003e\u003cbr\u003e\n(Source: NHK PR, edited)","duration":25,"endDate":{"day":null,"month":null,"year":null},"episodes":22,"format":"TV","genres":["Adventure","Drama","Fantasy","Psychological","Supernatural"],"id":162669,"idMal":54703,"isAdult":false,"meanScore":76,"nextAiringEpisode":{"airingAt":1772894700,"episode":18,"timeUntilAiring":60218},"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/162669","startDate":{"day":4,"month":10,"year":2025},"status":"RELEASING","synonyms":[],"title":{"english":"To Your Eternity Season 3","native":"不滅のあなたへ Season 3","romaji":"Fumetsu no Anata e Season 3","userPreferred":"Fumetsu no Anata e Season 3"},"trailer":{"id":"JmT51BjIJ5w","site":"youtube","thumbnail":"https://i.ytimg.com/vi/JmT51BjIJ5w/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx204066-Gb5k7j6Cpbng.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx204066-Gb5k7j6Cpbng.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx204066-Gb5k7j6Cpbng.jpg"},"description":"Movie compilation of the Shibuya Incident Arc from the second season of \u003ci\u003eJujutsu Kaisen\u003c/i\u003e and the first two episodes of the third season's Culling Game Arc.\n\u003cbr\u003e\u003cbr\u003e\nA veil abruptly descends over the busy Shibuya area amid the bustling Halloween crowds, trapping countless civilians inside. Satoru Gojo, the strongest jujutsu sorcerer, steps into the chaos. But lying in wait are curse users and spirits scheming to seal him away.\n\u003cbr\u003e\u003cbr\u003e\nYuji Itadori, accompanied by his classmates and other top-tier jujutsu sorcerers, enters the fray in an unprecedented clash of curses — the Shibuya Incident.\n\u003cbr\u003e\u003cbr\u003e\nIn the aftermath, ten colonies across Japan are transformed into dens of curses in a plan orchestrated by Noritoshi Kamo, the most wicked sorcerer in history. As the deadly Culling Game starts, Special Grade sorcerer Yuta Okkotsu is assigned to carry out Yuji’s execution for his perceived crimes.\n\u003cbr\u003e\u003cbr\u003e\n(Source: GKIDS)","duration":88,"endDate":{"day":7,"month":11,"year":2025},"episodes":1,"format":"MOVIE","genres":["Action","Drama","Supernatural"],"id":204066,"idMal":62392,"isAdult":false,"meanScore":76,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/204066","startDate":{"day":7,"month":11,"year":2025},"status":"FINISHED","synonyms":["JJK Movie","JUJUTSU KAISEN: Execution"],"title":{"english":"JUJUTSU KAISEN: Execution -Shibuya Incident x The Culling Game Begins-","native":"呪術廻戦『渋谷事変 特別編集版』×『死滅回游 先行上映』","romaji":"Jujutsu Kaisen: Shibuya Jihen Tokubetsu Henshuu-ban x Shimetsu Kaiyuu Senkou Jouei","userPreferred":"Jujutsu Kaisen: Shibuya Jihen Tokubetsu Henshuu-ban x Shimetsu Kaiyuu Senkou Jouei"},"trailer":{"id":"VEjVqXiiUNY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/VEjVqXiiUNY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/185116-eQ55D57Wj1oJ.jpg","countryOfOrigin":"JP","coverImage":{"color":"#43aee4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185116-DIFRjiMgz1IS.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185116-DIFRjiMgz1IS.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185116-DIFRjiMgz1IS.jpg"},"description":"The story of \u003ci\u003eGNOSIA\u003c/i\u003e takes place on a ship drifting through space. Gnosia is an enemy that disguises itself as a human and attacks them. It is now on the spaceship, causing everyone onboard to be suspicious of each other. The crew decides to vote on the most suspicious-looking person every day and put them into a cold sleep.\u003cbr\u003e\u003cbr\u003e\n\nIf the humans succeed in putting Gnosia to sleep, they'll win. On the other hand, if they don't, everyone on board is in danger. The right decision must be made. No matter what decision is made by the main character, Yuri, she finds herself in a time loop that returns her to the first day of the crisis. \u003cbr\u003e\u003cbr\u003e\n\nWill the crew on board make the right decision? What is the secret behind the time loop? What secrets hide behind the faces of everyone on board?\u003cbr\u003e\u003cbr\u003e\n\n\u003ci\u003eGNOSIA\u003c/i\u003e begins now – a story of looping, fleeting moments that feels like an eternity but passes by in an instant.\u003cbr\u003e\u003cbr\u003e\n\nHave a pleasant journey.\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":25,"endDate":{"day":15,"month":3,"year":2026},"episodes":21,"format":"TV","genres":["Drama","Mystery","Sci-Fi","Thriller"],"id":185116,"idMal":60427,"isAdult":false,"meanScore":76,"nextAiringEpisode":{"airingAt":1772895600,"episode":20,"timeUntilAiring":61118},"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/185116","startDate":{"day":12,"month":10,"year":2025},"status":"RELEASING","synonyms":[],"title":{"english":"GNOSIA","native":"グノーシア","romaji":"Gnosia","userPreferred":"Gnosia"},"trailer":{"id":"Rm4ipMdFpeA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Rm4ipMdFpeA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/162890-aY5XAN4j9Ph2.jpg","countryOfOrigin":"JP","coverImage":{"color":"#5dc9f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx162890-vDRlo1KuRM6W.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx162890-vDRlo1KuRM6W.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx162890-vDRlo1KuRM6W.jpg"},"description":"An anime adaptation of the \u003ci\u003eGintama\u003c/i\u003e light novel spin-off.\n\u003cbr\u003e\u003cbr\u003e\nSakata Ginpachi is a high-school teacher with his trademark silver, curly hair, dead-fish eyes, and sloppily worn lab coat.\nHe's in charge of Gintama High School's Class 3-Z: home to a ragtag group of frequent troublemakers including idol otaku, hurloines, stalkers, mayo guzzlers, sadists, delinquents, and many more.\n\u003cbr\u003e\u003cbr\u003e\nIf you thought this roller-coaster life would have Ginpachi holding his head in his hands, you thought wrong, as he nonchalantly resolves any trouble that comes his way. And if you thought this unique group of students would overcome adversity and come together as one, you thought wrong again, as they continue to raise hell!\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003e\"Oh, come on! Can 3-Z get any more ungovernable?!\"\u003c/i\u003e\n\u003cbr\u003e\u003cbr\u003e\nYou can never tell what this atypical teacher is thinking and he never seems up for the task, but he always comes through when it counts. He and his students star in this school-life comedy full of laughs, tears, and the whole kitchen sink!\nForget nerds, forget jocks, and come enjoy the kind of youthful days that only \u003ci\u003eGintama\u003c/i\u003e could ever deliver!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll) \n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Announced at the the \"Gintama Ato no Matsuri 2023\" event.","duration":24,"endDate":{"day":23,"month":12,"year":2025},"episodes":12,"format":"TV","genres":["Comedy"],"id":162890,"idMal":54757,"isAdult":false,"meanScore":76,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/162890","startDate":{"day":7,"month":10,"year":2025},"status":"FINISHED","synonyms":["3-Z Class's Ginpachi-sensei","3rd Year Class Z Ginpachi-sensei","GINTAMA: Mr. Ginpachi's Zany Class","กินทามะ - ปี 3 ห้อง z อาจารย์กินปาจิ"],"title":{"english":"GINTAMA - Mr. Ginpachi's Zany Class","native":"3年Z組銀八先生","romaji":"3-nen Z-gumi Ginpachi-sensei","userPreferred":"3-nen Z-gumi Ginpachi-sensei"},"trailer":{"id":"e5x47GIm6Po","site":"youtube","thumbnail":"https://i.ytimg.com/vi/e5x47GIm6Po/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/179302-hX6lxG28Nzuf.jpg","countryOfOrigin":"JP","coverImage":{"color":"#d61a35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx179302-gWWAh5BfQyl4.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx179302-gWWAh5BfQyl4.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx179302-gWWAh5BfQyl4.jpg"},"description":"In a future where children are few and regarded as Japan's most valuable assets, Christmas has become a mere legend of the past. For the students of Daikoku Welfare Academy—a boarding school where they are educated, protected, and monitored—the mythical Santa Claus is a forgotten character of fiction. For the adults, Santa Claus is a very real menace that needs to be neutralized by the Saint Nick Pursuit Unit in case he makes an appearance.\n\u003cbr\u003e\u003cbr\u003e\nShiori Fuyumura, a student of Daikoku Welfare Academy, is determined to find her best friend, Ichie Ono, who has been declared dead after being missing for six months. One morning, Fuyumura summons her fellow class representative, Kazushige Sanda, only to attack the unknowing boy. She is convinced that Sanda is the descendant of the infamous Santa Claus—the only person who can make her wish of finding Ono come true—and is determined to force out his dormant true self by any means necessary.\n\u003cbr\u003e\u003cbr\u003e\n(Source: MAL Rewrite)","duration":24,"endDate":{"day":20,"month":12,"year":2025},"episodes":12,"format":"TV","genres":["Drama","Mystery"],"id":179302,"idMal":59267,"isAdult":false,"meanScore":75,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/179302","startDate":{"day":4,"month":10,"year":2025},"status":"FINISHED","synonyms":["サンダ"],"title":{"english":"SANDA","native":"SANDA","romaji":"SANDA","userPreferred":"SANDA"},"trailer":{"id":"PG9F1afLT-Y","site":"youtube","thumbnail":"https://i.ytimg.com/vi/PG9F1afLT-Y/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e450f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx185801-HaxWxYlkFnRg.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx185801-HaxWxYlkFnRg.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx185801-HaxWxYlkFnRg.png"},"description":"The second half of \u003ci\u003eNageki no Bourei wa Intai shitai\u003c/i\u003e.\n\u003cbr\u003e\u003cbr\u003e\nKrai’s adventures as a reluctant leader return, with more chaos ahead.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll News)","duration":24,"endDate":{"day":13,"month":12,"year":2025},"episodes":11,"format":"ONA","genres":["Action","Comedy","Fantasy"],"id":185801,"idMal":60619,"isAdult":false,"meanScore":75,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/185801","startDate":{"day":4,"month":10,"year":2025},"status":"FINISHED","synonyms":["Let This Grieving Soul Retire! Woe is the Weakling Who Leads the Strongest Party 2","Let This Grieving Soul Retire Sequel","嘆きの亡霊は引退したい 2クール"],"title":{"english":"Let This Grieving Soul Retire Cour 2","native":"嘆きの亡霊は引退したい 2","romaji":"Nageki no Bourei wa Intai Shitai 2","userPreferred":"Nageki no Bourei wa Intai Shitai 2"},"trailer":{"id":"f9iNG9he4bg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/f9iNG9he4bg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/180523-ddHpvzlj9RlP.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e43593","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx180523-FjvW1XByUNMK.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx180523-FjvW1XByUNMK.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx180523-FjvW1XByUNMK.jpg"},"description":"An MMO gamer awakens as the Black-Winged Tyrant, Lufas Maphaahl, rising from her sealed fate—only to find this is very real. Her defeat 200 years ago unleashed monsters of death, and the legend is one of terror. Now, trapped in the body of history’s most feared conqueror, he must survive a world that wants her dead…and uncover why he’s here.\n\u003cbr\u003e\u003cbr\u003e\n(Source: Crunchyroll)","duration":23,"endDate":{"day":13,"month":12,"year":2025},"episodes":12,"format":"ONA","genres":["Action","Adventure","Fantasy"],"id":180523,"idMal":59644,"isAdult":false,"meanScore":74,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/180523","startDate":{"day":27,"month":9,"year":2025},"status":"FINISHED","synonyms":["A Wild Last Boss Appears!"],"title":{"english":"A Wild Last Boss Appeared!","native":"野生のラスボスが現れた！","romaji":"Yasei no Last Boss ga Arawareta!","userPreferred":"Yasei no Last Boss ga Arawareta!"},"trailer":{"id":"KVT_ODZn9Ys","site":"youtube","thumbnail":"https://i.ytimg.com/vi/KVT_ODZn9Ys/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/183385-tK0LdiABACjw.jpg","countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx183385-f1TgnttLckBT.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx183385-f1TgnttLckBT.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx183385-f1TgnttLckBT.jpg"},"description":"Hinako lives alone by the sea, quietly drifting through life after losing her family years ago. One day, a mermaid named Shiori saves her from a monster and says she’s come to eat her—just not yet. Until then, Shiori will stay by her side and keep her safe. In that moment, a deep hope swells in Hinako: Maybe this girl can finally grant her the ending she’s been waiting for.\n\u003cBR\u003e\u003cBR\u003e\n(Source: Crunchyroll)","duration":24,"endDate":{"day":25,"month":12,"year":2025},"episodes":13,"format":"TV","genres":["Drama","Horror","Psychological","Romance","Supernatural"],"id":183385,"idMal":60168,"isAdult":false,"meanScore":74,"nextAiringEpisode":null,"season":"FALL","seasonYear":2025,"siteUrl":"https://anilist.co/anime/183385","startDate":{"day":2,"month":10,"year":2025},"status":"FINISHED","synonyms":["A Monster Wants to Eat Me","WataTabe","わたたべ","หากวันใดใครตนนั้นใคร่กลืนกิน"],"title":{"english":"This Monster Wants to Eat Me","native":"私を喰べたい、ひとでなし","romaji":"Watashi wo Tabetai, Hitodenashi","userPreferred":"Watashi wo Tabetai, Hitodenashi"},"trailer":{"id":"sGCfgvjn4CU","site":"youtube","thumbnail":"https://i.ytimg.com/vi/sGCfgvjn4CU/hqdefault.jpg"},"type":"ANIME"}],"pageInfo":{"currentPage":1,"hasNextPage":true,"lastPage":250,"perPage":20,"total":5000}}},"updated_at":"2026-03-07T01:01:22.762915+03:00"},"{\"query\":\"query ListAnime ($page: Int, $search: String, $perPage: Int, $sort: [MediaSort], $status: [MediaStatus], $genres: [String], $averageScore_greater: Int, $season: MediaSeason, $seasonYear: Int, $format: MediaFormat, $isAdult: Boolean) {\\n\\tPage(page: $page, perPage: $perPage) {\\n\\t\\tpageInfo {\\n\\t\\t\\thasNextPage\\n\\t\\t\\ttotal\\n\\t\\t\\tperPage\\n\\t\\t\\tcurrentPage\\n\\t\\t\\tlastPage\\n\\t\\t}\\n\\t\\tmedia(type: ANIME, search: $search, sort: $sort, status_in: $status, isAdult: $isAdult, format: $format, genre_in: $genres, averageScore_greater: $averageScore_greater, season: $season, seasonYear: $seasonYear, format_not: MUSIC) {\\n\\t\\t\\t... baseAnime\\n\\t\\t}\\n\\t}\\n}\\nfragment baseAnime on Media {\\n\\tid\\n\\tidMal\\n\\tsiteUrl\\n\\tstatus(version: 2)\\n\\tseason\\n\\ttype\\n\\tformat\\n\\tseasonYear\\n\\tbannerImage\\n\\tepisodes\\n\\tsynonyms\\n\\tisAdult\\n\\tcountryOfOrigin\\n\\tmeanScore\\n\\tdescription\\n\\tgenres\\n\\tduration\\n\\ttrailer {\\n\\t\\tid\\n\\t\\tsite\\n\\t\\tthumbnail\\n\\t}\\n\\ttitle {\\n\\t\\tuserPreferred\\n\\t\\tromaji\\n\\t\\tenglish\\n\\t\\tnative\\n\\t}\\n\\tcoverImage {\\n\\t\\textraLarge\\n\\t\\tlarge\\n\\t\\tmedium\\n\\t\\tcolor\\n\\t}\\n\\tstartDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tendDate {\\n\\t\\tyear\\n\\t\\tmonth\\n\\t\\tday\\n\\t}\\n\\tnextAiringEpisode {\\n\\t\\tairingAt\\n\\t\\ttimeUntilAiring\\n\\t\\tepisode\\n\\t}\\n}\\n\",\"variables\":{\"isAdult\":false,\"page\":1,\"perPage\":20,\"sort\":[\"TRENDING_DESC\"],\"status\":[\"NOT_YET_RELEASED\"]}}":{"value":{"Page":{"media":[{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e47843","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx208766-PYhW16CKj4fO.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx208766-PYhW16CKj4fO.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx208766-PYhW16CKj4fO.png"},"description":null,"duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Slice of Life"],"id":208766,"idMal":null,"isAdult":false,"meanScore":null,"nextAiringEpisode":null,"season":null,"seasonYear":null,"siteUrl":"https://anilist.co/anime/208766","startDate":{"day":null,"month":null,"year":2027},"status":"NOT_YET_RELEASED","synonyms":[],"title":{"english":null,"native":"ブレス","romaji":"Bless","userPreferred":"Bless"},"trailer":{"id":"ECI_iIX7LU0","site":"youtube","thumbnail":"https://i.ytimg.com/vi/ECI_iIX7LU0/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx208754-333Nyh5abrqS.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx208754-333Nyh5abrqS.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx208754-333Nyh5abrqS.png"},"description":"The world’s first full-dive VRMMO, Sword Art Online—known as SAO. What was meant to be a dream come true has instead transformed into a deadly game where dying in the virtual world means dying in reality.\u003cbr\u003e\u003cbr\u003e\nEmirun and Rex, who once knew each other in the real world, reunite by chance within SAO. They join a scouting party to learn how to survive in this unforgiving world. One day, however, they encounter a mysterious PK (Player Killer) known only as the Black Swordsman. When Emirun rushes to the scene, she finds Rex collapsed in despair, and the Black Swordsman standing over him. The one who wiped out their entire scouting party—was the Black Swordsman.\u003cbr\u003e\u003cbr\u003e\nDetermined to avenge their fallen comrades, Emirun and Rex seek out the legendary prodigy swordswoman Asuna, and begin intense training under her guidance. In a death game where even players turn against one another, what new beginning will these two reach at the end of their struggle…?\u003cbr\u003e\u003cbr\u003e(Source: Official Site, translated)\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: Released as part of the Echoes of Aincrad: Sword Art Online's game limited edition.\u003c/i\u003e","duration":110,"endDate":{"day":10,"month":7,"year":2026},"episodes":1,"format":"MOVIE","genres":["Action","Adventure"],"id":208754,"idMal":null,"isAdult":false,"meanScore":null,"nextAiringEpisode":{"airingAt":1783609200,"episode":1,"timeUntilAiring":10774717},"season":"SUMMER","seasonYear":2026,"siteUrl":"https://anilist.co/anime/208754","startDate":{"day":10,"month":7,"year":2026},"status":"NOT_YET_RELEASED","synonyms":[],"title":{"english":null,"native":"Unanswered//butterfly: Sword Art Online","romaji":"Unanswered//butterfly: Sword Art Online","userPreferred":"Unanswered//butterfly: Sword Art Online"},"trailer":{"id":"Zj4FqCJiW80","site":"youtube","thumbnail":"https://i.ytimg.com/vi/Zj4FqCJiW80/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/147105-fTjmRrILFixZ.jpg","countryOfOrigin":"JP","coverImage":{"color":null,"extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx147105-QrKDkM4yqp7f.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx147105-QrKDkM4yqp7f.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx147105-QrKDkM4yqp7f.jpg"},"description":"In a world where everyone takes wonders like magic spells and dragons for granted, Coco is a girl with a simple dream: she wants to be a witch. But everybody knows magicians are born, not made, and Coco was not born with a gift for magic. Resigned to her un-magical life, Coco is about to give up on her dream to become a witch … until the day she meets Qifrey, a mysterious, traveling magician. After secretly seeing Qifrey perform magic in a way she’s never seen before, Coco soon learns what everybody “knows” might not be the truth, and discovers that her magical dream may not be as far away as it may seem... \u003cbr\u003e\n\u003cbr\u003e\n(Source: Kodansha USA) ","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Adventure","Drama","Fantasy"],"id":147105,"idMal":51553,"isAdult":false,"meanScore":null,"nextAiringEpisode":{"airingAt":1775484000,"episode":1,"timeUntilAiring":2649517},"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/147105","startDate":{"day":6,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":["Atelier of Witch Hat"," จอมเวทฝึกหัดกับหมวกมหัศจรรย์","Atelier spiczastych kapeluszy","Cadı Şapkası Atölyesi"],"title":{"english":"Witch Hat Atelier","native":"とんがり帽子のアトリエ","romaji":"Tongari Boushi no Atelier","userPreferred":"Tongari Boushi no Atelier"},"trailer":{"id":"rc26AwBXlUE","site":"youtube","thumbnail":"https://i.ytimg.com/vi/rc26AwBXlUE/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#c950f1","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx202102-7qDmTI7eT5xF.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx202102-7qDmTI7eT5xF.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx202102-7qDmTI7eT5xF.png"},"description":"A multi-ending adventure about a girl with quite a need for approval who wants to become the bestest streamer = Internet Angel\n\u003cbr\u003e\u003cbr\u003e\n(Source: WSS playground, edited)\n\u003cbr\u003e\u003cbr\u003e\n\u003ci\u003eNote: The series had an advanced screening titled \u003cb\u003eNEEDY GIRL OVERDOSE -OVERTURE-\u003c/b\u003e at Theater Shinjuku and Theater Umeda on March 6, 2026.\u003c/i\u003e","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":13,"format":"TV","genres":["Adventure","Drama","Psychological","Slice of Life"],"id":202102,"idMal":62913,"isAdult":false,"meanScore":null,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/202102","startDate":{"day":null,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":["ニーディガール オーバードーズ","NEEDY STREAMER OVERLOAD","NEEDY GIRL OVERDOSE -OVERTURE-"],"title":{"english":"NEEDY GIRL OVERDOSE","native":"NEEDY GIRL OVERDOSE","romaji":"NEEDY GIRL OVERDOSE","userPreferred":"NEEDY GIRL OVERDOSE"},"trailer":{"id":"uhpjHk0zSJA","site":"youtube","thumbnail":"https://i.ytimg.com/vi/uhpjHk0zSJA/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":"https://s4.anilist.co/file/anilistcdn/media/anime/banner/195600-UxHvDXwzJxlP.jpg","countryOfOrigin":"JP","coverImage":{"color":"#e49335","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx195600-moI0UFArtOme.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx195600-moI0UFArtOme.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx195600-moI0UFArtOme.jpg"},"description":"In a remote mountain village under the watchful eyes of two stone guardians, the young Yuru contentedly lives off the land while staying close to the only family he has left—Asa, his precious twin sister. Asa, meanwhile, carries out a mysterious “duty” on behalf of the village while locked in a cage. Why is Asa a prisoner? And what other secrets does Yuru’s otherwise idyllic home hide?\n\u003cbr\u003e\u003cbr\u003e(Source: Square Enix)","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Comedy","Fantasy"],"id":195600,"idMal":62001,"isAdult":false,"meanScore":null,"nextAiringEpisode":{"airingAt":1775313000,"episode":1,"timeUntilAiring":2478517},"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/195600","startDate":{"day":4,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":["ヨミツガ","YomiTsuga"],"title":{"english":"Daemons of the Shadow Realm","native":"黄泉のツガイ","romaji":"Yomi no Tsugai","userPreferred":"Yomi no Tsugai"},"trailer":{"id":"XCyj9KKKjUI","site":"youtube","thumbnail":"https://i.ytimg.com/vi/XCyj9KKKjUI/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#86e450","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx189046-wHJEsaV5gzZB.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx189046-wHJEsaV5gzZB.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx189046-wHJEsaV5gzZB.jpg"},"description":"The fourth season of \u003ci\u003eRe:Zero kara Hajimeru Isekai Seikatsu\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\n\n\u003ci\u003eNote: World Premiere of Episode 1 screened at Lucca Comics \u0026 Games 2025 on November 1, 2025, before the Japanese television broadcast.\n\n","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Action","Adventure","Drama","Fantasy","Psychological","Romance"],"id":189046,"idMal":61316,"isAdult":false,"meanScore":null,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/189046","startDate":{"day":null,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":[],"title":{"english":"Re:ZERO - Starting Life in Another World- Season 4","native":"Re:ゼロから始める異世界生活 4th season","romaji":"Re:Zero kara Hajimeru Isekai Seikatsu 4th Season","userPreferred":"Re:Zero kara Hajimeru Isekai Seikatsu 4th Season"},"trailer":{"id":"i8EjBP85cCc","site":"youtube","thumbnail":"https://i.ytimg.com/vi/i8EjBP85cCc/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#aec9e4","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx180745-OEZaBeEdWozn.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx180745-OEZaBeEdWozn.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx180745-OEZaBeEdWozn.png"},"description":"The fourth season of \u003ci\u003e Youkoso Jitsuryoku Shijou Shugi no Kyoushitsu e\u003c/i\u003e.\u003cbr\u003e\u003cbr\u003e\nAs Ayanokouji and his classmates begin their second year at the Advanced Nurturing High School, they’re greeted by a fresh gauntlet of exams and a fresh batch of rather unique first-year students. They’ll have to get to know each other quickly, because the first special exam pairs the first-years with the second-years on a written test—with only the second-years facing expulsion if their team performs poorly! Worse yet? It seems one of the new first-years is also from the White Room. Can Ayanokouji avoid expulsion while sussing out the identity of this hidden foe?\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas)","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Drama","Psychological"],"id":180745,"idMal":59708,"isAdult":false,"meanScore":null,"nextAiringEpisode":{"airingAt":1774969200,"episode":1,"timeUntilAiring":2134717},"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/180745","startDate":{"day":1,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":[" Youkoso Jitsuryoku Shijou Shugi no Kyoushitsu e: 2-nensei-hen","ようこそ実力至上主義の教室へ ２年生編","Classroom of the Elite: Year 2","Classroom of the Elite Season 4","ようこそ実力至上主義の教室へ 4th Season 2年生1学期"],"title":{"english":"Classroom of the Elite 2nd Year","native":"ようこそ実力至上主義の教室へ 4th Season 2年生編1学期","romaji":"Youkoso Jitsuryoku Shijou Shugi no Kyoushitsu e 4th Season 2-nensei-hen Ichi Gakki","userPreferred":"Youkoso Jitsuryoku Shijou Shugi no Kyoushitsu e 4th Season 2-nensei-hen Ichi Gakki"},"trailer":{"id":"kAncxuwCPZg","site":"youtube","thumbnail":"https://i.ytimg.com/vi/kAncxuwCPZg/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4bb35","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx204319-qhw2yBXBUgJT.png","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx204319-qhw2yBXBUgJT.png","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx204319-qhw2yBXBUgJT.png"},"description":"Tachibana Souta jumps from one part-time job to the next, just coasting through life. He’s unremarkable except for being pretty short. One day, he’s roped into a new gig: working as a gopher for his older sister’s college volleyball team! Suddenly surrounded by a bunch of voluptuous women who all tower over him, Souta finds himself the subject of more female interest than he’s ever had. First, he has to figure out which girl he even wants to try to get with…and then he has to make sure their big, athletic bodies don’t actually destroy him in the act!\n\u003cbr\u003e\u003cbr\u003e\n(Source: Seven Seas Entertainment)","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":"TV","genres":["Ecchi","Romance","Sports"],"id":204319,"idMal":63248,"isAdult":false,"meanScore":null,"nextAiringEpisode":null,"season":"SPRING","seasonYear":2026,"siteUrl":"https://anilist.co/anime/204319","startDate":{"day":null,"month":4,"year":2026},"status":"NOT_YET_RELEASED","synonyms":[],"title":{"english":"Do You Like Big Girls?","native":"大きい女の子は好きですか？","romaji":"Ookii Onnanoko wa Suki desu ka?","userPreferred":"Ookii Onnanoko wa Suki desu ka?"},"trailer":{"id":"lykS0V2dnWY","site":"youtube","thumbnail":"https://i.ytimg.com/vi/lykS0V2dnWY/hqdefault.jpg"},"type":"ANIME"},{"bannerImage":null,"countryOfOrigin":"JP","coverImage":{"color":"#e4a150","extraLarge":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/large/bx182300-IYkq5KrkQq1V.jpg","large":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/medium/bx182300-IYkq5KrkQq1V.jpg","medium":"https://s4.anilist.co/file/anilistcdn/media/anime/cover/small/bx182300-IYkq5KrkQq1V.jpg"},"description":"The second season of \u003ci\u003eTsue to Tsurugi no Wistoria\u003c/i\u003e.","duration":null,"endDate":{"day":null,"month":null,"year":null},"episodes":null,"format":