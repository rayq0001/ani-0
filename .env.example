# Anyverse AI Ecosystem - Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# REQUIRED: Google Gemini API (Core AI Features)
# Get your key from: https://aistudio.google.com/
# Used for: OCR, Chat, Recaps, Search, Lore
# =============================================================================
GEMINI_API_KEY=AIzaSyBORvl77MmKeyyMgCvvwFVgy4VCqUckmAU

# =============================================================================
# OPTIONAL: OpenAI API (Cultural Translation)
# Get your key from: https://platform.openai.com/
# Used for: Arabic dialect localization, cultural context
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# OPTIONAL: Replicate API (Image/Video Generation)
# Get your token from: https://replicate.com/account
# Used for: Stable Diffusion, ControlNet, Anime generation
# =============================================================================
REPLICATE_API_TOKEN=your_replicate_token_here

# =============================================================================
# OPTIONAL: ElevenLabs API (Voice Dubbing)
# Get your key from: https://elevenlabs.io/api
# Used for: Text-to-speech, voice cloning
# =============================================================================
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# =============================================================================
# OPTIONAL: Pinecone API (Character Memory)
# Get your key from: https://www.pinecone.io/
# Used for: Long-term character memory, context retention
# =============================================================================
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1

# =============================================================================
# Feature Flags (Enable/Disable AI Features)
# Set to "true" or "false"
# =============================================================================
ENABLE_IMAGE_GENERATION=true
ENABLE_VIDEO_GENERATION=true
ENABLE_MUSIC_GENERATION=true
ENABLE_TTS=true
ENABLE_EMOTION=false
ENABLE_CULTURE=true

# =============================================================================
# Rate Limits (Requests per hour per user tier)
# =============================================================================
FREE_TIER_LIMIT=10
PRO_TIER_LIMIT=100
ELITE_TIER_LIMIT=500

# =============================================================================
# Cache Settings
# =============================================================================
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# =============================================================================
# Monetization (AnyCoin)
# =============================================================================
# Web3 wallet configuration for micro-transactions
# ANYVERSE_WALLET_PRIVATE_KEY=your_wallet_private_key
# ANYVERSE_CONTRACT_ADDRESS=your_contract_address

